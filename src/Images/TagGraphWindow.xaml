<Window x:Class="Images.TagGraphWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:Images.Localization"
        Title="{x:Static loc:Strings.TagGraphWindowTitle}"
        Width="1080"
        Height="760"
        MinWidth="900"
        MinHeight="620"
        WindowStartupLocation="CenterOwner">
    <Grid Background="{DynamicResource BaseBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource ToolWindowHeader}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="{x:Static loc:Strings.TagGraphHeading}" Style="{StaticResource Text.Title}" />
                    <TextBlock Text="{x:Static loc:Strings.TagGraphSubtitle}"
                               Style="{StaticResource Text.Caption}"
                               Margin="0,3,0,0" />
                </StackPanel>
                <Button Grid.Column="1"
                        Style="{StaticResource ChromeButton}"
                        Click="RefreshButton_Click"
                        AutomationProperties.Name="{x:Static loc:Strings.TagGraphRefresh}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE72C;"
                                   FontFamily="{StaticResource IconFontFamily}"
                                   FontSize="12"
                                   Margin="0,0,8,0"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="{x:Static loc:Strings.TagGraphRefresh}" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource ToolWindowSidebar}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="{x:Static loc:Strings.TagGraphCurrentImage}" Style="{StaticResource SectionLabel}" />
                        <Border Style="{StaticResource Card}" Padding="13,12">
                            <StackPanel>
                                <TextBlock x:Name="CurrentImageText"
                                           Text="{x:Static loc:Strings.TagGraphNoImageSelected}"
                                           Style="{StaticResource Text.Body}"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap" />
                                <TextBlock x:Name="CurrentImagePathText"
                                           Text="{x:Static loc:Strings.TagGraphNoImageHint}"
                                           Style="{StaticResource Text.Hint}"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0" />
                                <TextBox x:Name="TagInputBox"
                                         MinHeight="118"
                                         Margin="0,12,0,0"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         AutomationProperties.Name="{x:Static loc:Strings.TagGraphCurrentImage}" />
                                <TextBlock Text="{x:Static loc:Strings.TagGraphTagInputHint}"
                                           Style="{StaticResource Text.Hint}"
                                           TextWrapping="Wrap"
                                           Margin="0,6,0,0" />
                                <CheckBox x:Name="IncludeParentsCheckBox"
                                          IsChecked="True"
                                          Content="{x:Static loc:Strings.TagGraphIncludeParents}"
                                          Margin="0,10,0,0"
                                          AutomationProperties.Name="{x:Static loc:Strings.TagGraphIncludeParents}" />
                                <WrapPanel Margin="0,12,0,0">
                                    <Button Style="{StaticResource ChromeButton}"
                                            Margin="0,0,8,0"
                                            Click="ImportSidecarButton_Click"
                                            AutomationProperties.Name="{x:Static loc:Strings.TagGraphImportSidecar}">
                                        <TextBlock Text="{x:Static loc:Strings.TagGraphImportSidecar}" />
                                    </Button>
                                    <Button Style="{StaticResource PrimaryButton}"
                                            Click="ExportSidecarButton_Click"
                                            AutomationProperties.Name="{x:Static loc:Strings.TagGraphExportSidecar}">
                                        <TextBlock Text="{x:Static loc:Strings.TagGraphExportSidecar}" />
                                    </Button>
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Divider}" />

                        <TextBlock Text="{x:Static loc:Strings.TagGraphNamespaces}" Style="{StaticResource SectionLabel}" />
                        <Border Style="{StaticResource Card}" Padding="13,12">
                            <StackPanel>
                                <TextBlock Text="{x:Static loc:Strings.TagGraphNamespacesHint}"
                                           Style="{StaticResource Text.Hint}"
                                           TextWrapping="Wrap" />
                                <TextBox x:Name="NamespacePrefixBox"
                                         Margin="0,10,0,0"
                                         AutomationProperties.Name="{x:Static loc:Strings.TagGraphNamespacePrefixAutomationName}" />
                                <TextBox x:Name="NamespaceLabelBox"
                                         Margin="0,8,0,0"
                                         AutomationProperties.Name="{x:Static loc:Strings.TagGraphNamespaceLabelAutomationName}" />
                                <Button Style="{StaticResource ChromeButton}"
                                        Margin="0,10,0,0"
                                        HorizontalAlignment="Left"
                                        Click="AddNamespaceButton_Click"
                                        AutomationProperties.Name="{x:Static loc:Strings.TagGraphAddNamespace}">
                                    <TextBlock Text="{x:Static loc:Strings.TagGraphAddNamespace}" />
                                </Button>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Divider}" />

                        <TextBlock Text="{x:Static loc:Strings.TagGraphPreview}" Style="{StaticResource SectionLabel}" />
                        <Border Style="{StaticResource Card}" Padding="13,12">
                            <StackPanel>
                                <TextBox x:Name="PreviewTagBox"
                                         AutomationProperties.Name="{x:Static loc:Strings.TagGraphPreview}" />
                                <Button Style="{StaticResource ChromeButton}"
                                        Margin="0,10,0,0"
                                        HorizontalAlignment="Left"
                                        Click="PreviewButton_Click"
                                        AutomationProperties.Name="{x:Static loc:Strings.TagGraphPreviewExpansion}">
                                    <TextBlock Text="{x:Static loc:Strings.TagGraphPreviewExpansion}" />
                                </Button>
                                <ListBox x:Name="PreviewList"
                                         MinHeight="96"
                                         Margin="0,10,0,0"
                                         AutomationProperties.Name="{x:Static loc:Strings.TagGraphPreview}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="1"
                          HorizontalAlignment="Stretch"
                          Background="{DynamicResource HairlineBrush}" />

            <Grid Grid.Column="2" Background="{DynamicResource ViewportBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="{DynamicResource SurfacePanelBrush}"
                        BorderBrush="{DynamicResource HairlineBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="16,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="GraphSummaryText"
                                   Text="3 namespaces, 0 aliases, 0 parents"
                                   Style="{StaticResource Text.Caption}"
                                   VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Border Style="{StaticResource Badge}" Margin="0,0,8,0">
                                <TextBlock Text="{x:Static loc:Strings.TagGraphLocalOnly}"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource SubtextBrush}" />
                            </Border>
                            <Border Style="{StaticResource Badge}">
                                <TextBlock Text="{x:Static loc:Strings.TagGraphOffline}"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource SubtextBrush}" />
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Row="1" Margin="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Grid.Column="0"
                            Style="{StaticResource Card}"
                            Padding="13,12"
                            Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="{x:Static loc:Strings.TagGraphAliasSibling}"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextBrush}" />
                            <TextBlock Text="{x:Static loc:Strings.TagGraphAliasHint}"
                                       Style="{StaticResource Text.Hint}"
                                       TextWrapping="Wrap"
                                       Margin="0,3,0,0" />
                            <TextBox x:Name="AliasBox"
                                     Margin="0,10,0,0"
                                     AutomationProperties.Name="{x:Static loc:Strings.TagGraphAliasTagAutomationName}" />
                            <TextBox x:Name="AliasTargetBox"
                                     Margin="0,8,0,0"
                                     AutomationProperties.Name="{x:Static loc:Strings.TagGraphAliasTargetAutomationName}" />
                            <Button Style="{StaticResource ChromeButton}"
                                    Margin="0,10,0,0"
                                    HorizontalAlignment="Left"
                                    Click="AddAliasButton_Click"
                                    AutomationProperties.Name="{x:Static loc:Strings.TagGraphAddAlias}">
                                <TextBlock Text="{x:Static loc:Strings.TagGraphAddAlias}" />
                            </Button>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="0"
                            Grid.Column="2"
                            Style="{StaticResource Card}"
                            Padding="13,12"
                            Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="{x:Static loc:Strings.TagGraphParent}"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextBrush}" />
                            <TextBlock Text="{x:Static loc:Strings.TagGraphParentHint}"
                                       Style="{StaticResource Text.Hint}"
                                       TextWrapping="Wrap"
                                       Margin="0,3,0,0" />
                            <TextBox x:Name="ParentTagBox"
                                     Margin="0,10,0,0"
                                     AutomationProperties.Name="{x:Static loc:Strings.TagGraphParentTagAutomationName}" />
                            <TextBox x:Name="ParentBox"
                                     Margin="0,8,0,0"
                                     AutomationProperties.Name="{x:Static loc:Strings.TagGraphParentTargetAutomationName}" />
                            <Button Style="{StaticResource ChromeButton}"
                                    Margin="0,10,0,0"
                                    HorizontalAlignment="Left"
                                    Click="AddParentButton_Click"
                                    AutomationProperties.Name="{x:Static loc:Strings.TagGraphAddParent}">
                                <TextBlock Text="{x:Static loc:Strings.TagGraphAddParent}" />
                            </Button>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1"
                            Grid.Column="0"
                            Style="{StaticResource Card}"
                            Padding="13,12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="{x:Static loc:Strings.TagGraphNamespacesAndAliases}" Style="{StaticResource SectionLabel}" />
                            <ListBox x:Name="AliasList"
                                     Grid.Row="1"
                                     Margin="0,8,0,0"
                                     AutomationProperties.Name="{x:Static loc:Strings.TagGraphNamespacesAndAliases}" />
                        </Grid>
                    </Border>

                    <Border Grid.Row="1"
                            Grid.Column="2"
                            Style="{StaticResource Card}"
                            Padding="13,12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="{x:Static loc:Strings.TagGraphParentGraph}" Style="{StaticResource SectionLabel}" />
                            <ListBox x:Name="ParentList"
                                     Grid.Row="1"
                                     Margin="0,8,0,0"
                                     AutomationProperties.Name="{x:Static loc:Strings.TagGraphParentGraph}" />
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>

        <Border Grid.Row="2"
                Style="{StaticResource WindowStatusBar}">
            <StackPanel Orientation="Horizontal">
                <Ellipse x:Name="StatusDot"
                         Width="8"
                         Height="8"
                         Fill="{DynamicResource GreenBrush}"
                         Margin="0,0,9,0"
                         VerticalAlignment="Center" />
                <TextBlock x:Name="StatusText"
                           Text="{x:Static loc:Strings.TagGraphReadyStatus}"
                           Style="{StaticResource Text.Caption}"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
