<Window x:Class="Images.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:Images.Localization"
        Title="{x:Static loc:Strings.SettingsWindowTitle}"
        Width="720"
        Height="640"
        MinWidth="640"
        MinHeight="540"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="CanResize"
        Background="{StaticResource BaseBrush}"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True">

    <Window.Resources>
        <Style x:Key="SettingsCard" TargetType="Border" BasedOn="{StaticResource Card}">
            <Setter Property="Padding" Value="16,14" />
            <Setter Property="Margin" Value="0,0,0,16" />
        </Style>

        <Style x:Key="SettingsDivider" TargetType="Border">
            <Setter Property="Height" Value="1" />
            <Setter Property="Background" Value="{StaticResource HairlineBrush}" />
            <Setter Property="Margin" Value="0,14" />
        </Style>

        <Style x:Key="SettingsIconTile" TargetType="Border">
            <Setter Property="Width" Value="38" />
            <Setter Property="Height" Value="38" />
            <Setter Property="CornerRadius" Value="{StaticResource Radius.Md.CR}" />
            <Setter Property="Background" Value="#1F89B4FA" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalAlignment" Value="Top" />
        </Style>
    </Window.Resources>

    <Grid Margin="28,24,28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,22">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Style="{StaticResource Text.Display}"
                           Text="{x:Static loc:Strings.SettingsHeading}" />
                <TextBlock Style="{StaticResource Text.Subtitle}"
                           Text="{x:Static loc:Strings.SettingsSubtitle}"
                           Margin="0,5,0,0"
                           MaxWidth="540" />
            </StackPanel>

            <Border Grid.Column="1"
                    Style="{StaticResource SettingsIconTile}"
                    Margin="16,0,0,0"
                    AutomationProperties.Name="{x:Static loc:Strings.SettingsHeading}">
                <TextBlock Text="&#xE713;"
                           FontFamily="{StaticResource IconFontFamily}"
                           FontSize="15"
                           Foreground="{StaticResource AccentBrush}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
            </Border>
        </Grid>

        <TabControl Grid.Row="1">
            <TabItem Header="{x:Static loc:Strings.SettingsSectionGeneral}">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              CanContentScroll="False">
                    <StackPanel>
                        <Border Style="{StaticResource SettingsCard}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,18,0">
                                        <TextBlock Text="{x:Static loc:Strings.SettingsLanguageTitle}"
                                                   Style="{StaticResource Text.Body}"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="{x:Static loc:Strings.SettingsLanguageDescription}"
                                                   Style="{StaticResource Text.Hint}"
                                                   Margin="0,3,0,0"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                    <ComboBox Grid.Column="1"
                                              VerticalAlignment="Center"
                                              MinWidth="170"
                                              ItemsSource="{Binding AvailableLocales}"
                                              SelectedItem="{Binding SelectedLocale}"
                                              AutomationProperties.Name="{x:Static loc:Strings.SettingsLanguageTitle}" />
                                </Grid>

                                <Border Style="{StaticResource SettingsDivider}" />

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,18,0">
                                        <TextBlock Text="{x:Static loc:Strings.SettingsRememberWindowTitle}"
                                                   Style="{StaticResource Text.Body}"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="{x:Static loc:Strings.SettingsRememberWindowDescription}"
                                                   Style="{StaticResource Text.Hint}"
                                                   Margin="0,3,0,0"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                    <CheckBox Grid.Column="1"
                                              VerticalAlignment="Center"
                                              IsChecked="{Binding RememberWindowPlacement}"
                                              AutomationProperties.Name="{x:Static loc:Strings.SettingsRememberWindowTitle}" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SettingsCard}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Style="{StaticResource SettingsIconTile}"
                                        Margin="0,0,14,0">
                                    <TextBlock Text="&#xE895;"
                                               FontFamily="{StaticResource IconFontFamily}"
                                               FontSize="14"
                                               Foreground="{StaticResource AccentBrush}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Border>

                                <StackPanel Grid.Column="1" Margin="0,0,18,0">
                                    <TextBlock Text="{x:Static loc:Strings.SettingsUpdateCheckTitle}"
                                               Style="{StaticResource Text.Body}"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding UpdateCheckDescription}"
                                               Style="{StaticResource Text.Hint}"
                                               Margin="0,3,0,0"
                                               TextWrapping="Wrap" />
                                </StackPanel>

                                <CheckBox Grid.Column="2"
                                          VerticalAlignment="Center"
                                          IsChecked="{Binding UpdateCheckEnabled}"
                                          AutomationProperties.Name="{x:Static loc:Strings.SettingsUpdateCheckTitle}" />
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="{x:Static loc:Strings.SettingsSectionAppearance}">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              CanContentScroll="False">
                    <StackPanel>
                        <Border Style="{StaticResource SettingsCard}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,18,0">
                                        <TextBlock Text="{x:Static loc:Strings.SettingsFilmstripTitle}"
                                                   Style="{StaticResource Text.Body}"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="{x:Static loc:Strings.SettingsFilmstripDescription}"
                                                   Style="{StaticResource Text.Hint}"
                                                   Margin="0,3,0,0"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                    <CheckBox Grid.Column="1"
                                              VerticalAlignment="Center"
                                              IsChecked="{Binding FilmstripVisibleOnStartup}"
                                              AutomationProperties.Name="{x:Static loc:Strings.SettingsFilmstripTitle}" />
                                </Grid>

                                <Border Style="{StaticResource SettingsDivider}" />

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,18,0">
                                        <TextBlock Text="{x:Static loc:Strings.SettingsMetadataHudTitle}"
                                                   Style="{StaticResource Text.Body}"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="{x:Static loc:Strings.SettingsMetadataHudDescription}"
                                                   Style="{StaticResource Text.Hint}"
                                                   Margin="0,3,0,0"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                    <CheckBox Grid.Column="1"
                                              VerticalAlignment="Center"
                                              IsChecked="{Binding MetadataHudVisibleOnStartup}"
                                              AutomationProperties.Name="{x:Static loc:Strings.SettingsMetadataHudTitle}" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SettingsCard}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,18,0">
                                    <TextBlock Text="{x:Static loc:Strings.SettingsConfirmRecycleBinTitle}"
                                               Style="{StaticResource Text.Body}"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="{x:Static loc:Strings.SettingsConfirmRecycleBinDescription}"
                                               Style="{StaticResource Text.Hint}"
                                               Margin="0,3,0,0"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                                <CheckBox Grid.Column="1"
                                          VerticalAlignment="Center"
                                          IsChecked="{Binding ConfirmRecycleBinDeletes}"
                                          AutomationProperties.Name="{x:Static loc:Strings.SettingsConfirmRecycleBinTitle}" />
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="{x:Static loc:Strings.SettingsSectionAccessibility}">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              CanContentScroll="False">
                    <Border Style="{StaticResource SettingsCard}">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,18,0">
                                    <TextBlock Text="{x:Static loc:Strings.SettingsReduceMotionTitle}"
                                               Style="{StaticResource Text.Body}"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="{x:Static loc:Strings.SettingsReduceMotionDescription}"
                                               Style="{StaticResource Text.Hint}"
                                               Margin="0,3,0,0"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                                <CheckBox Grid.Column="1"
                                          VerticalAlignment="Center"
                                          IsChecked="{Binding ReduceMotion}"
                                          AutomationProperties.Name="{x:Static loc:Strings.SettingsReduceMotionTitle}" />
                            </Grid>

                            <Border Style="{StaticResource SettingsDivider}" />

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,18,0">
                                    <TextBlock Text="{x:Static loc:Strings.SettingsHighContrastTitle}"
                                               Style="{StaticResource Text.Body}"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="{x:Static loc:Strings.SettingsHighContrastDescription}"
                                               Style="{StaticResource Text.Hint}"
                                               Margin="0,3,0,0"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                                <CheckBox Grid.Column="1"
                                          VerticalAlignment="Center"
                                          IsChecked="{Binding HighContrastMode}"
                                          AutomationProperties.Name="{x:Static loc:Strings.SettingsHighContrastTitle}" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="{x:Static loc:Strings.SettingsSectionAdvanced}">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              CanContentScroll="False">
                    <StackPanel>
                        <Border Style="{StaticResource SettingsCard}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,18,0">
                                        <TextBlock Text="{x:Static loc:Strings.SettingsArchiveRtlTitle}"
                                                   Style="{StaticResource Text.Body}"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="{x:Static loc:Strings.SettingsArchiveRtlDescription}"
                                                   Style="{StaticResource Text.Hint}"
                                                   Margin="0,3,0,0"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                    <CheckBox Grid.Column="1"
                                              VerticalAlignment="Center"
                                              IsChecked="{Binding ArchiveRightToLeft}"
                                              AutomationProperties.Name="{x:Static loc:Strings.SettingsArchiveRtlTitle}" />
                                </Grid>

                                <Border Style="{StaticResource SettingsDivider}" />

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,18,0">
                                        <TextBlock Text="{x:Static loc:Strings.SettingsArchiveCleanScanTitle}"
                                                   Style="{StaticResource Text.Body}"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="{x:Static loc:Strings.SettingsArchiveCleanScanDescription}"
                                                   Style="{StaticResource Text.Hint}"
                                                   Margin="0,3,0,0"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                    <CheckBox Grid.Column="1"
                                              VerticalAlignment="Center"
                                              IsChecked="{Binding ArchiveOldScanFilter}"
                                              AutomationProperties.Name="{x:Static loc:Strings.SettingsArchiveCleanScanTitle}" />
                                </Grid>

                                <Border Style="{StaticResource SettingsDivider}" />

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,18,0">
                                        <TextBlock Text="{x:Static loc:Strings.SettingsArchiveSpreadTitle}"
                                                   Style="{StaticResource Text.Body}"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="{x:Static loc:Strings.SettingsArchiveSpreadDescription}"
                                                   Style="{StaticResource Text.Hint}"
                                                   Margin="0,3,0,0"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                    <CheckBox Grid.Column="1"
                                              VerticalAlignment="Center"
                                              IsChecked="{Binding ArchiveSpreadMode}"
                                              AutomationProperties.Name="{x:Static loc:Strings.SettingsArchiveSpreadTitle}" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SettingsCard}">
                            <StackPanel>
                                <TextBlock Text="{x:Static loc:Strings.SettingsHotkeysFixed}"
                                           Style="{StaticResource Text.Body}"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="{x:Static loc:Strings.SettingsHotkeysDescription}"
                                           Style="{StaticResource Text.Hint}"
                                           Margin="0,5,0,0"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{Binding HotkeySummary}"
                                           Style="{StaticResource Text.Hint}"
                                           Margin="0,8,0,0"
                                           TextWrapping="Wrap" />
                                <DataGrid ItemsSource="{Binding ShortcutRows}"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          HeadersVisibility="Column"
                                          GridLinesVisibility="None"
                                          MinHeight="240"
                                          MaxHeight="320"
                                          Margin="0,14,0,0"
                                          Background="Transparent"
                                          BorderBrush="{StaticResource HairlineBrush}"
                                          Foreground="{StaticResource TextBrush}"
                                          RowBackground="Transparent"
                                          AlternatingRowBackground="#10181825"
                                          HorizontalScrollBarVisibility="Disabled"
                                          SelectionMode="Single"
                                          AutomationProperties.Name="{x:Static loc:Strings.SettingsSectionHotkeys}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="{x:Static loc:Strings.SettingsHotkeyColumnCategory}"
                                                            Binding="{Binding Category}"
                                                            IsReadOnly="True"
                                                            Width="110" />
                                        <DataGridTextColumn Header="{x:Static loc:Strings.SettingsHotkeyColumnAction}"
                                                            Binding="{Binding ActionName}"
                                                            IsReadOnly="True"
                                                            Width="*" />
                                        <DataGridTemplateColumn Header="{x:Static loc:Strings.SettingsHotkeyColumnShortcut}"
                                                                Width="120">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBox Text="{Binding ShortcutText, UpdateSourceTrigger=PropertyChanged}"
                                                             MinWidth="92"
                                                             Padding="6,3"
                                                             AutomationProperties.Name="{Binding ActionName}" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn Header="{x:Static loc:Strings.SettingsHotkeyColumnDefault}"
                                                            Binding="{Binding DefaultShortcutText}"
                                                            IsReadOnly="True"
                                                            Width="96" />
                                        <DataGridTemplateColumn Header="{x:Static loc:Strings.SettingsHotkeyColumnActions}"
                                                                Width="116">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Button Style="{StaticResource ChromeButton}"
                                                                Command="{Binding DataContext.ApplyShortcutCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                CommandParameter="{Binding}"
                                                                Padding="8,3"
                                                                MinHeight="26"
                                                                Margin="0,0,6,0"
                                                                Content="{x:Static loc:Strings.SettingsHotkeyApply}" />
                                                        <Button Style="{StaticResource ChromeButton}"
                                                                Command="{Binding DataContext.ResetShortcutCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                CommandParameter="{Binding}"
                                                                Padding="8,3"
                                                                MinHeight="26"
                                                                Content="{x:Static loc:Strings.SettingsHotkeyReset}" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="{x:Static loc:Strings.SettingsSectionTextExtraction}">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              CanContentScroll="False">
                    <StackPanel>
                        <Border Style="{StaticResource SettingsCard}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Style="{StaticResource SettingsIconTile}"
                                        Margin="0,0,14,0">
                                    <TextBlock Text="&#xE8EA;"
                                               FontFamily="{StaticResource IconFontFamily}"
                                               FontSize="15"
                                               Foreground="{StaticResource AccentBrush}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Border>

                                <StackPanel Grid.Column="1" Margin="0,0,18,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding OcrStatusTitle}"
                                                   Style="{StaticResource Text.Body}"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center" />
                                        <Border Padding="7,2"
                                                Margin="10,0,0,0"
                                                VerticalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border" BasedOn="{StaticResource Badge}">
                                                    <Setter Property="Background" Value="{StaticResource WarningPanelBrush}" />
                                                    <Setter Property="BorderBrush" Value="{StaticResource YellowBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsOcrAvailable}" Value="True">
                                                            <Setter Property="Background" Value="#22A6E3A1" />
                                                            <Setter Property="BorderBrush" Value="{StaticResource GreenBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding OcrStatusBadge}"
                                                       FontSize="10.5"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextBrush}" />
                                        </Border>
                                    </StackPanel>

                                    <TextBlock Text="{Binding OcrStatusDescription}"
                                               Style="{StaticResource Text.Hint}"
                                               Margin="0,5,0,0"
                                               TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding OcrLanguageSummary}"
                                               Style="{StaticResource Text.Caption}"
                                               Margin="0,9,0,0"
                                               TextWrapping="Wrap" />
                                </StackPanel>

                                <StackPanel Grid.Column="2"
                                            Width="136"
                                            VerticalAlignment="Top">
                                    <Button Style="{StaticResource ChromeButton}"
                                            Command="{Binding OpenOcrLanguageSettingsCommand}"
                                            Padding="11,5"
                                            MinHeight="32"
                                            HorizontalAlignment="Stretch"
                                            ToolTip="{x:Static loc:Strings.SettingsOcrLanguagesTooltip}"
                                            AutomationProperties.Name="{x:Static loc:Strings.SettingsOcrLanguagesAutomationName}">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <TextBlock Text="&#xE713;"
                                                       FontFamily="{StaticResource IconFontFamily}"
                                                       FontSize="11"
                                                       Margin="0,0,7,0"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Text="{x:Static loc:Strings.SettingsOcrLanguagesButton}"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource ChromeButton}"
                                            Command="{Binding RefreshOcrStatusCommand}"
                                            Padding="11,5"
                                            MinHeight="32"
                                            Margin="0,8,0,0"
                                            HorizontalAlignment="Stretch"
                                            AutomationProperties.Name="{x:Static loc:Strings.SettingsOcrRefreshAutomationName}">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <TextBlock Text="&#xE72C;"
                                                       FontFamily="{StaticResource IconFontFamily}"
                                                       FontSize="11"
                                                       Margin="0,0,7,0"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Text="{x:Static loc:Strings.SettingsOcrRefreshButton}"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource SettingsCard}"
                                Background="#14181825">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE72E;"
                                           FontFamily="{StaticResource IconFontFamily}"
                                           FontSize="12"
                                           Foreground="{StaticResource OverlayBrush}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,9,0" />
                                <TextBlock Text="{x:Static loc:Strings.SettingsOcrPrivacyNote}"
                                           Style="{StaticResource Text.Hint}"
                                           TextWrapping="Wrap"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="{x:Static loc:Strings.SettingsSectionDiagnostics}">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              CanContentScroll="False">
                    <StackPanel>
                        <Border Style="{StaticResource SettingsCard}">
                            <StackPanel>
                                <TextBlock Text="{Binding DiagnosticsStorageSummary}"
                                           Style="{StaticResource Text.Hint}"
                                           TextWrapping="Wrap" />

                                <WrapPanel Margin="0,14,0,0">
                                    <Button Style="{StaticResource ChromeButton}"
                                            Command="{Binding OpenAppDataCommand}"
                                            Padding="12,6"
                                            MinHeight="32"
                                            Margin="0,0,8,8"
                                            AutomationProperties.Name="{x:Static loc:Strings.SettingsAppDataAutomationName}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE838;"
                                                       FontFamily="{StaticResource IconFontFamily}"
                                                       FontSize="11"
                                                       Margin="0,0,7,0"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Text="{x:Static loc:Strings.SettingsAppDataButton}"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>

                                    <Button Style="{StaticResource ChromeButton}"
                                            Command="{Binding OpenLogsCommand}"
                                            Padding="12,6"
                                            MinHeight="32"
                                            Margin="0,0,8,8"
                                            AutomationProperties.Name="{x:Static loc:Strings.SettingsLogsAutomationName}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE8A5;"
                                                       FontFamily="{StaticResource IconFontFamily}"
                                                       FontSize="11"
                                                       Margin="0,0,7,0"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Text="{x:Static loc:Strings.SettingsLogsButton}"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SettingsCard}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Style="{StaticResource SettingsIconTile}"
                                        Margin="0,0,14,0">
                                    <TextBlock Text="&#xE72E;"
                                               FontFamily="{StaticResource IconFontFamily}"
                                               FontSize="14"
                                               Foreground="{StaticResource AccentBrush}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Border>

                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{x:Static loc:Strings.SettingsSectionPrivacy}"
                                               Style="{StaticResource Text.Body}"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding UpdateCheckDescription}"
                                               Style="{StaticResource Text.Hint}"
                                               Margin="0,4,0,0"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <Grid Grid.Row="2" Margin="0,18,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Padding="12,9"
                    Margin="0,0,14,0"
                    Visibility="{Binding SettingsStatusText, Converter={StaticResource BoolToVis}}"
                    AutomationProperties.LiveSetting="Polite">
                <Border.Style>
                    <Style TargetType="Border" BasedOn="{StaticResource Card}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SettingsStatusTone}" Value="Success">
                                <Setter Property="Background" Value="#1FA6E3A1" />
                                <Setter Property="BorderBrush" Value="{StaticResource GreenBrush}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding SettingsStatusTone}" Value="Warning">
                                <Setter Property="Background" Value="{StaticResource WarningPanelBrush}" />
                                <Setter Property="BorderBrush" Value="{StaticResource YellowBrush}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding SettingsStatusIcon}"
                               FontFamily="{StaticResource IconFontFamily}"
                               FontSize="12"
                               VerticalAlignment="Center"
                               Margin="0,0,9,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SettingsStatusTone}" Value="Success">
                                        <Setter Property="Foreground" Value="{StaticResource GreenBrush}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding SettingsStatusTone}" Value="Warning">
                                        <Setter Property="Foreground" Value="{StaticResource YellowBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Text="{Binding SettingsStatusText}"
                               Style="{StaticResource Text.Caption}"
                               TextWrapping="Wrap"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Border>

            <Button Grid.Column="1"
                    Content="{x:Static loc:Strings.SettingsCloseButton}"
                    Style="{StaticResource ChromeButton}"
                    HorizontalAlignment="Right"
                    Padding="20,7"
                    MinWidth="92"
                    IsCancel="True"
                    Click="CloseButton_Click"
                    AutomationProperties.Name="{x:Static loc:Strings.SettingsCloseAutomationName}" />
        </Grid>
    </Grid>
</Window>
