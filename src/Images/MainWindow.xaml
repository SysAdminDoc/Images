                                        <Grid.RowDefinitions>
                                            <RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition />
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="{Binding PreviousNextShortcutText}" />
                                        <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Previous / next image or book page" />
                                        <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="{Binding FirstLastShortcutText}" />
                                        <TextBlock Grid.Row="1" Grid.Column="1" Style="{StaticResource MetaValue}" Text="First / last image or book page" />
                                        <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="Space / Bksp" />
                                        <TextBlock Grid.Row="2" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Next / previous image or book page" />
                                        <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="Mouse X1 / X2" />
                                        <TextBlock Grid.Row="3" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Previous / next image (5-button mouse)" />
                                        <TextBlock Grid.Row="4" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="{Binding ShortcutTexts[refresh]}" />
                                        <TextBlock Grid.Row="4" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Rescan folder" />
                                    </Grid>

                                    <TextBlock Text="View" Style="{StaticResource SectionLabel}" />
                                    <Grid Margin="0,0,0,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition />
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="Wheel" />
                                        <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Zoom about cursor" />
                                        <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="Shift + Wheel" />
                                        <TextBlock Grid.Row="1" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Pan horizontally" />
                                        <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="+ / −" />
                                        <TextBlock Grid.Row="2" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Zoom in / out" />
                                        <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="0 / 1" />
                                        <TextBlock Grid.Row="3" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Fit to viewport / 1:1 pixel" />
                                        <TextBlock Grid.Row="4" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="F11" />
                                        <TextBlock Grid.Row="4" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Toggle fullscreen" />
                                        <TextBlock Grid.Row="5" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="{Binding ShortcutTexts[filmstrip]}" />
                                        <TextBlock Grid.Row="5" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Toggle filmstrip" />
                                        <TextBlock Grid.Row="6" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="{Binding ShortcutTexts[metadata-hud]}" />
                                        <TextBlock Grid.Row="6" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Toggle metadata HUD" />
                                        <TextBlock Grid.Row="7" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="{Binding ShortcutTexts[crop-mode]}" />
                                        <TextBlock Grid.Row="7" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Toggle crop mode" />
                                        <TextBlock Grid.Row="8" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="{Binding ShortcutTexts[selection-mode]}" />
                                        <TextBlock Grid.Row="8" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Toggle pixel selection" />
                                        <TextBlock Grid.Row="9" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="{Binding ShortcutTexts[exposure-brush]}" />
                                        <TextBlock Grid.Row="9" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Toggle exposure brush" />
                                        <TextBlock Grid.Row="10" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="{Binding ShortcutTexts[red-eye]}" />
                                        <TextBlock Grid.Row="10" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Toggle red-eye correction" />
                                        <TextBlock Grid.Row="11" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="{Binding ShortcutTexts[retouch]}" />
                                        <TextBlock Grid.Row="11" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Toggle clone/heal retouch" />
                                        <TextBlock Grid.Row="12" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="{Binding ShortcutTexts[compare]}" />
                                        <TextBlock Grid.Row="12" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Compare with next image" />
                                        <TextBlock Grid.Row="13" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="O / X" />
                                        <TextBlock Grid.Row="13" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Toggle compare overlay / swap A-B" />
                                        <TextBlock Grid.Row="14" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="[ / ]" />
                                        <TextBlock Grid.Row="14" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Adjust compare overlay opacity" />
                                        <TextBlock Grid.Row="15" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="{Binding ShortcutTexts[compare-with]}" />
                                        <TextBlock Grid.Row="15" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Compare with chosen image" />
                                        <TextBlock Grid.Row="16" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="Hold Middle" />
                                        <TextBlock Grid.Row="16" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Loupe — magnify pixels under the cursor" />
                                        <TextBlock Grid.Row="17" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="{Binding ShortcutTexts[loupe]}" />
                                        <TextBlock Grid.Row="17" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Loupe — centered lens, pan to move" />
                                        <TextBlock Grid.Row="18" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="Ctrl+Shift+Drag" />
                                        <TextBlock Grid.Row="18" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Zoom to selection" />
                                    </Grid>

                                    <TextBlock Text="File" Style="{StaticResource SectionLabel}" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition />
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="{Binding ShortcutTexts[open]}" />
                                        <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Open image" />
                                        <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="{Binding ShortcutTexts[paste]}" />
                                        <TextBlock Grid.Row="1" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Paste image from clipboard" />
                                        <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="{Binding ShortcutTexts[save-copy]}" />
                                        <TextBlock Grid.Row="2" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Save a copy" />
                                        <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="{Binding ShortcutTexts[print]}" />
                                        <TextBlock Grid.Row="3" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Print current image" />
                                        <TextBlock Grid.Row="4" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="{Binding ShortcutTexts[delete]}" />
                                        <TextBlock Grid.Row="4" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Send to Recycle Bin" />
                                        <TextBlock Grid.Row="5" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="{Binding ShortcutTexts[reload]}" />
                                        <TextBlock Grid.Row="5" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Reload current image" />
                                        <TextBlock Grid.Row="6" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="{Binding ShortcutTexts[settings]}" />
                                        <TextBlock Grid.Row="6" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Settings" />
                                        <TextBlock Grid.Row="7" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="{Binding ShortcutTexts[reference-board]}" />
                                        <TextBlock Grid.Row="7" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Open reference board" />
                                        <TextBlock Grid.Row="8" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="{Binding ShortcutTexts[duplicate-cleanup]}" />
                                        <TextBlock Grid.Row="8" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Open duplicate cleanup" />
                                        <TextBlock Grid.Row="9" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="{Binding ShortcutTexts[file-health-scan]}" />
                                        <TextBlock Grid.Row="9" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Open file health scan" />
                                        <TextBlock Grid.Row="10" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="{Binding ShortcutTexts[tag-graph]}" />
                                        <TextBlock Grid.Row="10" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Open tag relationships" />
                                        <TextBlock Grid.Row="11" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="{Binding ShortcutTexts[import-inbox]}" />
                                        <TextBlock Grid.Row="11" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Open import inbox" />
                                        <TextBlock Grid.Row="12" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="{Binding ShortcutTexts[macro-actions]}" />
                                        <TextBlock Grid.Row="12" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Open macro actions" />
                                        <TextBlock Grid.Row="13" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="{Binding ShortcutTexts[batch-processor]}" />
                                        <TextBlock Grid.Row="13" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Open batch processor" />
                                        <TextBlock Grid.Row="14" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="{Binding ShortcutTexts[edit-stack]}" />
                                        <TextBlock Grid.Row="14" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Open edit history" />
                                        <TextBlock Grid.Row="15" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="{Binding ShortcutTexts[resize]}" />
                                        <TextBlock Grid.Row="15" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Open resize dialog" />
                                        <TextBlock Grid.Row="16" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="{Binding ShortcutTexts[adjustments]}" />
                                        <TextBlock Grid.Row="16" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Open adjustments" />
                                        <TextBlock Grid.Row="17" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="{Binding ShortcutTexts[effects]}" />
                                        <TextBlock Grid.Row="17" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Open effects" />
                                        <TextBlock Grid.Row="18" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="{Binding ShortcutTexts[auto-enhance]}" />
                                        <TextBlock Grid.Row="18" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Apply Auto Enhance" />
                                        <TextBlock Grid.Row="19" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="{Binding ShortcutTexts[perspective]}" />
                                        <TextBlock Grid.Row="19" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Open perspective correction" />
                                        <TextBlock Grid.Row="20" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="Enter" />
                                        <TextBlock Grid.Row="20" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Apply crop / commit rename" />
                                        <TextBlock Grid.Row="21" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="Esc" />
                                        <TextBlock Grid.Row="21" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Revert rename / dismiss overlay / exit fullscreen" />
                                    </Grid>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>

                    <!-- V20-29: Command palette overlay — Ctrl+Shift+P opens. Type to filter, Enter to execute, Escape to dismiss. -->
                    <Grid Visibility="{Binding ShowCommandPalette, Converter={StaticResource BoolToVis}}">
                        <Rectangle Fill="{DynamicResource OverlayDimmerBrush}" IsHitTestVisible="True"
                                   MouseDown="CommandPalette_DimmerClick" />
                        <Border Style="{StaticResource ElevatedCard}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Top"
                                Margin="0,80,0,0"
                                Width="520"
                                MaxHeight="460"
                                Padding="0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <!-- Search input -->
                                <Border Grid.Row="0" Padding="14,12" BorderThickness="0,0,0,1"
                                        BorderBrush="{DynamicResource HairlineBrush}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="&#xE721;"
                                                   FontFamily="{StaticResource IconFontFamily}"
                                                   FontSize="14"
                                                   Foreground="{DynamicResource OverlayBrush}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,10,0" />
                                        <TextBox x:Name="CommandPaletteInput"
                                                 Grid.Column="1"
                                                 Text="{Binding CommandPaletteFilterText, UpdateSourceTrigger=PropertyChanged}"
                                                 Background="Transparent"
                                                 BorderThickness="0"
                                                 Foreground="{DynamicResource TextBrush}"
                                                 CaretBrush="{DynamicResource AccentBrush}"
                                                 FontSize="14"
                                                 Padding="0,4"
                                                 VerticalContentAlignment="Center"
                                                 PreviewKeyDown="CommandPaletteInput_PreviewKeyDown"
                                                 AutomationProperties.Name="{loc:Loc AutomationMainWindowCommandPaletteSearch}" />
                                    </Grid>
                                </Border>

                                <!-- Filtered command list -->
                                <ListBox Grid.Row="1"
                                         x:Name="CommandPaletteList"
                                         ItemsSource="{Binding FilteredCommandPaletteItems}"
                                         SelectedIndex="{Binding SelectedCommandPaletteIndex, Mode=TwoWay}"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         VirtualizingStackPanel.IsVirtualizing="True"
                                         MouseDoubleClick="CommandPaletteList_MouseDoubleClick"
                                         MaxHeight="380"
                                         Padding="4,4"
                                         AutomationProperties.Name="{x:Static loc:Strings.CommandPaletteCommandListAutomationName}">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Padding" Value="12,8" />
                                            <Setter Property="Margin" Value="2,1" />
                                            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                                            <Setter Property="Background" Value="Transparent" />
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                            <Setter Property="AutomationProperties.Name" Value="{Binding Name}" />
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListBoxItem">
                                                        <Border x:Name="Bd"
                                                                Background="{TemplateBinding Background}"
                                                                CornerRadius="{StaticResource Radius.Sm.CR}"
                                                                Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter />
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsSelected" Value="True">
                                                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Surface0Brush}" />
                                                            </Trigger>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Surface0Brush}" />
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding Category}"
                                                           Foreground="{DynamicResource SubtextBrush}"
                                                           FontSize="11"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,8,0"
                                                           MinWidth="60" />
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding Name}"
                                                           Foreground="{DynamicResource TextBrush}"
                                                           FontSize="13"
                                                           VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding Shortcut}"
                                                           Foreground="{DynamicResource OverlayBrush}"
                                                           FontSize="11"
                                                           VerticalAlignment="Center"
                                                           Margin="12,0,0,0" />
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- Loading indicator — centered pill while image is decoding -->
                    <Border HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Visibility="{Binding IsImageLoading, Converter={StaticResource BoolToVis}}"
                            IsHitTestVisible="False"
                            AutomationProperties.Name="{x:Static loc:Strings.MainImageLoading}"
                            AutomationProperties.LiveSetting="Polite">
                        <Border Style="{StaticResource FloatingChrome}" Padding="14,8">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="6" Height="6"
                                         Fill="{DynamicResource AccentBrush}"
                                         Margin="0,0,8,0"
                                         VerticalAlignment="Center">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsImageLoading}" Value="True">
                                                    <DataTrigger.EnterActions>
                                                        <BeginStoryboard x:Name="LoadingPulse">
                                                            <Storyboard RepeatBehavior="Forever">
                                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                 From="0.3" To="1" AutoReverse="True"
                                                                                 Duration="0:0:0.6" />
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </DataTrigger.EnterActions>
                                                    <DataTrigger.ExitActions>
                                                        <StopStoryboard BeginStoryboardName="LoadingPulse" />
                                                    </DataTrigger.ExitActions>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock Text="{x:Static loc:Strings.MainImageLoading}"
                                           Style="{StaticResource Text.Caption}"
                                           Foreground="{DynamicResource FloatingChromeTextBrush}"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </Border>

                    <!-- Operation status — short live-region feedback for reload/export/edit work. -->
                    <Border HorizontalAlignment="Center"
                            VerticalAlignment="Top"
                            Margin="0,24,0,0"
                            MaxWidth="420"
                            Visibility="{Binding ShowOperationStatus, Converter={StaticResource BoolToVis}}"
                            AutomationProperties.Name="{Binding OperationStatusTitle}"
                            AutomationProperties.LiveSetting="Polite"
                            IsHitTestVisible="False">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource FloatingChrome}">
                                <Setter Property="BorderBrush" Value="{DynamicResource YellowBrush}" />
                                <Setter Property="Opacity" Value="0" />
                                <Style.Triggers>
                                    <Trigger Property="IsVisible" Value="True">
                                        <Trigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                     From="0" To="1"
                                                                     Duration="{StaticResource Motion.Base}">
                                                        <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </Trigger.EnterActions>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Width="32"
                                    Height="32"
                                    CornerRadius="{StaticResource Radius.Sm.CR}"
                                    BorderThickness="1"
                                    Background="{DynamicResource WarningPanelBrush}"
                                    BorderBrush="{DynamicResource YellowBrush}"
                                    VerticalAlignment="Center"
                                    Margin="0,0,12,0">
                                <TextBlock Text="&#xE895;"
                                           FontFamily="{StaticResource IconFontFamily}"
                                           FontSize="13"
                                           Foreground="{DynamicResource YellowBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding OperationStatusTitle}"
                                           Foreground="{DynamicResource FloatingChromeTextBrush}"
                                           FontSize="12.5"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="{Binding OperationStatusDetail}"
                                           Foreground="{DynamicResource SubtextBrush}"
                                           FontSize="11.5"
                                           LineHeight="16"
                                           TextWrapping="Wrap"
                                           Margin="0,3,0,0" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Toast notification — elevated floating chrome, fades on show via Opacity trigger -->
                    <Border x:Name="ToastHost"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Bottom"
                            Margin="0,0,0,88"
                            Visibility="{Binding ToastMessage, Converter={StaticResource BoolToVis}}"
                            AutomationProperties.LiveSetting="Polite">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource Toast}">
                                <Setter Property="Opacity" Value="0" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ToastTone}" Value="Success">
                                        <Setter Property="BorderBrush" Value="{DynamicResource GreenBrush}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ToastTone}" Value="Warning">
                                        <Setter Property="BorderBrush" Value="{DynamicResource YellowBrush}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ToastTone}" Value="Error">
                                        <Setter Property="BorderBrush" Value="{DynamicResource RedBrush}" />
                                    </DataTrigger>
                                    <Trigger Property="IsVisible" Value="True">
                                        <Trigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                     From="0" To="1"
                                                                     Duration="{StaticResource Motion.Base}">
                                                        <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </Trigger.EnterActions>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="{StaticResource IconFontFamily}"
                                       FontSize="13"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="&#xE930;" />
                                        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ToastTone}" Value="Success">
                                                <Setter Property="Text" Value="&#xE73E;" />
                                                <Setter Property="Foreground" Value="{DynamicResource GreenBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding ToastTone}" Value="Warning">
                                                <Setter Property="Text" Value="&#xE783;" />
                                                <Setter Property="Foreground" Value="{DynamicResource YellowBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding ToastTone}" Value="Error">
                                                <Setter Property="Text" Value="&#xE783;" />
                                                <Setter Property="Foreground" Value="{DynamicResource RedBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Text="{Binding ToastMessage}"
                                       Foreground="{DynamicResource FloatingChromeTextBrush}"
                                       FontSize="13"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </Grid>

            </Grid>

            <!-- Bottom toolbar — premium horizontal chrome bar with 1-px top highlight.
                 V20-32: peek-mode hides the entire toolbar so the image fills the window with
                 zero chrome. The Width="Auto" outer column on the side panel + IsFullscreen=true
                 binding handles the right-side panel; this Visibility handles the toolbar row. -->
            <Grid x:Name="BottomToolbarGrid" Grid.Row="1"
                  Visibility="{Binding IsPeekMode, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="1" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <!-- Subtle top highlight: sits just inside the divider line, gives the toolbar a
                     gently lit edge like polished macOS / Win11 chrome. -->
                <Border Grid.Row="0" Height="1" Background="{DynamicResource DividerBrush}" />
                <Border Grid.Row="1"
                        Background="{DynamicResource WorkspaceTopBarBrush}"
                        BorderBrush="{DynamicResource WorkspaceTopBarBorderBrush}"
                        BorderThickness="0,1,0,0">
                    <Grid Margin="14,8,14,9">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Margin="0,0,0,8"
                                Visibility="{Binding ShowFilmstrip, Converter={StaticResource BoolToVis}}">
                            <ListBox x:Name="FilmstripItems"
                                     ItemsSource="{Binding FolderPreviewItems}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Padding="0,0,0,4"
                                     MaxHeight="94"
                                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                     ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                     ScrollViewer.CanContentScroll="True"
                                     VirtualizingPanel.IsVirtualizing="True"
                                     VirtualizingPanel.VirtualizationMode="Recycling"
                                     VirtualizingPanel.CacheLength="2,2"
                                     VirtualizingPanel.CacheLengthUnit="Item"
                                     KeyboardNavigation.DirectionalNavigation="Cycle"
                                     KeyboardNavigation.TabNavigation="Continue"
                                     AutomationProperties.Name="{loc:Loc AutomationMainWindowBottomFolderFilmstrip}">
                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <VirtualizingStackPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Padding" Value="0" />
                                            <Setter Property="Margin" Value="0" />
                                            <Setter Property="Focusable" Value="False" />
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListBoxItem">
                                                        <ContentPresenter />
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Button Command="{Binding DataContext.OpenPreviewItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    Loaded="PreviewThumbnail_Loaded"
                                                    Width="78"
                                                    MinHeight="76"
                                                    Margin="0,0,7,0"
                                                    Padding="4"
                                                    HorizontalContentAlignment="Stretch"
                                                    VerticalContentAlignment="Stretch"
                                                    ToolTip="{Binding Path}"
                                                    Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    AutomationProperties.Name="{Binding FileName}"
                                                    AutomationProperties.HelpText="{Binding PositionText}"
                                                    AutomationProperties.ItemStatus="{Binding PositionText}">
                                                <Button.ContextMenu>
                                                    <ContextMenu Style="{StaticResource ViewportContextMenu}">
                                                        <MenuItem Header="Open"
                                                                  Command="{Binding PlacementTarget.Tag.OpenPreviewItemCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                                            <MenuItem.Icon>
                                                                <TextBlock Style="{StaticResource MenuItemIcon}" Text="&#xE8E5;" />
                                                            </MenuItem.Icon>
                                                        </MenuItem>
                                                        <MenuItem Header="Reveal in Explorer"
                                                                  Command="{Binding PlacementTarget.Tag.RevealPreviewItemCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                                            <MenuItem.Icon>
                                                                <TextBlock Style="{StaticResource MenuItemIcon}" Text="&#xE838;" />
                                                            </MenuItem.Icon>
                                                        </MenuItem>
                                                        <MenuItem Header="Copy path"
                                                                  Command="{Binding PlacementTarget.Tag.CopyPreviewPathCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                                            <MenuItem.Icon>
                                                                <TextBlock Style="{StaticResource MenuItemIcon}" Text="&#xE8C8;" />
                                                            </MenuItem.Icon>
                                                        </MenuItem>
                                                    </ContextMenu>
                                                </Button.ContextMenu>
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource ChromeButton}">
                                                        <Setter Property="Background" Value="{DynamicResource Surface0Brush}" />
                                                        <Setter Property="BorderBrush" Value="{DynamicResource HairlineBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                                                <Setter Property="Background" Value="{DynamicResource AccentWarmPanelBrush}" />
                                                                <Setter Property="BorderBrush" Value="{DynamicResource AccentWarmBrush}" />
                                                            </DataTrigger>
                                                            <Trigger Property="IsKeyboardFocused" Value="True">
                                                                <Setter Property="Background" Value="{DynamicResource AccentWarmPanelBrush}" />
                                                                <Setter Property="BorderBrush" Value="{DynamicResource FocusRingBrush}" />
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                                <StackPanel>
                                                    <Border Height="44"
                                                            CornerRadius="{StaticResource Radius.Sm.CR}"
                                                            Background="{DynamicResource ViewportBrush}"
                                                            BorderBrush="{DynamicResource HairlineBrush}"
                                                            BorderThickness="1"
                                                            ClipToBounds="True">
                                                        <Grid>
                                                            <Image Source="{Binding Thumbnail}"
                                                                   Stretch="UniformToFill"
                                                                   RenderOptions.BitmapScalingMode="HighQuality"
                                                                   Visibility="{Binding HasThumbnail, Converter={StaticResource BoolToVis}}" />
                                                            <TextBlock Text="&#xEB9F;"
                                                                       FontFamily="{StaticResource IconFontFamily}"
                                                                       FontSize="16"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"
                                                                       Visibility="{Binding HasThumbnail, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="{x:Type TextBlock}">
                                                                        <Setter Property="Foreground" Value="{DynamicResource OverlayBrush}" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding ThumbnailFailed}" Value="True">
                                                                                <Setter Property="Text" Value="&#xE783;" />
                                                                                <Setter Property="Foreground" Value="{DynamicResource YellowBrush}" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </Grid>
                                                    </Border>
                                                    <TextBlock Text="{Binding FileName}"
                                                               Foreground="{DynamicResource TextBrush}"
                                                               FontSize="10.5"
                                                               FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis"
                                                               Margin="1,5,1,0" />
                                                    <TextBlock Text="{Binding PositionText}"
                                                               Foreground="{DynamicResource OverlayBrush}"
                                                               FontSize="10"
                                                               Margin="1,1,1,0" />
                                                </StackPanel>
                                            </Button>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                        </Border>

                        <!-- Current file info gets its own row so command clusters never collide on narrow widths. -->
                        <Grid x:Name="CurrentFileInfoRow"
                              Grid.Row="1"
                              MinHeight="20"
                              Margin="0"
                              Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Visibility="{Binding HasImage, Converter={StaticResource BoolToVis}}">
                                <Button Style="{StaticResource ChromeButton}"
                                        Click="FolderSortButton_Click"
                                        Padding="9,4"
                                        MinHeight="26"
                                        Margin="0,0,10,0"
                                        ToolTip="{Binding FolderSortTooltip}"
                                        AutomationProperties.Name="{loc:Loc AutomationMainWindowFolderSort}"
                                        AutomationProperties.HelpText="{Binding FolderSortTooltip}">
                                    <Button.ContextMenu>
                                        <ContextMenu Style="{StaticResource ViewportContextMenu}">
                                            <MenuItem Header="Name (natural)"
                                                      Command="{Binding PlacementTarget.DataContext.SetFolderSortCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="NaturalName"
                                                      IsCheckable="True"
                                                      IsChecked="{Binding PlacementTarget.DataContext.CurrentSortMode, RelativeSource={RelativeSource AncestorType=ContextMenu}, Converter={StaticResource SortModeMatches}, ConverterParameter=NaturalName, Mode=OneWay}" />
                                            <MenuItem Header="Explorer-like name order"
                                                      Command="{Binding PlacementTarget.DataContext.SetFolderSortCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="ExplorerLike"
                                                      IsCheckable="True"
                                                      IsChecked="{Binding PlacementTarget.DataContext.CurrentSortMode, RelativeSource={RelativeSource AncestorType=ContextMenu}, Converter={StaticResource SortModeMatches}, ConverterParameter=ExplorerLike, Mode=OneWay}" />
                                            <MenuItem Header="Name (Z to A)"
                                                      Command="{Binding PlacementTarget.DataContext.SetFolderSortCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="NameDescending"
                                                      IsCheckable="True"
                                                      IsChecked="{Binding PlacementTarget.DataContext.CurrentSortMode, RelativeSource={RelativeSource AncestorType=ContextMenu}, Converter={StaticResource SortModeMatches}, ConverterParameter=NameDescending, Mode=OneWay}" />
                                            <Separator />
                                            <MenuItem Header="Modified (newest first)"
                                                      Command="{Binding PlacementTarget.DataContext.SetFolderSortCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="ModifiedNewest"
                                                      IsCheckable="True"
                                                      IsChecked="{Binding PlacementTarget.DataContext.CurrentSortMode, RelativeSource={RelativeSource AncestorType=ContextMenu}, Converter={StaticResource SortModeMatches}, ConverterParameter=ModifiedNewest, Mode=OneWay}" />
                                            <MenuItem Header="Modified (oldest first)"
                                                      Command="{Binding PlacementTarget.DataContext.SetFolderSortCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="ModifiedOldest"
                                                      IsCheckable="True"
                                                      IsChecked="{Binding PlacementTarget.DataContext.CurrentSortMode, RelativeSource={RelativeSource AncestorType=ContextMenu}, Converter={StaticResource SortModeMatches}, ConverterParameter=ModifiedOldest, Mode=OneWay}" />
                                            <MenuItem Header="Created (newest first)"
                                                      Command="{Binding PlacementTarget.DataContext.SetFolderSortCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="CreatedNewest"
                                                      IsCheckable="True"
                                                      IsChecked="{Binding PlacementTarget.DataContext.CurrentSortMode, RelativeSource={RelativeSource AncestorType=ContextMenu}, Converter={StaticResource SortModeMatches}, ConverterParameter=CreatedNewest, Mode=OneWay}" />
                                            <MenuItem Header="Created (oldest first)"
                                                      Command="{Binding PlacementTarget.DataContext.SetFolderSortCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="CreatedOldest"
                                                      IsCheckable="True"
                                                      IsChecked="{Binding PlacementTarget.DataContext.CurrentSortMode, RelativeSource={RelativeSource AncestorType=ContextMenu}, Converter={StaticResource SortModeMatches}, ConverterParameter=CreatedOldest, Mode=OneWay}" />
                                            <Separator />
                                            <MenuItem Header="Size (largest first)"
                                                      Command="{Binding PlacementTarget.DataContext.SetFolderSortCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="SizeLargest"
                                                      IsCheckable="True"
                                                      IsChecked="{Binding PlacementTarget.DataContext.CurrentSortMode, RelativeSource={RelativeSource AncestorType=ContextMenu}, Converter={StaticResource SortModeMatches}, ConverterParameter=SizeLargest, Mode=OneWay}" />
                                            <MenuItem Header="Size (smallest first)"
                                                      Command="{Binding PlacementTarget.DataContext.SetFolderSortCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="SizeSmallest"
                                                      IsCheckable="True"
                                                      IsChecked="{Binding PlacementTarget.DataContext.CurrentSortMode, RelativeSource={RelativeSource AncestorType=ContextMenu}, Converter={StaticResource SortModeMatches}, ConverterParameter=SizeSmallest, Mode=OneWay}" />
                                            <MenuItem Header="Type, then name"
                                                      Command="{Binding PlacementTarget.DataContext.SetFolderSortCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="ExtensionThenName"
                                                      IsCheckable="True"
                                                      IsChecked="{Binding PlacementTarget.DataContext.CurrentSortMode, RelativeSource={RelativeSource AncestorType=ContextMenu}, Converter={StaticResource SortModeMatches}, ConverterParameter=ExtensionThenName, Mode=OneWay}" />
                                        </ContextMenu>
                                    </Button.ContextMenu>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="&#xE8CB;"
                                                   FontFamily="{StaticResource IconFontFamily}"
                                                   FontSize="11"
                                                   Margin="0,0,6,0"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding FolderSortLabel}"
                                                   FontSize="11.5"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                                <TextBlock Text="{Binding CurrentFileName}"
                                           Foreground="{DynamicResource TextBrush}"
                                           FontWeight="SemiBold"
                                           FontSize="13"
                                           MaxWidth="260"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="  ·  "
                                           Foreground="{DynamicResource OverlayBrush}"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="{Binding DimensionsText}"
                                           Foreground="{DynamicResource SubtextBrush}"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="  ·  "
                                           Foreground="{DynamicResource OverlayBrush}"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="{Binding FileSizeText}"
                                           Foreground="{DynamicResource SubtextBrush}"
                                           VerticalAlignment="Center" />

                                <Border Margin="10,0,0,0"
                                        Padding="8,2"
                                        CornerRadius="{StaticResource Radius.Sm.CR}"
                                        Background="{DynamicResource MauvePanelBrush}"
                                        BorderBrush="{DynamicResource MauveBrush}"
                                        BorderThickness="1"
                                        VerticalAlignment="Center"
                                        Visibility="{Binding HasMultiplePages, Converter={StaticResource BoolToVis}}"
                                        AutomationProperties.Name="{loc:Loc AutomationMainWindowPagedFile}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE8A5;"
                                                   FontFamily="{StaticResource IconFontFamily}"
                                                   FontSize="10"
                                                   Foreground="{DynamicResource MauveBrush}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,5,0" />
                                        <TextBlock Text="{Binding PagePositionText}"
                                                   FontSize="10.5"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource MauveBrush}"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Border>

                                <!-- Animated-image chip — only surfaces when CurrentAnimation is non-null.
                                     Small green status chip so the GIF/APNG/animated-WebP state reads at a glance
                                     without competing with the primary command row. -->
                                <Border Margin="10,0,0,0"
                                        Padding="8,2"
                                        CornerRadius="{StaticResource Radius.Sm.CR}"
                                        Background="{DynamicResource SuccessPanelBrush}"
                                        BorderBrush="{DynamicResource GreenBrush}"
                                        BorderThickness="1"
                                        VerticalAlignment="Center"
                                        Visibility="{Binding IsAnimated, Converter={StaticResource BoolToVis}}"
                                        AutomationProperties.Name="{loc:Loc AutomationMainWindowAnimatedImage}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE768;"
                                                   FontFamily="{StaticResource IconFontFamily}"
                                                   FontSize="10"
                                                   Foreground="{DynamicResource GreenBrush}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,5,0" />
                                        <TextBlock Text="{Binding AnimationFrameCountText}"
                                                   FontSize="10.5"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource GreenBrush}"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Border>

                                <!-- Channel-isolation chip (V20-28) — shows the active R/G/B/A filter.
                                     Click cycles to the next channel mode. -->
                                <Border Margin="10,0,0,0"
                                        Padding="8,2"
                                        MinHeight="24"
                                        CornerRadius="{StaticResource Radius.Sm.CR}"
                                        Background="{DynamicResource AccentSelectionBrush}"
                                        BorderBrush="{DynamicResource AccentBrush}"
                                        BorderThickness="1"
                                        VerticalAlignment="Center"
                                        Visibility="{Binding IsChannelIsolated, Converter={StaticResource BoolToVis}}"
                                        AutomationProperties.Name="{loc:Loc AutomationMainWindowChannelIsolationActive}"
                                        Cursor="Hand"
                                        MouseLeftButtonUp="ChannelChip_Click">
                                    <TextBlock Text="{Binding ChannelModeLabel}"
                                               FontSize="10.5"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource AccentBrush}"
                                               VerticalAlignment="Center" />
                                </Border>

                                <!-- V20-31: listen-mode chip — shows the active loopback TCP port. -->
                                <Border Margin="10,0,0,0"
                                        Padding="8,2"
                                        CornerRadius="{StaticResource Radius.Sm.CR}"
                                        Background="{DynamicResource SuccessPanelBrush}"
                                        BorderBrush="{DynamicResource GreenBrush}"
                                        BorderThickness="1"
                                        VerticalAlignment="Center"
                                        Visibility="{Binding IsListening, Converter={StaticResource BoolToVis}}"
                                        ToolTip="{Binding ListenPortTooltip}"
                                        AutomationProperties.Name="{loc:Loc AutomationMainWindowListenModeActive}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE703;"
                                                   FontFamily="{StaticResource IconFontFamily}"
                                                   FontSize="10"
                                                   Foreground="{DynamicResource GreenBrush}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,4,0" />
                                        <TextBlock Text="{Binding ListenPortLabel}"
                                                   FontSize="10.5"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource GreenBrush}"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Border>

                                <!-- V30-33: slideshow indicator chip -->
                                <Border x:Name="SlideshowChip"
                                        Margin="10,0,0,0"
                                        Padding="8,2"
                                        MinHeight="24"
                                        CornerRadius="{StaticResource Radius.Sm.CR}"
                                        Background="{DynamicResource SuccessPanelBrush}"
                                        BorderBrush="{DynamicResource GreenBrush}"
                                        BorderThickness="1"
                                        VerticalAlignment="Center"
                                        Visibility="{Binding IsSlideshowActive, Converter={StaticResource BoolToVis}}"
                                        ToolTip="Click to pause/resume, Escape to stop"
                                        Cursor="Hand"
                                        MouseEnter="SlideshowChip_MouseEnter"
                                        MouseLeave="SlideshowChip_MouseLeave"
                                        MouseLeftButtonDown="SlideshowChip_MouseLeftButtonDown"
                                        AutomationProperties.Name="{loc:Loc AutomationMainWindowSlideshowActive}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE768;"
                                                   FontFamily="{StaticResource IconFontFamily}"
                                                   FontSize="10"
                                                   Foreground="{DynamicResource GreenBrush}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,4,0" />
                                        <TextBlock Text="{Binding SlideshowStatusText}"
                                                   FontSize="10.5"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource GreenBrush}"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Visibility="{Binding HasImage, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}">
                                <TextBlock Text="Ready"
                                           Foreground="{DynamicResource TextBrush}"
                                           FontWeight="SemiBold"
                                           FontSize="13"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="  ·  "
                                           Foreground="{DynamicResource OverlayBrush}"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="Open or drop a supported file to start viewing."
                                           Foreground="{DynamicResource SubtextBrush}"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Grid>

                        <!-- Wrapping command row preserves all actions instead of clipping at the minimum width. -->
                        <WrapPanel Grid.Row="2"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center">
                            <Button Style="{StaticResource ToolbarButton}" Command="{Binding PrevCommand}" Content="&#xE76B;" ToolTip="Previous (Left)" AutomationProperties.Name="{loc:Loc AutomationMainWindowPreviousImage}" />
                            <Button Style="{StaticResource ToolbarButton}" Command="{Binding RotateCcwCommand}" Content="&#xE7AD;" ToolTip="Rotate left" Margin="4,0,0,0" AutomationProperties.Name="{loc:Loc AutomationMainWindowRotateLeft}" />
                            <Button x:Name="FitButton"
                                    Style="{StaticResource ToolbarTextButton}"
                                    Content="Fit"
                                    Click="FitButton_Click"
                                    ToolTip="Fit image to viewport"
                                    Margin="8,0,0,0"
                                    AutomationProperties.Name="{Binding ToolTip, RelativeSource={RelativeSource Self}}" />
                            <Button Style="{StaticResource ToolbarButton}" Command="{Binding OpenCommand}" Content="&#xE8E5;" ToolTip="Open…" Margin="4,0,0,0" Visibility="Collapsed" AutomationProperties.Name="{loc:Loc AutomationMainWindowOpenImage}" />
                            <Button Style="{StaticResource ToolbarButton}" Command="{Binding RotateCwCommand}" Content="&#xE7AC;" ToolTip="Rotate right" Margin="4,0,0,0" AutomationProperties.Name="{loc:Loc AutomationMainWindowRotateRight}" />
                            <Button Style="{StaticResource ToolbarButton}" Command="{Binding NextCommand}" Content="&#xE76C;" ToolTip="Next (Right)" Margin="4,0,0,0" AutomationProperties.Name="{loc:Loc AutomationMainWindowNextImage}" />
                            <Button Command="{Binding ToggleFilmstripCommand}"
                                    Content="&#xEB9F;"
                                    ToolTip="{Binding FilmstripToggleTooltip}"
                                    Margin="4,0,0,0"
                                    Visibility="{Binding CanToggleFilmstrip, Converter={StaticResource BoolToVis}}"
                                    AutomationProperties.Name="{loc:Loc AutomationMainWindowToggleFilmstrip}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource ToolbarButton}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsFilmstripVisible}" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource AccentWarmPanelBrush}" />
                                                <Setter Property="BorderBrush" Value="{DynamicResource AccentWarmBrush}" />
                                                <Setter Property="Foreground" Value="{DynamicResource AccentWarmBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Command="{Binding ToggleMetadataHudCommand}"
                                    Content="&#xE946;"
                                    ToolTip="{Binding MetadataHudToggleTooltip}"
                                    Margin="4,0,0,0"
                                    Visibility="Collapsed"
                                    AutomationProperties.Name="{loc:Loc AutomationMainWindowToggleMetadataHUD}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource ToolbarButton}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsMetadataHudVisible}" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource AccentPanelBrush}" />
                                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                                <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Command="{Binding ExtractTextCommand}"
                                    Content="&#xE8EA;"
                                    ToolTip="{Binding OcrModeTooltip}"
                                    Margin="4,0,0,0"
                                    Visibility="Collapsed"
                                    AutomationProperties.Name="{loc:Loc AutomationMainWindowExtractText}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource ToolbarButton}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsOcrMode}" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource AccentPanelBrush}" />
                                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                                <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsOcrBusy}" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource WarningPanelBrush}" />
                                                <Setter Property="BorderBrush" Value="{DynamicResource YellowBrush}" />
                                                <Setter Property="Foreground" Value="{DynamicResource YellowBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Border Width="1"
                                    Height="22"
                                    Background="{DynamicResource HairlineBrush}"
                                    Margin="12,6"
                                    Visibility="{Binding HasMultiplePages, Converter={StaticResource BoolToVis}}" />
                            <Button Style="{StaticResource ToolbarButton}"
                                    Command="{Binding PrevPageCommand}"
                                    Content="&#xE76B;"
                                    ToolTip="Previous page"
                                    AutomationProperties.Name="{loc:Loc AutomationMainWindowPreviousPage}"
                                    Visibility="{Binding HasMultiplePages, Converter={StaticResource BoolToVis}}" />
                            <Button Style="{StaticResource ToolbarButton}"
                                    Command="{Binding NextPageCommand}"
                                    Content="&#xE76C;"
                                    ToolTip="Next page"
                                    Margin="4,0,0,0"
                                    AutomationProperties.Name="{loc:Loc AutomationMainWindowNextPage}"
                                    Visibility="{Binding HasMultiplePages, Converter={StaticResource BoolToVis}}" />
                            <Border Width="1" Height="22" Background="{DynamicResource HairlineBrush}" Margin="12,6" />
                            <Button Style="{StaticResource ToolbarButton}" Command="{Binding DeleteCommand}" Content="&#xE74D;" ToolTip="Delete (Recycle Bin)" AutomationProperties.Name="{loc:Loc AutomationMainWindowSendImageToRecycleBin}" />
                            <Border Width="1" Height="22" Background="{DynamicResource HairlineBrush}" Margin="12,6" />
                            <Button Style="{StaticResource ToolbarButton}" Command="{Binding RevealCommand}" Content="&#xE838;" ToolTip="Reveal in Explorer" AutomationProperties.Name="{loc:Loc AutomationMainWindowRevealImageInExplorer}" />
                            <Button Style="{StaticResource ToolbarButton}" Command="{Binding CopyPathCommand}" Content="&#xE8C8;" ToolTip="Copy path" Margin="4,0,0,0" Visibility="Collapsed" AutomationProperties.Name="{loc:Loc AutomationMainWindowCopyFilePath}" />
                            <Button Style="{StaticResource ToolbarButton}" Command="{Binding RefreshCommand}" Content="&#xE72C;" ToolTip="{Binding ShortcutTexts[refresh], StringFormat=Refresh folder ({0})}" Margin="4,0,0,0" Visibility="Collapsed" AutomationProperties.Name="{loc:Loc AutomationMainWindowRefreshFolder}" />
                            <Border Width="1" Height="22" Background="{DynamicResource HairlineBrush}" Margin="12,6" />
                            <Button Style="{StaticResource ToolbarButton}"
                                    Content="&#xE949;"
                                    Click="ZoomOutButton_Click"
                                    ToolTip="Zoom out"
                                    AutomationProperties.Name="{Binding ToolTip, RelativeSource={RelativeSource Self}}" />
                            <Button Style="{StaticResource ToolbarButton}"
                                    Content="&#xE948;"
                                    Click="ZoomInButton_Click"
                                    ToolTip="Zoom in"
                                    Margin="4,0,0,0"
                                    AutomationProperties.Name="{Binding ToolTip, RelativeSource={RelativeSource Self}}" />
                        </WrapPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- ============ RIGHT: Contextual details panel ============ -->
        <Border x:Name="RightSidePanel" Grid.Column="2"
                Width="300"
                Visibility="{Binding IsFullscreen, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}"
                Background="{DynamicResource InspectorPanelBrush}"
                BorderBrush="{DynamicResource HairlineBrush}"
                BorderThickness="1,0,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0">
                <StackPanel Margin="16,18,16,24">

                    <!-- Panel header -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Style="{StaticResource Text.Title}"
                                       Text="Details" />
                            <TextBlock Style="{StaticResource Text.Subtitle}"
                                       Text="Filename, metadata, and local status."
                                       TextWrapping="Wrap"
                                       Margin="0,6,0,0"
                                       Visibility="Collapsed" />
                        </StackPanel>
                        <!-- V15-06: click the info icon for the About dialog. Keeps the header
                             visually clean — no visible button chrome, just an accent on hover. -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top" Margin="8,0,0,0" Visibility="Collapsed">
                            <Button Command="{Binding SettingsCommand}"
                                    Style="{StaticResource ToolbarButton}"
                                    Content="&#xE713;"
                                    ToolTip="{Binding ShortcutTexts[settings], StringFormat=Settings ({0})}"
                                    AutomationProperties.Name="{loc:Loc AutomationMainWindowSettings}" />
                            <Button Command="{Binding AboutCommand}"
                                    Style="{StaticResource ToolbarButton}"
                                    Content="&#xE946;"
                                    ToolTip="About Images"
                                    AutomationProperties.Name="{loc:Loc AutomationMainWindowAboutImages}"
                                    Margin="4,0,0,0" />
                        </StackPanel>
                    </Grid>

                    <Border Style="{StaticResource Card}"
                            Background="{DynamicResource AccentPanelBrush}"
                            BorderBrush="{DynamicResource AccentBrush}"
                            Margin="0,0,0,20"
                            Visibility="{Binding HasUpdateAvailable, Converter={StaticResource BoolToVis}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="&#xE895;"
                                       FontFamily="{StaticResource IconFontFamily}"
                                       FontSize="14"
                                       Foreground="{DynamicResource AccentBrush}"
                                       Margin="0,1,10,0"
                                       VerticalAlignment="Top" />
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{Binding LatestUpdateTag, StringFormat=Update {0} is available}"
                                           FontSize="12.5"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}" />
                                <TextBlock Text="Open the release page when you are ready to install it."
                                           Style="{StaticResource Text.Hint}"
                                           Margin="0,3,0,0" />
                            </StackPanel>
                            <Button Grid.Column="2"
                                    Command="{Binding OpenLatestUpdateCommand}"
                                    Style="{StaticResource ChromeButton}"
                                    Padding="12,4"
                                    MinHeight="28"
                                    Margin="12,0,0,0"
                                    VerticalAlignment="Center"
                                    AutomationProperties.Name="{loc:Loc AutomationMainWindowViewAvailableUpdate}">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE8A7;"
                                               FontFamily="{StaticResource IconFontFamily}"
                                               FontSize="11"
                                               Margin="0,0,7,0"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="View" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource Card}"
                            BorderBrush="{DynamicResource AccentBrush}"
                            Margin="0,0,0,20"
                            Visibility="{Binding IsCheckingForUpdates, Converter={StaticResource BoolToVis}}"
                            AutomationProperties.Name="{loc:Loc AutomationMainWindowUpdateCheckStatus}"
                            AutomationProperties.LiveSetting="Polite">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0"
                                    Width="32"
                                    Height="32"
                                    CornerRadius="{StaticResource Radius.Sm.CR}"
                                    BorderThickness="1"
                                    Background="{DynamicResource AccentPanelBrush}"
                                    BorderBrush="{DynamicResource AccentBrush}"
                                    VerticalAlignment="Top"
                                    Margin="0,0,12,0">
                                <TextBlock Text="&#xE895;"
                                           FontFamily="{StaticResource IconFontFamily}"
                                           FontSize="13"
                                           Foreground="{DynamicResource AccentBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Checking for updates"
                                           Style="{StaticResource Text.Caption}"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}" />
                                <TextBlock Text="{Binding UpdateCheckStatusText}"
                                           Style="{StaticResource Text.Hint}"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Margin="0,0,0,20"
                            Visibility="{Binding HasSecondaryStatus, Converter={StaticResource BoolToVis}}"
                            AutomationProperties.Name="{Binding SecondaryStatusTitle}"
                            AutomationProperties.LiveSetting="Polite">
                        <Border.Style>
                            <Style TargetType="{x:Type Border}" BasedOn="{StaticResource Card}">
                                <Setter Property="BorderBrush" Value="{DynamicResource HairlineBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SecondaryStatusTone}" Value="Info">
                                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding SecondaryStatusTone}" Value="Success">
                                        <Setter Property="BorderBrush" Value="{DynamicResource GreenBrush}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding SecondaryStatusTone}" Value="Warning">
                                        <Setter Property="Background" Value="{DynamicResource WarningPanelBrush}" />
                                        <Setter Property="BorderBrush" Value="{DynamicResource YellowBrush}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding SecondaryStatusTone}" Value="Error">
                                        <Setter Property="BorderBrush" Value="{DynamicResource RedBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Width="32"
                                    Height="32"
                                    CornerRadius="{StaticResource Radius.Sm.CR}"
                                    BorderThickness="1"
                                    VerticalAlignment="Top"
                                    Margin="0,0,12,0">
                                <Border.Style>
                                    <Style TargetType="{x:Type Border}">
                                        <Setter Property="Background" Value="{DynamicResource AccentPanelBrush}" />
                                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SecondaryStatusTone}" Value="Success">
                                                <Setter Property="BorderBrush" Value="{DynamicResource GreenBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding SecondaryStatusTone}" Value="Warning">
                                                <Setter Property="Background" Value="{DynamicResource WarningPanelBrush}" />
                                                <Setter Property="BorderBrush" Value="{DynamicResource YellowBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding SecondaryStatusTone}" Value="Error">
                                                <Setter Property="BorderBrush" Value="{DynamicResource RedBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>

                                <TextBlock Text="{Binding SecondaryStatusIcon}"
                                           FontFamily="{StaticResource IconFontFamily}"
                                           FontSize="13"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="{x:Type TextBlock}">
                                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SecondaryStatusTone}" Value="Success">
                                                    <Setter Property="Foreground" Value="{DynamicResource GreenBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding SecondaryStatusTone}" Value="Warning">
                                                    <Setter Property="Foreground" Value="{DynamicResource YellowBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding SecondaryStatusTone}" Value="Error">
                                                    <Setter Property="Foreground" Value="{DynamicResource RedBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{Binding SecondaryStatusTitle}"
                                           Style="{StaticResource Text.Caption}"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}" />
                                <TextBlock Text="{Binding SecondaryStatusDetail}"
                                           Style="{StaticResource Text.Hint}"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Margin="0,0,0,20"
                            Visibility="{Binding HasBackgroundActivity, Converter={StaticResource BoolToVis}}"
                            AutomationProperties.Name="{Binding ActivitySummaryText}"
                            AutomationProperties.LiveSetting="Polite">
                        <Border.Style>
                            <Style TargetType="{x:Type Border}" BasedOn="{StaticResource Card}">
                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                            </Style>
                        </Border.Style>
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           FontFamily="{StaticResource IconFontFamily}"
                                           FontSize="14"
                                           Margin="0,1,10,0"
                                           VerticalAlignment="Top">
                                    <TextBlock.Style>
                                        <Style TargetType="{x:Type TextBlock}">
                                            <Setter Property="Text" Value="&#xE916;" />
                                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ActivityRunningCount}" Value="0">
                                                    <Setter Property="Text" Value="&#xE7BA;" />
                                                    <Setter Property="Foreground" Value="{DynamicResource YellowBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Activity"
                                               Style="{StaticResource Text.Caption}"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextBrush}" />
                                    <TextBlock Text="{Binding ActivitySummaryText}"
                                               Style="{StaticResource Text.Hint}"
                                               TextWrapping="Wrap"
                                               Margin="0,4,0,0" />
                                </StackPanel>
                            </Grid>
                            <ItemsControl ItemsSource="{Binding ActivityJobs}"
                                          Margin="0,8,0,0"
                                          MaxHeight="160">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="6,4" Margin="0,0,0,2"
                                                Background="{DynamicResource SubtleSurfaceBrush}"
                                                CornerRadius="4">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Name}"
                                                           Style="{StaticResource Text.Caption}"
                                                           TextTrimming="CharacterEllipsis"
                                                           VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding DurationText}"
                                                           Style="{StaticResource Text.Caption}"
                                                           Foreground="{DynamicResource SubtextBrush}"
                                                           Margin="8,0"
                                                           VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding StateText}"
                                                           VerticalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="{x:Type TextBlock}" BasedOn="{StaticResource Text.Caption}">
                                                            <Setter Property="Foreground" Value="{DynamicResource SubtextBrush}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding State}" Value="Running">
                                                                    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding State}" Value="Faulted">
                                                                    <Setter Property="Foreground" Value="{DynamicResource RedBrush}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- FOLDER PREVIEW fallback — remains in the side panel when the bottom
                         filmstrip is hidden so thumbnail jumping is never lost. -->
                    <StackPanel Visibility="{Binding ShowSideFolderPreview, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Folder preview" Style="{StaticResource SectionLabel}" />
                        <ListBox x:Name="SidePreviewItems"
                                 ItemsSource="{Binding FolderPreviewItems}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Padding="0,0,0,6"
                                 Margin="0,0,0,16"
                                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                 ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                 ScrollViewer.CanContentScroll="True"
                                 VirtualizingPanel.IsVirtualizing="True"
                                 VirtualizingPanel.VirtualizationMode="Recycling"
                                 VirtualizingPanel.CacheLength="2,2"
                                 VirtualizingPanel.CacheLengthUnit="Item"
                                 KeyboardNavigation.DirectionalNavigation="Cycle"
                                 KeyboardNavigation.TabNavigation="Continue"
                                 AutomationProperties.Name="{loc:Loc AutomationMainWindowFolderPreviewThumbnails}">
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <VirtualizingStackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="Margin" Value="0" />
                                        <Setter Property="Focusable" Value="False" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <ContentPresenter />
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Button Command="{Binding DataContext.OpenPreviewItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Loaded="PreviewThumbnail_Loaded"
                                                Width="88"
                                                MinHeight="104"
                                                Margin="0,0,8,0"
                                                Padding="5"
                                                HorizontalContentAlignment="Stretch"
                                                VerticalContentAlignment="Stretch"
                                                ToolTip="{Binding Path}"
                                                Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}"
                                                AutomationProperties.Name="{Binding FileName}"
                                                AutomationProperties.HelpText="{Binding PositionText}"
                                                AutomationProperties.ItemStatus="{Binding PositionText}">
                                            <Button.ContextMenu>
                                                <ContextMenu Style="{StaticResource ViewportContextMenu}">
                                                    <MenuItem Header="Open"
                                                              Command="{Binding PlacementTarget.Tag.OpenPreviewItemCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                                        <MenuItem.Icon>
                                                            <TextBlock Style="{StaticResource MenuItemIcon}" Text="&#xE8E5;" />
                                                        </MenuItem.Icon>
                                                    </MenuItem>
                                                    <MenuItem Header="Reveal in Explorer"
                                                              Command="{Binding PlacementTarget.Tag.RevealPreviewItemCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                                        <MenuItem.Icon>
                                                            <TextBlock Style="{StaticResource MenuItemIcon}" Text="&#xE838;" />
                                                        </MenuItem.Icon>
                                                    </MenuItem>
                                                    <MenuItem Header="Copy path"
                                                              Command="{Binding PlacementTarget.Tag.CopyPreviewPathCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                                        <MenuItem.Icon>
                                                            <TextBlock Style="{StaticResource MenuItemIcon}" Text="&#xE8C8;" />
                                                        </MenuItem.Icon>
                                                    </MenuItem>
                                                </ContextMenu>
                                            </Button.ContextMenu>
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource ChromeButton}">
                                                    <Setter Property="Background" Value="{DynamicResource Surface0Brush}" />
                                                    <Setter Property="BorderBrush" Value="{DynamicResource HairlineBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource AccentPanelBrush}" />
                                                            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                                        </DataTrigger>
                                                        <Trigger Property="IsKeyboardFocused" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource AccentSelectionBrush}" />
                                                            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <StackPanel>
                                                <Border Height="56"
                                                        CornerRadius="{StaticResource Radius.Sm.CR}"
                                                        Background="{DynamicResource ViewportBrush}"
                                                        BorderBrush="{DynamicResource HairlineBrush}"
                                                        BorderThickness="1"
                                                        ClipToBounds="True">
                                                    <Grid>
                                                        <Image Source="{Binding Thumbnail}"
                                                               Stretch="UniformToFill"
                                                               RenderOptions.BitmapScalingMode="HighQuality"
                                                               Visibility="{Binding HasThumbnail, Converter={StaticResource BoolToVis}}" />
                                                        <TextBlock Text="&#xEB9F;"
                                                                   FontFamily="{StaticResource IconFontFamily}"
                                                                   FontSize="18"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"
                                                                   Visibility="{Binding HasThumbnail, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}">
                                                            <TextBlock.Style>
                                                                <Style TargetType="{x:Type TextBlock}">
                                                                    <Setter Property="Foreground" Value="{DynamicResource OverlayBrush}" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding ThumbnailFailed}" Value="True">
                                                                            <Setter Property="Text" Value="&#xE783;" />
                                                                            <Setter Property="Foreground" Value="{DynamicResource YellowBrush}" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Grid>
                                                </Border>
                                                <TextBlock Text="{Binding FileName}"
                                                           Foreground="{DynamicResource TextBrush}"
                                                           FontSize="11.5"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis"
                                                           Margin="1,7,1,0" />
                                                <TextBlock Text="{Binding PositionText}"
                                                           Foreground="{DynamicResource OverlayBrush}"
                                                           FontSize="10.5"
                                                           Margin="1,1,1,0" />
                                            </StackPanel>
                                        </Button>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                    </StackPanel>

                    <!-- RENAME section -->
                    <TextBlock Text="Filename" Style="{StaticResource SectionLabel}" />

                    <!-- Stem editor + locked extension chip -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="StemEditor"
                                 Grid.Column="0"
                                 Text="{Binding EditableStem, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="15"
                                 IsEnabled="{Binding HasImage}"
                                 PreviewKeyDown="StemEditor_PreviewKeyDown"
                                 SelectionChanged="StemEditor_SelectionChanged"
                                 AutomationProperties.AutomationId="StemEditor"
                                 AutomationProperties.Name="{loc:Loc AutomationMainWindowFileNameWithoutExtension}" />
                        <Button Grid.Column="1"
                                Margin="10,0,0,0"
                                Padding="11,0"
                                MinWidth="72"
                                Height="36"
                                Command="{Binding UnlockExtensionCommand}"
                                IsEnabled="{Binding HasImage}"
                                ToolTip="{Binding ExtensionLockHelpText}"
                                AutomationProperties.Name="{Binding ExtensionLockText}"
                                AutomationProperties.HelpText="{Binding ExtensionLockHelpText}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ChromeButton}">
                                    <Style.Triggers>
                                        <!-- Locked (default) already carries the chrome treatment.
                                             Unlocked echoes the YellowBrush warning accent from the
                                             panel below so the two read as the same state. -->
                                        <DataTrigger Binding="{Binding IsExtensionUnlocked}" Value="True">
                                            <Setter Property="BorderBrush" Value="{DynamicResource YellowBrush}" />
                                            <Setter Property="Background" Value="{DynamicResource WarningPanelBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <!-- Locked padlock -->
                                <TextBlock Text="&#xE72E;"
                                           FontFamily="{StaticResource IconFontFamily}"
                                           FontSize="11"
                                           VerticalAlignment="Center"
                                           Margin="0,0,7,0"
                                           Foreground="{DynamicResource SubtextBrush}"
                                           Visibility="{Binding IsExtensionUnlocked, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}" />
                                <!-- Unlocked pencil-edit -->
                                <TextBlock Text="&#xE70F;"
                                           FontFamily="{StaticResource IconFontFamily}"
                                           FontSize="11"
                                           VerticalAlignment="Center"
                                           Margin="0,0,7,0"
                                           Foreground="{DynamicResource YellowBrush}"
                                           Visibility="{Binding IsExtensionUnlocked, Converter={StaticResource BoolToVis}}" />
                                <TextBlock Text="{Binding Extension}"
                                           VerticalAlignment="Center"
                                           FontFamily="Consolas"
                                           FontSize="13" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <!-- Extension-unlocked warning + editor -->
                    <Border Margin="0,12,0,0"
                            Padding="13,11"
                            Background="{DynamicResource WarningPanelBrush}"
                            BorderBrush="{DynamicResource YellowBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource Radius.Sm.CR}"
                            Visibility="{Binding IsExtensionUnlocked, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <TextBlock Text="Changing the extension only renames the file. Use a supported Images format; this will not convert the image."
                                       Foreground="{DynamicResource YellowBrush}"
                                       FontSize="12"
                                       LineHeight="17"
                                       TextWrapping="Wrap" />
                            <TextBox Text="{Binding Extension, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,8,0,0"
                                     FontFamily="Consolas"
                                     AutomationProperties.Name="{loc:Loc AutomationMainWindowFileExtension}" />
                        </StackPanel>
                    </Border>

                    <!-- Live status card — preview + colored status dot -->
                    <Border Style="{StaticResource StatusCard}" Margin="0,14,0,0" Visibility="Collapsed">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- Status dot: color transitions are DataTrigger SolidColorBrush swaps.
                                 The success-pulse ScaleTransform grows on 'Saved' via a triggered
                                 storyboard so a rename commit feels confirmed, not silent. -->
                            <Ellipse Grid.Column="0" RenderTransformOrigin="0.5,0.5">
                                <Ellipse.RenderTransform>
                                    <ScaleTransform ScaleX="1" ScaleY="1" />
                                </Ellipse.RenderTransform>
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse" BasedOn="{StaticResource StatusDot}">
                                        <Setter Property="Fill" Value="{DynamicResource OverlayBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding RenameStatus}" Value="Pending">
                                                <Setter Property="Fill" Value="{DynamicResource YellowBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding RenameStatus}" Value="Saved">
                                                <Setter Property="Fill" Value="{DynamicResource GreenBrush}" />
                                                <DataTrigger.EnterActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <!-- Walk the RenderTransform path so the animation resolves on the triggered
                                                                 Ellipse itself; style-scoped TargetName can't reach a templated child. -->
                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                                             From="1" To="1.5"
                                                                             AutoReverse="True"
                                                                             Duration="{StaticResource Motion.Base}">
                                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
                                                            </DoubleAnimation>
                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                                             From="1" To="1.5"
                                                                             AutoReverse="True"
                                                                             Duration="{StaticResource Motion.Base}">
                                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
                                                            </DoubleAnimation>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </DataTrigger.EnterActions>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding RenameStatus}" Value="Conflict">
                                                <Setter Property="Fill" Value="{DynamicResource MauveBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding RenameStatus}" Value="Error">
                                                <Setter Property="Fill" Value="{DynamicResource RedBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{Binding RenameStatusText}"
                                           Foreground="{DynamicResource TextBrush}"
                                           FontSize="12.5"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="{Binding RenamePreview}"
                                           Foreground="{DynamicResource SubtextBrush}"
                                           FontSize="12"
                                           Margin="0,3,0,0"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <TextBlock Style="{StaticResource Text.Hint}"
                               Text="Changes save automatically."
                               Margin="1,8,0,0" />

                    <StackPanel Visibility="{Binding IsArchiveBook, Converter={StaticResource BoolToVis}}">
                        <Border Style="{StaticResource Divider}" />
                        <TextBlock Text="Book controls" Style="{StaticResource SectionLabel}" />

                        <Border Style="{StaticResource Card}"
                                AutomationProperties.Name="{loc:Loc AutomationMainWindowArchiveBookControls}"
                                AutomationProperties.LiveSetting="Polite">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0"
                                            Width="32"
                                            Height="32"
                                            CornerRadius="{StaticResource Radius.Sm.CR}"
                                            BorderThickness="1"
                                            Background="{DynamicResource AccentPanelBrush}"
                                            BorderBrush="{DynamicResource AccentBrush}"
                                            VerticalAlignment="Top"
                                            Margin="0,0,12,0">
                                        <TextBlock Text="&#xE8A5;"
                                                   FontFamily="{StaticResource IconFontFamily}"
                                                   FontSize="13"
                                                   Foreground="{DynamicResource AccentBrush}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </Border>

                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{Binding CurrentArchiveProgressText}"
                                                   FontSize="12.5"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextBrush}"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding DecoderUsed}"
                                                   FontSize="11.5"
                                                   Margin="0,3,0,0"
                                                   Foreground="{DynamicResource OverlayBrush}"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </Grid>

                                <UniformGrid Columns="4" Margin="0,12,0,0">
                                    <Button Style="{StaticResource ChromeButton}"
                                            MinHeight="32"
                                            Margin="0,0,6,0"
                                            Command="{Binding FirstPageCommand}"
                                            ToolTip="First page"
                                            AutomationProperties.Name="{loc:Loc AutomationMainWindowFirstBookPage}">
                                        <TextBlock Text="&#xE892;"
                                                   FontFamily="{StaticResource IconFontFamily}"
                                                   FontSize="12"
                                                   HorizontalAlignment="Center" />
                                    </Button>
                                    <Button Style="{StaticResource ChromeButton}"
                                            MinHeight="32"
                                            Margin="0,0,6,0"
                                            Command="{Binding PrevPageCommand}"
                                            ToolTip="Previous page"
                                            AutomationProperties.Name="{loc:Loc AutomationMainWindowPreviousBookPage}">
                                        <TextBlock Text="&#xE76B;"
                                                   FontFamily="{StaticResource IconFontFamily}"
                                                   FontSize="12"
                                                   HorizontalAlignment="Center" />
                                    </Button>
                                    <Button Style="{StaticResource ChromeButton}"
                                            MinHeight="32"
                                            Margin="0,0,6,0"
                                            Command="{Binding NextPageCommand}"
                                            ToolTip="Next page"
                                            AutomationProperties.Name="{loc:Loc AutomationMainWindowNextBookPage}">
                                        <TextBlock Text="&#xE76C;"
                                                   FontFamily="{StaticResource IconFontFamily}"
                                                   FontSize="12"
                                                   HorizontalAlignment="Center" />
                                    </Button>
                                    <Button Style="{StaticResource ChromeButton}"
                                            MinHeight="32"
                                            Command="{Binding LastPageCommand}"
                                            ToolTip="Last page"
                                            AutomationProperties.Name="{loc:Loc AutomationMainWindowLastBookPage}">
                                        <TextBlock Text="&#xE893;"
                                                   FontFamily="{StaticResource IconFontFamily}"
                                                   FontSize="12"
                                                   HorizontalAlignment="Center" />
                                    </Button>
                                </UniformGrid>

                                <Border Margin="0,12,0,0"
                                        Padding="10,9"
                                        CornerRadius="{StaticResource Radius.Sm.CR}"
                                        Background="{DynamicResource SubtleSurfaceBrush}"
                                        BorderBrush="{DynamicResource HairlineBrush}"
                                        BorderThickness="1">
                                    <StackPanel>
                                        <CheckBox IsChecked="{Binding ArchiveRightToLeft, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  Content="{Binding ArchivePageTurnModeText}"
                                                  ToolTip="{Binding ArchivePageTurnModeHint}"
                                                  AutomationProperties.Name="{loc:Loc AutomationMainWindowRightToLeftBookPageTurns}" />
                                        <TextBlock Text="{Binding ArchivePageTurnModeHint}"
                                                   Margin="28,5,0,0"
                                                   FontSize="11.5"
                                                   Foreground="{DynamicResource OverlayBrush}"
                                                   TextWrapping="Wrap" />
                                        <CheckBox IsChecked="{Binding ArchiveOldScanFilterEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  Content="{Binding ArchiveOldScanFilterText}"
                                                  ToolTip="{Binding ArchiveOldScanFilterHint}"
                                                  Margin="0,12,0,0"
                                                  AutomationProperties.Name="{loc:Loc AutomationMainWindowCleanOldArchiveScans}" />
                                        <TextBlock Text="{Binding ArchiveOldScanFilterHint}"
                                                   Margin="28,5,0,0"
                                                   FontSize="11.5"
                                                   Foreground="{DynamicResource OverlayBrush}"
                                                   TextWrapping="Wrap" />
                                        <CheckBox IsChecked="{Binding ArchiveSpreadModeEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  Content="{Binding ArchiveSpreadModeText}"
                                                  ToolTip="{Binding ArchiveSpreadModeHint}"
                                                  Margin="0,12,0,0"
                                                  AutomationProperties.Name="{loc:Loc AutomationMainWindowTwoPageArchiveSpreads}" />
                                        <TextBlock Text="{Binding ArchiveSpreadModeHint}"
                                                   Margin="28,5,0,0"
                                                   FontSize="11.5"
                                                   Foreground="{DynamicResource OverlayBrush}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <Border Style="{StaticResource Divider}" Visibility="Collapsed" />

                    <!-- RECENT RENAMES section -->
                    <TextBlock Text="Recent renames" Style="{StaticResource SectionLabel}" Visibility="Collapsed" />

                    <Border Style="{StaticResource Card}"
                            Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="No renames yet"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="12.5"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="Your undo list will appear here."
                                       Foreground="{DynamicResource OverlayBrush}"
                                       FontSize="12"
                                       LineHeight="17"
                                       TextWrapping="Wrap"
                                       Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>

                    <ItemsControl ItemsSource="{Binding RecentRenames}"
                                  Visibility="Collapsed"
                                  KeyboardNavigation.DirectionalNavigation="Cycle"
                                  KeyboardNavigation.TabNavigation="Continue"
                                  AutomationProperties.Name="{loc:Loc AutomationMainWindowRecentRenames}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource InteractiveCard}"
                                        Padding="13,10"
                                        Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock FontSize="12" TextTrimming="CharacterEllipsis">
                                                <Run Text="{Binding FromPath, Converter={x:Static vm:PathToFileNameConverter.Instance}, Mode=OneWay}"
                                                     Foreground="{DynamicResource SubtextBrush}" />
                                            </TextBlock>
                                            <TextBlock FontSize="12" TextTrimming="CharacterEllipsis" Margin="0,2,0,0">
                                                <Run Text="→ " Foreground="{DynamicResource OverlayBrush}" />
                                                <Run Text="{Binding ToPath, Converter={x:Static vm:PathToFileNameConverter.Instance}, Mode=OneWay}"
                                                     Foreground="{DynamicResource TextBrush}" />
                                            </TextBlock>
                                        </StackPanel>
                                        <Button Grid.Column="1"
                                                Style="{StaticResource ChromeButton}"
                                                Padding="14,4"
                                                MinHeight="28"
                                                VerticalAlignment="Center"
                                                Margin="12,0,0,0"
                                                Command="{Binding DataContext.UndoRenameCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                AutomationProperties.Name="{loc:Loc AutomationMainWindowUndoRename}">
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <TextBlock Text="&#xE7A7;"
                                                           FontFamily="{StaticResource IconFontFamily}"
                                                           FontSize="11"
                                                           Margin="0,0,7,0"
                                                           VerticalAlignment="Center" />
                                                <TextBlock Text="Undo" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- RECENT FOLDERS section (V20-02 UI consumer — data layer shipped v0.1.7).
                         Whole block hides when the MRU is empty so a fresh install / first-run
                         user doesn't see an orphan "Recent folders" header above nothing. -->
                    <StackPanel Visibility="Collapsed">
                        <Border Style="{StaticResource Divider}" />
                        <TextBlock Text="Recent folders" Style="{StaticResource SectionLabel}" />
                        <ItemsControl ItemsSource="{Binding RecentFolders}"
                                      KeyboardNavigation.DirectionalNavigation="Cycle"
                                      KeyboardNavigation.TabNavigation="Continue"
                                      AutomationProperties.Name="{loc:Loc AutomationMainWindowRecentFolders}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource ChromeButton}"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Stretch"
                                            Padding="13,10"
                                            Margin="0,0,0,8"
                                            Command="{Binding DataContext.OpenRecentFolderCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="{Binding}"
                                            AutomationProperties.Name="{Binding}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="&#xE8B7;"
                                                       FontFamily="{StaticResource IconFontFamily}"
                                                       FontSize="13"
                                                       Foreground="{DynamicResource SubtextBrush}"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,10,0" />
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{Binding Converter={x:Static vm:PathToFileNameConverter.Instance}, Mode=OneWay}"
                                                           FontSize="12.5"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis"
                                                           Foreground="{DynamicResource TextBrush}" />
                                                <TextBlock Text="{Binding Converter={x:Static vm:PathToParentConverter.Instance}, Mode=OneWay}"
                                                           FontSize="11.5"
                                                           Margin="0,2,0,0"
                                                           TextTrimming="CharacterEllipsis"
                                                           Foreground="{DynamicResource OverlayBrush}" />
                                            </StackPanel>
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <StackPanel Visibility="Collapsed">
                        <Border Style="{StaticResource Divider}" />
                        <TextBlock Text="Book history" Style="{StaticResource SectionLabel}" />
                        <ItemsControl ItemsSource="{Binding RecentArchiveBooks}"
                                      KeyboardNavigation.DirectionalNavigation="Cycle"
                                      KeyboardNavigation.TabNavigation="Continue"
                                      AutomationProperties.Name="{loc:Loc AutomationMainWindowArchiveBookHistory}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource ChromeButton}"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Stretch"
                                            Padding="13,10"
                                            Margin="0,0,0,8"
                                            Command="{Binding DataContext.OpenRecentArchiveCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="{Binding Path}"
                                            AutomationProperties.Name="{Binding Path}"
                                            AutomationProperties.HelpText="{Binding ProgressText}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0"
                                                    Width="28"
                                                    Height="28"
                                                    CornerRadius="{StaticResource Radius.Sm.CR}"
                                                    BorderThickness="1"
                                                    Background="{DynamicResource AccentPanelBrush}"
                                                    BorderBrush="{DynamicResource HairlineBrush}"
                                                    VerticalAlignment="Center"
                                                    Margin="0,0,10,0">
                                                <TextBlock Text="&#xE8A5;"
                                                           FontFamily="{StaticResource IconFontFamily}"
                                                           FontSize="12"
                                                           Foreground="{DynamicResource AccentBrush}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" />
                                            </Border>

                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{Binding Path, Converter={x:Static vm:PathToFileNameConverter.Instance}, Mode=OneWay}"
                                                           FontSize="12.5"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis"
                                                           Foreground="{DynamicResource TextBrush}" />
                                                <TextBlock Text="{Binding Path, Converter={x:Static vm:PathToParentConverter.Instance}, Mode=OneWay}"
                                                           FontSize="11.5"
                                                           Margin="0,2,0,0"
                                                           TextTrimming="CharacterEllipsis"
                                                           Foreground="{DynamicResource OverlayBrush}" />
                                            </StackPanel>

                                            <Border Grid.Column="2"
                                                    Style="{StaticResource Badge}"
                                                    Margin="10,0,0,0"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{Binding ProgressText}"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource SubtextBrush}" />
                                            </Border>
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <Border Style="{StaticResource Divider}" />

                    <!-- DETAILS section -->
                    <TextBlock Text="Details" Style="{StaticResource SectionLabel}" />

                    <Grid Margin="1,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Folder"  Style="{StaticResource MetaLabel}" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding CurrentFolder}"   Style="{StaticResource MetaValue}" ToolTip="{Binding CurrentFolder}" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Size"    Style="{StaticResource MetaLabel}" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding FileSizeText}"    Style="{StaticResource MetaValue}" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Pixels"  Style="{StaticResource MetaLabel}" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding DimensionsText}"  Style="{StaticResource MetaValue}" />

                        <TextBlock Grid.Row="3"
                                   Grid.Column="0"
                                   Text="{Binding PageLabel}"
                                   Style="{StaticResource MetaLabel}"
                                   Visibility="{Binding HasMultiplePages, Converter={StaticResource BoolToVis}}" />
                        <TextBlock Grid.Row="3"
                                   Grid.Column="1"
                                   Text="{Binding PagePositionText}"
                                   Style="{StaticResource MetaValue}"
                                   Visibility="{Binding HasMultiplePages, Converter={StaticResource BoolToVis}}" />

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Decoder" Style="{StaticResource MetaLabel}" />
                        <Border Grid.Row="4" Grid.Column="1"
                                Style="{StaticResource Badge}"
                                Margin="0,0,0,10"
                                VerticalAlignment="Center">
                            <TextBlock Text="{Binding DecoderUsed}"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource SubtextBrush}" />
                        </Border>
                    </Grid>

                    <Expander x:Name="InspectorToolsExpander"
                              Style="{StaticResource InspectorExpander}"
                              Header="Tools"
                              IsExpanded="False"
                              Margin="0,4,0,0"
                              Visibility="Collapsed">
                    <StackPanel>
                    <Border Style="{StaticResource Divider}" />

                    <!-- ORGANIZATION section -->
                    <TextBlock Text="Organization" Style="{StaticResource SectionLabel}" />
                    <Border Style="{StaticResource Card}"
                            Padding="13,12"
                            AutomationProperties.Name="{loc:Loc AutomationMainWindowOrganizationControls}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Tag relationships"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}" />
                                <TextBlock Text="Manage private local tag namespaces, aliases, parents, and XMP sidecar tag export."
                                           Style="{StaticResource Text.Hint}"
                                           TextWrapping="Wrap"
                                           Margin="0,3,0,0" />
                            </StackPanel>
                            <StackPanel Grid.Column="1"
                                        Margin="12,0,0,0">
                                <Button Command="{Binding OpenTagGraphCommand}"
                                        Style="{StaticResource SidePanelToolButton}"
                                        AutomationProperties.Name="{loc:Loc AutomationMainWindowOpenTagRelationships}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE8EC;" FontFamily="{StaticResource IconFontFamily}" FontSize="11" Margin="0,0,8,0" VerticalAlignment="Center" />
                                        <TextBlock Text="Tags" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                                <Button Command="{Binding OpenImportInboxCommand}"
                                        Style="{StaticResource SidePanelToolButton}"
                                        Margin="0,8,0,0"
                                        AutomationProperties.Name="{loc:Loc AutomationMainWindowOpenImportInbox}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE8B7;" FontFamily="{StaticResource IconFontFamily}" FontSize="11" Margin="0,0,8,0" VerticalAlignment="Center" />
                                        <TextBlock Text="Inbox" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource Divider}" />

                    <!-- AUTOMATION section -->
                    <TextBlock Text="Automation" Style="{StaticResource SectionLabel}" />
                    <Border Style="{StaticResource Card}"
                            Padding="13,12"
                            AutomationProperties.Name="{loc:Loc AutomationMainWindowAutomationControls}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Macro actions"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}" />
                                <TextBlock Text="Build inspectable JSON actions, manage local model files, and search the current folder through the local semantic index."
                                           Style="{StaticResource Text.Hint}"
                                           TextWrapping="Wrap"
                                           Margin="0,3,0,0" />
                            </StackPanel>
                            <StackPanel Grid.Column="1"
                                        Margin="12,0,0,0">
                                <Button Command="{Binding OpenMacroActionsCommand}"
                                        Style="{StaticResource SidePanelToolButton}"
                                        AutomationProperties.Name="{loc:Loc AutomationMainWindowOpenMacroActions}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE945;" FontFamily="{StaticResource IconFontFamily}" FontSize="11" Margin="0,0,8,0" VerticalAlignment="Center" />
                                        <TextBlock Text="Macros" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                                <Button Command="{Binding OpenBatchProcessorCommand}"
                                        Style="{StaticResource SidePanelToolButton}"
                                        Margin="0,8,0,0"
                                        AutomationProperties.Name="{loc:Loc AutomationMainWindowOpenBatchProcessor}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE8EF;" FontFamily="{StaticResource IconFontFamily}" FontSize="11" Margin="0,0,8,0" VerticalAlignment="Center" />
                                        <TextBlock Text="Batch" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                                <Button Command="{Binding OpenModelManagerCommand}"
                                        Style="{StaticResource SidePanelToolButton}"
                                        Margin="0,8,0,0"
                                        AutomationProperties.Name="{loc:Loc AutomationMainWindowOpenModelManager}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE950;" FontFamily="{StaticResource IconFontFamily}" FontSize="11" Margin="0,0,8,0" VerticalAlignment="Center" />
                                        <TextBlock Text="Models" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                                <Button Command="{Binding OpenSemanticSearchCommand}"
                                        Style="{StaticResource SidePanelToolButton}"
                                        Margin="0,8,0,0"
                                        AutomationProperties.Name="{loc:Loc AutomationMainWindowOpenSemanticSearch}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE721;" FontFamily="{StaticResource IconFontFamily}" FontSize="11" Margin="0,0,8,0" VerticalAlignment="Center" />
                                        <TextBlock Text="Search" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource Divider}" />

                    <!-- CLEANUP section -->
                    <TextBlock Text="Cleanup" Style="{StaticResource SectionLabel}" />
                    <Border Style="{StaticResource Card}"
                            Padding="13,12"
                            AutomationProperties.Name="{loc:Loc AutomationMainWindowCleanupControls}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Cleanup tools"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}" />
                                <TextBlock Text="Find duplicate images, bad extensions, broken files, and temporary artifacts in local folders."
                                           Style="{StaticResource Text.Hint}"
                                           TextWrapping="Wrap"
                                           Margin="0,3,0,0" />
                            </StackPanel>
                            <StackPanel Grid.Column="1"
                                        Margin="12,0,0,0">
                                <Button Command="{Binding OpenDuplicateCleanupCommand}"
                                        Style="{StaticResource SidePanelToolButton}"
                                        AutomationProperties.Name="{loc:Loc AutomationMainWindowOpenDuplicateCleanup}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE8C8;" FontFamily="{StaticResource IconFontFamily}" FontSize="11" Margin="0,0,8,0" VerticalAlignment="Center" />
                                        <TextBlock Text="Duplicates" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                                <Button Command="{Binding OpenFileHealthScanCommand}"
                                        Style="{StaticResource SidePanelToolButton}"
                                        Margin="0,8,0,0"
                                        AutomationProperties.Name="{loc:Loc AutomationMainWindowOpenFileHealthScan}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE946;" FontFamily="{StaticResource IconFontFamily}" FontSize="11" Margin="0,0,8,0" VerticalAlignment="Center" />
                                        <TextBlock Text="File health" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                                <Button Command="{Binding OpenRecoveryCenterCommand}"
                                        Style="{StaticResource SidePanelToolButton}"
                                        Margin="0,8,0,0"
                                        AutomationProperties.Name="{loc:Loc AutomationMainWindowOpenRecoveryCenter}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE777;" FontFamily="{StaticResource IconFontFamily}" FontSize="11" Margin="0,0,8,0" VerticalAlignment="Center" />
                                        <TextBlock Text="Recovery" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource Divider}" />

                    <!-- COMPARE section -->
                    <TextBlock Text="Compare" Style="{StaticResource SectionLabel}" />
                    <Border Style="{StaticResource Card}"
                            Padding="13,12"
                            AutomationProperties.Name="{loc:Loc AutomationMainWindowCompareControls}">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{Binding CompareModeText}"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextBrush}" />
                                    <TextBlock Text="{Binding CompareStatusText}"
                                               Style="{StaticResource Text.Hint}"
                                               TextWrapping="Wrap"
                                               Margin="0,3,0,0" />
                                </StackPanel>
                                <StackPanel Grid.Column="1"
                                            Margin="12,0,0,0">
                                    <Button Command="{Binding StartCompareCommand}"
                                            Style="{StaticResource ChromeButton}"
                                            MinWidth="92"
                                            AutomationProperties.Name="{loc:Loc AutomationMainWindowCompareWithNextImage}">
                                        <TextBlock Text="Next" />
                                    </Button>
                                    <Button Command="{Binding CompareWithCommand}"
                                            Style="{StaticResource ChromeButton}"
                                            MinWidth="92"
                                            Margin="0,8,0,0"
                                            AutomationProperties.Name="{loc:Loc AutomationMainWindowCompareWithChosenImage}">
                                        <TextBlock Text="Choose" />
                                    </Button>
                                </StackPanel>
                            </Grid>

                            <WrapPanel Margin="0,12,0,0"
                                       Visibility="{Binding IsCompareMode, Converter={StaticResource BoolToVis}}">
                                <Button Command="{Binding ToggleCompareOverlayCommand}"
                                        Style="{StaticResource ChromeButton}"
                                        Margin="0,0,8,8"
                                        AutomationProperties.Name="{loc:Loc AutomationMainWindowToggleCompareLayout}">
                                    <TextBlock Text="{Binding CompareLayoutToggleText}" />
                                </Button>
                                <Button Command="{Binding SwapCompareCommand}"
                                        Style="{StaticResource ChromeButton}"
                                        Margin="0,0,8,8"
                                        AutomationProperties.Name="{loc:Loc AutomationMainWindowSwapCompareAAndB}">
                                    <TextBlock Text="Swap A/B" />
                                </Button>
                                <Button Command="{Binding ExitCompareCommand}"
                                        Style="{StaticResource ChromeButton}"
                                        Margin="0,0,8,8"
                                        AutomationProperties.Name="{loc:Loc AutomationMainWindowExitCompareMode}">
                                    <TextBlock Text="Exit" />
                                </Button>
                            </WrapPanel>

                            <Grid Margin="0,4,0,0"
                                  Visibility="{Binding IsCompareMode, Converter={StaticResource BoolToVis}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="B opacity"
                                           Style="{StaticResource Text.Hint}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,0" />
                                <Slider Grid.Column="1"
                                        Minimum="0.05"
                                        Maximum="1"
                                        TickFrequency="0.05"
                                        SmallChange="0.05"
                                        LargeChange="0.1"
                                        Value="{Binding CompareOverlayOpacity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        AutomationProperties.Name="{loc:Loc AutomationMainWindowCompareBOpacity}" />
                                <TextBlock Grid.Column="2"
                                           Text="{Binding CompareOverlayOpacityText}"
                                           Style="{StaticResource Text.Caption}"
                                           VerticalAlignment="Center"
                                           Margin="10,0,0,0" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Divider}" />

                    <!-- OVERLAY section -->
                    <TextBlock Text="Overlay" Style="{StaticResource SectionLabel}" />
                    <Border Style="{StaticResource Card}"
                            Padding="13,12"
                            AutomationProperties.Name="{loc:Loc AutomationMainWindowPinnedOverlayControls}">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{Binding OverlayModeText}"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextBrush}" />
                                    <TextBlock Text="{Binding OverlayStatusText}"
                                               Style="{StaticResource Text.Hint}"
                                               TextWrapping="Wrap"
                                               Margin="0,3,0,0" />
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Command="{Binding ToggleOverlayModeCommand}"
                                        Style="{StaticResource ChromeButton}"
                                        MinWidth="74"
                                        Margin="12,0,0,0"
                                        AutomationProperties.Name="{loc:Loc AutomationMainWindowTogglePinnedOverlayMode}"
                                        AutomationProperties.HelpText="{Binding OverlayStatusText}">
                                    <TextBlock Text="{Binding OverlayToggleText}" />
                                </Button>
                            </Grid>

                            <Grid Margin="0,12,0,0"
                                  IsEnabled="{Binding IsPinnedOverlayMode}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="Opacity"
                                           Style="{StaticResource Text.Hint}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,0" />
                                <Slider Grid.Column="1"
                                        Minimum="0.25"
                                        Maximum="1"
                                        TickFrequency="0.05"
                                        SmallChange="0.05"
                                        LargeChange="0.1"
                                        Value="{Binding OverlayOpacity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        AutomationProperties.Name="{loc:Loc AutomationMainWindowPinnedOverlayOpacity}" />
                                <TextBlock Grid.Column="2"
                                           Text="{Binding OverlayOpacityText}"
                                           Style="{StaticResource Text.Caption}"
                                           VerticalAlignment="Center"
                                           Margin="10,0,0,0" />
                            </Grid>

                            <CheckBox IsChecked="{Binding IsOverlayClickThrough, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      Content="{Binding OverlayClickThroughText}"
                                      IsEnabled="{Binding IsPinnedOverlayMode}"
                                      Margin="0,12,0,0"
                                      ToolTip="{Binding OverlayExitText}"
                                      AutomationProperties.Name="{loc:Loc AutomationMainWindowToggleClickThroughOverlay}"
                                      AutomationProperties.HelpText="{Binding OverlayStatusText}" />

                            <Border Margin="0,12,0,0"
                                    Padding="10"
                                    CornerRadius="{StaticResource Radius.Sm.CR}"
                                    Background="{DynamicResource SubtleSurfaceBrush}"
                                    BorderBrush="{DynamicResource HairlineBrush}"
                                    BorderThickness="1">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE946;"
                                               FontFamily="{StaticResource IconFontFamily}"
                                               FontSize="12"
                                               Foreground="{DynamicResource AccentBrush}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,9,0" />
                                    <TextBlock Text="{Binding OverlayExitText}"
                                               Style="{StaticResource Text.Caption}"
                                               TextWrapping="Wrap"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>

                            <WrapPanel Margin="0,12,0,0">
                                <Button Command="{Binding ExitOverlayModeCommand}"
                                        Style="{StaticResource ChromeButton}"
                                        Margin="0,0,8,0"
                                        AutomationProperties.Name="{loc:Loc AutomationMainWindowExitPinnedOverlayMode}">
                                    <TextBlock Text="Exit overlay" />
                                </Button>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <StackPanel Visibility="{Binding IsAnimated, Converter={StaticResource BoolToVis}}">
                        <Border Style="{StaticResource Divider}" />

                        <!-- ANIMATION section -->
                        <TextBlock Text="Animation" Style="{StaticResource SectionLabel}" />
                        <Border Style="{StaticResource Card}"
                                Padding="13,12"
                                AutomationProperties.Name="{loc:Loc AutomationMainWindowAnimationFrameWorkbench}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding SelectedAnimationFrameText}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextBrush}" />
                                        <TextBlock Text="{Binding AnimationWorkbenchStatusText}"
                                                   Style="{StaticResource Text.Hint}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,3,0,0" />
                                    </StackPanel>
                                    <Button Grid.Column="1"
                                            Command="{Binding ToggleAnimationPlaybackCommand}"
                                            Style="{StaticResource ChromeButton}"
                                            MinWidth="62"
                                            Margin="12,0,0,0"
                                            AutomationProperties.Name="{loc:Loc AutomationMainWindowPlayOrPauseAnimation}">
                                        <TextBlock Text="{Binding AnimationPlaybackText}" />
                                    </Button>
                                </Grid>

                                <Grid Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding SelectedAnimationTimestampText}"
                                               Style="{StaticResource Text.Caption}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,10,0" />
                                    <Slider Grid.Column="1"
                                            Minimum="0"
                                            Maximum="{Binding AnimationFrameSliderMaximum}"
                                            Value="{Binding AnimationScrubberValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            TickFrequency="1"
                                            IsSnapToTickEnabled="True"
                                            SmallChange="1"
                                            LargeChange="5"
                                            AutomationProperties.Name="{loc:Loc AutomationMainWindowAnimationFrameScrubber}" />
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding SelectedAnimationFrameDelayText}"
                                               Style="{StaticResource Text.Caption}"
                                               VerticalAlignment="Center"
                                               Margin="10,0,0,0" />
                                </Grid>

                                <UniformGrid Columns="4" Margin="0,12,0,0">
                                    <Button Command="{Binding FirstAnimationFrameCommand}"
                                            Style="{StaticResource ChromeButton}"
                                            Margin="0,0,6,0"
                                            ToolTip="First frame"
                                            AutomationProperties.Name="{loc:Loc AutomationMainWindowFirstAnimationFrame}">
                                        <TextBlock Text="First" />
                                    </Button>
                                    <Button Command="{Binding PreviousAnimationFrameCommand}"
                                            Style="{StaticResource ChromeButton}"
                                            Margin="0,0,6,0"
                                            ToolTip="Previous frame"
                                            AutomationProperties.Name="{loc:Loc AutomationMainWindowPreviousAnimationFrame}">
                                        <TextBlock Text="Prev" />
                                    </Button>
                                    <Button Command="{Binding NextAnimationFrameCommand}"
                                            Style="{StaticResource ChromeButton}"
                                            Margin="0,0,6,0"
                                            ToolTip="Next frame"
                                            AutomationProperties.Name="{loc:Loc AutomationMainWindowNextAnimationFrame}">
                                        <TextBlock Text="Next" />
                                    </Button>
                                    <Button Command="{Binding LastAnimationFrameCommand}"
                                            Style="{StaticResource ChromeButton}"
                                            ToolTip="Last frame"
                                            AutomationProperties.Name="{loc:Loc AutomationMainWindowLastAnimationFrame}">
                                        <TextBlock Text="Last" />
                                    </Button>
                                </UniformGrid>

                                <Grid Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="Speed"
                                               Style="{StaticResource Text.Hint}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,10,0" />
                                    <Slider Grid.Column="1"
                                            Minimum="0.25"
                                            Maximum="4"
                                            TickFrequency="0.25"
                                            IsSnapToTickEnabled="True"
                                            Value="{Binding AnimationPlaybackSpeed, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            AutomationProperties.Name="{loc:Loc AutomationMainWindowAnimationPlaybackSpeed}" />
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding AnimationPlaybackSpeedText}"
                                               Style="{StaticResource Text.Caption}"
                                               VerticalAlignment="Center"
                                               Margin="10,0,0,0" />
                                </Grid>

                                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                              VerticalScrollBarVisibility="Disabled"
                                              Margin="0,12,0,0"
                                              AutomationProperties.Name="{loc:Loc AutomationMainWindowAnimationFrameTimeline}">
                                    <ItemsControl ItemsSource="{Binding AnimationFrames}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Command="{Binding DataContext.SetAnimationFrameCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding Index}"
                                                        PreviewMouseMove="AnimationFrame_PreviewMouseMove"
                                                        Style="{StaticResource ChromeButton}"
                                                        Padding="0"
                                                        Margin="0,0,8,0"
                                                        ToolTip="{Binding TimestampText}"
                                                        AutomationProperties.Name="{Binding FrameText}">
                                                    <Border Width="70"
                                                            Padding="5"
                                                            CornerRadius="{StaticResource Radius.Sm.CR}"
                                                            BorderThickness="1">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="BorderBrush" Value="{DynamicResource HairlineBrush}" />
                                                                <Setter Property="Background" Value="{DynamicResource PanelBrush}" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                                                        <Setter Property="Background" Value="{DynamicResource AccentPanelBrush}" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <StackPanel>
                                                            <Image Source="{Binding Preview}"
                                                                   Width="58"
                                                                   Height="42"
                                                                   Stretch="Uniform"
                                                                   RenderOptions.BitmapScalingMode="HighQuality" />
                                                            <TextBlock Text="{Binding FrameText}"
                                                                       Style="{StaticResource Text.Caption}"
                                                                       TextAlignment="Center"
                                                                       Margin="0,4,0,0" />
                                                            <TextBlock Text="{Binding DelayText}"
                                                                       Style="{StaticResource Text.Hint}"
                                                                       TextAlignment="Center" />
                                                        </StackPanel>
                                                    </Border>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>

                                <WrapPanel Margin="0,12,0,0">
                                    <Button Command="{Binding CopyAnimationFrameCommand}"
                                            Style="{StaticResource ChromeButton}"
                                            Margin="0,0,8,8"
                                            AutomationProperties.Name="{loc:Loc AutomationMainWindowCopySelectedAnimationFrame}">
                                        <TextBlock Text="Copy frame" />
                                    </Button>
                                    <Button Command="{Binding ExportAnimationFrameCommand}"
                                            Style="{StaticResource ChromeButton}"
                                            Margin="0,0,8,8"
                                            AutomationProperties.Name="{loc:Loc AutomationMainWindowExportSelectedAnimationFrame}">
                                        <TextBlock Text="Export frame" />
                                    </Button>
                                </WrapPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <Border Style="{StaticResource Divider}" />

                    <!-- SELECTION section -->
                    <TextBlock Text="Selection" Style="{StaticResource SectionLabel}" />
                    <Border Style="{StaticResource Card}"
                            Padding="13,12"
                            IsEnabled="{Binding CanUseSelection}">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{Binding SelectionModeText}"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextBrush}" />
                                    <TextBlock Text="{Binding SelectionModeHelpText}"
                                               Style="{StaticResource Text.Hint}"
                                               TextWrapping="Wrap"
                                               Margin="0,3,0,0" />
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Command="{Binding ToggleSelectionModeCommand}"
                                        Style="{StaticResource ChromeButton}"
                                        MinWidth="72"
                                        Margin="12,0,0,0"
                                        AutomationProperties.Name="{loc:Loc AutomationMainWindowTogglePixelSelectionMode}">
                                    <TextBlock Text="{Binding SelectionModeText}" />
                                </Button>
                            </Grid>

                            <Border Background="{DynamicResource PanelBrush}"
                                    BorderBrush="{DynamicResource HairlineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource Radius.Sm.CR}"
                                    Padding="10"
                                    Margin="0,12,0,0">
                                <StackPanel>
                                    <TextBlock Text="{Binding SelectionStatusText}"
                                               Style="{StaticResource Text.Caption}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding CanvasSelectionText}"
                                               Style="{StaticResource Text.Body}"
                                               Margin="0,8,0,0" />
                                </StackPanel>
                            </Border>

                            <WrapPanel Margin="0,12,0,0">
                                <Button Command="{Binding CopySelectionCommand}"
                                        Style="{StaticResource AccentButton}"
                                        Margin="0,0,8,8"
                                        AutomationProperties.Name="{loc:Loc AutomationMainWindowCopySelectedPixels}">
                                    <TextBlock Text="Copy selection" />
                                </Button>
                                <Button Command="{Binding ClearSelectionCommand}"
                                        Style="{StaticResource ChromeButton}"
                                        Margin="0,0,8,8"
                                        AutomationProperties.Name="{loc:Loc AutomationMainWindowClearSelectedPixels}">
                                    <TextBlock Text="Clear" />
                                </Button>
                                <Button Command="{Binding CancelSelectionCommand}"
                                        Style="{StaticResource ChromeButton}"
                                        Margin="0,0,0,8"
                                        AutomationProperties.Name="{loc:Loc AutomationMainWindowCancelPixelSelectionMode}">
                                    <TextBlock Text="Cancel" />
                                </Button>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Divider}" />

                    <!-- CROP section -->
                    <TextBlock Text="Crop" Style="{StaticResource SectionLabel}" />
                    <Border Style="{StaticResource Card}"
                            Padding="13,12"
                            IsEnabled="{Binding CanUseCrop}">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{Binding CropModeText}"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextBrush}" />
                                    <TextBlock Text="{Binding CropModeHelpText}"
                                               Style="{StaticResource Text.Hint}"
                                               TextWrapping="Wrap"
                                               Margin="0,3,0,0" />
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Command="{Binding ToggleCropModeCommand}"
                                        Style="{StaticResource ChromeButton}"
                                        MinWidth="72"
                                        Margin="12,0,0,0"
                                        AutomationProperties.Name="{loc:Loc AutomationMainWindowToggleCropMode}">
                                    <TextBlock Text="{Binding CropModeText}" />
                                </Button>
                            </Grid>

                            <Border Background="{DynamicResource PanelBrush}"
                                    BorderBrush="{DynamicResource HairlineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource Radius.Sm.CR}"
                                    Padding="10"
                                    Margin="0,12,0,0">
                                <StackPanel>
                                    <TextBlock Text="{Binding CropStatusText}"
                                               Style="{StaticResource Text.Caption}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding CropSelectionText}"
                                               Style="{StaticResource Text.Body}"
                                               Margin="0,8,0,0" />
                                </StackPanel>
                            </Border>

                            <TextBlock Text="Aspect ratio"
                                       Style="{StaticResource Text.Caption}"
                                       Margin="0,12,0,6" />
                            <WrapPanel>
                                <Button Command="{Binding SetCropAspectPresetCommand}"
                                        CommandParameter="free"
                                        Style="{StaticResource ChromeButton}"
                                        Margin="0,0,8,8"
                                        AutomationProperties.Name="{loc:Loc AutomationMainWindowFreeCropAspect}">
                                    <TextBlock Text="Free" />
                                </Button>
                                <Button Command="{Binding SetCropAspectPresetCommand}"
                                        CommandParameter="square"
                                        Style="{StaticResource ChromeButton}"
                                        Margin="0,0,8,8"
                                        AutomationProperties.Name="{loc:Loc AutomationMainWindowSquareCropAspect}">
                                    <TextBlock Text="1:1" />
                                </Button>
                                <Button Command="{Binding SetCropAspectPresetCommand}"
                                        CommandParameter="3x2"
                                        Style="{StaticResource ChromeButton}"
                                        Margin="0,0,8,8"
                                        AutomationProperties.Name="{loc:Loc AutomationMainWindowThreeByTwoCropAspect}">
                                    <TextBlock Text="3:2" />
                                </Button>
                                <Button Command="{Binding SetCropAspectPresetCommand}"
                                        CommandParameter="4x3"
                                        Style="{StaticResource ChromeButton}"
                                        Margin="0,0,8,8"
                                        AutomationProperties.Name="{loc:Loc AutomationMainWindowFourByThreeCropAspect}">
                                    <TextBlock Text="4:3" />
                                </Button>
                                <Button Command="{Binding SetCropAspectPresetCommand}"
                                        CommandParameter="16x9"
                                        Style="{StaticResource ChromeButton}"
                                        Margin="0,0,8,8"
                                        AutomationProperties.Name="{loc:Loc AutomationMainWindowSixteenByNineCropAspect}">
                                    <TextBlock Text="16:9" />
                                </Button>
                                <Button Command="{Binding SetCropAspectPresetCommand}"
                                        CommandParameter="custom"
                                        Style="{StaticResource ChromeButton}"
                                        Margin="0,0,0,8"
                                        AutomationProperties.Name="{loc:Loc AutomationMainWindowCustomCropAspect}">
                                    <TextBlock Text="Custom" />
                                </Button>
                            </WrapPanel>

                            <Grid Visibility="{Binding ShowCustomCropAspect, Converter={StaticResource BoolToVis}}"
                                  Margin="0,2,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="68" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="68" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         Text="{Binding CustomCropAspectWidth, UpdateSourceTrigger=PropertyChanged}"
                                         AutomationProperties.Name="{loc:Loc AutomationMainWindowCustomCropAspectWidth}" />
                                <TextBlock Grid.Column="1"
                                           Text=":"
                                           Style="{StaticResource Text.Body}"
                                           VerticalAlignment="Center"
                                           Margin="8,0" />
                                <TextBox Grid.Column="2"
                                         Text="{Binding CustomCropAspectHeight, UpdateSourceTrigger=PropertyChanged}"
                                         AutomationProperties.Name="{loc:Loc AutomationMainWindowCustomCropAspectHeight}" />
                            </Grid>

                            <TextBlock Text="{Binding CropAspectHelpText}"
                                       Style="{StaticResource Text.Hint}"
                                       TextWrapping="Wrap" />

                            <WrapPanel Margin="0,12,0,0">
                                <Button Command="{Binding ApplyCropCommand}"
                                        Style="{StaticResource ChromeButton}"
                                        Margin="0,0,8,8"
                                        AutomationProperties.Name="{loc:Loc AutomationMainWindowApplyCropToFile}">
                                    <TextBlock Text="Apply crop" />
                                </Button>
                                <Button Command="{Binding CancelCropCommand}"
                                        Style="{StaticResource ChromeButton}"
                                        Margin="0,0,0,8"
                                        AutomationProperties.Name="{loc:Loc AutomationMainWindowCancelCrop}">
                                    <TextBlock Text="Cancel" />
                                </Button>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Divider}" />

                    <!-- LOCAL EXPOSURE section -->
                    <TextBlock Text="Local exposure" Style="{StaticResource SectionLabel}" />
                    <Border Style="{StaticResource Card}"
                            Padding="13,12"
                            IsEnabled="{Binding CanUseExposureBrush}">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{Binding ExposureBrushModeText}"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextBrush}" />
                                    <TextBlock Text="{Binding ExposureBrushModeHelpText}"
                                               Style="{StaticResource Text.Hint}"
                                               TextWrapping="Wrap"
                                               Margin="0,3,0,0" />
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Command="{Binding ToggleExposureBrushModeCommand}"
                                        Style="{StaticResource ChromeButton}"
                                        MinWidth="72"
                                        Margin="12,0,0,0"
                                        AutomationProperties.Name="{loc:Loc AutomationMainWindowToggleLocalExposureBrush}">
                                    <TextBlock Text="{Binding ExposureBrushModeText}" />
                                </Button>
                            </Grid>

                            <Border Background="{DynamicResource PanelBrush}"
                                    BorderBrush="{DynamicResource HairlineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource Radius.Sm.CR}"
                                    Padding="10"
                                    Margin="0,12,0,0">
                                <StackPanel>
                                    <TextBlock Text="{Binding ExposureBrushStatusText}"
                                               Style="{StaticResource Text.Caption}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding ExposureBrushStrokeText}"
                                               Style="{StaticResource Text.Body}"
                                               Margin="0,8,0,0" />
                                </StackPanel>
                            </Border>

                            <TextBlock Text="Mode"
                                       Style="{StaticResource Text.Caption}"
                                       Margin="0,12,0,6" />
                            <WrapPanel>
                                <Button Command="{Binding SetExposureBrushModeCommand}"
                                        CommandParameter="dodge"
                                        Style="{StaticResource ChromeButton}"
                                        Margin="0,0,8,8"
                                        AutomationProperties.Name="{loc:Loc AutomationMainWindowUseDodgeBrush}">
                                    <TextBlock Text="Dodge" />
                                </Button>
                                <Button Command="{Binding SetExposureBrushModeCommand}"
                                        CommandParameter="burn"
                                        Style="{StaticResource ChromeButton}"
                                        Margin="0,0,8,8"
                                        AutomationProperties.Name="{loc:Loc AutomationMainWindowUseBurnBrush}">
                                    <TextBlock Text="Burn" />
                                </Button>
                                <TextBlock Text="{Binding ExposureBrushToneText}"
                                           Style="{StaticResource Text.Hint}"
                                           VerticalAlignment="Center"
                                           Margin="2,0,0,8" />
                            </WrapPanel>

                            <Grid Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Radius"
                                           Style="{StaticResource Text.Caption}" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding ExposureBrushRadiusText}"
                                           Style="{StaticResource Text.Caption}" />
                            </Grid>
                            <Slider Minimum="4"
                                    Maximum="320"
                                    TickFrequency="4"
                                    IsSnapToTickEnabled="False"
                                    Value="{Binding ExposureBrushRadius, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    AutomationProperties.Name="{loc:Loc AutomationMainWindowExposureBrushRadius}" />

                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Strength"
                                           Style="{StaticResource Text.Caption}" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding ExposureBrushStrengthText}"
                                           Style="{StaticResource Text.Caption}" />
                            </Grid>
                            <Slider Minimum="1"
                                    Maximum="100"
                                    TickFrequency="1"
                                    IsSnapToTickEnabled="False"
                                    Value="{Binding ExposureBrushStrength, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    AutomationProperties.Name="{loc:Loc AutomationMainWindowExposureBrushStrength}" />

                            <WrapPanel Margin="0,12,0,0">
                                <Button Command="{Binding ApplyExposureBrushCommand}"
                                        Style="{StaticResource ChromeButton}"
                                        Margin="0,0,8,8"
                                        AutomationProperties.Name="{loc:Loc AutomationMainWindowApplyLocalExposureBrushToEditHistory}">
                                    <TextBlock Text="Apply brush" />
                                </Button>
                                <Button Command="{Binding ClearExposureBrushCommand}"
                                        Style="{StaticResource ChromeButton}"
                                        Margin="0,0,8,8"
                                        AutomationProperties.Name="{loc:Loc AutomationMainWindowClearLocalExposureBrushStrokes}">
                                    <TextBlock Text="Clear" />
                                </Button>
                                <Button Command="{Binding CancelExposureBrushCommand}"
                                        Style="{StaticResource ChromeButton}"
                                        Margin="0,0,0,8"
                                        AutomationProperties.Name="{loc:Loc AutomationMainWindowCancelLocalExposureBrush}">
                                    <TextBlock Text="Cancel" />
                                </Button>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Divider}" />

                    <!-- RED-EYE section -->
                    <TextBlock Text="Red-eye correction" Style="{StaticResource SectionLabel}" />
                    <Border Style="{StaticResource Card}"
                            Padding="13,12"
                            IsEnabled="{Binding CanUseRedEyeCorrection}">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{Binding RedEyeCorrectionModeText}"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextBrush}" />
                                    <TextBlock Text="{Binding RedEyeCorrectionModeHelpText}"
                                               Style="{StaticResource Text.Hint}"
                                               TextWrapping="Wrap"
                                               Margin="0,3,0,0" />
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Command="{Binding ToggleRedEyeModeCommand}"
                                        Style="{StaticResource ChromeButton}"
                                        MinWidth="72"
                                        Margin="12,0,0,0"
                                        AutomationProperties.Name="{loc:Loc AutomationMainWindowToggleRedEyeCorrection}">
                                    <TextBlock Text="{Binding RedEyeCorrectionModeText}" />
                                </Button>
                            </Grid>

                            <Border Background="{DynamicResource PanelBrush}"
                                    BorderBrush="{DynamicResource HairlineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource Radius.Sm.CR}"
                                    Padding="10"
                                    Margin="0,12,0,0">
                                <StackPanel>
                                    <TextBlock Text="{Binding RedEyeCorrectionStatusText}"
                                               Style="{StaticResource Text.Caption}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding RedEyeCorrectionMarkText}"
                                               Style="{StaticResource Text.Body}"
                                               Margin="0,8,0,0" />
                                </StackPanel>
                            </Border>

                            <Grid Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Radius"
                                           Style="{StaticResource Text.Caption}" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding RedEyeCorrectionRadiusText}"
                                           Style="{StaticResource Text.Caption}" />
                            </Grid>
                            <Slider Minimum="4"
                                    Maximum="180"
                                    TickFrequency="2"
                                    IsSnapToTickEnabled="False"
                                    Value="{Binding RedEyeCorrectionRadius, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    AutomationProperties.Name="{loc:Loc AutomationMainWindowRedEyeCorrectionRadius}" />

                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Strength"
                                           Style="{StaticResource Text.Caption}" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding RedEyeCorrectionStrengthText}"
                                           Style="{StaticResource Text.Caption}" />
                            </Grid>
                            <Slider Minimum="5"
                                    Maximum="100"
                                    TickFrequency="1"
                                    IsSnapToTickEnabled="False"
                                    Value="{Binding RedEyeCorrectionStrength, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    AutomationProperties.Name="{loc:Loc AutomationMainWindowRedEyeCorrectionStrength}" />

                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Red threshold"
                                           Style="{StaticResource Text.Caption}" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding RedEyeCorrectionThresholdText}"
                                           Style="{StaticResource Text.Caption}" />
                            </Grid>
                            <Slider Minimum="0"
                                    Maximum="100"
                                    TickFrequency="1"
                                    IsSnapToTickEnabled="False"
                                    Value="{Binding RedEyeCorrectionThreshold, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    AutomationProperties.Name="{loc:Loc AutomationMainWindowRedEyeCorrectionRedThreshold}" />

                            <WrapPanel Margin="0,12,0,0">
                                <Button Command="{Binding ApplyRedEyeCorrectionCommand}"
                                        Style="{StaticResource ChromeButton}"
                                        Margin="0,0,8,8"
                                        AutomationProperties.Name="{loc:Loc AutomationMainWindowApplyRedEyeCorrectionToEditHistory}">
                                    <TextBlock Text="Apply red-eye" />
                                </Button>
                                <Button Command="{Binding ClearRedEyeCorrectionCommand}"
                                        Style="{StaticResource ChromeButton}"
                                        Margin="0,0,8,8"
                                        AutomationProperties.Name="{loc:Loc AutomationMainWindowClearRedEyeCorrectionMarks}">
                                    <TextBlock Text="Clear" />
                                </Button>
                                <Button Command="{Binding CancelRedEyeCorrectionCommand}"
                                        Style="{StaticResource ChromeButton}"
                                        Margin="0,0,0,8"
                                        AutomationProperties.Name="{loc:Loc AutomationMainWindowCancelRedEyeCorrection}">
                                    <TextBlock Text="Cancel" />
                                </Button>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Divider}" />

                    <!-- RETOUCH section -->
                    <TextBlock Text="Clone / heal" Style="{StaticResource SectionLabel}" />
                    <Border Style="{StaticResource Card}"
                            Padding="13,12"
                            IsEnabled="{Binding CanUseRetouch}">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{Binding RetouchModeText}"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextBrush}" />
                                    <TextBlock Text="{Binding RetouchModeHelpText}"
                                               Style="{StaticResource Text.Hint}"
                                               TextWrapping="Wrap"
                                               Margin="0,3,0,0" />
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Command="{Binding ToggleRetouchModeCommand}"
                                        Style="{StaticResource ChromeButton}"
                                        MinWidth="72"
                                        Margin="12,0,0,0"
                                        AutomationProperties.Name="{loc:Loc AutomationMainWindowToggleCloneAndHealRetouch}">
                                    <TextBlock Text="{Binding RetouchModeText}" />
                                </Button>
                            </Grid>

                            <Border Background="{DynamicResource PanelBrush}"
                                    BorderBrush="{DynamicResource HairlineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource Radius.Sm.CR}"
                                    Padding="10"
                                    Margin="0,12,0,0">
                                <StackPanel>
                                    <TextBlock Text="{Binding RetouchStatusText}"
                                               Style="{StaticResource Text.Caption}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding RetouchSourceText}"
                                               Style="{StaticResource Text.Body}"
                                               Margin="0,8,0,0" />
                                    <TextBlock Text="{Binding RetouchStrokeText}"
                                               Style="{StaticResource Text.Caption}"
                                               Margin="0,4,0,0" />
                                </StackPanel>
                            </Border>

                            <TextBlock Text="Mode"
                                       Style="{StaticResource Text.Caption}"
                                       Margin="0,12,0,6" />
                            <WrapPanel>
                                <Button Command="{Binding SetRetouchModeCommand}"
                                        CommandParameter="clone"
                                        Style="{StaticResource ChromeButton}"
                                        Margin="0,0,8,8"
                                        AutomationProperties.Name="{loc:Loc AutomationMainWindowUseCloneStamp}">
                                    <TextBlock Text="Clone" />
                                </Button>
                                <Button Command="{Binding SetRetouchModeCommand}"
                                        CommandParameter="heal"
                                        Style="{StaticResource ChromeButton}"
                                        Margin="0,0,8,8"
                                        AutomationProperties.Name="{loc:Loc AutomationMainWindowUseHealingBrush}">
                                    <TextBlock Text="Heal" />
                                </Button>
                                <TextBlock Text="{Binding RetouchBrushModeText}"
                                           Style="{StaticResource Text.Hint}"
                                           VerticalAlignment="Center"
                                           Margin="2,0,0,8" />
                            </WrapPanel>

                            <Grid Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Radius"
                                           Style="{StaticResource Text.Caption}" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding RetouchRadiusText}"
                                           Style="{StaticResource Text.Caption}" />
                            </Grid>
                            <Slider Minimum="4"
                                    Maximum="220"
                                    TickFrequency="2"
                                    IsSnapToTickEnabled="False"
                                    Value="{Binding RetouchRadius, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    AutomationProperties.Name="{loc:Loc AutomationMainWindowRetouchBrushRadius}" />

                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Strength"
                                           Style="{StaticResource Text.Caption}" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding RetouchStrengthText}"
                                           Style="{StaticResource Text.Caption}" />
                            </Grid>
                            <Slider Minimum="5"
                                    Maximum="100"
                                    TickFrequency="1"
                                    IsSnapToTickEnabled="False"
                                    Value="{Binding RetouchStrength, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    AutomationProperties.Name="{loc:Loc AutomationMainWindowRetouchBrushStrength}" />

                            <WrapPanel Margin="0,12,0,0">
                                <Button Command="{Binding ApplyRetouchCommand}"
                                        Style="{StaticResource ChromeButton}"
                                        Margin="0,0,8,8"
                                        AutomationProperties.Name="{loc:Loc AutomationMainWindowApplyRetouchToEditHistory}">
                                    <TextBlock Text="Apply retouch" />
                                </Button>
                                <Button Command="{Binding ClearRetouchCommand}"
                                        Style="{StaticResource ChromeButton}"
                                        Margin="0,0,8,8"
                                        AutomationProperties.Name="{loc:Loc AutomationMainWindowClearRetouchStrokes}">
                                    <TextBlock Text="Clear" />
                                </Button>
                                <Button Command="{Binding ClearRetouchSourceCommand}"
                                        Style="{StaticResource ChromeButton}"
                                        Margin="0,0,8,8"
                                        AutomationProperties.Name="{loc:Loc AutomationMainWindowClearRetouchSource}">
                                    <TextBlock Text="Source" />
                                </Button>
                                <Button Command="{Binding CancelRetouchCommand}"
                                        Style="{StaticResource ChromeButton}"
                                        Margin="0,0,0,8"
                                        AutomationProperties.Name="{loc:Loc AutomationMainWindowCancelRetouch}">
                                    <TextBlock Text="Cancel" />
                                </Button>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Divider}" />

                    <!-- INSPECTOR section -->
                    <TextBlock Text="Inspector" Style="{StaticResource SectionLabel}" />
                    <Border Style="{StaticResource Card}"
                            Padding="13,12"
                            IsEnabled="{Binding CanUseInspector}">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{Binding InspectorModeText}"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextBrush}" />
                                    <TextBlock Text="{Binding InspectorModeHelpText}"
                                               Style="{StaticResource Text.Hint}"
                                               TextWrapping="Wrap"
                                               Margin="0,3,0,0" />
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Command="{Binding ToggleInspectorCommand}"
                                        Style="{StaticResource ChromeButton}"
                                        MinWidth="72"
                                        Margin="12,0,0,0"
                                        AutomationProperties.Name="{loc:Loc AutomationMainWindowTogglePixelInspector}">
                                    <TextBlock Text="{Binding InspectorModeText}" />
                                </Button>
                            </Grid>

                            <CheckBox IsChecked="{Binding InspectorNearestNeighborPreview, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      Content="Nearest-neighbor preview"
                                      Margin="0,12,0,0"
                                      ToolTip="Use crisp scaling for pixel-art inspection."
                                      AutomationProperties.Name="{loc:Loc AutomationMainWindowUseNearestNeighborPreviewScaling}" />

                            <Border Background="{DynamicResource PanelBrush}"
                                    BorderBrush="{DynamicResource HairlineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource Radius.Sm.CR}"
                                    Padding="10"
                                    Margin="0,12,0,0">
                                <StackPanel>
                                    <TextBlock Text="{Binding InspectorStatusText}"
                                               Style="{StaticResource Text.Caption}"
                                               TextWrapping="Wrap" />
                                    <UniformGrid Columns="2" Margin="0,10,0,0">
                                        <StackPanel Margin="0,0,10,8">
                                            <TextBlock Text="Coordinate" Style="{StaticResource Text.Hint}" />
                                            <TextBlock Text="{Binding InspectorCoordinateText}" Style="{StaticResource Text.Body}" />
                                        </StackPanel>
                                        <StackPanel Margin="0,0,0,8">
                                            <TextBlock Text="Hex" Style="{StaticResource Text.Hint}" />
                                            <TextBlock Text="{Binding InspectorHexText}" Style="{StaticResource Text.Body}" />
                                        </StackPanel>
                                        <StackPanel Margin="0,0,10,8">
                                            <TextBlock Text="RGB" Style="{StaticResource Text.Hint}" />
                                            <TextBlock Text="{Binding InspectorRgbText}" Style="{StaticResource Text.Body}" />
                                        </StackPanel>
                                        <StackPanel Margin="0,0,0,8">
                                            <TextBlock Text="HSV / Alpha" Style="{StaticResource Text.Hint}" />
                                            <TextBlock Text="{Binding InspectorHsvText}" Style="{StaticResource Text.Body}" />
                                            <TextBlock Text="{Binding InspectorAlphaText}" Style="{StaticResource Text.Hint}" />
                                        </StackPanel>
                                    </UniformGrid>
                                    <TextBlock Text="{Binding InspectorSelectionText}"
                                               Style="{StaticResource Text.Caption}"
                                               Margin="0,2,0,0" />
                                </StackPanel>
                            </Border>

                            <WrapPanel Margin="0,12,0,0">
                                <Button Command="{Binding CopyInspectorHexCommand}"
                                        Style="{StaticResource ChromeButton}"
                                        Margin="0,0,8,8"
                                        AutomationProperties.Name="{loc:Loc AutomationMainWindowCopyHEXColor}">
                                    <TextBlock Text="Copy HEX" />
                                </Button>
                                <Button Command="{Binding CopyInspectorRgbCommand}"
                                        Style="{StaticResource ChromeButton}"
                                        Margin="0,0,8,8"
                                        AutomationProperties.Name="{loc:Loc AutomationMainWindowCopyRGBColor}">
                                    <TextBlock Text="Copy RGB" />
                                </Button>
                                <Button Command="{Binding CopyInspectorHsvCommand}"
                                        Style="{StaticResource ChromeButton}"
                                        Margin="0,0,8,8"
                                        AutomationProperties.Name="{loc:Loc AutomationMainWindowCopyHSVColor}">
                                    <TextBlock Text="Copy HSV" />
                                </Button>
                                <Button Command="{Binding ClearInspectorSelectionCommand}"
                                        Style="{StaticResource ChromeButton}"
                                        Margin="0,0,0,8"
                                        AutomationProperties.Name="{loc:Loc AutomationMainWindowClearInspectorMeasurement}">
                                    <TextBlock Text="Clear measure" />
                                </Button>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    </StackPanel>
                    </Expander>

                    <StackPanel Visibility="{Binding PhotoMetadataRows.Count, Converter={StaticResource BoolToVis}}">
                        <Border Style="{StaticResource Divider}" />
                        <TextBlock Text="Photo metadata" Style="{StaticResource SectionLabel}" />
                        <ItemsControl ItemsSource="{Binding PhotoMetadataRows}"
                                      AutomationProperties.Name="{loc:Loc AutomationMainWindowPhotoMetadata}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="1,0,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Label}"
                                                   Style="{StaticResource MetaLabel}" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Value}"
                                                   Style="{StaticResource MetaValue}"
                                                   ToolTip="{Binding Value}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <Expander x:Name="MoreDetailsExpander"
                              Style="{StaticResource InspectorExpander}"
                              Header="More details"
                              IsExpanded="False"
                              Margin="0,4,0,0"
                              Visibility="{Binding ShowColorAnalysisPanel, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                        <Border Style="{StaticResource Divider}" />
                        <TextBlock Text="Color &amp; histogram" Style="{StaticResource SectionLabel}" />

                        <ItemsControl ItemsSource="{Binding ColorAnalysisRows}"
                                      Visibility="{Binding ColorAnalysisRows.Count, Converter={StaticResource BoolToVis}}"
                                      AutomationProperties.Name="{loc:Loc AutomationMainWindowColorProfileAndHistogram}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="1,0,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Label}"
                                                   Style="{StaticResource MetaLabel}" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Value}"
                                                   Style="{StaticResource MetaValue}"
                                                   ToolTip="{Binding Value}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Border Style="{StaticResource Card}"
                                Margin="0,6,0,0"
                                Visibility="{Binding ColorAnalysisWarningText, Converter={StaticResource BoolToVis}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE7BA;"
                                           FontFamily="{StaticResource IconFontFamily}"
                                           FontSize="12"
                                           Foreground="{DynamicResource YellowBrush}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,9,0" />
                                <TextBlock Text="{Binding ColorAnalysisWarningText}"
                                           Style="{StaticResource Text.Hint}"
                                           TextWrapping="Wrap"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Card}"
                                Margin="0,6,0,0"
                                Visibility="{Binding ColorAnalysisStatusText, Converter={StaticResource BoolToVis}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE946;"
                                           FontFamily="{StaticResource IconFontFamily}"
                                           FontSize="12"
                                           Foreground="{DynamicResource OverlayBrush}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,9,0" />
                                <TextBlock Text="{Binding ColorAnalysisStatusText}"
                                           Style="{StaticResource Text.Hint}"
                                           TextWrapping="Wrap"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                        </StackPanel>
                    </Expander>

                    <StackPanel Visibility="{Binding ShowC2paPanel, Converter={StaticResource BoolToVis}}">
                        <Border Style="{StaticResource Divider}" />
                        <TextBlock Text="content credentials" Style="{StaticResource SectionLabel}" />

                        <Border Style="{StaticResource Card}" Margin="0,4,0,0"
                                ToolTip="{Binding C2paTrustBadgeTooltip}"
                                Visibility="{Binding HasC2paCredentials, Converter={StaticResource BoolToVis}}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="&#xE72E;"
                                               FontFamily="{StaticResource IconFontFamily}"
                                               FontSize="14"
                                               Foreground="{DynamicResource AccentBrush}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,0" />
                                    <TextBlock Text="{Binding C2paTrustBadgeText}"
                                               Style="{StaticResource Text.Body}"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center" />
                                </StackPanel>

                                <TextBlock Text="{Binding C2paClaimGeneratorText}"
                                           Style="{StaticResource Text.Hint}"
                                           TextWrapping="Wrap"
                                           Visibility="{Binding C2paClaimGeneratorText, Converter={StaticResource BoolToVis}}"
                                           Margin="0,0,0,2" />

                                <TextBlock Text="{Binding C2paSignatureDateText}"
                                           Style="{StaticResource Text.Hint}"
                                           TextWrapping="Wrap"
                                           Visibility="{Binding C2paSignatureDateText, Converter={StaticResource BoolToVis}}"
                                           Margin="0,0,0,2" />

                                <TextBlock Text="{Binding C2paAssertionsSummaryText}"
                                           Style="{StaticResource Text.Hint}"
                                           TextWrapping="Wrap"
                                           Visibility="{Binding C2paAssertionsSummaryText, Converter={StaticResource BoolToVis}}"
                                           Margin="0,0,0,2" />

                                <TextBlock Text="{Binding C2paIngredientsSummaryText}"
                                           Style="{StaticResource Text.Hint}"
                                           TextWrapping="Wrap"
                                           Visibility="{Binding C2paIngredientsSummaryText, Converter={StaticResource BoolToVis}}" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Card}"
                                Margin="0,4,0,0"
                                Visibility="{Binding IsC2paLoading, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="Checking content credentials..."
                                       Style="{StaticResource Text.Hint}"
                                       VerticalAlignment="Center" />
                        </Border>
                    </StackPanel>

                    <Border Style="{StaticResource Card}"
                            Margin="0,4,0,0"
                            Visibility="{Binding ShowMetadataStatus, Converter={StaticResource BoolToVis}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE946;"
                                       FontFamily="{StaticResource IconFontFamily}"
                                       FontSize="12"
                                       Foreground="{DynamicResource OverlayBrush}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,9,0" />
                            <TextBlock Text="{Binding MetadataStatusText}"
                                       Style="{StaticResource Text.Hint}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
