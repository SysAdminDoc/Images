<Window x:Class="Images.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Images.ViewModels"
        xmlns:ctl="clr-namespace:Images.Controls"
        xmlns:loc="clr-namespace:Images.Localization"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="{Binding WindowTitle}"
        Width="1280" Height="840"
        MinWidth="760" MinHeight="560"
        WindowStartupLocation="CenterScreen"
        AllowDrop="True"
        DragEnter="Window_DragEnter"
        DragLeave="Window_DragLeave"
        Drop="Window_Drop"
        DragOver="Window_DragOver"
        PreviewKeyDown="Window_PreviewKeyDown"
        KeyDown="Window_KeyDown"
        PreviewMouseDown="Window_PreviewMouseDown"
        Background="{DynamicResource BaseBrush}"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <!-- V15-07: side panel column collapses to 0 in fullscreen. Width="Auto" + the
                  Border's Visibility binding below drops the column to zero width when the
                  Border is Collapsed (Auto sizes to hidden-content width). -->
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <Border x:Name="WorkflowRail"
                Grid.Column="0"
                Width="52"
                Background="{DynamicResource NavRailBrush}"
                BorderBrush="{DynamicResource NavRailBorderBrush}"
                BorderThickness="0,0,1,0"
                Visibility="{Binding IsFullscreen, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}"
                AutomationProperties.Name="{loc:Loc AutomationMainWindowWorkflowNavigation}">
            <Grid Margin="6,12,6,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Width="32"
                        Height="32"
                        CornerRadius="{StaticResource Radius.Md.CR}"
                        Background="{DynamicResource AccentWarmPanelBrush}"
                        BorderBrush="{DynamicResource AccentWarmBrush}"
                        BorderThickness="1"
                        HorizontalAlignment="Center"
                        ToolTip="Images workspace">
                    <TextBlock Text="&#xEB9F;"
                               FontFamily="{StaticResource IconFontFamily}"
                               FontSize="18"
                               Foreground="{DynamicResource AccentWarmBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>

                <StackPanel Grid.Row="1"
                            VerticalAlignment="Top"
                            Margin="0,20,0,0">
                    <Button Style="{StaticResource NavRailButton}"
                            Command="{Binding OpenCommand}"
                            ToolTip="Open an image or folder"
                            AutomationProperties.Name="{loc:Loc AutomationMainWindowLibrary}">
                        <TextBlock Text="&#xE8E5;" FontFamily="{StaticResource IconFontFamily}" FontSize="16" TextAlignment="Center" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                    </Button>
                    <Button Style="{StaticResource NavRailButton}"
                            Command="{Binding ToggleGalleryCommand}"
                            ToolTip="Gallery"
                            AutomationProperties.Name="{loc:Loc AutomationMainWindowGalleryWorkbench}">
                        <TextBlock Text="&#xE8A9;" FontFamily="{StaticResource IconFontFamily}" FontSize="16" TextAlignment="Center" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                    </Button>
                </StackPanel>

                <StackPanel Grid.Row="2">
                    <Button Style="{StaticResource NavRailButton}"
                            Command="{Binding SettingsCommand}"
                            ToolTip="Settings"
                            AutomationProperties.Name="{loc:Loc AutomationMainWindowSettings}">
                        <TextBlock Text="&#xE713;" FontFamily="{StaticResource IconFontFamily}" FontSize="15" TextAlignment="Center" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ============ LEFT: Viewport, floating chrome, bottom toolbar ============ -->
        <Grid Grid.Column="1" Background="{DynamicResource ViewportBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid x:Name="Viewport"
                  Grid.Row="0"
                  ClipToBounds="True"
                  Background="Transparent"
                  PreviewMouseRightButtonUp="Viewport_PreviewMouseRightButtonUp">
                <!-- V15-02: right-click context menu on the viewport. Rename-TextBox's own
                     built-in edit menu is unaffected because ContextMenu here is attached to
                     this Grid, not to descendants. -->
                <Grid.ContextMenu>
                    <ContextMenu Style="{StaticResource ViewportContextMenu}"
                                 AutomationProperties.AutomationId="ViewportContextMenu"
                                 AutomationProperties.Name="{loc:Loc AutomationMainWindowViewportContextMenu}">
                        <MenuItem Header="Open…" Command="{Binding OpenCommand}" InputGestureText="{Binding ShortcutTexts[open]}">
                            <MenuItem.Icon>
                                <TextBlock Style="{StaticResource MenuItemIcon}" Text="&#xE8E5;" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="Browse folder…" Command="{Binding BrowseFolderCommand}" InputGestureText="{Binding ShortcutTexts[browse-folder]}">
                            <MenuItem.Icon>
                                <TextBlock Style="{StaticResource MenuItemIcon}" Text="&#xE8B7;" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="Paste from clipboard" Command="{Binding PasteFromClipboardCommand}" InputGestureText="{Binding ShortcutTexts[paste]}">
                            <MenuItem.Icon>
                                <TextBlock Style="{StaticResource MenuItemIcon}" Text="&#xE77F;" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="Reload" Command="{Binding ReloadCommand}" InputGestureText="{Binding ShortcutTexts[reload]}">
                            <MenuItem.Icon>
                                <TextBlock Style="{StaticResource MenuItemIcon}" Text="&#xE72C;" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <Separator />
                        <MenuItem Header="Compare"
                                  AutomationProperties.AutomationId="ViewportContextMenuCompare">
                            <MenuItem.Icon>
                                <TextBlock Style="{StaticResource MenuItemIcon}" Text="&#xE8AB;" />
                            </MenuItem.Icon>
                            <MenuItem Header="{Binding CompareModeText}" Command="{Binding StartCompareCommand}" InputGestureText="{Binding ShortcutTexts[compare]}" />
                            <MenuItem Header="Compare with…" Command="{Binding CompareWithCommand}" InputGestureText="{Binding ShortcutTexts[compare-with]}" AutomationProperties.AutomationId="ViewportContextMenuCompareWith" />
                            <MenuItem Header="Exit compare" Command="{Binding ExitCompareCommand}" InputGestureText="Esc" />
                        </MenuItem>
                        <MenuItem Header="View">
                            <MenuItem.Icon>
                                <TextBlock Style="{StaticResource MenuItemIcon}" Text="&#xE890;" />
                            </MenuItem.Icon>
                            <MenuItem Header="Previous page" Command="{Binding PrevPageCommand}" />
                            <MenuItem Header="Next page" Command="{Binding NextPageCommand}" />
                            <Separator />
                            <MenuItem Header="Metadata HUD"
                                      Command="{Binding ToggleMetadataHudCommand}"
                                      InputGestureText="{Binding ShortcutTexts[metadata-hud]}"
                                      IsCheckable="True"
                                      IsChecked="{Binding IsMetadataHudVisible, Mode=OneWay}" />
                        </MenuItem>
                        <Separator />
                        <MenuItem Header="Edit">
                            <MenuItem.Icon>
                                <TextBlock Style="{StaticResource MenuItemIcon}" Text="&#xE70F;" />
                            </MenuItem.Icon>
                            <MenuItem Header="Edit history" Command="{Binding OpenEditStackCommand}" InputGestureText="{Binding ShortcutTexts[edit-stack]}" />
                            <Separator />
                            <MenuItem Header="Adjustments…" Command="{Binding OpenAdjustmentsCommand}" InputGestureText="{Binding ShortcutTexts[adjustments]}" />
                            <MenuItem Header="Effects…" Command="{Binding OpenEffectsCommand}" InputGestureText="{Binding ShortcutTexts[effects]}" />
                            <MenuItem Header="Auto Enhance" Command="{Binding AutoEnhanceCommand}" InputGestureText="{Binding ShortcutTexts[auto-enhance]}" />
                            <MenuItem Header="Annotations…" Command="{Binding OpenAnnotationsCommand}" />
                            <Separator />
                            <MenuItem Header="Local tools">
                                <MenuItem Header="{Binding ExposureBrushModeText}"
                                          Command="{Binding ToggleExposureBrushModeCommand}"
                                          InputGestureText="{Binding ShortcutTexts[exposure-brush]}"
                                          IsCheckable="True"
                                          IsChecked="{Binding IsExposureBrushMode, Mode=OneWay}" />
                                <MenuItem Header="{Binding RedEyeCorrectionModeText}"
                                          Command="{Binding ToggleRedEyeModeCommand}"
                                          InputGestureText="{Binding ShortcutTexts[red-eye]}"
                                          IsCheckable="True"
                                          IsChecked="{Binding IsRedEyeCorrectionMode, Mode=OneWay}" />
                                <MenuItem Header="{Binding RetouchModeText}"
                                          Command="{Binding ToggleRetouchModeCommand}"
                                          InputGestureText="{Binding ShortcutTexts[retouch]}"
                                          IsCheckable="True"
                                          IsChecked="{Binding IsRetouchMode, Mode=OneWay}" />
                                <MenuItem Header="{Binding SelectionModeText}"
                                          Command="{Binding ToggleSelectionModeCommand}"
                                          InputGestureText="{Binding ShortcutTexts[selection-mode]}"
                                          IsCheckable="True"
                                          IsChecked="{Binding IsSelectionMode, Mode=OneWay}" />
                            </MenuItem>
                            <MenuItem Header="Overlay">
                                <MenuItem Header="{Binding OverlayModeText}"
                                          Command="{Binding ToggleOverlayModeCommand}"
                                          IsCheckable="True"
                                          IsChecked="{Binding IsPinnedOverlayMode, Mode=OneWay}" />
                                <MenuItem Header="Exit overlay"
                                          Command="{Binding ExitOverlayModeCommand}"
                                          InputGestureText="Ctrl+Alt+O" />
                            </MenuItem>
                        </MenuItem>
                        <MenuItem Header="Transform">
                            <MenuItem.Icon>
                                <TextBlock Style="{StaticResource MenuItemIcon}" Text="&#xE7AD;" />
                            </MenuItem.Icon>
                            <MenuItem Header="Resize…" Command="{Binding OpenResizeDialogCommand}" InputGestureText="{Binding ShortcutTexts[resize]}" />
                            <MenuItem Header="Perspective…" Command="{Binding OpenPerspectiveCommand}" InputGestureText="{Binding ShortcutTexts[perspective]}" />
                            <MenuItem Header="{Binding CropModeText}"
                                      Command="{Binding ToggleCropModeCommand}"
                                      InputGestureText="{Binding ShortcutTexts[crop-mode]}"
                                      IsCheckable="True"
                                      IsChecked="{Binding IsCropMode, Mode=OneWay}" />
                            <Separator />
                            <MenuItem Header="Rotate left" Command="{Binding RotateCcwCommand}" />
                            <MenuItem Header="Rotate right" Command="{Binding RotateCwCommand}" />
                            <MenuItem Header="Rotate 180°" Command="{Binding Rotate180Command}" />
                            <MenuItem Header="Apply rotation to file" Command="{Binding ApplyRotationToFileCommand}" />
                            <Separator />
                            <MenuItem Header="Flip horizontal" Command="{Binding FlipHorizontalCommand}" />
                            <MenuItem Header="Flip vertical" Command="{Binding FlipVerticalCommand}" />
                        </MenuItem>
                        <MenuItem Header="Organize">
                            <MenuItem.Icon>
                                <TextBlock Style="{StaticResource MenuItemIcon}" Text="&#xE8EC;" />
                            </MenuItem.Icon>
                            <MenuItem Header="Reference board" Command="{Binding OpenReferenceBoardCommand}" InputGestureText="{Binding ShortcutTexts[reference-board]}" />
                            <MenuItem Header="Duplicate cleanup" Command="{Binding OpenDuplicateCleanupCommand}" InputGestureText="{Binding ShortcutTexts[duplicate-cleanup]}" />
                            <MenuItem Header="Semantic search" Command="{Binding OpenSemanticSearchCommand}" />
                            <MenuItem Header="Tag relationships" Command="{Binding OpenTagGraphCommand}" InputGestureText="{Binding ShortcutTexts[tag-graph]}" />
                            <MenuItem Header="Import inbox" Command="{Binding OpenImportInboxCommand}" InputGestureText="{Binding ShortcutTexts[import-inbox]}" />
                        </MenuItem>
                        <MenuItem Header="Workflow tools">
                            <MenuItem.Icon>
                                <TextBlock Style="{StaticResource MenuItemIcon}" Text="&#xE945;" />
                            </MenuItem.Icon>
                            <MenuItem Header="Macro actions" Command="{Binding OpenMacroActionsCommand}" InputGestureText="{Binding ShortcutTexts[macro-actions]}" />
                            <MenuItem Header="Batch processor" Command="{Binding OpenBatchProcessorCommand}" InputGestureText="{Binding ShortcutTexts[batch-processor]}" />
                            <Separator />
                            <MenuItem Header="File health scan" Command="{Binding OpenFileHealthScanCommand}" InputGestureText="{Binding ShortcutTexts[file-health-scan]}" />
                            <MenuItem Header="Recovery center" Command="{Binding OpenRecoveryCenterCommand}" />
                            <MenuItem Header="Model manager" Command="{Binding OpenModelManagerCommand}" />
                        </MenuItem>
                        <Separator />
                        <MenuItem Header="File actions">
                            <MenuItem.Icon>
                                <TextBlock Style="{StaticResource MenuItemIcon}" Text="&#xE8E5;" />
                            </MenuItem.Icon>
                            <MenuItem Header="Reveal in Explorer" Command="{Binding RevealCommand}" />
                            <MenuItem Header="Open with default app" Command="{Binding OpenInDefaultAppCommand}" />
                            <Separator />
                            <MenuItem Header="Copy">
                                <MenuItem Header="Copy path" Command="{Binding CopyPathCommand}" />
                                <MenuItem Header="Copy image" Command="{Binding CopyImageCommand}" />
                                <MenuItem Header="Copy image and path" Command="{Binding CopyImageAndPathCommand}" />
                                <Separator />
                                <MenuItem Header="Copy to folder…" Command="{Binding CopyToFolderCommand}" />
                                <MenuItem Header="Copy to recent folder"
                                          Tag="{Binding}"
                                          ItemsSource="{Binding RecentTransferFolders}"
                                          Visibility="{Binding RecentTransferFolders.Count, Converter={StaticResource BoolToVis}}">
                                    <MenuItem.ItemContainerStyle>
                                        <Style TargetType="{x:Type MenuItem}" BasedOn="{StaticResource {x:Type MenuItem}}">
                                            <Setter Property="Header" Value="{Binding Converter={x:Static vm:PathToFileNameConverter.Instance}, Mode=OneWay}" />
                                            <Setter Property="ToolTip" Value="{Binding}" />
                                            <Setter Property="Command" Value="{Binding Tag.CopyToFolderCommand, RelativeSource={RelativeSource AncestorType=MenuItem}}" />
                                            <Setter Property="CommandParameter" Value="{Binding}" />
                                        </Style>
                                    </MenuItem.ItemContainerStyle>
                                </MenuItem>
                            </MenuItem>
                            <MenuItem Header="Move">
                                <MenuItem Header="Move to folder…" Command="{Binding MoveToFolderCommand}" />
                                <MenuItem Header="Move to recent folder"
                                          Tag="{Binding}"
                                          ItemsSource="{Binding RecentTransferFolders}"
                                          Visibility="{Binding RecentTransferFolders.Count, Converter={StaticResource BoolToVis}}">
                                    <MenuItem.ItemContainerStyle>
                                        <Style TargetType="{x:Type MenuItem}" BasedOn="{StaticResource {x:Type MenuItem}}">
                                            <Setter Property="Header" Value="{Binding Converter={x:Static vm:PathToFileNameConverter.Instance}, Mode=OneWay}" />
                                            <Setter Property="ToolTip" Value="{Binding}" />
                                            <Setter Property="Command" Value="{Binding Tag.MoveToFolderCommand, RelativeSource={RelativeSource AncestorType=MenuItem}}" />
                                            <Setter Property="CommandParameter" Value="{Binding}" />
                                        </Style>
                                    </MenuItem.ItemContainerStyle>
                                </MenuItem>
                            </MenuItem>
                            <Separator />
                            <MenuItem Header="Strip GPS location" Command="{Binding StripLocationCommand}" />
                            <MenuItem Header="Strip metadata">
                                <MenuItem Header="Device info (make, model, serial)" Command="{Binding StripDeviceInfoCommand}" />
                                <MenuItem Header="Timestamps" Command="{Binding StripTimestampsCommand}" />
                                <MenuItem Header="Software and comments" Command="{Binding StripSoftwareCommand}" />
                                <Separator />
                                <MenuItem Header="All metadata" Command="{Binding StripAllMetadataCommand}" />
                            </MenuItem>
                            <MenuItem Header="Extract motion video"
                                      Command="{Binding ExtractMotionVideoCommand}"
                                      Visibility="{Binding IsMotionPhoto, Converter={StaticResource BoolToVis}}" />
                        </MenuItem>
                        <MenuItem Header="Output">
                            <MenuItem.Icon>
                                <TextBlock Style="{StaticResource MenuItemIcon}" Text="&#xE74E;" />
                            </MenuItem.Icon>
                            <MenuItem Header="Save a copy…" Command="{Binding SaveAsCopyCommand}" InputGestureText="{Binding ShortcutTexts[save-copy]}" />
                            <MenuItem Header="Export workbench…" Command="{Binding OpenExportWorkbenchCommand}" InputGestureText="{Binding ShortcutTexts[export-workbench]}" />
                            <Separator />
                            <MenuItem Header="Print…" Command="{Binding PrintCommand}" InputGestureText="{Binding ShortcutTexts[print]}" />
                            <MenuItem Header="Print to default printer" Command="{Binding PrintDefaultCommand}" />
                            <MenuItem Header="Send to email" Command="{Binding SendToEmailCommand}" />
                            <Separator />
                            <MenuItem Header="Set as desktop wallpaper">
                                <MenuItem Header="Fill"
                                          Command="{Binding SetAsWallpaperCommand}"
                                          CommandParameter="Fill" />
                                <MenuItem Header="Fit"
                                          Command="{Binding SetAsWallpaperCommand}"
                                          CommandParameter="Fit" />
                                <MenuItem Header="Span"
                                          Command="{Binding SetAsWallpaperCommand}"
                                          CommandParameter="Span" />
                                <MenuItem Header="Tile"
                                          Command="{Binding SetAsWallpaperCommand}"
                                          CommandParameter="Tile" />
                            </MenuItem>
                        </MenuItem>
                        <Separator />
                        <MenuItem Header="Move to Recycle Bin…" Command="{Binding DeleteCommand}" InputGestureText="{Binding ShortcutTexts[delete]}">
                            <MenuItem.Icon>
                                <TextBlock Style="{StaticResource MenuItemIcon}" Text="&#xE74D;" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <Separator />
                        <MenuItem Header="Settings…" Command="{Binding SettingsCommand}" InputGestureText="{Binding ShortcutTexts[settings]}">
                            <MenuItem.Icon>
                                <TextBlock Style="{StaticResource MenuItemIcon}" Text="&#xE713;" />
                            </MenuItem.Icon>
                        </MenuItem>
                    </ContextMenu>
                </Grid.ContextMenu>

                <ctl:ZoomPanImage x:Name="Canvas"
                                   Source="{Binding CurrentImage}"
                                   AutomationProperties.AutomationId="ImageCanvas"
                                   TilePyramid="{Binding CurrentTilePyramid}"
                                   Animation="{Binding CurrentAnimation}"
                                   AnimationFrameIndex="{Binding CurrentAnimationFrameIndex}"
                                   Rotation="{Binding Rotation}"
                                   FlipHorizontal="{Binding FlipHorizontal}"
                                   FlipVertical="{Binding FlipVertical}"
                                   InspectorMode="{Binding IsCanvasSelectionMode}"
                                   UseNearestNeighborScaling="{Binding InspectorNearestNeighborPreview}"
                                   PreserveViewOnSourceChange="{Binding IsZoomLocked}"
                                   ShowTransparencyGrid="{Binding ShowTransparencyGrid}"
                                   LoupeFactor="{Binding LoupeMagnification}"
                                   Visibility="{Binding ShowCompareMode, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}"
                                   PreviewMouseRightButtonUp="Viewport_PreviewMouseRightButtonUp"
                                   MouseMove="Canvas_MouseMove"
                                   MouseLeave="Canvas_MouseLeave"
                                   LostMouseCapture="Canvas_LostMouseCapture"
                                   MouseLeftButtonDown="Canvas_MouseLeftButtonDown"
                                   MouseLeftButtonUp="Canvas_MouseLeftButtonUp" />

                <Grid x:Name="MotionVideoOverlay"
                      Visibility="{Binding IsMotionVideoPlaying, Converter={StaticResource BoolToVis}}"
                      Background="{DynamicResource BaseBrush}">
                    <MediaElement x:Name="MotionVideoPlayer"
                                  LoadedBehavior="Play"
                                  UnloadedBehavior="Manual"
                                  Stretch="Uniform"
                                  MediaEnded="MotionVideoPlayer_MediaEnded" />
                    <Button Content="&#xE711;"
                            FontFamily="{DynamicResource IconFontFamily}"
                            FontSize="18"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="12"
                            Width="36" Height="36"
                            Style="{DynamicResource ChromeButton}"
                            Command="{Binding StopMotionVideoCommand}"
                            AutomationProperties.Name="{loc:Loc AutomationMainWindowStopMotionVideo}"
                            ToolTip="Stop video" />
                </Grid>

                <Grid Visibility="{Binding ShowCompareMode, Converter={StaticResource BoolToVis}}"
                      AutomationProperties.Name="{loc:Loc AutomationMainWindowImageCompareMode}"
                      AutomationProperties.HelpText="{Binding CompareStatusText}">
                    <Grid Visibility="{Binding IsCompareOverlayMode, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="1" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0" Background="{DynamicResource ViewportBrush}" ClipToBounds="True">
                            <ctl:ZoomPanImage x:Name="ComparePrimaryCanvas"
                                              Source="{Binding CurrentImage}"
                                              Rotation="{Binding Rotation}"
                                              FlipHorizontal="{Binding FlipHorizontal}"
                                              FlipVertical="{Binding FlipVertical}"
                                              UseNearestNeighborScaling="{Binding InspectorNearestNeighborPreview}"
                                              ViewChanged="CompareCanvas_ViewChanged"
                                              AutomationProperties.Name="{loc:Loc AutomationMainWindowCompareAImage}" />
                            <Border HorizontalAlignment="Left"
                                    VerticalAlignment="Top"
                                    Margin="16"
                                    Padding="10,7"
                                    CornerRadius="{StaticResource Radius.Sm.CR}"
                                    Background="{DynamicResource ToastBrush}"
                                    BorderBrush="{DynamicResource HairlineBrush}"
                                    BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="A"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource AccentBrush}" />
                                    <TextBlock Text="{Binding ComparePrimaryFileName}"
                                               Style="{StaticResource Text.Caption}"
                                               TextTrimming="CharacterEllipsis"
                                               MaxWidth="300" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border Grid.Column="1" Background="{DynamicResource HairlineBrush}" />

                        <Grid Grid.Column="2" Background="{DynamicResource ViewportBrush}" ClipToBounds="True">
                            <ctl:ZoomPanImage x:Name="CompareSecondaryCanvas"
                                              Source="{Binding CompareImage}"
                                              Rotation="{Binding Rotation}"
                                              FlipHorizontal="{Binding FlipHorizontal}"
                                              FlipVertical="{Binding FlipVertical}"
                                              UseNearestNeighborScaling="{Binding InspectorNearestNeighborPreview}"
                                              ViewChanged="CompareCanvas_ViewChanged"
                                              AutomationProperties.Name="{loc:Loc AutomationMainWindowCompareBImage}" />
                            <Border HorizontalAlignment="Left"
                                    VerticalAlignment="Top"
                                    Margin="16"
                                    Padding="10,7"
                                    CornerRadius="{StaticResource Radius.Sm.CR}"
                                    Background="{DynamicResource ToastBrush}"
                                    BorderBrush="{DynamicResource HairlineBrush}"
                                    BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="B"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource YellowBrush}" />
                                    <TextBlock Text="{Binding CompareSecondaryFileName}"
                                               Style="{StaticResource Text.Caption}"
                                               TextTrimming="CharacterEllipsis"
                                               MaxWidth="300" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>

                    <Grid Visibility="{Binding IsCompareOverlayMode, Converter={StaticResource BoolToVis}}"
                          Background="{DynamicResource ViewportBrush}"
                          ClipToBounds="True">
                        <ctl:ZoomPanImage x:Name="CompareOverlayPrimaryCanvas"
                                          Source="{Binding CurrentImage}"
                                          Rotation="{Binding Rotation}"
                                          FlipHorizontal="{Binding FlipHorizontal}"
                                          FlipVertical="{Binding FlipVertical}"
                                          UseNearestNeighborScaling="{Binding InspectorNearestNeighborPreview}"
                                          ViewChanged="CompareCanvas_ViewChanged"
                                          AutomationProperties.Name="{loc:Loc AutomationMainWindowCompareOverlayAImage}" />
                        <ctl:ZoomPanImage x:Name="CompareOverlaySecondaryCanvas"
                                          Source="{Binding CompareImage}"
                                          Rotation="{Binding Rotation}"
                                          FlipHorizontal="{Binding FlipHorizontal}"
                                          FlipVertical="{Binding FlipVertical}"
                                          Opacity="{Binding CompareOverlayOpacity}"
                                          IsHitTestVisible="False"
                                          UseNearestNeighborScaling="{Binding InspectorNearestNeighborPreview}"
                                          ViewChanged="CompareCanvas_ViewChanged"
                                          AutomationProperties.Name="{loc:Loc AutomationMainWindowCompareOverlayBImage}" />
                        <Border HorizontalAlignment="Left"
                                VerticalAlignment="Top"
                                Margin="16"
                                Padding="10,7"
                                CornerRadius="{StaticResource Radius.Sm.CR}"
                                Background="{DynamicResource ToastBrush}"
                                BorderBrush="{DynamicResource HairlineBrush}"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="Overlay A/B"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource AccentBrush}" />
                                <TextBlock Text="{Binding CompareStatusText}"
                                           Style="{StaticResource Text.Caption}"
                                           TextTrimming="CharacterEllipsis"
                                           MaxWidth="520" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>

                <!-- OCR text extraction overlay — selectable recognized text regions.
                      Target binding keeps OCR pixel coordinates aligned with image zoom/pan transforms. -->
                <ctl:OcrOverlay Visibility="{Binding IsOcrMode, Converter={StaticResource BoolToVis}}"
                                Target="{Binding ElementName=Canvas}"
                                IsHitTestVisible="{Binding IsOcrMode}"
                                Opacity="0.95"
                                AutomationProperties.Name="{loc:Loc AutomationMainWindowOCRTextOverlay}" />

                <ctl:SelectionOverlay Visibility="{Binding ShowSelectionOverlay, Converter={StaticResource BoolToVis}}"
                                      Target="{Binding ElementName=Canvas}"
                                      Selection="{Binding CanvasSelection}"
                                      CopyCommand="{Binding CopySelectionCommand}"
                                      ClearCommand="{Binding ClearSelectionCommand}"
                                      Opacity="0.98"
                                      AutomationProperties.Name="{loc:Loc AutomationMainWindowPixelSelectionOverlay}" />

                <ctl:CropOverlay Visibility="{Binding ShowCropOverlay, Converter={StaticResource BoolToVis}}"
                                 Target="{Binding ElementName=Canvas}"
                                 Selection="{Binding CropSelection}"
                                 ApplyCommand="{Binding ApplyCropCommand}"
                                 Opacity="0.98"
                                 AutomationProperties.Name="{loc:Loc AutomationMainWindowCropSelectionOverlay}" />

                <ctl:LocalExposureBrushOverlay Visibility="{Binding ShowExposureBrushOverlay, Converter={StaticResource BoolToVis}}"
                                               Target="{Binding ElementName=Canvas}"
                                               Strokes="{Binding ExposureBrushStrokes}"
                                               Opacity="0.92"
                                               AutomationProperties.Name="{loc:Loc AutomationMainWindowLocalExposureBrushOverlay}" />

                <ctl:RedEyeCorrectionOverlay Visibility="{Binding ShowRedEyeCorrectionOverlay, Converter={StaticResource BoolToVis}}"
                                             Target="{Binding ElementName=Canvas}"
                                             Marks="{Binding RedEyeCorrectionMarks}"
                                             Opacity="0.94"
                                             AutomationProperties.Name="{loc:Loc AutomationMainWindowRedEyeCorrectionOverlay}" />

                <ctl:RetouchBrushOverlay Visibility="{Binding ShowRetouchOverlay, Converter={StaticResource BoolToVis}}"
                                         Target="{Binding ElementName=Canvas}"
                                         Strokes="{Binding RetouchStrokes}"
                                         Opacity="0.92"
                                         AutomationProperties.Name="{loc:Loc AutomationMainWindowRetouchBrushOverlay}" />

                <Border HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        MaxWidth="760"
                        Margin="24,18,24,0"
                        Padding="13,9"
                        CornerRadius="{StaticResource Radius.Md.CR}"
                        Background="{DynamicResource ToastBrush}"
                        BorderBrush="{DynamicResource AccentBrush}"
                        BorderThickness="1"
                        Effect="{StaticResource Elevation.Low}"
                        IsHitTestVisible="False"
                        Visibility="{Binding ShowOverlayBanner, Converter={StaticResource BoolToVis}}"
                        AutomationProperties.Name="{loc:Loc AutomationMainWindowPinnedOverlayStatus}"
                        AutomationProperties.HelpText="{Binding OverlayStatusText}">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="28"
                                Height="28"
                                CornerRadius="{StaticResource Radius.Sm.CR}"
                                Background="{DynamicResource AccentPanelBrush}"
                                BorderBrush="{DynamicResource HairlineBrush}"
                                BorderThickness="1"
                                Margin="0,0,11,0">
                            <TextBlock Text="&#xE7B3;"
                                       FontFamily="{StaticResource IconFontFamily}"
                                       FontSize="13"
                                       Foreground="{DynamicResource AccentBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding OverlayModeText}"
                                       FontSize="12.5"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource FloatingChromeTextBrush}" />
                            <TextBlock Text="{Binding OverlayStatusText}"
                                       Style="{StaticResource Text.Caption}"
                                       TextWrapping="Wrap"
                                       MaxWidth="660"
                                       Margin="0,2,0,0" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Empty state — first-run guidance and recovery links -->
                <Border Style="{StaticResource ElevatedCard}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        MaxWidth="480"
                        Padding="24,22"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        Effect="{x:Null}"
                        Visibility="{Binding IsViewerEmpty, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <Image Source="Resources/logo.png"
                               Width="54"
                               Height="54"
                               HorizontalAlignment="Center"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               Opacity="0.94" />
                        <TextBlock Style="{StaticResource Text.Title}"
                                   Text="Open an image to begin"
                                   HorizontalAlignment="Center"
                                   Margin="0,16,0,0" />
                        <TextBlock Style="{StaticResource Text.Body}"
                                   Text="Drop an image here, choose one from disk, or paste from the clipboard."
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   Margin="0,8,0,0"
                                   MaxWidth="400" />

                        <Grid x:Name="EmptyCapabilityGrid"
                              Margin="0,20,0,0"
                              MaxWidth="456"
                              Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Grid.Column="0" Margin="0,0,20,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="&#xE72E;"
                                           FontFamily="{StaticResource IconFontFamily}"
                                           FontSize="13"
                                           Foreground="{DynamicResource AccentBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Top"
                                           Margin="0,2,0,0" />
                                <StackPanel Grid.Column="1">
                                    <TextBlock Style="{StaticResource Text.Body}" Text="Local by default" />
                                    <TextBlock Style="{StaticResource Text.Caption}"
                                               Text="{Binding FirstRunPrivacyText}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Grid>

                            <Grid Grid.Row="0" Grid.Column="1" Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="&#xE8E5;"
                                           FontFamily="{StaticResource IconFontFamily}"
                                           FontSize="13"
                                           Foreground="{DynamicResource AccentBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Top"
                                           Margin="0,2,0,0" />
                                <StackPanel Grid.Column="1">
                                    <TextBlock Style="{StaticResource Text.Body}" Text="Broad format support" />
                                    <TextBlock Style="{StaticResource Text.Caption}"
                                               Text="{Binding FirstRunFormatStatusText}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Grid>

                            <Grid Grid.Row="1" Grid.Column="0" Margin="0,0,20,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="&#xE8C8;"
                                           FontFamily="{StaticResource IconFontFamily}"
                                           FontSize="13"
                                           Foreground="{DynamicResource AccentBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Top"
                                           Margin="0,2,0,0" />
                                <StackPanel Grid.Column="1">
                                    <TextBlock Style="{StaticResource Text.Body}" Text="Text extraction readiness" />
                                    <TextBlock Style="{StaticResource Text.Caption}"
                                               Text="{Binding FirstRunOcrStatusText}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Grid>

                            <Grid Grid.Row="1" Grid.Column="1" Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="&#xE8A5;"
                                           FontFamily="{StaticResource IconFontFamily}"
                                           FontSize="13"
                                           Foreground="{DynamicResource AccentBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Top"
                                           Margin="0,2,0,0" />
                                <StackPanel Grid.Column="1">
                                    <TextBlock Style="{StaticResource Text.Body}" Text="Document previews" />
                                    <TextBlock Style="{StaticResource Text.Caption}"
                                               Text="{Binding FirstRunDocumentStatusText}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Grid>

                            <Grid Grid.Row="2" Grid.ColumnSpan="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="&#xE946;"
                                           FontFamily="{StaticResource IconFontFamily}"
                                           FontSize="13"
                                           Foreground="{DynamicResource AccentBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Top"
                                           Margin="0,2,0,0" />
                                <StackPanel Grid.Column="1">
                                    <TextBlock Style="{StaticResource Text.Body}" Text="Recovery links" />
                                    <TextBlock Style="{StaticResource Text.Caption}"
                                               Text="{Binding FirstRunRecoveryText}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Grid>
                        </Grid>

                        <WrapPanel HorizontalAlignment="Center" Margin="0,22,0,0">
                            <Button Command="{Binding OpenCommand}"
                                    Style="{StaticResource PrimaryButton}"
                                    Margin="0,0,10,8"
                                    ToolTip="{Binding ShortcutTexts[open], StringFormat=Open image ({0})}"
                                    AutomationProperties.Name="{loc:Loc AutomationMainWindowOpenImage}"
                                    AutomationProperties.HelpText="{Binding ShortcutTexts[open], StringFormat=Choose an image file from disk. Shortcut: {0}.}">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE8E5;"
                                               FontFamily="{StaticResource IconFontFamily}"
                                               FontSize="13"
                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                               Margin="0,0,9,0"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="Open image…"
                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding PasteFromClipboardCommand}"
                                    Style="{StaticResource ChromeButton}"
                                    Margin="0,0,10,8"
                                    ToolTip="{Binding ShortcutTexts[paste], StringFormat=Paste image or supported file from clipboard ({0})}"
                                    AutomationProperties.Name="{loc:Loc AutomationMainWindowPasteFromClipboard}"
                                    AutomationProperties.HelpText="{Binding ShortcutTexts[paste], StringFormat=Open a supported image file from the clipboard or save and open clipboard bitmap data. Shortcut: {0}.}">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE77F;"
                                               FontFamily="{StaticResource IconFontFamily}"
                                               FontSize="12"
                                               Margin="0,0,8,0"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="Paste" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding SettingsCommand}"
                                    Style="{StaticResource ChromeButton}"
                                    Visibility="Collapsed"
                                    Margin="0,0,10,8"
                                    ToolTip="{Binding ShortcutTexts[settings], StringFormat=Open Settings ({0})}"
                                    AutomationProperties.Name="{loc:Loc AutomationMainWindowOpenSettings}">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE713;"
                                               FontFamily="{StaticResource IconFontFamily}"
                                               FontSize="12"
                                               Margin="0,0,8,0"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="Settings" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding AboutCommand}"
                                    Style="{StaticResource ChromeButton}"
                                    Visibility="Collapsed"
                                    Margin="0,0,0,8"
                                    ToolTip="Open diagnostics and app information"
                                    AutomationProperties.Name="{loc:Loc AutomationMainWindowOpenDiagnostics}">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE946;"
                                               FontFamily="{StaticResource IconFontFamily}"
                                               FontSize="12"
                                               Margin="0,0,8,0"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="Diagnostics" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </WrapPanel>

                        <WrapPanel HorizontalAlignment="Center" Margin="0,4,0,0" Visibility="Collapsed">
                            <Button Command="{Binding OpenImportInboxCommand}"
                                    Style="{StaticResource ChromeButton}"
                                    Margin="0,0,10,8"
                                    AutomationProperties.Name="{loc:Loc AutomationMainWindowOpenImportInbox}">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE8B5;"
                                               FontFamily="{StaticResource IconFontFamily}"
                                               FontSize="12"
                                               Margin="0,0,8,0"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="Import inbox" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </WrapPanel>

                        <StackPanel Margin="0,14,0,0"
                                    Visibility="{Binding RecentFolders.Count, Converter={StaticResource BoolToVis}}">
                            <TextBlock Style="{StaticResource Text.Hint}"
                                       Text="Recent folders"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,6" />
                            <ItemsControl ItemsSource="{Binding RecentFolders}" MaxHeight="120">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Style="{StaticResource ChromeButton}"
                                                Command="{Binding DataContext.OpenRecentFolderCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"
                                                Padding="8,4"
                                                Margin="0,0,0,2"
                                                HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Left"
                                                AutomationProperties.Name="{Binding}">
                                            <TextBlock Text="{Binding Converter={StaticResource PathToFileNameConverter}}"
                                                       Style="{StaticResource Text.Caption}"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding}" />
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <StackPanel Margin="0,10,0,0"
                                    Visibility="Collapsed"
                                    >
                            <TextBlock Style="{StaticResource Text.Hint}"
                                       Text="Recent books"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,6" />
                            <ItemsControl ItemsSource="{Binding RecentArchiveBooks}" MaxHeight="90">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Style="{StaticResource ChromeButton}"
                                                Command="{Binding DataContext.OpenRecentArchiveCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"
                                                Padding="8,4"
                                                Margin="0,0,0,2"
                                                HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Left"
                                                AutomationProperties.Name="{Binding Path, Converter={StaticResource PathToFileNameConverter}}">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Path, Converter={StaticResource PathToFileNameConverter}}"
                                                           Style="{StaticResource Text.Caption}"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding ProgressText}"
                                                           Style="{StaticResource Text.Caption}"
                                                           Foreground="{DynamicResource SubtextBrush}"
                                                           Margin="8,0,0,0" />
                                            </StackPanel>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <TextBlock Style="{StaticResource Text.Hint}"
                                   Text="Tip: arrow keys browse the folder, Enter commits a rename."
                                   Visibility="Collapsed"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   Margin="0,12,0,0" />
                    </StackPanel>
                </Border>

                <!-- Decode error state — semantic-red tinted card -->
                <Border Style="{StaticResource ElevatedCard}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        MaxWidth="500"
                        Background="{DynamicResource DangerPanelBrush}"
                        BorderBrush="{DynamicResource RedBrush}"
                        Visibility="{Binding HasLoadError, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="&#xE783;"
                                   FontFamily="{StaticResource IconFontFamily}"
                                   FontSize="38"
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource RedBrush}" />
                        <TextBlock Style="{StaticResource Text.Title}"
                                   Text="{Binding LoadErrorTitle}"
                                   HorizontalAlignment="Center"
                                   Margin="0,14,0,0" />
                        <TextBlock Style="{StaticResource Text.Subtitle}"
                                   Text="{Binding LoadErrorMessage}"
                                   TextAlignment="Center"
                                   Margin="0,10,0,0" />
                        <TextBlock Style="{StaticResource Text.Hint}"
                                   Text="{Binding LoadErrorHelpText}"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   Margin="0,10,0,0" />
                        <WrapPanel HorizontalAlignment="Center" Margin="0,22,0,0">
                            <Button Command="{Binding OpenCommand}"
                                    Style="{StaticResource PrimaryButton}"
                                    Margin="0,0,12,8"
                                    AutomationProperties.Name="{loc:Loc AutomationMainWindowTryAnotherImage}">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE8E5;"
                                               FontFamily="{StaticResource IconFontFamily}"
                                               FontSize="12"
                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                               Margin="0,0,8,0"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="Try another image"
                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding AboutCommand}"
                                    Style="{StaticResource ChromeButton}"
                                    Margin="0,0,12,8"
                                    Visibility="{Binding LoadErrorShowsCodecDetails, Converter={StaticResource BoolToVis}}"
                                    AutomationProperties.Name="{loc:Loc AutomationMainWindowOpenCodecDetails}">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE946;"
                                               FontFamily="{StaticResource IconFontFamily}"
                                               FontSize="12"
                                               Margin="0,0,8,0"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="Codec details" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding InstallStoreExtensionCommand}"
                                    Style="{StaticResource PrimaryButton}"
                                    Margin="0,0,12,8"
                                    Visibility="{Binding HasLoadErrorStoreAction, Converter={StaticResource BoolToVis}}"
                                    AutomationProperties.Name="{loc:Loc AutomationMainWindowOpenMicrosoftStoreToInstallCodecExtension}">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE719;"
                                               FontFamily="{StaticResource IconFontFamily}"
                                               FontSize="12"
                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                               Margin="0,0,8,0"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding LoadErrorStoreActionLabel}"
                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding RevealCommand}"
                                    Style="{StaticResource ChromeButton}"
                                    Margin="0,0,0,8"
                                    AutomationProperties.Name="{loc:Loc AutomationMainWindowRevealCurrentFileInExplorer}">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE838;"
                                               FontFamily="{StaticResource IconFontFamily}"
                                               FontSize="12"
                                               Margin="0,0,8,0"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="Reveal file" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <!-- Drag-and-drop confidence layer -->
                <Border Margin="32"
                        Background="{DynamicResource DropOverlayBrush}"
                        BorderThickness="2"
                        CornerRadius="{StaticResource Radius.Xl.CR}"
                        Visibility="{Binding IsDropTargetActive, Converter={StaticResource BoolToVis}}">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="BorderBrush" Value="{DynamicResource RedBrush}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsDropAccepted}" Value="True">
                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Border Style="{StaticResource ElevatedCard}"
                            Background="{DynamicResource DropOverlayPanelBrush}"
                            MaxWidth="420"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                        <StackPanel>
                            <TextBlock Text="{Binding IsDropAccepted, Converter={StaticResource DropAcceptedIcon}}"
                                       FontFamily="{StaticResource IconFontFamily}"
                                       FontSize="38"
                                       HorizontalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource RedBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsDropAccepted}" Value="True">
                                                <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Style="{StaticResource Text.Title}"
                                       Text="{Binding DropOverlayTitle}"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       Margin="0,14,0,0" />
                            <TextBlock Style="{StaticResource Text.Subtitle}"
                                       Text="{Binding DropOverlayMessage}"
                                       TextAlignment="Center"
                                       Margin="0,8,0,0" />
                        </StackPanel>
                    </Border>
                </Border>

                <Border x:Name="GalleryWorkbench"
                        Background="{DynamicResource ViewerSurfaceBrush}"
                        Padding="24,20"
                        Visibility="{Binding ShowGallery, Converter={StaticResource BoolToVis}}"
                        Panel.ZIndex="18"
                        AutomationProperties.Name="{loc:Loc AutomationMainWindowGalleryWorkbench}"
                        AutomationProperties.LiveSetting="Polite">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border Width="34"
                                    Height="34"
                                    CornerRadius="{StaticResource Radius.Lg.CR}"
                                    Background="{DynamicResource AccentWarmPanelBrush}"
                                    BorderBrush="{DynamicResource HairlineBrush}"
                                    BorderThickness="1"
                                    VerticalAlignment="Center">
                                <TextBlock Text="&#xE8A9;"
                                           FontFamily="{StaticResource IconFontFamily}"
                                           FontSize="15"
                                           Foreground="{DynamicResource AccentWarmBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1"
                                        Margin="12,0,16,0"
                                        VerticalAlignment="Center">
                                <TextBlock Text="Gallery"
                                           Style="{StaticResource Text.Title}"
                                           FontSize="18" />
                                <TextBlock Text="{Binding GalleryStatusText}"
                                           Style="{StaticResource Text.Hint}"
                                           Margin="0,3,0,0" />
                                <Border Margin="0,6,0,0"
                                        Padding="8,2"
                                        HorizontalAlignment="Left"
                                        CornerRadius="{StaticResource Radius.Sm.CR}"
                                        Background="{DynamicResource PanelBrush}"
                                        BorderBrush="{DynamicResource HairlineBrush}"
                                        BorderThickness="1"
                                        Visibility="{Binding IsGallerySmartFilterIndexing, Converter={StaticResource BoolToVis}}"
                                        AutomationProperties.Name="{loc:Loc AutomationMainWindowIndexingGalleryFilters}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE895;"
                                                   FontFamily="{StaticResource IconFontFamily}"
                                                   FontSize="10"
                                                   Margin="0,0,6,0"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Text="Indexing filters..."
                                                   Style="{StaticResource Text.Hint}"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                            <Button Grid.Column="2"
                                    Style="{StaticResource ChromeButton}"
                                    Command="{Binding CloseGalleryCommand}"
                                    Width="34"
                                    Height="34"
                                    Padding="0"
                                    ToolTip="Close gallery"
                                    AutomationProperties.Name="{loc:Loc AutomationMainWindowCloseGallery}">
                                <TextBlock Text="&#xE8BB;"
                                           FontFamily="{StaticResource IconFontFamily}"
                                           FontSize="12"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Button>
                        </Grid>

                        <WrapPanel Grid.Row="1"
                                   Margin="0,0,0,12"
                                   KeyboardNavigation.TabNavigation="Continue"
                                   AutomationProperties.Name="{loc:Loc AutomationMainWindowGallerySortControls}">
                            <Border Width="280"
                                    Height="32"
                                    Margin="0,0,8,8"
                                    Padding="10,0"
                                    CornerRadius="{StaticResource Radius.Sm.CR}"
                                    Background="{DynamicResource PanelBrush}"
                                    BorderBrush="{DynamicResource HairlineBrush}"
                                    BorderThickness="1"
                                    ToolTip="{Binding GalleryFilterTooltip}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="&#xE721;"
                                               FontFamily="{StaticResource IconFontFamily}"
                                               FontSize="11"
                                               Foreground="{DynamicResource OverlayBrush}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,0" />
                                    <TextBox Grid.Column="1"
                                             Text="{Binding GalleryFilterText, UpdateSourceTrigger=PropertyChanged}"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             Padding="0"
                                             MinHeight="24"
                                             VerticalContentAlignment="Center"
                                             AutomationProperties.Name="{loc:Loc AutomationMainWindowFilterGallery}" />
                                    <Button Grid.Column="2"
                                            Command="{Binding ClearGalleryFilterCommand}"
                                            Width="24"
                                            Height="24"
                                            Padding="0"
                                            Margin="6,0,0,0"
                                            Visibility="{Binding HasGalleryFilter, Converter={StaticResource BoolToVis}}"
                                            ToolTip="Clear filter"
                                            AutomationProperties.Name="{loc:Loc AutomationMainWindowClearGalleryFilter}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource ChromeButton}">
                                                <Setter Property="BorderThickness" Value="0" />
                                                <Setter Property="Background" Value="Transparent" />
                                            </Style>
                                        </Button.Style>
                                        <TextBlock Text="&#xE711;"
                                                   FontFamily="{StaticResource IconFontFamily}"
                                                   FontSize="10"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </Button>
                                </Grid>
                            </Border>
                            <Button Command="{Binding SetFolderSortCommand}"
                                    CommandParameter="NaturalName"
                                    Padding="12,6"
                                    MinHeight="30"
                                    Margin="0,0,8,8"
                                    AutomationProperties.Name="{loc:Loc AutomationMainWindowSortGalleryByName}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource ChromeButton}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CurrentSortMode, Converter={StaticResource SortModeMatches}, ConverterParameter=NaturalName}" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource AccentWarmPanelBrush}" />
                                                <Setter Property="BorderBrush" Value="{DynamicResource AccentWarmBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE8CB;"
                                               FontFamily="{StaticResource IconFontFamily}"
                                               FontSize="11"
                                               Margin="0,0,7,0"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="Name" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding SetFolderSortCommand}"
                                    CommandParameter="ExplorerLike"
                                    Visibility="Collapsed"
                                    Padding="12,6"
                                    MinHeight="30"
                                    Margin="0,0,8,8"
                                    AutomationProperties.Name="{loc:Loc AutomationMainWindowSortGalleryByExplorerLikeName}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource ChromeButton}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CurrentSortMode, Converter={StaticResource SortModeMatches}, ConverterParameter=ExplorerLike}" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource AccentPanelBrush}" />
                                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE8B7;"
                                               FontFamily="{StaticResource IconFontFamily}"
                                               FontSize="11"
                                               Margin="0,0,7,0"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="Explorer" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding SetFolderSortCommand}"
                                    CommandParameter="ModifiedNewest"
                                    Padding="12,6"
                                    MinHeight="30"
                                    Margin="0,0,8,8"
                                    AutomationProperties.Name="{loc:Loc AutomationMainWindowSortGalleryByNewestModifiedDate}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource ChromeButton}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CurrentSortMode, Converter={StaticResource SortModeMatches}, ConverterParameter=ModifiedNewest}" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource AccentWarmPanelBrush}" />
                                                <Setter Property="BorderBrush" Value="{DynamicResource AccentWarmBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE823;"
                                               FontFamily="{StaticResource IconFontFamily}"
                                               FontSize="11"
                                               Margin="0,0,7,0"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="Newest" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding SetFolderSortCommand}"
                                    CommandParameter="ExtensionThenName"
                                    Padding="12,6"
                                    MinHeight="30"
                                    Margin="0,0,8,8"
                                    AutomationProperties.Name="{loc:Loc AutomationMainWindowSortGalleryByType}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource ChromeButton}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CurrentSortMode, Converter={StaticResource SortModeMatches}, ConverterParameter=ExtensionThenName}" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource AccentWarmPanelBrush}" />
                                                <Setter Property="BorderBrush" Value="{DynamicResource AccentWarmBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE8B7;"
                                               FontFamily="{StaticResource IconFontFamily}"
                                               FontSize="11"
                                               Margin="0,0,7,0"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="Type" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding SetFolderSortCommand}"
                                    CommandParameter="SizeLargest"
                                    Visibility="Collapsed"
                                    Padding="12,6"
                                    MinHeight="30"
                                    Margin="0,0,8,8"
                                    AutomationProperties.Name="{loc:Loc AutomationMainWindowSortGalleryByLargestFileSize}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource ChromeButton}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CurrentSortMode, Converter={StaticResource SortModeMatches}, ConverterParameter=SizeLargest}" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource AccentPanelBrush}" />
                                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE8EF;"
                                               FontFamily="{StaticResource IconFontFamily}"
                                               FontSize="11"
                                               Margin="0,0,7,0"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="Size" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding ApplyGallerySmartFilterCommand}"
                                    CommandParameter="orientation:landscape"
                                    Visibility="Collapsed"
                                    Style="{StaticResource ChromeButton}"
                                    Padding="12,6"
                                    MinHeight="30"
                                    Margin="0,0,8,8"
                                    ToolTip="{Binding GalleryFilterTooltip}"
                                    AutomationProperties.Name="{loc:Loc AutomationMainWindowFilterGalleryToLandscapeImages}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE809;"
                                               FontFamily="{StaticResource IconFontFamily}"
                                               FontSize="11"
                                               Margin="0,0,7,0"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="Landscape" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding ApplyGallerySmartFilterCommand}"
                                    CommandParameter="orientation:portrait"
                                    Visibility="Collapsed"
                                    Style="{StaticResource ChromeButton}"
                                    Padding="12,6"
                                    MinHeight="30"
                                    Margin="0,0,8,8"
                                    ToolTip="{Binding GalleryFilterTooltip}"
                                    AutomationProperties.Name="{loc:Loc AutomationMainWindowFilterGalleryToPortraitImages}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE91B;"
                                               FontFamily="{StaticResource IconFontFamily}"
                                               FontSize="11"
                                               Margin="0,0,7,0"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="Portrait" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding ApplyGallerySmartFilterCommand}"
                                    CommandParameter="date:week"
                                    Visibility="Collapsed"
                                    Style="{StaticResource ChromeButton}"
                                    Padding="12,6"
                                    MinHeight="30"
                                    Margin="0,0,8,8"
                                    ToolTip="{Binding GalleryFilterTooltip}"
                                    AutomationProperties.Name="{loc:Loc AutomationMainWindowFilterGalleryToRecentlyModifiedImages}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE823;"
                                               FontFamily="{StaticResource IconFontFamily}"
                                               FontSize="11"
                                               Margin="0,0,7,0"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="Recent" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding ApplyGallerySmartFilterCommand}"
                                    CommandParameter="size:large"
                                    Visibility="Collapsed"
                                    Style="{StaticResource ChromeButton}"
                                    Padding="12,6"
                                    MinHeight="30"
                                    Margin="0,0,8,8"
                                    ToolTip="{Binding GalleryFilterTooltip}"
                                    AutomationProperties.Name="{loc:Loc AutomationMainWindowFilterGalleryToLargeImages}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE740;"
                                               FontFamily="{StaticResource IconFontFamily}"
                                               FontSize="11"
                                               Margin="0,0,7,0"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="Large" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding ApplyGallerySmartFilterCommand}"
                                    CommandParameter="duplicate:yes"
                                    Visibility="Collapsed"
                                    Style="{StaticResource ChromeButton}"
                                    Padding="12,6"
                                    MinHeight="30"
                                    Margin="0,0,8,8"
                                    ToolTip="{Binding GalleryFilterTooltip}"
                                    AutomationProperties.Name="{loc:Loc AutomationMainWindowFilterGalleryToExactDuplicates}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE8C8;"
                                               FontFamily="{StaticResource IconFontFamily}"
                                               FontSize="11"
                                               Margin="0,0,7,0"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="Duplicates" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <TextBlock Text="{Binding GalleryFilterSummaryText}"
                                       Visibility="{Binding GalleryFilterSummaryText, Converter={StaticResource BoolToVis}}"
                                       Style="{StaticResource Text.Hint}"
                                       VerticalAlignment="Center"
                                       Margin="2,0,8,8" />
                        </WrapPanel>

                        <Grid Grid.Row="2" Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="&#xE71E;"
                                           FontFamily="{StaticResource IconFontFamily}"
                                           FontSize="12"
                                           Foreground="{DynamicResource OverlayBrush}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,6,0" />
                                <Slider Minimum="80" Maximum="320"
                                        Value="{Binding GalleryTileSize, Mode=TwoWay}"
                                        Width="140"
                                        VerticalAlignment="Center"
                                        TickFrequency="40"
                                        IsSnapToTickEnabled="False"
                                        SmallChange="10"
                                        LargeChange="40"
                                        AutomationProperties.Name="{loc:Loc AutomationMainWindowThumbnailSize}"
                                        ToolTip="Thumbnail size" />
                                <TextBlock Text="&#xE8A3;"
                                           FontFamily="{StaticResource IconFontFamily}"
                                           FontSize="16"
                                           Foreground="{DynamicResource OverlayBrush}"
                                           VerticalAlignment="Center"
                                           Margin="6,0,0,0" />
                            </StackPanel>
                        </Grid>

                        <ListBox x:Name="GalleryItems"
                                 Grid.Row="3"
                                 ItemsSource="{Binding GalleryItems}"
                                 SelectedItem="{Binding SelectedGalleryItem, Mode=TwoWay}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Padding="0,0,0,10"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ScrollViewer.CanContentScroll="False"
                                 VirtualizingPanel.IsVirtualizing="False"
                                 KeyboardNavigation.DirectionalNavigation="Contained"
                                 MouseDoubleClick="GalleryItems_MouseDoubleClick"
                                 KeyboardNavigation.TabNavigation="Cycle"
                                 AutomationProperties.Name="{loc:Loc AutomationMainWindowGalleryThumbnails}"
                                 AutomationProperties.HelpText="{Binding GalleryStatusText}">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="0" />
                                    <Setter Property="Focusable" Value="False" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <ContentPresenter />
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Button Command="{Binding DataContext.OpenPreviewItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            Loaded="PreviewThumbnail_Loaded"
                                            Width="{Binding DataContext.GalleryTileSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                            Margin="0,0,10,10"
                                            Padding="7"
                                            HorizontalContentAlignment="Stretch"
                                            VerticalContentAlignment="Stretch"
                                            ToolTip="{Binding Path}"
                                            Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}"
                                            AutomationProperties.Name="{Binding FileName}"
                                            AutomationProperties.HelpText="{Binding PositionText}"
                                            AutomationProperties.ItemStatus="{Binding PositionText}">
                                        <Button.ContextMenu>
                                            <ContextMenu Style="{StaticResource ViewportContextMenu}">
                                                <MenuItem Header="Open"
                                                          Command="{Binding PlacementTarget.Tag.OpenPreviewItemCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                                    <MenuItem.Icon>
                                                        <TextBlock Style="{StaticResource MenuItemIcon}" Text="&#xE8E5;" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="Reveal in Explorer"
                                                          Command="{Binding PlacementTarget.Tag.RevealPreviewItemCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                                    <MenuItem.Icon>
                                                        <TextBlock Style="{StaticResource MenuItemIcon}" Text="&#xE838;" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="Copy path"
                                                          Command="{Binding PlacementTarget.Tag.CopyPreviewPathCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                                    <MenuItem.Icon>
                                                        <TextBlock Style="{StaticResource MenuItemIcon}" Text="&#xE8C8;" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                            </ContextMenu>
                                        </Button.ContextMenu>
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource ChromeButton}">
                                                <Setter Property="Background" Value="{DynamicResource Surface0Brush}" />
                                                <Setter Property="BorderBrush" Value="{DynamicResource HairlineBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource AccentWarmPanelBrush}" />
                                                        <Setter Property="BorderBrush" Value="{DynamicResource AccentWarmBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource AccentWarmPanelBrush}" />
                                                        <Setter Property="BorderBrush" Value="{DynamicResource AccentWarmBrush}" />
                                                    </DataTrigger>
                                                    <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource AccentWarmPanelBrush}" />
                                                        <Setter Property="BorderBrush" Value="{DynamicResource FocusRingBrush}" />
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <StackPanel>
                                            <Border Height="{Binding DataContext.GalleryTileImageHeight, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CornerRadius="{StaticResource Radius.Sm.CR}"
                                                    Background="{DynamicResource ViewportBrush}"
                                                    BorderBrush="{DynamicResource HairlineBrush}"
                                                    BorderThickness="1"
                                                    ClipToBounds="True">
                                                <Grid>
                                                    <Image Source="{Binding Thumbnail}"
                                                           Stretch="UniformToFill"
                                                           RenderOptions.BitmapScalingMode="HighQuality"
                                                           Visibility="{Binding HasThumbnail, Converter={StaticResource BoolToVis}}" />
                                                    <TextBlock Text="&#xEB9F;"
                                                               FontFamily="{StaticResource IconFontFamily}"
                                                               FontSize="23"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               Visibility="{Binding HasThumbnail, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}">
                                                        <TextBlock.Style>
                                                            <Style TargetType="{x:Type TextBlock}">
                                                                <Setter Property="Foreground" Value="{DynamicResource OverlayBrush}" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding ThumbnailFailed}" Value="True">
                                                                        <Setter Property="Text" Value="&#xE783;" />
                                                                        <Setter Property="Foreground" Value="{DynamicResource YellowBrush}" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Grid>
                                            </Border>
                                            <TextBlock Text="{Binding FileName}"
                                                       Foreground="{DynamicResource TextBrush}"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="1,8,1,0" />
                                            <TextBlock Text="{Binding PositionText}"
                                                       Foreground="{DynamicResource OverlayBrush}"
                                                       FontSize="10.5"
                                                       Margin="1,2,1,0" />
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <Border Grid.Row="3"
                                Background="{DynamicResource BaseBrush}"
                                Visibility="{Binding ShowGalleryFilterEmpty, Converter={StaticResource BoolToVis}}"
                                AutomationProperties.Name="{loc:Loc AutomationMainWindowNoGalleryFilterMatches}">
                            <StackPanel HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        MaxWidth="340">
                                <TextBlock Text="&#xE721;"
                                           FontFamily="{StaticResource IconFontFamily}"
                                           FontSize="28"
                                           Foreground="{DynamicResource OverlayBrush}"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="No matching images"
                                           Style="{StaticResource Text.Title}"
                                           FontSize="16"
                                           TextAlignment="Center"
                                           Margin="0,12,0,0" />
                                <TextBlock Text="{Binding GalleryStatusText}"
                                           Style="{StaticResource Text.Hint}"
                                           TextAlignment="Center"
                                           Margin="0,5,0,0" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- Floating chrome (only when an image is present) -->
                <Grid Visibility="{Binding HasImage, Converter={StaticResource BoolToVis}}">

                    <!-- Archive book page-turn zones. Narrow edge targets keep drag-pan available
                         across the center of the canvas while giving books a natural tap/click turn. -->
                    <Button Command="{Binding LeftBookPageTurnCommand}"
                            Style="{StaticResource BookPageTurnButton}"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Stretch"
                            Width="112"
                            Visibility="{Binding IsArchiveBook, Converter={StaticResource BoolToVis}}"
                            ToolTip="{Binding LeftBookPageTurnTooltip}"
                            AutomationProperties.Name="{Binding LeftBookPageTurnTooltip}">
                        <Border Width="38"
                                Height="82"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Margin="18,0,0,0"
                                CornerRadius="{StaticResource Radius.Lg.CR}"
                                Background="{DynamicResource FloatingChromeBrush}"
                                BorderBrush="{DynamicResource FloatingChromeBorderBrush}"
                                BorderThickness="1"
                                Opacity="0.72">
                            <TextBlock Text="&#xE76B;"
                                       FontFamily="{StaticResource IconFontFamily}"
                                       FontSize="18"
                                       Foreground="{DynamicResource FloatingChromeTextBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                    </Button>

                    <Button Command="{Binding RightBookPageTurnCommand}"
                            Style="{StaticResource BookPageTurnButton}"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Stretch"
                            Width="112"
                            Visibility="{Binding IsArchiveBook, Converter={StaticResource BoolToVis}}"
                            ToolTip="{Binding RightBookPageTurnTooltip}"
                            AutomationProperties.Name="{Binding RightBookPageTurnTooltip}">
                        <Border Width="38"
                                Height="82"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Margin="0,0,18,0"
                                CornerRadius="{StaticResource Radius.Lg.CR}"
                                Background="{DynamicResource FloatingChromeBrush}"
                                BorderBrush="{DynamicResource FloatingChromeBorderBrush}"
                                BorderThickness="1"
                                Opacity="0.72">
                            <TextBlock Text="&#xE76C;"
                                       FontFamily="{StaticResource IconFontFamily}"
                                       FontSize="18"
                                       Foreground="{DynamicResource FloatingChromeTextBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                    </Button>

                    <!-- Hover-reveal nav arrows -->
                    <Button x:Name="PrevArrow"
                            Style="{StaticResource NavArrowButton}"
                            Command="{Binding PrevCommand}"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Margin="22,0,0,0"
                            Content="&#xE76B;"
                            Opacity="0"
                            AutomationProperties.Name="{loc:Loc AutomationMainWindowPreviousImage}"
                            AutomationProperties.HelpText="Left arrow or Backspace" />
                    <Button x:Name="NextArrow"
                            Style="{StaticResource NavArrowButton}"
                            Command="{Binding NextCommand}"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Margin="0,0,22,0"
                            Content="&#xE76C;"
                            Opacity="0"
                            AutomationProperties.Name="{loc:Loc AutomationMainWindowNextImage}"
                            AutomationProperties.HelpText="Right arrow or Space" />

                    <!-- Position chip — elevated floating chrome -->
                    <Border Style="{StaticResource FloatingChrome}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Top"
                            Margin="0,18,0,0"
                            AutomationProperties.LiveSetting="Polite"
                            AutomationProperties.Name="{loc:Loc AutomationMainWindowFolderPosition}">
                        <TextBlock Text="{Binding PositionText}"
                                   Foreground="{DynamicResource FloatingChromeTextBrush}"
                                   FontSize="12"
                                   FontWeight="SemiBold" />
                    </Border>

                    <Border Style="{StaticResource FloatingChrome}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Top"
                            Margin="0,60,0,0"
                            Visibility="{Binding HasMultiplePages, Converter={StaticResource BoolToVis}}"
                            AutomationProperties.LiveSetting="Polite"
                            AutomationProperties.Name="{loc:Loc AutomationMainWindowPagePosition}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Style="{StaticResource ToolbarButton}"
                                    Width="30"
                                    Height="26"
                                    FontSize="11"
                                    Content="&#xE76B;"
                                    Command="{Binding PrevPageCommand}"
                                    ToolTip="Previous page"
                                    AutomationProperties.Name="{loc:Loc AutomationMainWindowPreviousPage}" />
                            <Slider Width="152"
                                    Minimum="1"
                                    Maximum="{Binding PageCount}"
                                    Value="{Binding PageNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Delay=120}"
                                    TickFrequency="1"
                                    SmallChange="1"
                                    LargeChange="5"
                                    IsSnapToTickEnabled="True"
                                    IsMoveToPointEnabled="True"
                                    VerticalAlignment="Center"
                                    Margin="8,0,0,0"
                                    ToolTip="{Binding PagePositionText}"
                                    AutomationProperties.Name="{loc:Loc AutomationMainWindowPageScrubber}"
                                    AutomationProperties.HelpText="Drag to jump to another page in the current document or archive." />
                            <TextBlock Text="{Binding PagePositionText}"
                                       Foreground="{DynamicResource FloatingChromeTextBrush}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Margin="8,0"
                                       VerticalAlignment="Center" />
                            <Button Style="{StaticResource ToolbarButton}"
                                    Width="30"
                                    Height="26"
                                    FontSize="11"
                                    Content="&#xE76C;"
                                    Command="{Binding NextPageCommand}"
                                    ToolTip="Next page"
                                    AutomationProperties.Name="{loc:Loc AutomationMainWindowNextPage}" />
                        </StackPanel>
                    </Border>

                    <!-- V20-22: optional EXIF HUD. Reads from the same local metadata rows as the side panel. -->
                    <Border Style="{StaticResource FloatingChrome}"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Margin="22,20,0,0"
                            MaxWidth="560"
                            Visibility="{Binding ShowMetadataHud, Converter={StaticResource BoolToVis}}"
                            AutomationProperties.Name="{loc:Loc AutomationMainWindowMetadataHUD}"
                            AutomationProperties.LiveSetting="Polite">
                        <StackPanel>
                            <DockPanel LastChildFill="False">
                                <StackPanel Orientation="Horizontal"
                                            DockPanel.Dock="Left"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="&#xE946;"
                                               FontFamily="{StaticResource IconFontFamily}"
                                               FontSize="12"
                                               Foreground="{DynamicResource AccentBrush}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,0" />
                                    <TextBlock Text="Photo metadata"
                                               Foreground="{DynamicResource FloatingChromeTextBrush}"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                                <Button Command="{Binding ToggleMetadataHudCommand}"
                                        Content="&#xE711;"
                                        ToolTip="Hide metadata HUD"
                                        DockPanel.Dock="Right"
                                        Margin="16,-3,-7,-3"
                                        AutomationProperties.Name="{loc:Loc AutomationMainWindowHideMetadataHUD}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource ToolbarButton}">
                                            <Setter Property="Width" Value="28" />
                                            <Setter Property="Height" Value="26" />
                                            <Setter Property="FontSize" Value="10" />
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </DockPanel>

                            <ItemsControl ItemsSource="{Binding PhotoMetadataRows}"
                                          Margin="0,10,-6,-6"
                                          Visibility="{Binding PhotoMetadataRows.Count, Converter={StaticResource BoolToVis}}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource Badge}"
                                                Margin="0,0,6,6"
                                                MaxWidth="250">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Label}"
                                                           FontSize="10"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource OverlayBrush}"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,6,0" />
                                                <TextBlock Text="{Binding Value}"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource FloatingChromeTextBrush}"
                                                           TextTrimming="CharacterEllipsis"
                                                           MaxWidth="170"
                                                           ToolTip="{Binding Value}"
                                                           VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <StackPanel Orientation="Horizontal"
                                        Margin="0,10,0,0"
                                        Visibility="{Binding MetadataStatusText, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="&#xE946;"
                                           FontFamily="{StaticResource IconFontFamily}"
                                           FontSize="11"
                                           Foreground="{DynamicResource OverlayBrush}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0" />
                                <TextBlock Text="{Binding MetadataStatusText}"
                                           Style="{StaticResource Text.Hint}"
                                           Foreground="{DynamicResource FloatingChromeTextBrush}"
                                           VerticalAlignment="Center" />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal"
                                        Margin="0,8,0,0"
                                        Visibility="{Binding HoverPixelText, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="&#xEF3C;"
                                           FontFamily="{StaticResource IconFontFamily}"
                                           FontSize="11"
                                           Foreground="{DynamicResource AccentBrush}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0" />
                                <TextBlock Text="{Binding HoverPixelText}"
                                           Style="{StaticResource Text.Hint}"
                                           Foreground="{DynamicResource FloatingChromeTextBrush}"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- OCR status — persistent while extraction is busy or selectable text is active. -->
                    <Border HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Margin="28,24,0,0"
                            MaxWidth="360"
                            Visibility="{Binding ShowOcrStatusPanel, Converter={StaticResource BoolToVis}}"
                            AutomationProperties.Name="{loc:Loc AutomationMainWindowTextExtractionStatus}"
                            AutomationProperties.LiveSetting="Polite">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource FloatingChrome}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsOcrBusy}" Value="True">
                                        <Setter Property="BorderBrush" Value="{DynamicResource YellowBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Width="32"
                                    Height="32"
                                    CornerRadius="{StaticResource Radius.Sm.CR}"
                                    BorderThickness="1"
                                    VerticalAlignment="Top"
                                    Margin="0,0,12,0">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{DynamicResource AccentPanelBrush}" />
                                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsOcrBusy}" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource WarningPanelBrush}" />
                                                <Setter Property="BorderBrush" Value="{DynamicResource YellowBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="&#xE8EA;"
                                           FontFamily="{StaticResource IconFontFamily}"
                                           FontSize="13"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsOcrBusy}" Value="True">
                                                    <Setter Property="Foreground" Value="{DynamicResource YellowBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
