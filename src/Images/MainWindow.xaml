<Window x:Class="Images.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Images.ViewModels"
        xmlns:ctl="clr-namespace:Images.Controls"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="Images"
        Width="1280" Height="820"
        MinWidth="800" MinHeight="540"
        WindowStartupLocation="CenterScreen"
        AllowDrop="True"
        DragEnter="Window_DragEnter"
        DragLeave="Window_DragLeave"
        Drop="Window_Drop"
        DragOver="Window_DragOver"
        KeyDown="Window_KeyDown"
        Background="{StaticResource BaseBrush}"
        TextOptions.TextFormattingMode="Display">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <Style x:Key="StatusDot" TargetType="Ellipse">
            <Setter Property="Width" Value="8" />
            <Setter Property="Height" Value="8" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource OverlayBrush}" />
            <Setter Property="Margin" Value="2,0,0,8" />
        </Style>

        <Style x:Key="MetaLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource OverlayBrush}" />
            <Setter Property="Margin" Value="0,0,14,8" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="MetaValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="340" />
        </Grid.ColumnDefinitions>

        <!-- ============ LEFT: Image viewport + nav chrome + bottom toolbar ============ -->
        <Grid Grid.Column="0" Background="{StaticResource ViewportBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Viewport with hover-reveal arrows -->
            <Grid x:Name="Viewport" Grid.Row="0" ClipToBounds="True">
                <ctl:ZoomPanImage x:Name="Canvas"
                                   Source="{Binding CurrentImage}"
                                   Rotation="{Binding Rotation}" />

                <!-- Empty state -->
                <Border HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        MaxWidth="430"
                        Padding="34,32"
                        Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource HairlineBrush}"
                        BorderThickness="1"
                        CornerRadius="14"
                        Visibility="{Binding IsViewerEmpty, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <Image Source="Resources/logo.png"
                               Width="74"
                               Height="74"
                               HorizontalAlignment="Center"
                               RenderOptions.BitmapScalingMode="HighQuality" />
                        <TextBlock Text="Open an image to begin"
                                   Foreground="{StaticResource TextBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,18,0,0"
                                   FontSize="20"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="Drag a file here, browse from disk, then rename, review, rotate, or move through the folder without leaving the viewer."
                                   Foreground="{StaticResource SubtextBrush}"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   LineHeight="20"
                                   Margin="0,8,0,0"
                                   FontSize="13" />
                        <Button Content="Open image"
                                Command="{Binding OpenCommand}"
                                Style="{StaticResource PrimaryButton}"
                                HorizontalAlignment="Center"
                                Margin="0,22,0,0"
                                Padding="24,9"
                                AutomationProperties.Name="Open image" />
                    </StackPanel>
                </Border>

                <!-- Decode error state -->
                <Border HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        MaxWidth="480"
                        Padding="28,26"
                        Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource RedBrush}"
                        BorderThickness="1"
                        CornerRadius="14"
                        Visibility="{Binding HasLoadError, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="&#xE783;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="34"
                                   HorizontalAlignment="Center"
                                   Foreground="{StaticResource RedBrush}" />
                        <TextBlock Text="This image could not be displayed"
                                   Foreground="{StaticResource TextBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,12,0,0"
                                   FontSize="18"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="{Binding LoadErrorMessage}"
                                   Foreground="{StaticResource SubtextBrush}"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   LineHeight="20"
                                   Margin="0,8,0,0" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                            <Button Content="Try another image"
                                    Command="{Binding OpenCommand}"
                                    Style="{StaticResource PrimaryButton}"
                                    Padding="18,8"
                                    AutomationProperties.Name="Try another image" />
                            <Button Content="Reveal file"
                                    Command="{Binding RevealCommand}"
                                    Style="{StaticResource ChromeButton}"
                                    Margin="10,0,0,0"
                                    Padding="18,8"
                                    AutomationProperties.Name="Reveal current file in Explorer" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Drag-and-drop confidence layer -->
                <Border Margin="28"
                        Background="{StaticResource DropOverlayBrush}"
                        BorderThickness="1.5"
                        CornerRadius="18"
                        Visibility="{Binding IsDropTargetActive, Converter={StaticResource BoolToVis}}">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="BorderBrush" Value="{StaticResource RedBrush}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsDropAccepted}" Value="True">
                                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Border Width="390"
                                MaxWidth="390"
                                Padding="28,24"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Background="{StaticResource ToastBrush}"
                                BorderBrush="{StaticResource HairlineBrush}"
                                BorderThickness="1"
                                CornerRadius="14">
                            <StackPanel>
                                <TextBlock Text="{Binding IsDropAccepted, Converter={StaticResource DropAcceptedIcon}}"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="34"
                                           HorizontalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource RedBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsDropAccepted}" Value="True">
                                                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Text="{Binding DropOverlayTitle}"
                                           Foreground="{StaticResource TextBrush}"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           FontSize="19"
                                           FontWeight="SemiBold"
                                           Margin="0,12,0,0" />
                                <TextBlock Text="{Binding DropOverlayMessage}"
                                           Foreground="{StaticResource SubtextBrush}"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           LineHeight="20"
                                           Margin="0,7,0,0" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- Hover-reveal nav arrows (only when image present) -->
                <Grid Visibility="{Binding HasImage, Converter={StaticResource BoolToVis}}">
                    <Button x:Name="PrevArrow"
                            Style="{StaticResource NavArrowButton}"
                            Command="{Binding PrevCommand}"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Margin="18,0,0,0"
                            Content="&#xE76B;"
                            FontFamily="Segoe MDL2 Assets"
                            FontSize="20"
                            Opacity="0"
                            AutomationProperties.Name="Previous image">
                        <Button.Triggers>
                            <EventTrigger RoutedEvent="Button.Loaded">
                                <BeginStoryboard>
                                    <Storyboard />
                                </BeginStoryboard>
                            </EventTrigger>
                        </Button.Triggers>
                    </Button>
                    <Button x:Name="NextArrow"
                            Style="{StaticResource NavArrowButton}"
                            Command="{Binding NextCommand}"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Margin="0,0,18,0"
                            Content="&#xE76C;"
                            FontFamily="Segoe MDL2 Assets"
                            FontSize="20"
                            Opacity="0"
                            AutomationProperties.Name="Next image" />

                    <!-- Position chip -->
                    <Border HorizontalAlignment="Center"
                            VerticalAlignment="Top"
                            Margin="0,16,0,0"
                            Background="{StaticResource FloatingChromeBrush}"
                            BorderBrush="{StaticResource FloatingChromeBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="12,6">
                        <TextBlock Text="{Binding PositionText}"
                                   Foreground="#FFEAEAEA"
                                   FontSize="12" />
                    </Border>

                    <!-- Toast notification -->
                    <Border HorizontalAlignment="Center"
                            VerticalAlignment="Bottom"
                            Margin="0,0,0,80"
                            Background="{StaticResource ToastBrush}"
                            BorderBrush="{StaticResource AccentBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="14,10"
                            Visibility="{Binding ToastMessage, Converter={StaticResource BoolToVis}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE930;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="13"
                                       Foreground="{StaticResource AccentBrush}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,9,0" />
                            <TextBlock Text="{Binding ToastMessage}"
                                       Foreground="#FFEAEAEA"
                                       FontSize="13"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>

            <!-- Bottom toolbar (Win7-style row) -->
            <Border Grid.Row="1"
                    Background="{StaticResource MantleBrush}"
                    BorderBrush="{StaticResource Surface0Brush}"
                    BorderThickness="0,1,0,0">
                <Grid Margin="14,9">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Left: info -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{Binding CurrentFileName}"
                                   Foreground="{StaticResource TextBrush}"
                                   FontWeight="SemiBold"
                                   FontSize="13"
                                   MaxWidth="280"
                                   TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="  ·  "
                                   Foreground="{StaticResource OverlayBrush}"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="{Binding DimensionsText}"
                                   Foreground="{StaticResource SubtextBrush}"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="  ·  "
                                   Foreground="{StaticResource OverlayBrush}"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="{Binding FileSizeText}"
                                   Foreground="{StaticResource SubtextBrush}"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <!-- Center: primary controls (Win7 layout: prev, rotate-l, play, rotate-r, next, delete) -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Style="{StaticResource ToolbarButton}" Command="{Binding PrevCommand}"     Content="&#xE76B;" ToolTip="Previous (Left)" AutomationProperties.Name="Previous image" />
                        <Button Style="{StaticResource ToolbarButton}" Command="{Binding RotateCcwCommand}" Content="&#xE7AD;" ToolTip="Rotate left" Margin="6,0,0,0" AutomationProperties.Name="Rotate left" />
                        <Button Style="{StaticResource ToolbarButton}" Command="{Binding OpenCommand}"      Content="&#xE8E5;" ToolTip="Open…" Margin="6,0,0,0" AutomationProperties.Name="Open image" />
                        <Button Style="{StaticResource ToolbarButton}" Command="{Binding RotateCwCommand}"  Content="&#xE7AC;" ToolTip="Rotate right" Margin="6,0,0,0" AutomationProperties.Name="Rotate right" />
                        <Button Style="{StaticResource ToolbarButton}" Command="{Binding NextCommand}"      Content="&#xE76C;" ToolTip="Next (Right)" Margin="6,0,0,0" AutomationProperties.Name="Next image" />
                        <Border Width="1" Background="{StaticResource Surface1Brush}" Margin="10,4" />
                        <Button Style="{StaticResource ToolbarButton}" Command="{Binding DeleteCommand}"    Content="&#xE74D;" ToolTip="Delete (Recycle Bin)" AutomationProperties.Name="Send image to Recycle Bin" />
                    </StackPanel>

                    <!-- Right: utility -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                        <Button Style="{StaticResource ToolbarButton}" Command="{Binding RevealCommand}"  Content="&#xE838;" ToolTip="Reveal in Explorer" AutomationProperties.Name="Reveal image in Explorer" />
                        <Button Style="{StaticResource ToolbarButton}" Command="{Binding CopyPathCommand}" Content="&#xE8C8;" ToolTip="Copy path" Margin="6,0,0,0" AutomationProperties.Name="Copy file path" />
                        <Button Style="{StaticResource ToolbarButton}" Command="{Binding RefreshCommand}"  Content="&#xE72C;" ToolTip="Refresh folder (F5)" Margin="6,0,0,0" AutomationProperties.Name="Refresh folder" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- ============ RIGHT: Rename panel ============ -->
        <Border Grid.Column="1"
                Background="{StaticResource MantleBrush}"
                BorderBrush="{StaticResource Surface0Brush}"
                BorderThickness="1,0,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0">
                <StackPanel Margin="18">

                    <StackPanel Margin="0,0,0,18">
                        <TextBlock Text="Images"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}" />
                        <TextBlock Text="Review, rename, and move through a folder without breaking flow."
                                   Foreground="{StaticResource SubtextBrush}"
                                   TextWrapping="Wrap"
                                   LineHeight="19"
                                   Margin="0,5,0,0" />
                    </StackPanel>

                    <TextBlock Text="RENAME" Style="{StaticResource SectionLabel}" />

                    <!-- Stem + extension chip, side by side -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="StemEditor"
                                 Grid.Column="0"
                                 Text="{Binding EditableStem, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="15"
                                 IsEnabled="{Binding HasImage}"
                                 PreviewKeyDown="StemEditor_PreviewKeyDown"
                                 AutomationProperties.Name="File name without extension" />
                        <Button Grid.Column="1"
                                Margin="8,0,0,0"
                                Padding="10,0"
                                MinWidth="64"
                                Height="34"
                                Command="{Binding UnlockExtensionCommand}"
                                IsEnabled="{Binding HasImage}"
                                Style="{StaticResource ChromeButton}"
                                ToolTip="Click to edit extension (normally locked)"
                                AutomationProperties.Name="Toggle extension editing">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE72E;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="11"
                                           VerticalAlignment="Center"
                                           Margin="0,0,6,0"
                                           Foreground="{StaticResource SubtextBrush}"
                                           Visibility="{Binding IsExtensionUnlocked, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}" />
                                <TextBlock Text="{Binding Extension}"
                                           VerticalAlignment="Center"
                                           FontFamily="Consolas"
                                           FontSize="13" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <!-- Extension unlocked warning + editor -->
                    <Border Margin="0,10,0,0"
                            Padding="11,9"
                            Background="{StaticResource WarningPanelBrush}"
                            BorderBrush="{StaticResource YellowBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Visibility="{Binding IsExtensionUnlocked, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                        <TextBlock Text="Extension editing is unlocked. This renames the file only; it does not convert image data."
                                   Foreground="{StaticResource YellowBrush}"
                                   FontSize="12"
                                   TextWrapping="Wrap" />
                        <TextBox Text="{Binding Extension, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,6,0,0"
                                 FontFamily="Consolas"
                                 AutomationProperties.Name="File extension" />
                        </StackPanel>
                    </Border>

                    <!-- Live preview + status -->
                    <Border Margin="0,12,0,0"
                            Padding="12,10"
                            Background="{StaticResource SurfacePanelBrush}"
                            BorderBrush="{StaticResource HairlineBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Ellipse Grid.Column="0">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse" BasedOn="{StaticResource StatusDot}">
                                        <Setter Property="Fill" Value="{StaticResource OverlayBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding RenameStatus}" Value="Pending">
                                                <Setter Property="Fill" Value="{StaticResource YellowBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding RenameStatus}" Value="Saved">
                                                <Setter Property="Fill" Value="{StaticResource GreenBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding RenameStatus}" Value="Conflict">
                                                <Setter Property="Fill" Value="{StaticResource MauveBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding RenameStatus}" Value="Error">
                                                <Setter Property="Fill" Value="{StaticResource RedBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{Binding RenameStatusText}"
                                           Foreground="{StaticResource TextBrush}"
                                           FontSize="12"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="{Binding RenamePreview}"
                                           Foreground="{StaticResource SubtextBrush}"
                                           FontSize="12"
                                           Margin="0,2,0,0"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <TextBlock Text="Renames save automatically after a short pause. Enter saves immediately; Esc reverts the edit."
                               Foreground="{StaticResource OverlayBrush}"
                               FontSize="11"
                               Margin="0,8,0,0"
                               TextWrapping="Wrap"
                               LineHeight="16" />

                    <!-- Divider -->
                    <Border Height="1" Background="{StaticResource Surface0Brush}" Margin="0,18,0,18" />

                    <!-- Recent renames -->
                    <TextBlock Text="RECENT RENAMES" Style="{StaticResource SectionLabel}" />

                    <Border Padding="12,11"
                            Background="{StaticResource SurfacePanelBrush}"
                            BorderBrush="{StaticResource HairlineBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Visibility="{Binding RecentRenames.Count, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}">
                        <StackPanel>
                            <TextBlock Text="No rename history yet"
                                       Foreground="{StaticResource TextBrush}"
                                       FontSize="12"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="Renames you make here will appear with one-click undo."
                                       Foreground="{StaticResource OverlayBrush}"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Margin="0,3,0,0" />
                        </StackPanel>
                    </Border>

                    <ItemsControl ItemsSource="{Binding RecentRenames}"
                                  KeyboardNavigation.DirectionalNavigation="Cycle"
                                  KeyboardNavigation.TabNavigation="Continue"
                                  AutomationProperties.Name="Recent renames">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource SurfacePanelBrush}"
                                        BorderBrush="{StaticResource HairlineBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="11,9"
                                        Margin="0,0,0,7">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock FontSize="12" TextTrimming="CharacterEllipsis">
                                                <Run Text="{Binding FromPath, Converter={x:Static vm:PathToFileNameConverter.Instance}, Mode=OneWay}"
                                                     Foreground="{StaticResource SubtextBrush}" />
                                            </TextBlock>
                                            <TextBlock FontSize="12" TextTrimming="CharacterEllipsis">
                                                <Run Text="→ " Foreground="{StaticResource OverlayBrush}" />
                                                <Run Text="{Binding ToPath, Converter={x:Static vm:PathToFileNameConverter.Instance}, Mode=OneWay}"
                                                     Foreground="{StaticResource TextBrush}" />
                                            </TextBlock>
                                        </StackPanel>
                                        <Button Grid.Column="1"
                                                Content="Undo"
                                                Style="{StaticResource ChromeButton}"
                                                Padding="12,3"
                                                VerticalAlignment="Center"
                                                Margin="10,0,0,0"
                                                Command="{Binding DataContext.UndoRenameCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                AutomationProperties.Name="Undo rename" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Divider -->
                    <Border Height="1" Background="{StaticResource Surface0Brush}" Margin="0,18,0,18" />

                    <!-- Metadata -->
                    <TextBlock Text="DETAILS" Style="{StaticResource SectionLabel}" />

                    <Grid Margin="2,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Folder" Style="{StaticResource MetaLabel}" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding CurrentFolder}" Style="{StaticResource MetaValue}" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Size" Style="{StaticResource MetaLabel}" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding FileSizeText}" Style="{StaticResource MetaValue}" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Pixels" Style="{StaticResource MetaLabel}" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding DimensionsText}" Style="{StaticResource MetaValue}" />

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Decoder" Style="{StaticResource MetaLabel}" />
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding DecoderUsed}" Style="{StaticResource MetaValue}" />
                    </Grid>

                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
