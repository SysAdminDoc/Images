<Window x:Class="Images.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Images.ViewModels"
        xmlns:ctl="clr-namespace:Images.Controls"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="{Binding WindowTitle}"
        Width="1280" Height="820"
        MinWidth="860" MinHeight="560"
        WindowStartupLocation="CenterScreen"
        AllowDrop="True"
        DragEnter="Window_DragEnter"
        DragLeave="Window_DragLeave"
        Drop="Window_Drop"
        DragOver="Window_DragOver"
        KeyDown="Window_KeyDown"
        PreviewMouseDown="Window_PreviewMouseDown"
        Background="{StaticResource BaseBrush}"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <!-- V15-07: side panel column collapses to 0 in fullscreen. Width="Auto" + the
                 Border's Visibility binding below drops the column to zero width when the
                 Border is Collapsed (Auto sizes to hidden-content width). -->
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!-- ============ LEFT: Viewport, floating chrome, bottom toolbar ============ -->
        <Grid Grid.Column="0" Background="{StaticResource ViewportBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid x:Name="Viewport" Grid.Row="0" ClipToBounds="True">
                <!-- V15-02: right-click context menu on the viewport. Rename-TextBox's own
                     built-in edit menu is unaffected because ContextMenu here is attached to
                     this Grid, not to descendants. -->
                <Grid.ContextMenu>
                    <ContextMenu Style="{StaticResource ViewportContextMenu}">
                        <MenuItem Header="Open…" Command="{Binding OpenCommand}" InputGestureText="Ctrl+O">
                            <MenuItem.Icon>
                                <TextBlock Style="{StaticResource MenuItemIcon}" Text="&#xE8E5;" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="Paste from clipboard" Command="{Binding PasteFromClipboardCommand}" InputGestureText="Ctrl+V">
                            <MenuItem.Icon>
                                <TextBlock Style="{StaticResource MenuItemIcon}" Text="&#xE77F;" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="Reference board" Command="{Binding OpenReferenceBoardCommand}" InputGestureText="Ctrl+B">
                            <MenuItem.Icon>
                                <TextBlock Style="{StaticResource MenuItemIcon}" Text="&#xE8B7;" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="Duplicate cleanup" Command="{Binding OpenDuplicateCleanupCommand}" InputGestureText="Ctrl+Shift+D">
                            <MenuItem.Icon>
                                <TextBlock Style="{StaticResource MenuItemIcon}" Text="&#xE8C8;" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="File health scan" Command="{Binding OpenFileHealthScanCommand}" InputGestureText="Ctrl+Shift+H">
                            <MenuItem.Icon>
                                <TextBlock Style="{StaticResource MenuItemIcon}" Text="&#xE946;" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="Tag relationships" Command="{Binding OpenTagGraphCommand}" InputGestureText="Ctrl+Shift+T">
                            <MenuItem.Icon>
                                <TextBlock Style="{StaticResource MenuItemIcon}" Text="&#xE8EC;" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="Import inbox" Command="{Binding OpenImportInboxCommand}" InputGestureText="Ctrl+Shift+I">
                            <MenuItem.Icon>
                                <TextBlock Style="{StaticResource MenuItemIcon}" Text="&#xE8B7;" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="Macro actions" Command="{Binding OpenMacroActionsCommand}" InputGestureText="Ctrl+Shift+M">
                            <MenuItem.Icon>
                                <TextBlock Style="{StaticResource MenuItemIcon}" Text="&#xE945;" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="Batch processor" Command="{Binding OpenBatchProcessorCommand}" InputGestureText="Ctrl+Shift+B">
                            <MenuItem.Icon>
                                <TextBlock Style="{StaticResource MenuItemIcon}" Text="&#xE8EF;" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="Edit history" Command="{Binding OpenEditStackCommand}" InputGestureText="Ctrl+Shift+E">
                            <MenuItem.Icon>
                                <TextBlock Style="{StaticResource MenuItemIcon}" Text="&#xE81C;" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="Resize..." Command="{Binding OpenResizeDialogCommand}" InputGestureText="Ctrl+Alt+R">
                            <MenuItem.Icon>
                                <TextBlock Style="{StaticResource MenuItemIcon}" Text="&#xE8A1;" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="Adjustments..." Command="{Binding OpenAdjustmentsCommand}" InputGestureText="Ctrl+Alt+A">
                            <MenuItem.Icon>
                                <TextBlock Style="{StaticResource MenuItemIcon}" Text="&#xE790;" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="{Binding ExposureBrushModeText}"
                                  Command="{Binding ToggleExposureBrushModeCommand}"
                                  InputGestureText="Ctrl+Alt+D"
                                  IsCheckable="True"
                                  IsChecked="{Binding IsExposureBrushMode, Mode=OneWay}">
                            <MenuItem.Icon>
                                <TextBlock Style="{StaticResource MenuItemIcon}" Text="&#xE790;" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="{Binding RedEyeCorrectionModeText}"
                                  Command="{Binding ToggleRedEyeModeCommand}"
                                  InputGestureText="Ctrl+Alt+Y"
                                  IsCheckable="True"
                                  IsChecked="{Binding IsRedEyeCorrectionMode, Mode=OneWay}">
                            <MenuItem.Icon>
                                <TextBlock Style="{StaticResource MenuItemIcon}" Text="&#xE7B3;" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="{Binding CropModeText}"
                                  Command="{Binding ToggleCropModeCommand}"
                                  InputGestureText="C"
                                  IsCheckable="True"
                                  IsChecked="{Binding IsCropMode, Mode=OneWay}">
                            <MenuItem.Icon>
                                <TextBlock Style="{StaticResource MenuItemIcon}" Text="&#xE7A8;" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="{Binding OverlayModeText}"
                                  Command="{Binding ToggleOverlayModeCommand}"
                                  IsCheckable="True"
                                  IsChecked="{Binding IsPinnedOverlayMode, Mode=OneWay}">
                            <MenuItem.Icon>
                                <TextBlock Style="{StaticResource MenuItemIcon}" Text="&#xE7B3;" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="Exit overlay"
                                  Command="{Binding ExitOverlayModeCommand}"
                                  InputGestureText="Ctrl+Alt+O">
                            <MenuItem.Icon>
                                <TextBlock Style="{StaticResource MenuItemIcon}" Text="&#xE711;" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="Reload" Command="{Binding ReloadCommand}" InputGestureText="Ctrl+Shift+R">
                            <MenuItem.Icon>
                                <TextBlock Style="{StaticResource MenuItemIcon}" Text="&#xE72C;" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="Previous page" Command="{Binding PrevPageCommand}">
                            <MenuItem.Icon>
                                <TextBlock Style="{StaticResource MenuItemIcon}" Text="&#xE76B;" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="Next page" Command="{Binding NextPageCommand}">
                            <MenuItem.Icon>
                                <TextBlock Style="{StaticResource MenuItemIcon}" Text="&#xE76C;" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="Save a copy…" Command="{Binding SaveAsCopyCommand}" InputGestureText="Ctrl+Shift+S">
                            <MenuItem.Icon>
                                <TextBlock Style="{StaticResource MenuItemIcon}" Text="&#xE74E;" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="Print…" Command="{Binding PrintCommand}" InputGestureText="Ctrl+P">
                            <MenuItem.Icon>
                                <TextBlock Style="{StaticResource MenuItemIcon}" Text="&#xE749;" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <Separator />
                        <MenuItem Header="Reveal in Explorer" Command="{Binding RevealCommand}">
                            <MenuItem.Icon>
                                <TextBlock Style="{StaticResource MenuItemIcon}" Text="&#xE838;" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="Copy path" Command="{Binding CopyPathCommand}">
                            <MenuItem.Icon>
                                <TextBlock Style="{StaticResource MenuItemIcon}" Text="&#xE8C8;" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="Open with default app" Command="{Binding OpenInDefaultAppCommand}">
                            <MenuItem.Icon>
                                <TextBlock Style="{StaticResource MenuItemIcon}" Text="&#xE8B5;" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="Strip GPS location" Command="{Binding StripLocationCommand}">
                            <MenuItem.Icon>
                                <TextBlock Style="{StaticResource MenuItemIcon}" Text="&#xE707;" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="Metadata HUD"
                                  Command="{Binding ToggleMetadataHudCommand}"
                                  InputGestureText="I"
                                  IsCheckable="True"
                                  IsChecked="{Binding IsMetadataHudVisible, Mode=OneWay}">
                            <MenuItem.Icon>
                                <TextBlock Style="{StaticResource MenuItemIcon}" Text="&#xE946;" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <Separator />
                        <MenuItem Header="Rotate left" Command="{Binding RotateCcwCommand}">
                            <MenuItem.Icon>
                                <TextBlock Style="{StaticResource MenuItemIcon}" Text="&#xE7AD;" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="Rotate right" Command="{Binding RotateCwCommand}">
                            <MenuItem.Icon>
                                <TextBlock Style="{StaticResource MenuItemIcon}" Text="&#xE7AC;" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="Rotate 180°" Command="{Binding Rotate180Command}">
                            <MenuItem.Icon>
                                <TextBlock FontSize="10.5"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource OverlayBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Text="180" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="Flip horizontal" Command="{Binding FlipHorizontalCommand}">
                            <MenuItem.Icon>
                                <TextBlock FontFamily="Segoe UI Symbol"
                                           FontSize="13"
                                           Foreground="{StaticResource OverlayBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Text="↔" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="Flip vertical" Command="{Binding FlipVerticalCommand}">
                            <MenuItem.Icon>
                                <TextBlock FontFamily="Segoe UI Symbol"
                                           FontSize="13"
                                           Foreground="{StaticResource OverlayBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Text="↕" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <Separator />
                        <MenuItem Header="Set as desktop wallpaper" Command="{Binding SetAsWallpaperCommand}">
                            <MenuItem.Icon>
                                <TextBlock FontFamily="Segoe UI Symbol"
                                           FontSize="12"
                                           Foreground="{StaticResource OverlayBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Text="▣" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <Separator />
                        <MenuItem Header="Move to Recycle Bin…" Command="{Binding DeleteCommand}" InputGestureText="Del">
                            <MenuItem.Icon>
                                <TextBlock Style="{StaticResource MenuItemIcon}" Text="&#xE74D;" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <Separator />
                        <MenuItem Header="Settings…" Command="{Binding SettingsCommand}" InputGestureText="Ctrl+,">
                            <MenuItem.Icon>
                                <TextBlock Style="{StaticResource MenuItemIcon}" Text="&#xE713;" />
                            </MenuItem.Icon>
                        </MenuItem>
                    </ContextMenu>
                </Grid.ContextMenu>

                <ctl:ZoomPanImage x:Name="Canvas"
                                   Source="{Binding CurrentImage}"
                                   Animation="{Binding CurrentAnimation}"
                                   AnimationFrameIndex="{Binding CurrentAnimationFrameIndex}"
                                   Rotation="{Binding Rotation}"
                                   FlipHorizontal="{Binding FlipHorizontal}"
                                   FlipVertical="{Binding FlipVertical}"
                                   InspectorMode="{Binding IsCanvasSelectionMode}"
                                   UseNearestNeighborScaling="{Binding InspectorNearestNeighborPreview}"
                                   MouseMove="Canvas_MouseMove"
                                   MouseLeave="Canvas_MouseLeave"
                                   MouseLeftButtonDown="Canvas_MouseLeftButtonDown"
                                   MouseLeftButtonUp="Canvas_MouseLeftButtonUp" />

                <!-- OCR text extraction overlay — selectable recognized text regions.
                      Target binding keeps OCR pixel coordinates aligned with image zoom/pan transforms. -->
                <ctl:OcrOverlay Visibility="{Binding IsOcrMode, Converter={StaticResource BoolToVis}}"
                                Target="{Binding ElementName=Canvas}"
                                IsHitTestVisible="{Binding IsOcrMode}"
                                Opacity="0.95"
                                AutomationProperties.Name="OCR text overlay" />

                <ctl:CropOverlay Visibility="{Binding ShowCropOverlay, Converter={StaticResource BoolToVis}}"
                                 Target="{Binding ElementName=Canvas}"
                                 Selection="{Binding CropSelection}"
                                 Opacity="0.98"
                                 AutomationProperties.Name="Crop selection overlay" />

                <ctl:LocalExposureBrushOverlay Visibility="{Binding ShowExposureBrushOverlay, Converter={StaticResource BoolToVis}}"
                                               Target="{Binding ElementName=Canvas}"
                                               Strokes="{Binding ExposureBrushStrokes}"
                                               Opacity="0.92"
                                               AutomationProperties.Name="Local exposure brush overlay" />

                <ctl:RedEyeCorrectionOverlay Visibility="{Binding ShowRedEyeCorrectionOverlay, Converter={StaticResource BoolToVis}}"
                                             Target="{Binding ElementName=Canvas}"
                                             Marks="{Binding RedEyeCorrectionMarks}"
                                             Opacity="0.94"
                                             AutomationProperties.Name="Red-eye correction overlay" />

                <Border HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        MaxWidth="760"
                        Margin="24,18,24,0"
                        Padding="13,9"
                        CornerRadius="{StaticResource Radius.Md.CR}"
                        Background="{StaticResource ToastBrush}"
                        BorderBrush="{StaticResource AccentBrush}"
                        BorderThickness="1"
                        Effect="{StaticResource Elevation.Low}"
                        IsHitTestVisible="False"
                        Visibility="{Binding ShowOverlayBanner, Converter={StaticResource BoolToVis}}"
                        AutomationProperties.Name="Pinned overlay status"
                        AutomationProperties.HelpText="{Binding OverlayStatusText}">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="28"
                                Height="28"
                                CornerRadius="{StaticResource Radius.Sm.CR}"
                                Background="#1F89B4FA"
                                BorderBrush="{StaticResource HairlineBrush}"
                                BorderThickness="1"
                                Margin="0,0,11,0">
                            <TextBlock Text="&#xE7B3;"
                                       FontFamily="{StaticResource IconFontFamily}"
                                       FontSize="13"
                                       Foreground="{StaticResource AccentBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding OverlayModeText}"
                                       FontSize="12.5"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource FloatingChromeTextBrush}" />
                            <TextBlock Text="{Binding OverlayStatusText}"
                                       Style="{StaticResource Text.Caption}"
                                       TextWrapping="Wrap"
                                       MaxWidth="660"
                                       Margin="0,2,0,0" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Empty state — first-run guidance and recovery links -->
                <Border Style="{StaticResource ElevatedCard}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        MaxWidth="540"
                        Padding="28,24"
                        Visibility="{Binding IsViewerEmpty, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <Image Source="Resources/logo.png"
                               Width="64"
                               Height="64"
                               HorizontalAlignment="Center"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               Opacity="0.94" />
                        <TextBlock Style="{StaticResource Text.Display}"
                                   Text="Open an image to begin"
                                   HorizontalAlignment="Center"
                                   Margin="0,18,0,0" />
                        <TextBlock Style="{StaticResource Text.Subtitle}"
                                   Text="Drop a file anywhere in the window, browse from disk, or paste from the clipboard. Images stays local by default and keeps recovery details close when setup needs attention."
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   Margin="0,10,0,0"
                                   MaxWidth="440" />

                        <Grid Margin="0,20,0,0" MaxWidth="456">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Grid.Column="0" Margin="0,0,20,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="&#xE72E;"
                                           FontFamily="{StaticResource IconFontFamily}"
                                           FontSize="13"
                                           Foreground="{StaticResource AccentBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Top"
                                           Margin="0,2,0,0" />
                                <StackPanel Grid.Column="1">
                                    <TextBlock Style="{StaticResource Text.Body}" Text="Local by default" />
                                    <TextBlock Style="{StaticResource Text.Caption}"
                                               Text="{Binding FirstRunPrivacyText}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Grid>

                            <Grid Grid.Row="0" Grid.Column="1" Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="&#xE8E5;"
                                           FontFamily="{StaticResource IconFontFamily}"
                                           FontSize="13"
                                           Foreground="{StaticResource AccentBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Top"
                                           Margin="0,2,0,0" />
                                <StackPanel Grid.Column="1">
                                    <TextBlock Style="{StaticResource Text.Body}" Text="Broad format support" />
                                    <TextBlock Style="{StaticResource Text.Caption}"
                                               Text="{Binding FirstRunFormatStatusText}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Grid>

                            <Grid Grid.Row="1" Grid.Column="0" Margin="0,0,20,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="&#xE8C8;"
                                           FontFamily="{StaticResource IconFontFamily}"
                                           FontSize="13"
                                           Foreground="{StaticResource AccentBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Top"
                                           Margin="0,2,0,0" />
                                <StackPanel Grid.Column="1">
                                    <TextBlock Style="{StaticResource Text.Body}" Text="Text extraction readiness" />
                                    <TextBlock Style="{StaticResource Text.Caption}"
                                               Text="{Binding FirstRunOcrStatusText}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Grid>

                            <Grid Grid.Row="1" Grid.Column="1" Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="&#xE8A5;"
                                           FontFamily="{StaticResource IconFontFamily}"
                                           FontSize="13"
                                           Foreground="{StaticResource AccentBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Top"
                                           Margin="0,2,0,0" />
                                <StackPanel Grid.Column="1">
                                    <TextBlock Style="{StaticResource Text.Body}" Text="Document previews" />
                                    <TextBlock Style="{StaticResource Text.Caption}"
                                               Text="{Binding FirstRunDocumentStatusText}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Grid>

                            <Grid Grid.Row="2" Grid.ColumnSpan="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="&#xE946;"
                                           FontFamily="{StaticResource IconFontFamily}"
                                           FontSize="13"
                                           Foreground="{StaticResource AccentBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Top"
                                           Margin="0,2,0,0" />
                                <StackPanel Grid.Column="1">
                                    <TextBlock Style="{StaticResource Text.Body}" Text="Recovery links" />
                                    <TextBlock Style="{StaticResource Text.Caption}"
                                               Text="{Binding FirstRunRecoveryText}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Grid>
                        </Grid>

                        <WrapPanel HorizontalAlignment="Center" Margin="0,22,0,0">
                            <Button Command="{Binding OpenCommand}"
                                    Style="{StaticResource PrimaryButton}"
                                    Margin="0,0,10,8"
                                    ToolTip="Open image (Ctrl+O)"
                                    AutomationProperties.Name="Open image"
                                    AutomationProperties.HelpText="Choose an image file from disk. Shortcut: Ctrl+O.">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE8E5;"
                                               FontFamily="{StaticResource IconFontFamily}"
                                               FontSize="13"
                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                               Margin="0,0,9,0"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="Open image..."
                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding PasteFromClipboardCommand}"
                                    Style="{StaticResource ChromeButton}"
                                    Margin="0,0,10,8"
                                    ToolTip="Paste image or supported file from clipboard (Ctrl+V)"
                                    AutomationProperties.Name="Paste from clipboard"
                                    AutomationProperties.HelpText="Open a supported image file from the clipboard, or save and open clipboard bitmap data. Shortcut: Ctrl+V.">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE77F;"
                                               FontFamily="{StaticResource IconFontFamily}"
                                               FontSize="12"
                                               Margin="0,0,8,0"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="Paste" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding SettingsCommand}"
                                    Style="{StaticResource ChromeButton}"
                                    Margin="0,0,10,8"
                                    ToolTip="Open Settings (Ctrl+,)"
                                    AutomationProperties.Name="Open settings">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE713;"
                                               FontFamily="{StaticResource IconFontFamily}"
                                               FontSize="12"
                                               Margin="0,0,8,0"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="Settings" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding AboutCommand}"
                                    Style="{StaticResource ChromeButton}"
                                    Margin="0,0,0,8"
                                    ToolTip="Open diagnostics and app information"
                                    AutomationProperties.Name="Open diagnostics">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE946;"
                                               FontFamily="{StaticResource IconFontFamily}"
                                               FontSize="12"
                                               Margin="0,0,8,0"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="Diagnostics" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </WrapPanel>

                        <TextBlock Style="{StaticResource Text.Hint}"
                                   Text="Tip: arrow keys browse the folder, Enter commits a rename."
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   Margin="0,12,0,0" />
                    </StackPanel>
                </Border>

                <!-- Decode error state — semantic-red tinted card -->
                <Border Style="{StaticResource ElevatedCard}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        MaxWidth="500"
                        Background="{StaticResource DangerPanelBrush}"
                        BorderBrush="{StaticResource RedBrush}"
                        Visibility="{Binding HasLoadError, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="&#xE783;"
                                   FontFamily="{StaticResource IconFontFamily}"
                                   FontSize="38"
                                   HorizontalAlignment="Center"
                                   Foreground="{StaticResource RedBrush}" />
                        <TextBlock Style="{StaticResource Text.Title}"
                                   Text="{Binding LoadErrorTitle}"
                                   HorizontalAlignment="Center"
                                   Margin="0,14,0,0" />
                        <TextBlock Style="{StaticResource Text.Subtitle}"
                                   Text="{Binding LoadErrorMessage}"
                                   TextAlignment="Center"
                                   Margin="0,10,0,0" />
                        <TextBlock Style="{StaticResource Text.Hint}"
                                   Text="{Binding LoadErrorHelpText}"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   Margin="0,10,0,0" />
                        <WrapPanel HorizontalAlignment="Center" Margin="0,22,0,0">
                            <Button Command="{Binding OpenCommand}"
                                    Style="{StaticResource PrimaryButton}"
                                    Margin="0,0,12,8"
                                    AutomationProperties.Name="Try another image">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE8E5;"
                                               FontFamily="{StaticResource IconFontFamily}"
                                               FontSize="12"
                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                               Margin="0,0,8,0"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="Try another image"
                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding AboutCommand}"
                                    Style="{StaticResource ChromeButton}"
                                    Margin="0,0,12,8"
                                    Visibility="{Binding LoadErrorShowsCodecDetails, Converter={StaticResource BoolToVis}}"
                                    AutomationProperties.Name="Open codec details">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE946;"
                                               FontFamily="{StaticResource IconFontFamily}"
                                               FontSize="12"
                                               Margin="0,0,8,0"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="Codec details" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding RevealCommand}"
                                    Style="{StaticResource ChromeButton}"
                                    Margin="0,0,0,8"
                                    AutomationProperties.Name="Reveal current file in Explorer">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE838;"
                                               FontFamily="{StaticResource IconFontFamily}"
                                               FontSize="12"
                                               Margin="0,0,8,0"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="Reveal file" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <!-- Drag-and-drop confidence layer -->
                <Border Margin="32"
                        Background="{StaticResource DropOverlayBrush}"
                        BorderThickness="2"
                        CornerRadius="{StaticResource Radius.Xl.CR}"
                        Visibility="{Binding IsDropTargetActive, Converter={StaticResource BoolToVis}}">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="BorderBrush" Value="{StaticResource RedBrush}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsDropAccepted}" Value="True">
                                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Border Style="{StaticResource ElevatedCard}"
                            Background="{StaticResource DropOverlayPanelBrush}"
                            MaxWidth="420"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                        <StackPanel>
                            <TextBlock Text="{Binding IsDropAccepted, Converter={StaticResource DropAcceptedIcon}}"
                                       FontFamily="{StaticResource IconFontFamily}"
                                       FontSize="38"
                                       HorizontalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource RedBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsDropAccepted}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Style="{StaticResource Text.Title}"
                                       Text="{Binding DropOverlayTitle}"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       Margin="0,14,0,0" />
                            <TextBlock Style="{StaticResource Text.Subtitle}"
                                       Text="{Binding DropOverlayMessage}"
                                       TextAlignment="Center"
                                       Margin="0,8,0,0" />
                        </StackPanel>
                    </Border>
                </Border>

                <Border Background="{StaticResource BaseBrush}"
                        Padding="28,24"
                        Visibility="{Binding ShowGallery, Converter={StaticResource BoolToVis}}"
                        Panel.ZIndex="18"
                        AutomationProperties.Name="Gallery workbench"
                        AutomationProperties.LiveSetting="Polite">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border Width="34"
                                    Height="34"
                                    CornerRadius="{StaticResource Radius.Lg.CR}"
                                    Background="#1F89B4FA"
                                    BorderBrush="{StaticResource HairlineBrush}"
                                    BorderThickness="1"
                                    VerticalAlignment="Center">
                                <TextBlock Text="&#xE8A9;"
                                           FontFamily="{StaticResource IconFontFamily}"
                                           FontSize="15"
                                           Foreground="{StaticResource AccentBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1"
                                        Margin="12,0,16,0"
                                        VerticalAlignment="Center">
                                <TextBlock Text="Gallery"
                                           Style="{StaticResource Text.Title}"
                                           FontSize="18" />
                                <TextBlock Text="{Binding GalleryStatusText}"
                                           Style="{StaticResource Text.Hint}"
                                           Margin="0,3,0,0" />
                            </StackPanel>
                            <Button Grid.Column="2"
                                    Style="{StaticResource ChromeButton}"
                                    Command="{Binding CloseGalleryCommand}"
                                    Width="34"
                                    Height="34"
                                    Padding="0"
                                    ToolTip="Close gallery"
                                    AutomationProperties.Name="Close gallery">
                                <TextBlock Text="&#xE8BB;"
                                           FontFamily="{StaticResource IconFontFamily}"
                                           FontSize="12"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Button>
                        </Grid>

                        <WrapPanel Grid.Row="1"
                                   Margin="0,0,0,18"
                                   KeyboardNavigation.TabNavigation="Continue"
                                   AutomationProperties.Name="Gallery sort controls">
                            <Border Width="280"
                                    Height="32"
                                    Margin="0,0,8,8"
                                    Padding="10,0"
                                    CornerRadius="{StaticResource Radius.Sm.CR}"
                                    Background="{StaticResource PanelBrush}"
                                    BorderBrush="{StaticResource HairlineBrush}"
                                    BorderThickness="1"
                                    ToolTip="{Binding GalleryFilterTooltip}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="&#xE721;"
                                               FontFamily="{StaticResource IconFontFamily}"
                                               FontSize="11"
                                               Foreground="{StaticResource OverlayBrush}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,0" />
                                    <TextBox Grid.Column="1"
                                             Text="{Binding GalleryFilterText, UpdateSourceTrigger=PropertyChanged}"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             Padding="0"
                                             MinHeight="24"
                                             VerticalContentAlignment="Center"
                                             AutomationProperties.Name="Filter gallery" />
                                    <Button Grid.Column="2"
                                            Command="{Binding ClearGalleryFilterCommand}"
                                            Width="24"
                                            Height="24"
                                            Padding="0"
                                            Margin="6,0,0,0"
                                            Visibility="{Binding HasGalleryFilter, Converter={StaticResource BoolToVis}}"
                                            ToolTip="Clear filter"
                                            AutomationProperties.Name="Clear gallery filter">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource ChromeButton}">
                                                <Setter Property="BorderThickness" Value="0" />
                                                <Setter Property="Background" Value="Transparent" />
                                            </Style>
                                        </Button.Style>
                                        <TextBlock Text="&#xE711;"
                                                   FontFamily="{StaticResource IconFontFamily}"
                                                   FontSize="10"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </Button>
                                </Grid>
                            </Border>
                            <Button Command="{Binding SetFolderSortCommand}"
                                    CommandParameter="NaturalName"
                                    Padding="12,6"
                                    MinHeight="30"
                                    Margin="0,0,8,8"
                                    AutomationProperties.Name="Sort gallery by name">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource ChromeButton}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CurrentSortMode, Converter={StaticResource SortModeMatches}, ConverterParameter=NaturalName}" Value="True">
                                                <Setter Property="Background" Value="#1F89B4FA" />
                                                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE8CB;"
                                               FontFamily="{StaticResource IconFontFamily}"
                                               FontSize="11"
                                               Margin="0,0,7,0"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="Name" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding SetFolderSortCommand}"
                                    CommandParameter="ModifiedNewest"
                                    Padding="12,6"
                                    MinHeight="30"
                                    Margin="0,0,8,8"
                                    AutomationProperties.Name="Sort gallery by newest modified date">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource ChromeButton}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CurrentSortMode, Converter={StaticResource SortModeMatches}, ConverterParameter=ModifiedNewest}" Value="True">
                                                <Setter Property="Background" Value="#1F89B4FA" />
                                                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE823;"
                                               FontFamily="{StaticResource IconFontFamily}"
                                               FontSize="11"
                                               Margin="0,0,7,0"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="Newest" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding SetFolderSortCommand}"
                                    CommandParameter="ExtensionThenName"
                                    Padding="12,6"
                                    MinHeight="30"
                                    Margin="0,0,8,8"
                                    AutomationProperties.Name="Sort gallery by type">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource ChromeButton}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CurrentSortMode, Converter={StaticResource SortModeMatches}, ConverterParameter=ExtensionThenName}" Value="True">
                                                <Setter Property="Background" Value="#1F89B4FA" />
                                                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE8B7;"
                                               FontFamily="{StaticResource IconFontFamily}"
                                               FontSize="11"
                                               Margin="0,0,7,0"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="Type" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding SetFolderSortCommand}"
                                    CommandParameter="SizeLargest"
                                    Padding="12,6"
                                    MinHeight="30"
                                    Margin="0,0,8,8"
                                    AutomationProperties.Name="Sort gallery by largest file size">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource ChromeButton}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CurrentSortMode, Converter={StaticResource SortModeMatches}, ConverterParameter=SizeLargest}" Value="True">
                                                <Setter Property="Background" Value="#1F89B4FA" />
                                                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE8EF;"
                                               FontFamily="{StaticResource IconFontFamily}"
                                               FontSize="11"
                                               Margin="0,0,7,0"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="Size" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding ApplyGallerySmartFilterCommand}"
                                    CommandParameter="orientation:landscape"
                                    Style="{StaticResource ChromeButton}"
                                    Padding="12,6"
                                    MinHeight="30"
                                    Margin="0,0,8,8"
                                    ToolTip="{Binding GalleryFilterTooltip}"
                                    AutomationProperties.Name="Filter gallery to landscape images">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE809;"
                                               FontFamily="{StaticResource IconFontFamily}"
                                               FontSize="11"
                                               Margin="0,0,7,0"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="Landscape" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding ApplyGallerySmartFilterCommand}"
                                    CommandParameter="orientation:portrait"
                                    Style="{StaticResource ChromeButton}"
                                    Padding="12,6"
                                    MinHeight="30"
                                    Margin="0,0,8,8"
                                    ToolTip="{Binding GalleryFilterTooltip}"
                                    AutomationProperties.Name="Filter gallery to portrait images">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE91B;"
                                               FontFamily="{StaticResource IconFontFamily}"
                                               FontSize="11"
                                               Margin="0,0,7,0"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="Portrait" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding ApplyGallerySmartFilterCommand}"
                                    CommandParameter="date:week"
                                    Style="{StaticResource ChromeButton}"
                                    Padding="12,6"
                                    MinHeight="30"
                                    Margin="0,0,8,8"
                                    ToolTip="{Binding GalleryFilterTooltip}"
                                    AutomationProperties.Name="Filter gallery to recently modified images">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE823;"
                                               FontFamily="{StaticResource IconFontFamily}"
                                               FontSize="11"
                                               Margin="0,0,7,0"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="Recent" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding ApplyGallerySmartFilterCommand}"
                                    CommandParameter="size:large"
                                    Style="{StaticResource ChromeButton}"
                                    Padding="12,6"
                                    MinHeight="30"
                                    Margin="0,0,8,8"
                                    ToolTip="{Binding GalleryFilterTooltip}"
                                    AutomationProperties.Name="Filter gallery to large images">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE740;"
                                               FontFamily="{StaticResource IconFontFamily}"
                                               FontSize="11"
                                               Margin="0,0,7,0"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="Large" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding ApplyGallerySmartFilterCommand}"
                                    CommandParameter="duplicate:yes"
                                    Style="{StaticResource ChromeButton}"
                                    Padding="12,6"
                                    MinHeight="30"
                                    Margin="0,0,8,8"
                                    ToolTip="{Binding GalleryFilterTooltip}"
                                    AutomationProperties.Name="Filter gallery to exact duplicates">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE8C8;"
                                               FontFamily="{StaticResource IconFontFamily}"
                                               FontSize="11"
                                               Margin="0,0,7,0"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="Duplicates" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <TextBlock Text="{Binding GalleryFilterSummaryText}"
                                       Visibility="{Binding GalleryFilterSummaryText, Converter={StaticResource BoolToVis}}"
                                       Style="{StaticResource Text.Hint}"
                                       VerticalAlignment="Center"
                                       Margin="2,0,8,8" />
                        </WrapPanel>

                        <ListBox x:Name="GalleryItems"
                                 Grid.Row="2"
                                 ItemsSource="{Binding GalleryItems}"
                                 SelectedItem="{Binding SelectedGalleryItem, Mode=TwoWay}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Padding="0,0,0,10"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ScrollViewer.CanContentScroll="False"
                                 VirtualizingPanel.IsVirtualizing="False"
                                 KeyboardNavigation.DirectionalNavigation="Contained"
                                 KeyboardNavigation.TabNavigation="Cycle"
                                 AutomationProperties.Name="Gallery thumbnails"
                                 AutomationProperties.HelpText="{Binding GalleryStatusText}">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="0" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <ContentPresenter />
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Button Command="{Binding DataContext.OpenPreviewItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            Loaded="PreviewThumbnail_Loaded"
                                            Width="150"
                                            MinHeight="172"
                                            Margin="0,0,12,12"
                                            Padding="7"
                                            HorizontalContentAlignment="Stretch"
                                            VerticalContentAlignment="Stretch"
                                            ToolTip="{Binding Path}"
                                            Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}"
                                            AutomationProperties.Name="{Binding FileName}"
                                            AutomationProperties.HelpText="{Binding PositionText}"
                                            AutomationProperties.ItemStatus="{Binding PositionText}">
                                        <Button.ContextMenu>
                                            <ContextMenu Style="{StaticResource ViewportContextMenu}">
                                                <MenuItem Header="Open"
                                                          Command="{Binding PlacementTarget.Tag.OpenPreviewItemCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                                    <MenuItem.Icon>
                                                        <TextBlock Style="{StaticResource MenuItemIcon}" Text="&#xE8E5;" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="Reveal in Explorer"
                                                          Command="{Binding PlacementTarget.Tag.RevealPreviewItemCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                                    <MenuItem.Icon>
                                                        <TextBlock Style="{StaticResource MenuItemIcon}" Text="&#xE838;" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="Copy path"
                                                          Command="{Binding PlacementTarget.Tag.CopyPreviewPathCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                                    <MenuItem.Icon>
                                                        <TextBlock Style="{StaticResource MenuItemIcon}" Text="&#xE8C8;" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                            </ContextMenu>
                                        </Button.ContextMenu>
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource ChromeButton}">
                                                <Setter Property="Background" Value="{StaticResource Surface0Brush}" />
                                                <Setter Property="BorderBrush" Value="{StaticResource HairlineBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                                        <Setter Property="Background" Value="#1F89B4FA" />
                                                        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                        <Setter Property="Background" Value="#2689B4FA" />
                                                        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                    </DataTrigger>
                                                    <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                                        <Setter Property="Background" Value="#2689B4FA" />
                                                        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <StackPanel>
                                            <Border Height="104"
                                                    CornerRadius="{StaticResource Radius.Sm.CR}"
                                                    Background="{StaticResource ViewportBrush}"
                                                    BorderBrush="{StaticResource HairlineBrush}"
                                                    BorderThickness="1"
                                                    ClipToBounds="True">
                                                <Grid>
                                                    <Image Source="{Binding Thumbnail}"
                                                           Stretch="UniformToFill"
                                                           RenderOptions.BitmapScalingMode="HighQuality"
                                                           Visibility="{Binding HasThumbnail, Converter={StaticResource BoolToVis}}" />
                                                    <TextBlock Text="&#xEB9F;"
                                                               FontFamily="{StaticResource IconFontFamily}"
                                                               FontSize="23"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               Visibility="{Binding HasThumbnail, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}">
                                                        <TextBlock.Style>
                                                            <Style TargetType="{x:Type TextBlock}">
                                                                <Setter Property="Foreground" Value="{StaticResource OverlayBrush}" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding ThumbnailFailed}" Value="True">
                                                                        <Setter Property="Text" Value="&#xE783;" />
                                                                        <Setter Property="Foreground" Value="{StaticResource YellowBrush}" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Grid>
                                            </Border>
                                            <TextBlock Text="{Binding FileName}"
                                                       Foreground="{StaticResource TextBrush}"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="1,8,1,0" />
                                            <TextBlock Text="{Binding PositionText}"
                                                       Foreground="{StaticResource OverlayBrush}"
                                                       FontSize="10.5"
                                                       Margin="1,2,1,0" />
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <Border Grid.Row="2"
                                Background="{StaticResource BaseBrush}"
                                Visibility="{Binding ShowGalleryFilterEmpty, Converter={StaticResource BoolToVis}}"
                                AutomationProperties.Name="No gallery filter matches">
                            <StackPanel HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        MaxWidth="340">
                                <TextBlock Text="&#xE721;"
                                           FontFamily="{StaticResource IconFontFamily}"
                                           FontSize="28"
                                           Foreground="{StaticResource OverlayBrush}"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="No matching images"
                                           Style="{StaticResource Text.Title}"
                                           FontSize="16"
                                           TextAlignment="Center"
                                           Margin="0,12,0,0" />
                                <TextBlock Text="{Binding GalleryStatusText}"
                                           Style="{StaticResource Text.Hint}"
                                           TextAlignment="Center"
                                           Margin="0,5,0,0" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- Floating chrome (only when an image is present) -->
                <Grid Visibility="{Binding HasImage, Converter={StaticResource BoolToVis}}">

                    <!-- Archive book page-turn zones. Narrow edge targets keep drag-pan available
                         across the center of the canvas while giving books a natural tap/click turn. -->
                    <Button Command="{Binding LeftBookPageTurnCommand}"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Stretch"
                            Width="112"
                            Padding="0"
                            BorderThickness="0"
                            Background="#01000000"
                            Cursor="Hand"
                            Visibility="{Binding IsArchiveBook, Converter={StaticResource BoolToVis}}"
                            ToolTip="{Binding LeftBookPageTurnTooltip}"
                            AutomationProperties.Name="{Binding LeftBookPageTurnTooltip}">
                        <Border Width="38"
                                Height="82"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Margin="18,0,0,0"
                                CornerRadius="{StaticResource Radius.Lg.CR}"
                                Background="{StaticResource FloatingChromeBrush}"
                                BorderBrush="{StaticResource FloatingChromeBorderBrush}"
                                BorderThickness="1"
                                Opacity="0.72">
                            <TextBlock Text="&#xE76B;"
                                       FontFamily="{StaticResource IconFontFamily}"
                                       FontSize="18"
                                       Foreground="{StaticResource FloatingChromeTextBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                    </Button>

                    <Button Command="{Binding RightBookPageTurnCommand}"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Stretch"
                            Width="112"
                            Padding="0"
                            BorderThickness="0"
                            Background="#01000000"
                            Cursor="Hand"
                            Visibility="{Binding IsArchiveBook, Converter={StaticResource BoolToVis}}"
                            ToolTip="{Binding RightBookPageTurnTooltip}"
                            AutomationProperties.Name="{Binding RightBookPageTurnTooltip}">
                        <Border Width="38"
                                Height="82"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Margin="0,0,18,0"
                                CornerRadius="{StaticResource Radius.Lg.CR}"
                                Background="{StaticResource FloatingChromeBrush}"
                                BorderBrush="{StaticResource FloatingChromeBorderBrush}"
                                BorderThickness="1"
                                Opacity="0.72">
                            <TextBlock Text="&#xE76C;"
                                       FontFamily="{StaticResource IconFontFamily}"
                                       FontSize="18"
                                       Foreground="{StaticResource FloatingChromeTextBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                    </Button>

                    <!-- Hover-reveal nav arrows -->
                    <Button x:Name="PrevArrow"
                            Style="{StaticResource NavArrowButton}"
                            Command="{Binding PrevCommand}"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Margin="22,0,0,0"
                            Content="&#xE76B;"
                            Opacity="0"
                            AutomationProperties.Name="Previous image"
                            AutomationProperties.HelpText="Left arrow or Backspace" />
                    <Button x:Name="NextArrow"
                            Style="{StaticResource NavArrowButton}"
                            Command="{Binding NextCommand}"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Margin="0,0,22,0"
                            Content="&#xE76C;"
                            Opacity="0"
                            AutomationProperties.Name="Next image"
                            AutomationProperties.HelpText="Right arrow or Space" />

                    <!-- Position chip — elevated pill -->
                    <Border Style="{StaticResource FloatingPill}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Top"
                            Margin="0,20,0,0"
                            AutomationProperties.LiveSetting="Polite"
                            AutomationProperties.Name="Folder position">
                        <TextBlock Text="{Binding PositionText}"
                                   Foreground="{StaticResource FloatingChromeTextBrush}"
                                   FontSize="12"
                                   FontWeight="SemiBold" />
                    </Border>

                    <Border Style="{StaticResource FloatingPill}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Top"
                            Margin="0,62,0,0"
                            Visibility="{Binding HasMultiplePages, Converter={StaticResource BoolToVis}}"
                            AutomationProperties.LiveSetting="Polite"
                            AutomationProperties.Name="Page position">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Style="{StaticResource ToolbarButton}"
                                    Width="30"
                                    Height="26"
                                    FontSize="11"
                                    Content="&#xE76B;"
                                    Command="{Binding PrevPageCommand}"
                                    ToolTip="Previous page"
                                    AutomationProperties.Name="Previous page" />
                            <Slider Width="152"
                                    Minimum="1"
                                    Maximum="{Binding PageCount}"
                                    Value="{Binding PageNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Delay=120}"
                                    TickFrequency="1"
                                    SmallChange="1"
                                    LargeChange="5"
                                    IsSnapToTickEnabled="True"
                                    IsMoveToPointEnabled="True"
                                    VerticalAlignment="Center"
                                    Margin="8,0,0,0"
                                    ToolTip="{Binding PagePositionText}"
                                    AutomationProperties.Name="Page scrubber"
                                    AutomationProperties.HelpText="Drag to jump to another page in the current document or archive." />
                            <TextBlock Text="{Binding PagePositionText}"
                                       Foreground="{StaticResource FloatingChromeTextBrush}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Margin="8,0"
                                       VerticalAlignment="Center" />
                            <Button Style="{StaticResource ToolbarButton}"
                                    Width="30"
                                    Height="26"
                                    FontSize="11"
                                    Content="&#xE76C;"
                                    Command="{Binding NextPageCommand}"
                                    ToolTip="Next page"
                                    AutomationProperties.Name="Next page" />
                        </StackPanel>
                    </Border>

                    <!-- V20-22: optional EXIF HUD. Reads from the same local metadata rows as the side panel. -->
                    <Border Style="{StaticResource FloatingPill}"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Margin="22,22,0,0"
                            MaxWidth="560"
                            Visibility="{Binding ShowMetadataHud, Converter={StaticResource BoolToVis}}"
                            AutomationProperties.Name="Metadata HUD"
                            AutomationProperties.LiveSetting="Polite">
                        <StackPanel>
                            <DockPanel LastChildFill="False">
                                <StackPanel Orientation="Horizontal"
                                            DockPanel.Dock="Left"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="&#xE946;"
                                               FontFamily="{StaticResource IconFontFamily}"
                                               FontSize="12"
                                               Foreground="{StaticResource AccentBrush}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,0" />
                                    <TextBlock Text="Photo metadata"
                                               Foreground="{StaticResource FloatingChromeTextBrush}"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                                <Button Command="{Binding ToggleMetadataHudCommand}"
                                        Content="&#xE711;"
                                        ToolTip="Hide metadata HUD"
                                        DockPanel.Dock="Right"
                                        Margin="16,-3,-7,-3"
                                        AutomationProperties.Name="Hide metadata HUD">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource ToolbarButton}">
                                            <Setter Property="Width" Value="28" />
                                            <Setter Property="Height" Value="26" />
                                            <Setter Property="FontSize" Value="10" />
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </DockPanel>

                            <ItemsControl ItemsSource="{Binding PhotoMetadataRows}"
                                          Margin="0,10,-6,-6"
                                          Visibility="{Binding PhotoMetadataRows.Count, Converter={StaticResource BoolToVis}}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource Badge}"
                                                Margin="0,0,6,6"
                                                MaxWidth="250">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Label}"
                                                           FontSize="10"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource OverlayBrush}"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,6,0" />
                                                <TextBlock Text="{Binding Value}"
                                                           FontSize="11"
                                                           Foreground="{StaticResource FloatingChromeTextBrush}"
                                                           TextTrimming="CharacterEllipsis"
                                                           MaxWidth="170"
                                                           ToolTip="{Binding Value}"
                                                           VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <StackPanel Orientation="Horizontal"
                                        Margin="0,10,0,0"
                                        Visibility="{Binding MetadataStatusText, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="&#xE946;"
                                           FontFamily="{StaticResource IconFontFamily}"
                                           FontSize="11"
                                           Foreground="{StaticResource OverlayBrush}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0" />
                                <TextBlock Text="{Binding MetadataStatusText}"
                                           Style="{StaticResource Text.Hint}"
                                           Foreground="{StaticResource FloatingChromeTextBrush}"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- OCR status — persistent while extraction is busy or selectable text is active. -->
                    <Border HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Margin="28,24,0,0"
                            MaxWidth="360"
                            Visibility="{Binding ShowOcrStatusPanel, Converter={StaticResource BoolToVis}}"
                            AutomationProperties.Name="Text extraction status"
                            AutomationProperties.LiveSetting="Polite">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource FloatingPill}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsOcrBusy}" Value="True">
                                        <Setter Property="BorderBrush" Value="{StaticResource YellowBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Width="32"
                                    Height="32"
                                    CornerRadius="{StaticResource Radius.Sm.CR}"
                                    BorderThickness="1"
                                    VerticalAlignment="Top"
                                    Margin="0,0,12,0">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#1F89B4FA" />
                                        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsOcrBusy}" Value="True">
                                                <Setter Property="Background" Value="{StaticResource WarningPanelBrush}" />
                                                <Setter Property="BorderBrush" Value="{StaticResource YellowBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="&#xE8EA;"
                                           FontFamily="{StaticResource IconFontFamily}"
                                           FontSize="13"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsOcrBusy}" Value="True">
                                                    <Setter Property="Foreground" Value="{StaticResource YellowBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding OcrStatusTitle}"
                                           Foreground="{StaticResource FloatingChromeTextBrush}"
                                           FontSize="12.5"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="{Binding OcrStatusDetail}"
                                           Foreground="{StaticResource SubtextBrush}"
                                           FontSize="11.5"
                                           LineHeight="16"
                                           TextWrapping="Wrap"
                                           Margin="0,3,0,0" />
                            </StackPanel>

                            <Button Grid.Column="2"
                                    Command="{Binding ExtractTextCommand}"
                                    Content="&#xE711;"
                                    Style="{StaticResource ToolbarButton}"
                                    ToolTip="{Binding OcrModeTooltip}"
                                    Margin="12,0,0,0"
                                    VerticalAlignment="Top"
                                    AutomationProperties.Name="{Binding OcrModeTooltip}" />
                        </Grid>
                    </Border>

                    <!-- First-run gesture hint — fades in + slides up, auto-dismisses after 2.4s -->
                    <Border HorizontalAlignment="Center"
                            VerticalAlignment="Bottom"
                            Margin="0,0,0,144"
                            Visibility="{Binding ShowGestureHint, Converter={StaticResource BoolToVis}}"
                            IsHitTestVisible="False"
                            AutomationProperties.LiveSetting="Polite">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource FloatingPill}">
                                <Setter Property="Opacity" Value="0" />
                                <Style.Triggers>
                                    <Trigger Property="IsVisible" Value="True">
                                        <Trigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                     From="0" To="1"
                                                                     Duration="{StaticResource Motion.Slow}">
                                                        <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </Trigger.EnterActions>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE7A5;"
                                       FontFamily="{StaticResource IconFontFamily}"
                                       FontSize="13"
                                       Foreground="{StaticResource AccentBrush}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0" />
                            <TextBlock Text="Scroll to zoom  ·  drag to pan  ·  double-click to fit"
                                       Foreground="{StaticResource FloatingChromeTextBrush}"
                                       FontSize="12"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <!-- V15-03: keyboard cheatsheet overlay — toggled by `?`, any key dismisses.
                         Sits above everything else in the viewport. Mouse passes through
                         everywhere except the card itself (IsHitTestVisible=False on the dimmer). -->
                    <Grid Visibility="{Binding ShowCheatsheet, Converter={StaticResource BoolToVis}}">
                        <Rectangle Fill="#CC000000" IsHitTestVisible="False" />
                        <Border Style="{StaticResource ElevatedCard}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                MaxWidth="540"
                                MaxHeight="520"
                                Padding="30,26,30,28">
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          CanContentScroll="False"
                                          Focusable="False">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource Text.Title}"
                                               Text="Keyboard shortcuts"
                                               HorizontalAlignment="Center" />
                                    <TextBlock Style="{StaticResource Text.Subtitle}"
                                               Text="Press any key to dismiss."
                                               HorizontalAlignment="Center"
                                               Margin="0,6,0,22" />

                                    <TextBlock Text="Navigate" Style="{StaticResource SectionLabel}" />
                                    <Grid Margin="0,0,0,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition />
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="← / →" />
                                        <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Previous / next image or book page" />
                                        <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="Home / End" />
                                        <TextBlock Grid.Row="1" Grid.Column="1" Style="{StaticResource MetaValue}" Text="First / last image or book page" />
                                        <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="Space / Bksp" />
                                        <TextBlock Grid.Row="2" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Next / previous image or book page" />
                                        <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="Mouse X1 / X2" />
                                        <TextBlock Grid.Row="3" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Previous / next image (5-button mouse)" />
                                        <TextBlock Grid.Row="4" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="F5" />
                                        <TextBlock Grid.Row="4" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Rescan folder" />
                                    </Grid>

                                    <TextBlock Text="View" Style="{StaticResource SectionLabel}" />
                                    <Grid Margin="0,0,0,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition />
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="Wheel" />
                                        <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Zoom about cursor" />
                                        <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="Shift + Wheel" />
                                        <TextBlock Grid.Row="1" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Pan horizontally" />
                                        <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="+ / −" />
                                        <TextBlock Grid.Row="2" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Zoom in / out" />
                                        <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="0 / 1" />
                                        <TextBlock Grid.Row="3" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Fit to viewport / 1:1 pixel" />
                                        <TextBlock Grid.Row="4" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="F11" />
                                        <TextBlock Grid.Row="4" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Toggle fullscreen" />
                                        <TextBlock Grid.Row="5" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="T" />
                                        <TextBlock Grid.Row="5" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Toggle filmstrip" />
                                        <TextBlock Grid.Row="6" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="I" />
                                        <TextBlock Grid.Row="6" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Toggle metadata HUD" />
                                        <TextBlock Grid.Row="7" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="C" />
                                        <TextBlock Grid.Row="7" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Toggle crop mode" />
                                        <TextBlock Grid.Row="8" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="Ctrl+Alt+D" />
                                        <TextBlock Grid.Row="8" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Toggle exposure brush" />
                                        <TextBlock Grid.Row="9" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="Ctrl+Alt+Y" />
                                        <TextBlock Grid.Row="9" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Toggle red-eye correction" />
                                    </Grid>

                                    <TextBlock Text="File" Style="{StaticResource SectionLabel}" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition />
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="Ctrl+O" />
                                        <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Open image" />
                                        <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="Ctrl+V" />
                                        <TextBlock Grid.Row="1" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Paste image from clipboard" />
                                        <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="Ctrl+Shift+S" />
                                        <TextBlock Grid.Row="2" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Save a copy" />
                                        <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="Ctrl+P" />
                                        <TextBlock Grid.Row="3" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Print current image" />
                                        <TextBlock Grid.Row="4" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="Del" />
                                        <TextBlock Grid.Row="4" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Send to Recycle Bin" />
                                        <TextBlock Grid.Row="5" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="Ctrl+Shift+R" />
                                        <TextBlock Grid.Row="5" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Reload current image" />
                                        <TextBlock Grid.Row="6" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="Ctrl+," />
                                        <TextBlock Grid.Row="6" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Settings" />
                                        <TextBlock Grid.Row="7" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="Ctrl+B" />
                                        <TextBlock Grid.Row="7" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Open reference board" />
                                        <TextBlock Grid.Row="8" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="Ctrl+Shift+D" />
                                        <TextBlock Grid.Row="8" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Open duplicate cleanup" />
                                        <TextBlock Grid.Row="9" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="Ctrl+Shift+H" />
                                        <TextBlock Grid.Row="9" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Open file health scan" />
                                        <TextBlock Grid.Row="10" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="Ctrl+Shift+T" />
                                        <TextBlock Grid.Row="10" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Open tag relationships" />
                                        <TextBlock Grid.Row="11" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="Ctrl+Shift+I" />
                                        <TextBlock Grid.Row="11" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Open import inbox" />
                                        <TextBlock Grid.Row="12" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="Ctrl+Shift+M" />
                                        <TextBlock Grid.Row="12" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Open macro actions" />
                                        <TextBlock Grid.Row="13" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="Ctrl+Shift+B" />
                                        <TextBlock Grid.Row="13" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Open batch processor" />
                                        <TextBlock Grid.Row="14" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="Ctrl+Shift+E" />
                                        <TextBlock Grid.Row="14" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Open edit history" />
                                        <TextBlock Grid.Row="15" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="Ctrl+Alt+R" />
                                        <TextBlock Grid.Row="15" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Open resize dialog" />
                                        <TextBlock Grid.Row="16" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="Ctrl+Alt+A" />
                                        <TextBlock Grid.Row="16" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Open adjustments" />
                                        <TextBlock Grid.Row="17" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="Enter" />
                                        <TextBlock Grid.Row="17" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Commit rename (in rename box)" />
                                        <TextBlock Grid.Row="18" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="Esc" />
                                        <TextBlock Grid.Row="18" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Revert rename / dismiss overlay / exit fullscreen" />
                                    </Grid>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>

                    <!-- Operation status — short live-region feedback for reload/export/edit work. -->
                    <Border HorizontalAlignment="Center"
                            VerticalAlignment="Top"
                            Margin="0,24,0,0"
                            MaxWidth="420"
                            Visibility="{Binding ShowOperationStatus, Converter={StaticResource BoolToVis}}"
                            AutomationProperties.Name="{Binding OperationStatusTitle}"
                            AutomationProperties.LiveSetting="Polite"
                            IsHitTestVisible="False">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource FloatingPill}">
                                <Setter Property="BorderBrush" Value="{StaticResource YellowBrush}" />
                                <Setter Property="Opacity" Value="0" />
                                <Style.Triggers>
                                    <Trigger Property="IsVisible" Value="True">
                                        <Trigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                     From="0" To="1"
                                                                     Duration="{StaticResource Motion.Base}">
                                                        <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </Trigger.EnterActions>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Width="32"
                                    Height="32"
                                    CornerRadius="{StaticResource Radius.Sm.CR}"
                                    BorderThickness="1"
                                    Background="{StaticResource WarningPanelBrush}"
                                    BorderBrush="{StaticResource YellowBrush}"
                                    VerticalAlignment="Center"
                                    Margin="0,0,12,0">
                                <TextBlock Text="&#xE895;"
                                           FontFamily="{StaticResource IconFontFamily}"
                                           FontSize="13"
                                           Foreground="{StaticResource YellowBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding OperationStatusTitle}"
                                           Foreground="{StaticResource FloatingChromeTextBrush}"
                                           FontSize="12.5"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="{Binding OperationStatusDetail}"
                                           Foreground="{StaticResource SubtextBrush}"
                                           FontSize="11.5"
                                           LineHeight="16"
                                           TextWrapping="Wrap"
                                           Margin="0,3,0,0" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Toast notification — elevated pill, fades on show via Opacity trigger -->
                    <Border x:Name="ToastHost"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Bottom"
                            Margin="0,0,0,88"
                            Visibility="{Binding ToastMessage, Converter={StaticResource BoolToVis}}"
                            AutomationProperties.LiveSetting="Polite">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource Toast}">
                                <Setter Property="Opacity" Value="0" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ToastTone}" Value="Success">
                                        <Setter Property="BorderBrush" Value="{StaticResource GreenBrush}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ToastTone}" Value="Warning">
                                        <Setter Property="BorderBrush" Value="{StaticResource YellowBrush}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ToastTone}" Value="Error">
                                        <Setter Property="BorderBrush" Value="{StaticResource RedBrush}" />
                                    </DataTrigger>
                                    <Trigger Property="IsVisible" Value="True">
                                        <Trigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                     From="0" To="1"
                                                                     Duration="{StaticResource Motion.Base}">
                                                        <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </Trigger.EnterActions>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="{StaticResource IconFontFamily}"
                                       FontSize="13"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="&#xE930;" />
                                        <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ToastTone}" Value="Success">
                                                <Setter Property="Text" Value="&#xE73E;" />
                                                <Setter Property="Foreground" Value="{StaticResource GreenBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding ToastTone}" Value="Warning">
                                                <Setter Property="Text" Value="&#xE783;" />
                                                <Setter Property="Foreground" Value="{StaticResource YellowBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding ToastTone}" Value="Error">
                                                <Setter Property="Text" Value="&#xE783;" />
                                                <Setter Property="Foreground" Value="{StaticResource RedBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Text="{Binding ToastMessage}"
                                       Foreground="{StaticResource FloatingChromeTextBrush}"
                                       FontSize="13"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </Grid>

            </Grid>

            <!-- Bottom toolbar — premium horizontal chrome bar with 1-px top highlight.
                 V20-32: peek-mode hides the entire toolbar so the image fills the window with
                 zero chrome. The Width="Auto" outer column on the side panel + IsFullscreen=true
                 binding handles the right-side panel; this Visibility handles the toolbar row. -->
            <Grid Grid.Row="1"
                  Visibility="{Binding IsPeekMode, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="1" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <!-- Subtle top highlight: sits just inside the divider line, gives the toolbar a
                     gently lit edge like polished macOS / Win11 chrome. -->
                <Border Grid.Row="0" Height="1" Background="#12CDD6F4" />
                <Border Grid.Row="1"
                        Background="{StaticResource MantleBrush}"
                        BorderBrush="{StaticResource HairlineBrush}"
                        BorderThickness="0,1,0,0">
                    <Grid Margin="20,10,20,12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Margin="0,0,0,10"
                                Visibility="{Binding ShowFilmstrip, Converter={StaticResource BoolToVis}}">
                            <ListBox x:Name="FilmstripItems"
                                     ItemsSource="{Binding FolderPreviewItems}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Padding="0,0,0,4"
                                     MaxHeight="110"
                                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                     ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                     ScrollViewer.CanContentScroll="True"
                                     VirtualizingPanel.IsVirtualizing="True"
                                     VirtualizingPanel.VirtualizationMode="Recycling"
                                     VirtualizingPanel.CacheLength="2,2"
                                     VirtualizingPanel.CacheLengthUnit="Item"
                                     KeyboardNavigation.DirectionalNavigation="Cycle"
                                     KeyboardNavigation.TabNavigation="Continue"
                                     AutomationProperties.Name="Bottom folder filmstrip">
                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <VirtualizingStackPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Padding" Value="0" />
                                            <Setter Property="Margin" Value="0" />
                                            <Setter Property="Focusable" Value="False" />
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListBoxItem">
                                                        <ContentPresenter />
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Button Command="{Binding DataContext.OpenPreviewItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    Loaded="PreviewThumbnail_Loaded"
                                                    Width="78"
                                                    MinHeight="88"
                                                    Margin="0,0,7,0"
                                                    Padding="4"
                                                    HorizontalContentAlignment="Stretch"
                                                    VerticalContentAlignment="Stretch"
                                                    ToolTip="{Binding Path}"
                                                    Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    AutomationProperties.Name="{Binding FileName}"
                                                    AutomationProperties.HelpText="{Binding PositionText}"
                                                    AutomationProperties.ItemStatus="{Binding PositionText}">
                                                <Button.ContextMenu>
                                                    <ContextMenu Style="{StaticResource ViewportContextMenu}">
                                                        <MenuItem Header="Open"
                                                                  Command="{Binding PlacementTarget.Tag.OpenPreviewItemCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                                            <MenuItem.Icon>
                                                                <TextBlock Style="{StaticResource MenuItemIcon}" Text="&#xE8E5;" />
                                                            </MenuItem.Icon>
                                                        </MenuItem>
                                                        <MenuItem Header="Reveal in Explorer"
                                                                  Command="{Binding PlacementTarget.Tag.RevealPreviewItemCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                                            <MenuItem.Icon>
                                                                <TextBlock Style="{StaticResource MenuItemIcon}" Text="&#xE838;" />
                                                            </MenuItem.Icon>
                                                        </MenuItem>
                                                        <MenuItem Header="Copy path"
                                                                  Command="{Binding PlacementTarget.Tag.CopyPreviewPathCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                                            <MenuItem.Icon>
                                                                <TextBlock Style="{StaticResource MenuItemIcon}" Text="&#xE8C8;" />
                                                            </MenuItem.Icon>
                                                        </MenuItem>
                                                    </ContextMenu>
                                                </Button.ContextMenu>
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource ChromeButton}">
                                                        <Setter Property="Background" Value="{StaticResource Surface0Brush}" />
                                                        <Setter Property="BorderBrush" Value="{StaticResource HairlineBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                                                <Setter Property="Background" Value="#1F89B4FA" />
                                                                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                            </DataTrigger>
                                                            <Trigger Property="IsKeyboardFocused" Value="True">
                                                                <Setter Property="Background" Value="#2689B4FA" />
                                                                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                                <StackPanel>
                                                    <Border Height="48"
                                                            CornerRadius="{StaticResource Radius.Sm.CR}"
                                                            Background="{StaticResource ViewportBrush}"
                                                            BorderBrush="{StaticResource HairlineBrush}"
                                                            BorderThickness="1"
                                                            ClipToBounds="True">
                                                        <Grid>
                                                            <Image Source="{Binding Thumbnail}"
                                                                   Stretch="UniformToFill"
                                                                   RenderOptions.BitmapScalingMode="HighQuality"
                                                                   Visibility="{Binding HasThumbnail, Converter={StaticResource BoolToVis}}" />
                                                            <TextBlock Text="&#xEB9F;"
                                                                       FontFamily="{StaticResource IconFontFamily}"
                                                                       FontSize="16"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"
                                                                       Visibility="{Binding HasThumbnail, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="{x:Type TextBlock}">
                                                                        <Setter Property="Foreground" Value="{StaticResource OverlayBrush}" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding ThumbnailFailed}" Value="True">
                                                                                <Setter Property="Text" Value="&#xE783;" />
                                                                                <Setter Property="Foreground" Value="{StaticResource YellowBrush}" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </Grid>
                                                    </Border>
                                                    <TextBlock Text="{Binding FileName}"
                                                               Foreground="{StaticResource TextBrush}"
                                                               FontSize="10.5"
                                                               FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis"
                                                               Margin="1,5,1,0" />
                                                    <TextBlock Text="{Binding PositionText}"
                                                               Foreground="{StaticResource OverlayBrush}"
                                                               FontSize="10"
                                                               Margin="1,1,1,0" />
                                                </StackPanel>
                                            </Button>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                        </Border>

                        <!-- Current file info gets its own row so command clusters never collide on narrow widths. -->
                        <Grid Grid.Row="1"
                              MinHeight="20"
                              Margin="0,0,0,9">
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Visibility="{Binding HasImage, Converter={StaticResource BoolToVis}}">
                                <Button Style="{StaticResource ChromeButton}"
                                        Click="FolderSortButton_Click"
                                        Padding="9,4"
                                        MinHeight="26"
                                        Margin="0,0,10,0"
                                        ToolTip="{Binding FolderSortTooltip}"
                                        AutomationProperties.Name="Folder sort"
                                        AutomationProperties.HelpText="{Binding FolderSortTooltip}">
                                    <Button.ContextMenu>
                                        <ContextMenu Style="{StaticResource ViewportContextMenu}">
                                            <MenuItem Header="Name (natural)"
                                                      Command="{Binding PlacementTarget.DataContext.SetFolderSortCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="NaturalName"
                                                      IsCheckable="True"
                                                      IsChecked="{Binding PlacementTarget.DataContext.CurrentSortMode, RelativeSource={RelativeSource AncestorType=ContextMenu}, Converter={StaticResource SortModeMatches}, ConverterParameter=NaturalName, Mode=OneWay}" />
                                            <MenuItem Header="Name (Z to A)"
                                                      Command="{Binding PlacementTarget.DataContext.SetFolderSortCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="NameDescending"
                                                      IsCheckable="True"
                                                      IsChecked="{Binding PlacementTarget.DataContext.CurrentSortMode, RelativeSource={RelativeSource AncestorType=ContextMenu}, Converter={StaticResource SortModeMatches}, ConverterParameter=NameDescending, Mode=OneWay}" />
                                            <Separator />
                                            <MenuItem Header="Modified (newest first)"
                                                      Command="{Binding PlacementTarget.DataContext.SetFolderSortCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="ModifiedNewest"
                                                      IsCheckable="True"
                                                      IsChecked="{Binding PlacementTarget.DataContext.CurrentSortMode, RelativeSource={RelativeSource AncestorType=ContextMenu}, Converter={StaticResource SortModeMatches}, ConverterParameter=ModifiedNewest, Mode=OneWay}" />
                                            <MenuItem Header="Modified (oldest first)"
                                                      Command="{Binding PlacementTarget.DataContext.SetFolderSortCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="ModifiedOldest"
                                                      IsCheckable="True"
                                                      IsChecked="{Binding PlacementTarget.DataContext.CurrentSortMode, RelativeSource={RelativeSource AncestorType=ContextMenu}, Converter={StaticResource SortModeMatches}, ConverterParameter=ModifiedOldest, Mode=OneWay}" />
                                            <MenuItem Header="Created (newest first)"
                                                      Command="{Binding PlacementTarget.DataContext.SetFolderSortCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="CreatedNewest"
                                                      IsCheckable="True"
                                                      IsChecked="{Binding PlacementTarget.DataContext.CurrentSortMode, RelativeSource={RelativeSource AncestorType=ContextMenu}, Converter={StaticResource SortModeMatches}, ConverterParameter=CreatedNewest, Mode=OneWay}" />
                                            <MenuItem Header="Created (oldest first)"
                                                      Command="{Binding PlacementTarget.DataContext.SetFolderSortCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="CreatedOldest"
                                                      IsCheckable="True"
                                                      IsChecked="{Binding PlacementTarget.DataContext.CurrentSortMode, RelativeSource={RelativeSource AncestorType=ContextMenu}, Converter={StaticResource SortModeMatches}, ConverterParameter=CreatedOldest, Mode=OneWay}" />
                                            <Separator />
                                            <MenuItem Header="Size (largest first)"
                                                      Command="{Binding PlacementTarget.DataContext.SetFolderSortCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="SizeLargest"
                                                      IsCheckable="True"
                                                      IsChecked="{Binding PlacementTarget.DataContext.CurrentSortMode, RelativeSource={RelativeSource AncestorType=ContextMenu}, Converter={StaticResource SortModeMatches}, ConverterParameter=SizeLargest, Mode=OneWay}" />
                                            <MenuItem Header="Size (smallest first)"
                                                      Command="{Binding PlacementTarget.DataContext.SetFolderSortCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="SizeSmallest"
                                                      IsCheckable="True"
                                                      IsChecked="{Binding PlacementTarget.DataContext.CurrentSortMode, RelativeSource={RelativeSource AncestorType=ContextMenu}, Converter={StaticResource SortModeMatches}, ConverterParameter=SizeSmallest, Mode=OneWay}" />
                                            <MenuItem Header="Type, then name"
                                                      Command="{Binding PlacementTarget.DataContext.SetFolderSortCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="ExtensionThenName"
                                                      IsCheckable="True"
                                                      IsChecked="{Binding PlacementTarget.DataContext.CurrentSortMode, RelativeSource={RelativeSource AncestorType=ContextMenu}, Converter={StaticResource SortModeMatches}, ConverterParameter=ExtensionThenName, Mode=OneWay}" />
                                        </ContextMenu>
                                    </Button.ContextMenu>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="&#xE8CB;"
                                                   FontFamily="{StaticResource IconFontFamily}"
                                                   FontSize="11"
                                                   Margin="0,0,6,0"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding FolderSortLabel}"
                                                   FontSize="11.5"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                                <TextBlock Text="{Binding CurrentFileName}"
                                           Foreground="{StaticResource TextBrush}"
                                           FontWeight="SemiBold"
                                           FontSize="13"
                                           MaxWidth="260"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="  ·  "
                                           Foreground="{StaticResource OverlayBrush}"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="{Binding DimensionsText}"
                                           Foreground="{StaticResource SubtextBrush}"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="  ·  "
                                           Foreground="{StaticResource OverlayBrush}"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="{Binding FileSizeText}"
                                           Foreground="{StaticResource SubtextBrush}"
                                           VerticalAlignment="Center" />

                                <Border Margin="10,0,0,0"
                                        Padding="8,2"
                                        CornerRadius="{StaticResource Radius.Sm.CR}"
                                        Background="#2ACBA6F7"
                                        BorderBrush="{StaticResource MauveBrush}"
                                        BorderThickness="1"
                                        VerticalAlignment="Center"
                                        Visibility="{Binding HasMultiplePages, Converter={StaticResource BoolToVis}}"
                                        AutomationProperties.Name="Paged file">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE8A5;"
                                                   FontFamily="{StaticResource IconFontFamily}"
                                                   FontSize="10"
                                                   Foreground="{StaticResource MauveBrush}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,5,0" />
                                        <TextBlock Text="{Binding PagePositionText}"
                                                   FontSize="10.5"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource MauveBrush}"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Border>

                                <!-- Animated-image chip — only surfaces when CurrentAnimation is non-null.
                                     Small green pill so the GIF/APNG/animated-WebP state reads at a glance
                                     without competing with the primary command row. -->
                                <Border Margin="10,0,0,0"
                                        Padding="8,2"
                                        CornerRadius="{StaticResource Radius.Sm.CR}"
                                        Background="#2AA6E3A1"
                                        BorderBrush="{StaticResource GreenBrush}"
                                        BorderThickness="1"
                                        VerticalAlignment="Center"
                                        Visibility="{Binding IsAnimated, Converter={StaticResource BoolToVis}}"
                                        AutomationProperties.Name="Animated image">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE768;"
                                                   FontFamily="{StaticResource IconFontFamily}"
                                                   FontSize="10"
                                                   Foreground="{StaticResource GreenBrush}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,5,0" />
                                        <TextBlock Text="{Binding AnimationFrameCountText}"
                                                   FontSize="10.5"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource GreenBrush}"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Visibility="{Binding HasImage, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}">
                                <TextBlock Text="Ready"
                                           Foreground="{StaticResource TextBrush}"
                                           FontWeight="SemiBold"
                                           FontSize="13"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="  ·  "
                                           Foreground="{StaticResource OverlayBrush}"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="Open or drop a supported file to start reviewing."
                                           Foreground="{StaticResource SubtextBrush}"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Grid>

                        <!-- Wrapping command row preserves all actions instead of clipping at the minimum width. -->
                        <WrapPanel Grid.Row="2"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center">
                            <Button Style="{StaticResource ToolbarButton}" Command="{Binding PrevCommand}" Content="&#xE76B;" ToolTip="Previous (Left)" AutomationProperties.Name="Previous image" />
                            <Button Style="{StaticResource ToolbarButton}" Command="{Binding RotateCcwCommand}" Content="&#xE7AD;" ToolTip="Rotate left" Margin="4,0,0,0" AutomationProperties.Name="Rotate left" />
                            <Button Style="{StaticResource ToolbarButton}" Command="{Binding OpenCommand}" Content="&#xE8E5;" ToolTip="Open…" Margin="4,0,0,0" AutomationProperties.Name="Open image" />
                            <Button Style="{StaticResource ToolbarButton}" Command="{Binding RotateCwCommand}" Content="&#xE7AC;" ToolTip="Rotate right" Margin="4,0,0,0" AutomationProperties.Name="Rotate right" />
                            <Button Style="{StaticResource ToolbarButton}" Command="{Binding NextCommand}" Content="&#xE76C;" ToolTip="Next (Right)" Margin="4,0,0,0" AutomationProperties.Name="Next image" />
                            <Button Command="{Binding ToggleFilmstripCommand}"
                                    Content="&#xEB9F;"
                                    ToolTip="{Binding FilmstripToggleTooltip}"
                                    Margin="4,0,0,0"
                                    Visibility="{Binding CanToggleFilmstrip, Converter={StaticResource BoolToVis}}"
                                    AutomationProperties.Name="Toggle filmstrip">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource ToolbarButton}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsFilmstripVisible}" Value="True">
                                                <Setter Property="Background" Value="#1F89B4FA" />
                                                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Command="{Binding ToggleMetadataHudCommand}"
                                    Content="&#xE946;"
                                    ToolTip="{Binding MetadataHudToggleTooltip}"
                                    Margin="4,0,0,0"
                                    Visibility="{Binding CanToggleMetadataHud, Converter={StaticResource BoolToVis}}"
                                    AutomationProperties.Name="Toggle metadata HUD">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource ToolbarButton}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsMetadataHudVisible}" Value="True">
                                                <Setter Property="Background" Value="#1F89B4FA" />
                                                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Command="{Binding ExtractTextCommand}"
                                    Content="&#xE8EA;"
                                    ToolTip="{Binding OcrModeTooltip}"
                                    Margin="4,0,0,0"
                                    Visibility="{Binding HasImage, Converter={StaticResource BoolToVis}}"
                                    AutomationProperties.Name="Extract text">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource ToolbarButton}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsOcrMode}" Value="True">
                                                <Setter Property="Background" Value="#1F89B4FA" />
                                                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsOcrBusy}" Value="True">
                                                <Setter Property="Background" Value="{StaticResource WarningPanelBrush}" />
                                                <Setter Property="BorderBrush" Value="{StaticResource YellowBrush}" />
                                                <Setter Property="Foreground" Value="{StaticResource YellowBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Border Width="1"
                                    Height="22"
                                    Background="{StaticResource HairlineBrush}"
                                    Margin="12,6"
                                    Visibility="{Binding HasMultiplePages, Converter={StaticResource BoolToVis}}" />
                            <Button Style="{StaticResource ToolbarButton}"
                                    Command="{Binding PrevPageCommand}"
                                    Content="&#xE76B;"
                                    ToolTip="Previous page"
                                    AutomationProperties.Name="Previous page"
                                    Visibility="{Binding HasMultiplePages, Converter={StaticResource BoolToVis}}" />
                            <Button Style="{StaticResource ToolbarButton}"
                                    Command="{Binding NextPageCommand}"
                                    Content="&#xE76C;"
                                    ToolTip="Next page"
                                    Margin="4,0,0,0"
                                    AutomationProperties.Name="Next page"
                                    Visibility="{Binding HasMultiplePages, Converter={StaticResource BoolToVis}}" />
                            <Border Width="1" Height="22" Background="{StaticResource HairlineBrush}" Margin="12,6" />
                            <Button Style="{StaticResource ToolbarButton}" Command="{Binding DeleteCommand}" Content="&#xE74D;" ToolTip="Delete (Recycle Bin)" AutomationProperties.Name="Send image to Recycle Bin" />
                            <Border Width="1" Height="22" Background="{StaticResource HairlineBrush}" Margin="12,6" />
                            <Button Style="{StaticResource ToolbarButton}" Command="{Binding SaveAsCopyCommand}" Content="&#xE74E;" ToolTip="Save a copy (Ctrl+Shift+S)" AutomationProperties.Name="Save a copy" />
                            <Button Style="{StaticResource ToolbarButton}" Command="{Binding PrintCommand}" Content="&#xE749;" ToolTip="Print (Ctrl+P)" Margin="4,0,0,0" AutomationProperties.Name="Print image" />
                            <Border Width="1" Height="22" Background="{StaticResource HairlineBrush}" Margin="12,6" />
                            <Button Style="{StaticResource ToolbarButton}" Command="{Binding RevealCommand}" Content="&#xE838;" ToolTip="Reveal in Explorer" AutomationProperties.Name="Reveal image in Explorer" />
                            <Button Style="{StaticResource ToolbarButton}" Command="{Binding CopyPathCommand}" Content="&#xE8C8;" ToolTip="Copy path" Margin="4,0,0,0" AutomationProperties.Name="Copy file path" />
                            <Button Style="{StaticResource ToolbarButton}" Command="{Binding StripLocationCommand}" Content="&#xE707;" ToolTip="Strip GPS location from file" Margin="4,0,0,0" AutomationProperties.Name="Strip GPS location" />
                            <Button Style="{StaticResource ToolbarButton}" Command="{Binding RefreshCommand}" Content="&#xE72C;" ToolTip="Refresh folder (F5)" Margin="4,0,0,0" AutomationProperties.Name="Refresh folder" />
                        </WrapPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- ============ RIGHT: Rename + Recent + Details panel ============ -->
        <Border Grid.Column="1"
                Width="360"
                Visibility="{Binding IsFullscreen, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}"
                Background="{StaticResource MantleBrush}"
                BorderBrush="{StaticResource HairlineBrush}"
                BorderThickness="1,0,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0">
                <StackPanel Margin="22,22,22,28">

                    <!-- Panel header -->
                    <Grid Margin="0,0,0,22">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Style="{StaticResource Text.Display}"
                                       Text="Images" />
                            <TextBlock Style="{StaticResource Text.Subtitle}"
                                       Text="Review, rename, and move through a folder without breaking flow."
                                       Margin="0,6,0,0" />
                        </StackPanel>
                        <!-- V15-06: click the info icon for the About dialog. Keeps the header
                             visually clean — no visible button chrome, just an accent on hover. -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top" Margin="8,0,0,0">
                            <Button Command="{Binding SettingsCommand}"
                                    Style="{StaticResource ToolbarButton}"
                                    Content="&#xE713;"
                                    ToolTip="Settings (Ctrl+,)"
                                    AutomationProperties.Name="Settings" />
                            <Button Command="{Binding AboutCommand}"
                                    Style="{StaticResource ToolbarButton}"
                                    Content="&#xE946;"
                                    ToolTip="About Images"
                                    AutomationProperties.Name="About Images"
                                    Margin="4,0,0,0" />
                        </StackPanel>
                    </Grid>

                    <Border Style="{StaticResource Card}"
                            Background="#1F89B4FA"
                            BorderBrush="{StaticResource AccentBrush}"
                            Margin="0,0,0,20"
                            Visibility="{Binding HasUpdateAvailable, Converter={StaticResource BoolToVis}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="&#xE895;"
                                       FontFamily="{StaticResource IconFontFamily}"
                                       FontSize="14"
                                       Foreground="{StaticResource AccentBrush}"
                                       Margin="0,1,10,0"
                                       VerticalAlignment="Top" />
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{Binding LatestUpdateTag, StringFormat=Update {0} is available}"
                                           FontSize="12.5"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextBrush}" />
                                <TextBlock Text="Open the release page when you are ready to install it."
                                           Style="{StaticResource Text.Hint}"
                                           Margin="0,3,0,0" />
                            </StackPanel>
                            <Button Grid.Column="2"
                                    Command="{Binding OpenLatestUpdateCommand}"
                                    Style="{StaticResource ChromeButton}"
                                    Padding="12,4"
                                    MinHeight="28"
                                    Margin="12,0,0,0"
                                    VerticalAlignment="Center"
                                    AutomationProperties.Name="View available update">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE8A7;"
                                               FontFamily="{StaticResource IconFontFamily}"
                                               FontSize="11"
                                               Margin="0,0,7,0"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="View" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource Card}"
                            BorderBrush="{StaticResource AccentBrush}"
                            Margin="0,0,0,20"
                            Visibility="{Binding IsCheckingForUpdates, Converter={StaticResource BoolToVis}}"
                            AutomationProperties.Name="Update check status"
                            AutomationProperties.LiveSetting="Polite">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0"
                                    Width="32"
                                    Height="32"
                                    CornerRadius="{StaticResource Radius.Sm.CR}"
                                    BorderThickness="1"
                                    Background="#1F89B4FA"
                                    BorderBrush="{StaticResource AccentBrush}"
                                    VerticalAlignment="Top"
                                    Margin="0,0,12,0">
                                <TextBlock Text="&#xE895;"
                                           FontFamily="{StaticResource IconFontFamily}"
                                           FontSize="13"
                                           Foreground="{StaticResource AccentBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Checking for updates"
                                           Style="{StaticResource Text.Caption}"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextBrush}" />
                                <TextBlock Text="{Binding UpdateCheckStatusText}"
                                           Style="{StaticResource Text.Hint}"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Margin="0,0,0,20"
                            Visibility="{Binding HasSecondaryStatus, Converter={StaticResource BoolToVis}}"
                            AutomationProperties.Name="{Binding SecondaryStatusTitle}"
                            AutomationProperties.LiveSetting="Polite">
                        <Border.Style>
                            <Style TargetType="{x:Type Border}" BasedOn="{StaticResource Card}">
                                <Setter Property="BorderBrush" Value="{StaticResource HairlineBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SecondaryStatusTone}" Value="Info">
                                        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding SecondaryStatusTone}" Value="Success">
                                        <Setter Property="BorderBrush" Value="{StaticResource GreenBrush}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding SecondaryStatusTone}" Value="Warning">
                                        <Setter Property="Background" Value="{StaticResource WarningPanelBrush}" />
                                        <Setter Property="BorderBrush" Value="{StaticResource YellowBrush}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding SecondaryStatusTone}" Value="Error">
                                        <Setter Property="BorderBrush" Value="{StaticResource RedBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Width="32"
                                    Height="32"
                                    CornerRadius="{StaticResource Radius.Sm.CR}"
                                    BorderThickness="1"
                                    VerticalAlignment="Top"
                                    Margin="0,0,12,0">
                                <Border.Style>
                                    <Style TargetType="{x:Type Border}">
                                        <Setter Property="Background" Value="#1F89B4FA" />
                                        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SecondaryStatusTone}" Value="Success">
                                                <Setter Property="BorderBrush" Value="{StaticResource GreenBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding SecondaryStatusTone}" Value="Warning">
                                                <Setter Property="Background" Value="{StaticResource WarningPanelBrush}" />
                                                <Setter Property="BorderBrush" Value="{StaticResource YellowBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding SecondaryStatusTone}" Value="Error">
                                                <Setter Property="BorderBrush" Value="{StaticResource RedBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>

                                <TextBlock Text="{Binding SecondaryStatusIcon}"
                                           FontFamily="{StaticResource IconFontFamily}"
                                           FontSize="13"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="{x:Type TextBlock}">
                                            <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SecondaryStatusTone}" Value="Success">
                                                    <Setter Property="Foreground" Value="{StaticResource GreenBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding SecondaryStatusTone}" Value="Warning">
                                                    <Setter Property="Foreground" Value="{StaticResource YellowBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding SecondaryStatusTone}" Value="Error">
                                                    <Setter Property="Foreground" Value="{StaticResource RedBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{Binding SecondaryStatusTitle}"
                                           Style="{StaticResource Text.Caption}"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextBrush}" />
                                <TextBlock Text="{Binding SecondaryStatusDetail}"
                                           Style="{StaticResource Text.Hint}"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- FOLDER PREVIEW fallback — remains in the side panel when the bottom
                         filmstrip is hidden so thumbnail jumping is never lost. -->
                    <StackPanel Visibility="{Binding ShowSideFolderPreview, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Folder preview" Style="{StaticResource SectionLabel}" />
                        <ListBox x:Name="SidePreviewItems"
                                 ItemsSource="{Binding FolderPreviewItems}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Padding="0,0,0,6"
                                 Margin="0,0,0,16"
                                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                 ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                 ScrollViewer.CanContentScroll="True"
                                 VirtualizingPanel.IsVirtualizing="True"
                                 VirtualizingPanel.VirtualizationMode="Recycling"
                                 VirtualizingPanel.CacheLength="2,2"
                                 VirtualizingPanel.CacheLengthUnit="Item"
                                 KeyboardNavigation.DirectionalNavigation="Cycle"
                                 KeyboardNavigation.TabNavigation="Continue"
                                 AutomationProperties.Name="Folder preview thumbnails">
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <VirtualizingStackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="Margin" Value="0" />
                                        <Setter Property="Focusable" Value="False" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <ContentPresenter />
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Button Command="{Binding DataContext.OpenPreviewItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Loaded="PreviewThumbnail_Loaded"
                                                Width="88"
                                                MinHeight="104"
                                                Margin="0,0,8,0"
                                                Padding="5"
                                                HorizontalContentAlignment="Stretch"
                                                VerticalContentAlignment="Stretch"
                                                ToolTip="{Binding Path}"
                                                Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}"
                                                AutomationProperties.Name="{Binding FileName}"
                                                AutomationProperties.HelpText="{Binding PositionText}"
                                                AutomationProperties.ItemStatus="{Binding PositionText}">
                                            <Button.ContextMenu>
                                                <ContextMenu Style="{StaticResource ViewportContextMenu}">
                                                    <MenuItem Header="Open"
                                                              Command="{Binding PlacementTarget.Tag.OpenPreviewItemCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                                        <MenuItem.Icon>
                                                            <TextBlock Style="{StaticResource MenuItemIcon}" Text="&#xE8E5;" />
                                                        </MenuItem.Icon>
                                                    </MenuItem>
                                                    <MenuItem Header="Reveal in Explorer"
                                                              Command="{Binding PlacementTarget.Tag.RevealPreviewItemCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                                        <MenuItem.Icon>
                                                            <TextBlock Style="{StaticResource MenuItemIcon}" Text="&#xE838;" />
                                                        </MenuItem.Icon>
                                                    </MenuItem>
                                                    <MenuItem Header="Copy path"
                                                              Command="{Binding PlacementTarget.Tag.CopyPreviewPathCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                                        <MenuItem.Icon>
                                                            <TextBlock Style="{StaticResource MenuItemIcon}" Text="&#xE8C8;" />
                                                        </MenuItem.Icon>
                                                    </MenuItem>
                                                </ContextMenu>
                                            </Button.ContextMenu>
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource ChromeButton}">
                                                    <Setter Property="Background" Value="{StaticResource Surface0Brush}" />
                                                    <Setter Property="BorderBrush" Value="{StaticResource HairlineBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                                            <Setter Property="Background" Value="#1F89B4FA" />
                                                            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                        </DataTrigger>
                                                        <Trigger Property="IsKeyboardFocused" Value="True">
                                                            <Setter Property="Background" Value="#2689B4FA" />
                                                            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <StackPanel>
                                                <Border Height="56"
                                                        CornerRadius="{StaticResource Radius.Sm.CR}"
                                                        Background="{StaticResource ViewportBrush}"
                                                        BorderBrush="{StaticResource HairlineBrush}"
                                                        BorderThickness="1"
                                                        ClipToBounds="True">
                                                    <Grid>
                                                        <Image Source="{Binding Thumbnail}"
                                                               Stretch="UniformToFill"
                                                               RenderOptions.BitmapScalingMode="HighQuality"
                                                               Visibility="{Binding HasThumbnail, Converter={StaticResource BoolToVis}}" />
                                                        <TextBlock Text="&#xEB9F;"
                                                                   FontFamily="{StaticResource IconFontFamily}"
                                                                   FontSize="18"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"
                                                                   Visibility="{Binding HasThumbnail, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}">
                                                            <TextBlock.Style>
                                                                <Style TargetType="{x:Type TextBlock}">
                                                                    <Setter Property="Foreground" Value="{StaticResource OverlayBrush}" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding ThumbnailFailed}" Value="True">
                                                                            <Setter Property="Text" Value="&#xE783;" />
                                                                            <Setter Property="Foreground" Value="{StaticResource YellowBrush}" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Grid>
                                                </Border>
                                                <TextBlock Text="{Binding FileName}"
                                                           Foreground="{StaticResource TextBrush}"
                                                           FontSize="11.5"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis"
                                                           Margin="1,7,1,0" />
                                                <TextBlock Text="{Binding PositionText}"
                                                           Foreground="{StaticResource OverlayBrush}"
                                                           FontSize="10.5"
                                                           Margin="1,1,1,0" />
                                            </StackPanel>
                                        </Button>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                    </StackPanel>

                    <!-- RENAME section -->
                    <TextBlock Text="Rename" Style="{StaticResource SectionLabel}" />

                    <!-- Stem editor + locked extension chip -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="StemEditor"
                                 Grid.Column="0"
                                 Text="{Binding EditableStem, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="15"
                                 IsEnabled="{Binding HasImage}"
                                 PreviewKeyDown="StemEditor_PreviewKeyDown"
                                 AutomationProperties.Name="File name without extension" />
                        <Button Grid.Column="1"
                                Margin="10,0,0,0"
                                Padding="11,0"
                                MinWidth="72"
                                Height="36"
                                Command="{Binding UnlockExtensionCommand}"
                                IsEnabled="{Binding HasImage}"
                                ToolTip="{Binding ExtensionLockHelpText}"
                                AutomationProperties.Name="{Binding ExtensionLockText}"
                                AutomationProperties.HelpText="{Binding ExtensionLockHelpText}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ChromeButton}">
                                    <Style.Triggers>
                                        <!-- Locked (default) already carries the chrome treatment.
                                             Unlocked echoes the YellowBrush warning accent from the
                                             panel below so the two read as the same state. -->
                                        <DataTrigger Binding="{Binding IsExtensionUnlocked}" Value="True">
                                            <Setter Property="BorderBrush" Value="{StaticResource YellowBrush}" />
                                            <Setter Property="Background" Value="{StaticResource WarningPanelBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <!-- Locked padlock -->
                                <TextBlock Text="&#xE72E;"
                                           FontFamily="{StaticResource IconFontFamily}"
                                           FontSize="11"
                                           VerticalAlignment="Center"
                                           Margin="0,0,7,0"
                                           Foreground="{StaticResource SubtextBrush}"
                                           Visibility="{Binding IsExtensionUnlocked, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}" />
                                <!-- Unlocked pencil-edit -->
                                <TextBlock Text="&#xE70F;"
                                           FontFamily="{StaticResource IconFontFamily}"
                                           FontSize="11"
                                           VerticalAlignment="Center"
                                           Margin="0,0,7,0"
                                           Foreground="{StaticResource YellowBrush}"
                                           Visibility="{Binding IsExtensionUnlocked, Converter={StaticResource BoolToVis}}" />
                                <TextBlock Text="{Binding Extension}"
                                           VerticalAlignment="Center"
                                           FontFamily="Consolas"
                                           FontSize="13" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <!-- Extension-unlocked warning + editor -->
                    <Border Margin="0,12,0,0"
                            Padding="13,11"
                            Background="{StaticResource WarningPanelBrush}"
                            BorderBrush="{StaticResource YellowBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource Radius.Sm.CR}"
                            Visibility="{Binding IsExtensionUnlocked, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <TextBlock Text="Changing the extension only renames the file. Use a supported Images format; this will not convert the image."
                                       Foreground="{StaticResource YellowBrush}"
                                       FontSize="12"
                                       LineHeight="17"
                                       TextWrapping="Wrap" />
                            <TextBox Text="{Binding Extension, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,8,0,0"
                                     FontFamily="Consolas"
                                     AutomationProperties.Name="File extension" />
                        </StackPanel>
                    </Border>

                    <!-- Live status card — preview + colored status dot -->
                    <Border Style="{StaticResource StatusCard}" Margin="0,14,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- Status dot: color transitions are DataTrigger SolidColorBrush swaps.
                                 The success-pulse ScaleTransform grows on 'Saved' via a triggered
                                 storyboard so a rename commit feels confirmed, not silent. -->
                            <Ellipse Grid.Column="0" RenderTransformOrigin="0.5,0.5">
                                <Ellipse.RenderTransform>
                                    <ScaleTransform ScaleX="1" ScaleY="1" />
                                </Ellipse.RenderTransform>
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse" BasedOn="{StaticResource StatusDot}">
                                        <Setter Property="Fill" Value="{StaticResource OverlayBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding RenameStatus}" Value="Pending">
                                                <Setter Property="Fill" Value="{StaticResource YellowBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding RenameStatus}" Value="Saved">
                                                <Setter Property="Fill" Value="{StaticResource GreenBrush}" />
                                                <DataTrigger.EnterActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <!-- Walk the RenderTransform path so the animation resolves on the triggered
                                                                 Ellipse itself; style-scoped TargetName can't reach a templated child. -->
                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                                             From="1" To="1.5"
                                                                             AutoReverse="True"
                                                                             Duration="{StaticResource Motion.Base}">
                                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
                                                            </DoubleAnimation>
                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                                             From="1" To="1.5"
                                                                             AutoReverse="True"
                                                                             Duration="{StaticResource Motion.Base}">
                                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
                                                            </DoubleAnimation>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </DataTrigger.EnterActions>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding RenameStatus}" Value="Conflict">
                                                <Setter Property="Fill" Value="{StaticResource MauveBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding RenameStatus}" Value="Error">
                                                <Setter Property="Fill" Value="{StaticResource RedBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{Binding RenameStatusText}"
                                           Foreground="{StaticResource TextBrush}"
                                           FontSize="12.5"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="{Binding RenamePreview}"
                                           Foreground="{StaticResource SubtextBrush}"
                                           FontSize="12"
                                           Margin="0,3,0,0"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <TextBlock Style="{StaticResource Text.Hint}"
                               Text="Renames save on pause. Enter commits now · Esc reverts."
                               Margin="1,10,0,0" />

                    <StackPanel Visibility="{Binding IsArchiveBook, Converter={StaticResource BoolToVis}}">
                        <Border Style="{StaticResource Divider}" />
                        <TextBlock Text="Book controls" Style="{StaticResource SectionLabel}" />

                        <Border Style="{StaticResource Card}"
                                AutomationProperties.Name="Archive book controls"
                                AutomationProperties.LiveSetting="Polite">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0"
                                            Width="32"
                                            Height="32"
                                            CornerRadius="{StaticResource Radius.Sm.CR}"
                                            BorderThickness="1"
                                            Background="#1A89B4FA"
                                            BorderBrush="{StaticResource AccentBrush}"
                                            VerticalAlignment="Top"
                                            Margin="0,0,12,0">
                                        <TextBlock Text="&#xE8A5;"
                                                   FontFamily="{StaticResource IconFontFamily}"
                                                   FontSize="13"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </Border>

                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{Binding CurrentArchiveProgressText}"
                                                   FontSize="12.5"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextBrush}"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding DecoderUsed}"
                                                   FontSize="11.5"
                                                   Margin="0,3,0,0"
                                                   Foreground="{StaticResource OverlayBrush}"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </Grid>

                                <UniformGrid Columns="4" Margin="0,12,0,0">
                                    <Button Style="{StaticResource ChromeButton}"
                                            MinHeight="32"
                                            Margin="0,0,6,0"
                                            Command="{Binding FirstPageCommand}"
                                            ToolTip="First page"
                                            AutomationProperties.Name="First book page">
                                        <TextBlock Text="&#xE892;"
                                                   FontFamily="{StaticResource IconFontFamily}"
                                                   FontSize="12"
                                                   HorizontalAlignment="Center" />
                                    </Button>
                                    <Button Style="{StaticResource ChromeButton}"
                                            MinHeight="32"
                                            Margin="0,0,6,0"
                                            Command="{Binding PrevPageCommand}"
                                            ToolTip="Previous page"
                                            AutomationProperties.Name="Previous book page">
                                        <TextBlock Text="&#xE76B;"
                                                   FontFamily="{StaticResource IconFontFamily}"
                                                   FontSize="12"
                                                   HorizontalAlignment="Center" />
                                    </Button>
                                    <Button Style="{StaticResource ChromeButton}"
                                            MinHeight="32"
                                            Margin="0,0,6,0"
                                            Command="{Binding NextPageCommand}"
                                            ToolTip="Next page"
                                            AutomationProperties.Name="Next book page">
                                        <TextBlock Text="&#xE76C;"
                                                   FontFamily="{StaticResource IconFontFamily}"
                                                   FontSize="12"
                                                   HorizontalAlignment="Center" />
                                    </Button>
                                    <Button Style="{StaticResource ChromeButton}"
                                            MinHeight="32"
                                            Command="{Binding LastPageCommand}"
                                            ToolTip="Last page"
                                            AutomationProperties.Name="Last book page">
                                        <TextBlock Text="&#xE893;"
                                                   FontFamily="{StaticResource IconFontFamily}"
                                                   FontSize="12"
                                                   HorizontalAlignment="Center" />
                                    </Button>
                                </UniformGrid>

                                <Border Margin="0,12,0,0"
                                        Padding="10,9"
                                        CornerRadius="{StaticResource Radius.Sm.CR}"
                                        Background="#10313244"
                                        BorderBrush="{StaticResource HairlineBrush}"
                                        BorderThickness="1">
                                    <StackPanel>
                                        <CheckBox IsChecked="{Binding ArchiveRightToLeft, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  Content="{Binding ArchivePageTurnModeText}"
                                                  ToolTip="{Binding ArchivePageTurnModeHint}"
                                                  AutomationProperties.Name="Right-to-left book page turns" />
                                        <TextBlock Text="{Binding ArchivePageTurnModeHint}"
                                                   Margin="28,5,0,0"
                                                   FontSize="11.5"
                                                   Foreground="{StaticResource OverlayBrush}"
                                                   TextWrapping="Wrap" />
                                        <CheckBox IsChecked="{Binding ArchiveOldScanFilterEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  Content="{Binding ArchiveOldScanFilterText}"
                                                  ToolTip="{Binding ArchiveOldScanFilterHint}"
                                                  Margin="0,12,0,0"
                                                  AutomationProperties.Name="Clean old archive scans" />
                                        <TextBlock Text="{Binding ArchiveOldScanFilterHint}"
                                                   Margin="28,5,0,0"
                                                   FontSize="11.5"
                                                   Foreground="{StaticResource OverlayBrush}"
                                                   TextWrapping="Wrap" />
                                        <CheckBox IsChecked="{Binding ArchiveSpreadModeEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  Content="{Binding ArchiveSpreadModeText}"
                                                  ToolTip="{Binding ArchiveSpreadModeHint}"
                                                  Margin="0,12,0,0"
                                                  AutomationProperties.Name="Two-page archive spreads" />
                                        <TextBlock Text="{Binding ArchiveSpreadModeHint}"
                                                   Margin="28,5,0,0"
                                                   FontSize="11.5"
                                                   Foreground="{StaticResource OverlayBrush}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <Border Style="{StaticResource Divider}" />

                    <!-- RECENT RENAMES section -->
                    <TextBlock Text="Recent renames" Style="{StaticResource SectionLabel}" />

                    <Border Style="{StaticResource Card}"
                            Visibility="{Binding RecentRenames.Count, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}">
                        <StackPanel>
                            <TextBlock Text="No renames yet"
                                       Foreground="{StaticResource TextBrush}"
                                       FontSize="12.5"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="Your undo list will appear here."
                                       Foreground="{StaticResource OverlayBrush}"
                                       FontSize="12"
                                       LineHeight="17"
                                       TextWrapping="Wrap"
                                       Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>

                    <ItemsControl ItemsSource="{Binding RecentRenames}"
                                  KeyboardNavigation.DirectionalNavigation="Cycle"
                                  KeyboardNavigation.TabNavigation="Continue"
                                  AutomationProperties.Name="Recent renames">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource InteractiveCard}"
                                        Padding="13,10"
                                        Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock FontSize="12" TextTrimming="CharacterEllipsis">
                                                <Run Text="{Binding FromPath, Converter={x:Static vm:PathToFileNameConverter.Instance}, Mode=OneWay}"
                                                     Foreground="{StaticResource SubtextBrush}" />
                                            </TextBlock>
                                            <TextBlock FontSize="12" TextTrimming="CharacterEllipsis" Margin="0,2,0,0">
                                                <Run Text="→ " Foreground="{StaticResource OverlayBrush}" />
                                                <Run Text="{Binding ToPath, Converter={x:Static vm:PathToFileNameConverter.Instance}, Mode=OneWay}"
                                                     Foreground="{StaticResource TextBrush}" />
                                            </TextBlock>
                                        </StackPanel>
                                        <Button Grid.Column="1"
                                                Style="{StaticResource ChromeButton}"
                                                Padding="14,4"
                                                MinHeight="28"
                                                VerticalAlignment="Center"
                                                Margin="12,0,0,0"
                                                Command="{Binding DataContext.UndoRenameCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                AutomationProperties.Name="Undo rename">
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <TextBlock Text="&#xE7A7;"
                                                           FontFamily="{StaticResource IconFontFamily}"
                                                           FontSize="11"
                                                           Margin="0,0,7,0"
                                                           VerticalAlignment="Center" />
                                                <TextBlock Text="Undo" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- RECENT FOLDERS section (V20-02 UI consumer — data layer shipped v0.1.7).
                         Whole block hides when the MRU is empty so a fresh install / first-run
                         user doesn't see an orphan "Recent folders" header above nothing. -->
                    <StackPanel Visibility="{Binding RecentFolders.Count, Converter={StaticResource BoolToVis}}">
                        <Border Style="{StaticResource Divider}" />
                        <TextBlock Text="Recent folders" Style="{StaticResource SectionLabel}" />
                        <ItemsControl ItemsSource="{Binding RecentFolders}"
                                      KeyboardNavigation.DirectionalNavigation="Cycle"
                                      KeyboardNavigation.TabNavigation="Continue"
                                      AutomationProperties.Name="Recent folders">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource ChromeButton}"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Stretch"
                                            Padding="13,10"
                                            Margin="0,0,0,8"
                                            Command="{Binding DataContext.OpenRecentFolderCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="{Binding}"
                                            AutomationProperties.Name="{Binding}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="&#xE8B7;"
                                                       FontFamily="{StaticResource IconFontFamily}"
                                                       FontSize="13"
                                                       Foreground="{StaticResource SubtextBrush}"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,10,0" />
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{Binding Converter={x:Static vm:PathToFileNameConverter.Instance}, Mode=OneWay}"
                                                           FontSize="12.5"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis"
                                                           Foreground="{StaticResource TextBrush}" />
                                                <TextBlock Text="{Binding Converter={x:Static vm:PathToParentConverter.Instance}, Mode=OneWay}"
                                                           FontSize="11.5"
                                                           Margin="0,2,0,0"
                                                           TextTrimming="CharacterEllipsis"
                                                           Foreground="{StaticResource OverlayBrush}" />
                                            </StackPanel>
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <StackPanel Visibility="{Binding RecentArchiveBooks.Count, Converter={StaticResource BoolToVis}}">
                        <Border Style="{StaticResource Divider}" />
                        <TextBlock Text="Book history" Style="{StaticResource SectionLabel}" />
                        <ItemsControl ItemsSource="{Binding RecentArchiveBooks}"
                                      KeyboardNavigation.DirectionalNavigation="Cycle"
                                      KeyboardNavigation.TabNavigation="Continue"
                                      AutomationProperties.Name="Archive book history">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource ChromeButton}"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Stretch"
                                            Padding="13,10"
                                            Margin="0,0,0,8"
                                            Command="{Binding DataContext.OpenRecentArchiveCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="{Binding Path}"
                                            AutomationProperties.Name="{Binding Path}"
                                            AutomationProperties.HelpText="{Binding ProgressText}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0"
                                                    Width="28"
                                                    Height="28"
                                                    CornerRadius="{StaticResource Radius.Sm.CR}"
                                                    BorderThickness="1"
                                                    Background="#1A89B4FA"
                                                    BorderBrush="{StaticResource HairlineBrush}"
                                                    VerticalAlignment="Center"
                                                    Margin="0,0,10,0">
                                                <TextBlock Text="&#xE8A5;"
                                                           FontFamily="{StaticResource IconFontFamily}"
                                                           FontSize="12"
                                                           Foreground="{StaticResource AccentBrush}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" />
                                            </Border>

                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{Binding Path, Converter={x:Static vm:PathToFileNameConverter.Instance}, Mode=OneWay}"
                                                           FontSize="12.5"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis"
                                                           Foreground="{StaticResource TextBrush}" />
                                                <TextBlock Text="{Binding Path, Converter={x:Static vm:PathToParentConverter.Instance}, Mode=OneWay}"
                                                           FontSize="11.5"
                                                           Margin="0,2,0,0"
                                                           TextTrimming="CharacterEllipsis"
                                                           Foreground="{StaticResource OverlayBrush}" />
                                            </StackPanel>

                                            <Border Grid.Column="2"
                                                    Style="{StaticResource Badge}"
                                                    Margin="10,0,0,0"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{Binding ProgressText}"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource SubtextBrush}" />
                                            </Border>
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <Border Style="{StaticResource Divider}" />

                    <!-- DETAILS section -->
                    <TextBlock Text="Details" Style="{StaticResource SectionLabel}" />

                    <Grid Margin="1,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Folder"  Style="{StaticResource MetaLabel}" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding CurrentFolder}"   Style="{StaticResource MetaValue}" ToolTip="{Binding CurrentFolder}" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Size"    Style="{StaticResource MetaLabel}" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding FileSizeText}"    Style="{StaticResource MetaValue}" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Pixels"  Style="{StaticResource MetaLabel}" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding DimensionsText}"  Style="{StaticResource MetaValue}" />

                        <TextBlock Grid.Row="3"
                                   Grid.Column="0"
                                   Text="{Binding PageLabel}"
                                   Style="{StaticResource MetaLabel}"
                                   Visibility="{Binding HasMultiplePages, Converter={StaticResource BoolToVis}}" />
                        <TextBlock Grid.Row="3"
                                   Grid.Column="1"
                                   Text="{Binding PagePositionText}"
                                   Style="{StaticResource MetaValue}"
                                   Visibility="{Binding HasMultiplePages, Converter={StaticResource BoolToVis}}" />

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Decoder" Style="{StaticResource MetaLabel}" />
                        <Border Grid.Row="4" Grid.Column="1"
                                Style="{StaticResource Badge}"
                                Margin="0,0,0,10"
                                VerticalAlignment="Center">
                            <TextBlock Text="{Binding DecoderUsed}"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource SubtextBrush}" />
                        </Border>
                    </Grid>

                    <Border Style="{StaticResource Divider}" />

                    <!-- ORGANIZATION section -->
                    <TextBlock Text="Organization" Style="{StaticResource SectionLabel}" />
                    <Border Style="{StaticResource Card}"
                            Padding="13,12"
                            AutomationProperties.Name="Organization controls">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Tag relationships"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextBrush}" />
                                <TextBlock Text="Manage private local tag namespaces, aliases, parents, and XMP sidecar tag export."
                                           Style="{StaticResource Text.Hint}"
                                           TextWrapping="Wrap"
                                           Margin="0,3,0,0" />
                            </StackPanel>
                            <StackPanel Grid.Column="1"
                                        Margin="12,0,0,0">
                                <Button Command="{Binding OpenTagGraphCommand}"
                                        Style="{StaticResource ChromeButton}"
                                        MinWidth="92"
                                        AutomationProperties.Name="Open tag relationships">
                                    <TextBlock Text="Tags" />
                                </Button>
                                <Button Command="{Binding OpenImportInboxCommand}"
                                        Style="{StaticResource ChromeButton}"
                                        MinWidth="92"
                                        Margin="0,8,0,0"
                                        AutomationProperties.Name="Open import inbox">
                                    <TextBlock Text="Inbox" />
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource Divider}" />

                    <!-- AUTOMATION section -->
                    <TextBlock Text="Automation" Style="{StaticResource SectionLabel}" />
                    <Border Style="{StaticResource Card}"
                            Padding="13,12"
                            AutomationProperties.Name="Automation controls">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Macro actions"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextBrush}" />
                                <TextBlock Text="Build inspectable JSON actions for export copies, GPS stripping, and rename patterns."
                                           Style="{StaticResource Text.Hint}"
                                           TextWrapping="Wrap"
                                           Margin="0,3,0,0" />
                            </StackPanel>
                            <StackPanel Grid.Column="1"
                                        Margin="12,0,0,0">
                                <Button Command="{Binding OpenMacroActionsCommand}"
                                        Style="{StaticResource ChromeButton}"
                                        MinWidth="92"
                                        AutomationProperties.Name="Open macro actions">
                                    <TextBlock Text="Macros" />
                                </Button>
                                <Button Command="{Binding OpenBatchProcessorCommand}"
                                        Style="{StaticResource ChromeButton}"
                                        MinWidth="92"
                                        Margin="0,8,0,0"
                                        AutomationProperties.Name="Open batch processor">
                                    <TextBlock Text="Batch" />
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource Divider}" />

                    <!-- CLEANUP section -->
                    <TextBlock Text="Cleanup" Style="{StaticResource SectionLabel}" />
                    <Border Style="{StaticResource Card}"
                            Padding="13,12"
                            AutomationProperties.Name="Cleanup controls">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Cleanup tools"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextBrush}" />
                                <TextBlock Text="Find duplicate images, bad extensions, broken files, and temporary artifacts in local folders."
                                           Style="{StaticResource Text.Hint}"
                                           TextWrapping="Wrap"
                                           Margin="0,3,0,0" />
                            </StackPanel>
                            <StackPanel Grid.Column="1"
                                        Margin="12,0,0,0">
                                <Button Command="{Binding OpenDuplicateCleanupCommand}"
                                        Style="{StaticResource ChromeButton}"
                                        MinWidth="86"
                                        AutomationProperties.Name="Open duplicate cleanup">
                                    <TextBlock Text="Duplicates" />
                                </Button>
                                <Button Command="{Binding OpenFileHealthScanCommand}"
                                        Style="{StaticResource ChromeButton}"
                                        MinWidth="86"
                                        Margin="0,8,0,0"
                                        AutomationProperties.Name="Open file health scan">
                                    <TextBlock Text="File health" />
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource Divider}" />

                    <!-- OVERLAY section -->
                    <TextBlock Text="Overlay" Style="{StaticResource SectionLabel}" />
                    <Border Style="{StaticResource Card}"
                            Padding="13,12"
                            AutomationProperties.Name="Pinned overlay controls">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{Binding OverlayModeText}"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextBrush}" />
                                    <TextBlock Text="{Binding OverlayStatusText}"
                                               Style="{StaticResource Text.Hint}"
                                               TextWrapping="Wrap"
                                               Margin="0,3,0,0" />
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Command="{Binding ToggleOverlayModeCommand}"
                                        Style="{StaticResource ChromeButton}"
                                        MinWidth="74"
                                        Margin="12,0,0,0"
                                        AutomationProperties.Name="Toggle pinned overlay mode"
                                        AutomationProperties.HelpText="{Binding OverlayStatusText}">
                                    <TextBlock Text="{Binding OverlayToggleText}" />
                                </Button>
                            </Grid>

                            <Grid Margin="0,12,0,0"
                                  IsEnabled="{Binding IsPinnedOverlayMode}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="Opacity"
                                           Style="{StaticResource Text.Hint}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,0" />
                                <Slider Grid.Column="1"
                                        Minimum="0.25"
                                        Maximum="1"
                                        TickFrequency="0.05"
                                        SmallChange="0.05"
                                        LargeChange="0.1"
                                        Value="{Binding OverlayOpacity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        AutomationProperties.Name="Pinned overlay opacity" />
                                <TextBlock Grid.Column="2"
                                           Text="{Binding OverlayOpacityText}"
                                           Style="{StaticResource Text.Caption}"
                                           VerticalAlignment="Center"
                                           Margin="10,0,0,0" />
                            </Grid>

                            <CheckBox IsChecked="{Binding IsOverlayClickThrough, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      Content="{Binding OverlayClickThroughText}"
                                      IsEnabled="{Binding IsPinnedOverlayMode}"
                                      Margin="0,12,0,0"
                                      ToolTip="{Binding OverlayExitText}"
                                      AutomationProperties.Name="Toggle click-through overlay"
                                      AutomationProperties.HelpText="{Binding OverlayStatusText}" />

                            <Border Margin="0,12,0,0"
                                    Padding="10"
                                    CornerRadius="{StaticResource Radius.Sm.CR}"
                                    Background="#10313244"
                                    BorderBrush="{StaticResource HairlineBrush}"
                                    BorderThickness="1">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE946;"
                                               FontFamily="{StaticResource IconFontFamily}"
                                               FontSize="12"
                                               Foreground="{StaticResource AccentBrush}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,9,0" />
                                    <TextBlock Text="{Binding OverlayExitText}"
                                               Style="{StaticResource Text.Caption}"
                                               TextWrapping="Wrap"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>

                            <WrapPanel Margin="0,12,0,0">
                                <Button Command="{Binding ExitOverlayModeCommand}"
                                        Style="{StaticResource ChromeButton}"
                                        Margin="0,0,8,0"
                                        AutomationProperties.Name="Exit pinned overlay mode">
                                    <TextBlock Text="Exit overlay" />
                                </Button>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <StackPanel Visibility="{Binding IsAnimated, Converter={StaticResource BoolToVis}}">
                        <Border Style="{StaticResource Divider}" />

                        <!-- ANIMATION section -->
                        <TextBlock Text="Animation" Style="{StaticResource SectionLabel}" />
                        <Border Style="{StaticResource Card}"
                                Padding="13,12"
                                AutomationProperties.Name="Animation frame workbench">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding SelectedAnimationFrameText}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextBrush}" />
                                        <TextBlock Text="{Binding AnimationWorkbenchStatusText}"
                                                   Style="{StaticResource Text.Hint}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,3,0,0" />
                                    </StackPanel>
                                    <Button Grid.Column="1"
                                            Command="{Binding ToggleAnimationPlaybackCommand}"
                                            Style="{StaticResource ChromeButton}"
                                            MinWidth="62"
                                            Margin="12,0,0,0"
                                            AutomationProperties.Name="Play or pause animation">
                                        <TextBlock Text="{Binding AnimationPlaybackText}" />
                                    </Button>
                                </Grid>

                                <Grid Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding SelectedAnimationTimestampText}"
                                               Style="{StaticResource Text.Caption}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,10,0" />
                                    <Slider Grid.Column="1"
                                            Minimum="0"
                                            Maximum="{Binding AnimationFrameSliderMaximum}"
                                            Value="{Binding AnimationScrubberValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            TickFrequency="1"
                                            IsSnapToTickEnabled="True"
                                            SmallChange="1"
                                            LargeChange="5"
                                            AutomationProperties.Name="Animation frame scrubber" />
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding SelectedAnimationFrameDelayText}"
                                               Style="{StaticResource Text.Caption}"
                                               VerticalAlignment="Center"
                                               Margin="10,0,0,0" />
                                </Grid>

                                <UniformGrid Columns="4" Margin="0,12,0,0">
                                    <Button Command="{Binding FirstAnimationFrameCommand}"
                                            Style="{StaticResource ChromeButton}"
                                            Margin="0,0,6,0"
                                            ToolTip="First frame"
                                            AutomationProperties.Name="First animation frame">
                                        <TextBlock Text="First" />
                                    </Button>
                                    <Button Command="{Binding PreviousAnimationFrameCommand}"
                                            Style="{StaticResource ChromeButton}"
                                            Margin="0,0,6,0"
                                            ToolTip="Previous frame"
                                            AutomationProperties.Name="Previous animation frame">
                                        <TextBlock Text="Prev" />
                                    </Button>
                                    <Button Command="{Binding NextAnimationFrameCommand}"
                                            Style="{StaticResource ChromeButton}"
                                            Margin="0,0,6,0"
                                            ToolTip="Next frame"
                                            AutomationProperties.Name="Next animation frame">
                                        <TextBlock Text="Next" />
                                    </Button>
                                    <Button Command="{Binding LastAnimationFrameCommand}"
                                            Style="{StaticResource ChromeButton}"
                                            ToolTip="Last frame"
                                            AutomationProperties.Name="Last animation frame">
                                        <TextBlock Text="Last" />
                                    </Button>
                                </UniformGrid>

                                <Grid Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="Speed"
                                               Style="{StaticResource Text.Hint}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,10,0" />
                                    <Slider Grid.Column="1"
                                            Minimum="0.25"
                                            Maximum="4"
                                            TickFrequency="0.25"
                                            IsSnapToTickEnabled="True"
                                            Value="{Binding AnimationPlaybackSpeed, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            AutomationProperties.Name="Animation playback speed" />
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding AnimationPlaybackSpeedText}"
                                               Style="{StaticResource Text.Caption}"
                                               VerticalAlignment="Center"
                                               Margin="10,0,0,0" />
                                </Grid>

                                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                              VerticalScrollBarVisibility="Disabled"
                                              Margin="0,12,0,0"
                                              AutomationProperties.Name="Animation frame timeline">
                                    <ItemsControl ItemsSource="{Binding AnimationFrames}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Command="{Binding DataContext.SetAnimationFrameCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding Index}"
                                                        PreviewMouseMove="AnimationFrame_PreviewMouseMove"
                                                        Style="{StaticResource ChromeButton}"
                                                        Padding="0"
                                                        Margin="0,0,8,0"
                                                        ToolTip="{Binding TimestampText}"
                                                        AutomationProperties.Name="{Binding FrameText}">
                                                    <Border Width="70"
                                                            Padding="5"
                                                            CornerRadius="{StaticResource Radius.Sm.CR}"
                                                            BorderThickness="1">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="BorderBrush" Value="{StaticResource HairlineBrush}" />
                                                                <Setter Property="Background" Value="{StaticResource PanelBrush}" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                                        <Setter Property="Background" Value="#1F89B4FA" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <StackPanel>
                                                            <Image Source="{Binding Preview}"
                                                                   Width="58"
                                                                   Height="42"
                                                                   Stretch="Uniform"
                                                                   RenderOptions.BitmapScalingMode="HighQuality" />
                                                            <TextBlock Text="{Binding FrameText}"
                                                                       Style="{StaticResource Text.Caption}"
                                                                       TextAlignment="Center"
                                                                       Margin="0,4,0,0" />
                                                            <TextBlock Text="{Binding DelayText}"
                                                                       Style="{StaticResource Text.Hint}"
                                                                       TextAlignment="Center" />
                                                        </StackPanel>
                                                    </Border>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>

                                <WrapPanel Margin="0,12,0,0">
                                    <Button Command="{Binding CopyAnimationFrameCommand}"
                                            Style="{StaticResource ChromeButton}"
                                            Margin="0,0,8,8"
                                            AutomationProperties.Name="Copy selected animation frame">
                                        <TextBlock Text="Copy frame" />
                                    </Button>
                                    <Button Command="{Binding ExportAnimationFrameCommand}"
                                            Style="{StaticResource ChromeButton}"
                                            Margin="0,0,8,8"
                                            AutomationProperties.Name="Export selected animation frame">
                                        <TextBlock Text="Export frame" />
                                    </Button>
                                </WrapPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <Border Style="{StaticResource Divider}" />

                    <!-- CROP section -->
                    <TextBlock Text="Crop" Style="{StaticResource SectionLabel}" />
                    <Border Style="{StaticResource Card}"
                            Padding="13,12"
                            IsEnabled="{Binding CanUseCrop}">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{Binding CropModeText}"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextBrush}" />
                                    <TextBlock Text="{Binding CropModeHelpText}"
                                               Style="{StaticResource Text.Hint}"
                                               TextWrapping="Wrap"
                                               Margin="0,3,0,0" />
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Command="{Binding ToggleCropModeCommand}"
                                        Style="{StaticResource ChromeButton}"
                                        MinWidth="72"
                                        Margin="12,0,0,0"
                                        AutomationProperties.Name="Toggle crop mode">
                                    <TextBlock Text="{Binding CropModeText}" />
                                </Button>
                            </Grid>

                            <Border Background="{StaticResource PanelBrush}"
                                    BorderBrush="{StaticResource HairlineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource Radius.Sm.CR}"
                                    Padding="10"
                                    Margin="0,12,0,0">
                                <StackPanel>
                                    <TextBlock Text="{Binding CropStatusText}"
                                               Style="{StaticResource Text.Caption}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding CropSelectionText}"
                                               Style="{StaticResource Text.Body}"
                                               Margin="0,8,0,0" />
                                </StackPanel>
                            </Border>

                            <TextBlock Text="Aspect ratio"
                                       Style="{StaticResource Text.Caption}"
                                       Margin="0,12,0,6" />
                            <WrapPanel>
                                <Button Command="{Binding SetCropAspectPresetCommand}"
                                        CommandParameter="free"
                                        Style="{StaticResource ChromeButton}"
                                        Margin="0,0,8,8"
                                        AutomationProperties.Name="Free crop aspect">
                                    <TextBlock Text="Free" />
                                </Button>
                                <Button Command="{Binding SetCropAspectPresetCommand}"
                                        CommandParameter="square"
                                        Style="{StaticResource ChromeButton}"
                                        Margin="0,0,8,8"
                                        AutomationProperties.Name="Square crop aspect">
                                    <TextBlock Text="1:1" />
                                </Button>
                                <Button Command="{Binding SetCropAspectPresetCommand}"
                                        CommandParameter="3x2"
                                        Style="{StaticResource ChromeButton}"
                                        Margin="0,0,8,8"
                                        AutomationProperties.Name="Three by two crop aspect">
                                    <TextBlock Text="3:2" />
                                </Button>
                                <Button Command="{Binding SetCropAspectPresetCommand}"
                                        CommandParameter="4x3"
                                        Style="{StaticResource ChromeButton}"
                                        Margin="0,0,8,8"
                                        AutomationProperties.Name="Four by three crop aspect">
                                    <TextBlock Text="4:3" />
                                </Button>
                                <Button Command="{Binding SetCropAspectPresetCommand}"
                                        CommandParameter="16x9"
                                        Style="{StaticResource ChromeButton}"
                                        Margin="0,0,8,8"
                                        AutomationProperties.Name="Sixteen by nine crop aspect">
                                    <TextBlock Text="16:9" />
                                </Button>
                                <Button Command="{Binding SetCropAspectPresetCommand}"
                                        CommandParameter="custom"
                                        Style="{StaticResource ChromeButton}"
                                        Margin="0,0,0,8"
                                        AutomationProperties.Name="Custom crop aspect">
                                    <TextBlock Text="Custom" />
                                </Button>
                            </WrapPanel>

                            <Grid Visibility="{Binding ShowCustomCropAspect, Converter={StaticResource BoolToVis}}"
                                  Margin="0,2,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="68" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="68" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         Text="{Binding CustomCropAspectWidth, UpdateSourceTrigger=PropertyChanged}"
                                         AutomationProperties.Name="Custom crop aspect width" />
                                <TextBlock Grid.Column="1"
                                           Text=":"
                                           Style="{StaticResource Text.Body}"
                                           VerticalAlignment="Center"
                                           Margin="8,0" />
                                <TextBox Grid.Column="2"
                                         Text="{Binding CustomCropAspectHeight, UpdateSourceTrigger=PropertyChanged}"
                                         AutomationProperties.Name="Custom crop aspect height" />
                            </Grid>

                            <TextBlock Text="{Binding CropAspectHelpText}"
                                       Style="{StaticResource Text.Hint}"
                                       TextWrapping="Wrap" />

                            <WrapPanel Margin="0,12,0,0">
                                <Button Command="{Binding ApplyCropCommand}"
                                        Style="{StaticResource ChromeButton}"
                                        Margin="0,0,8,8"
                                        AutomationProperties.Name="Apply crop to edit history">
                                    <TextBlock Text="Apply crop" />
                                </Button>
                                <Button Command="{Binding CancelCropCommand}"
                                        Style="{StaticResource ChromeButton}"
                                        Margin="0,0,0,8"
                                        AutomationProperties.Name="Cancel crop">
                                    <TextBlock Text="Cancel" />
                                </Button>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Divider}" />

                    <!-- LOCAL EXPOSURE section -->
                    <TextBlock Text="Local exposure" Style="{StaticResource SectionLabel}" />
                    <Border Style="{StaticResource Card}"
                            Padding="13,12"
                            IsEnabled="{Binding CanUseExposureBrush}">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{Binding ExposureBrushModeText}"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextBrush}" />
                                    <TextBlock Text="{Binding ExposureBrushModeHelpText}"
                                               Style="{StaticResource Text.Hint}"
                                               TextWrapping="Wrap"
                                               Margin="0,3,0,0" />
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Command="{Binding ToggleExposureBrushModeCommand}"
                                        Style="{StaticResource ChromeButton}"
                                        MinWidth="72"
                                        Margin="12,0,0,0"
                                        AutomationProperties.Name="Toggle local exposure brush">
                                    <TextBlock Text="{Binding ExposureBrushModeText}" />
                                </Button>
                            </Grid>

                            <Border Background="{StaticResource PanelBrush}"
                                    BorderBrush="{StaticResource HairlineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource Radius.Sm.CR}"
                                    Padding="10"
                                    Margin="0,12,0,0">
                                <StackPanel>
                                    <TextBlock Text="{Binding ExposureBrushStatusText}"
                                               Style="{StaticResource Text.Caption}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding ExposureBrushStrokeText}"
                                               Style="{StaticResource Text.Body}"
                                               Margin="0,8,0,0" />
                                </StackPanel>
                            </Border>

                            <TextBlock Text="Mode"
                                       Style="{StaticResource Text.Caption}"
                                       Margin="0,12,0,6" />
                            <WrapPanel>
                                <Button Command="{Binding SetExposureBrushModeCommand}"
                                        CommandParameter="dodge"
                                        Style="{StaticResource ChromeButton}"
                                        Margin="0,0,8,8"
                                        AutomationProperties.Name="Use dodge brush">
                                    <TextBlock Text="Dodge" />
                                </Button>
                                <Button Command="{Binding SetExposureBrushModeCommand}"
                                        CommandParameter="burn"
                                        Style="{StaticResource ChromeButton}"
                                        Margin="0,0,8,8"
                                        AutomationProperties.Name="Use burn brush">
                                    <TextBlock Text="Burn" />
                                </Button>
                                <TextBlock Text="{Binding ExposureBrushToneText}"
                                           Style="{StaticResource Text.Hint}"
                                           VerticalAlignment="Center"
                                           Margin="2,0,0,8" />
                            </WrapPanel>

                            <Grid Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Radius"
                                           Style="{StaticResource Text.Caption}" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding ExposureBrushRadiusText}"
                                           Style="{StaticResource Text.Caption}" />
                            </Grid>
                            <Slider Minimum="4"
                                    Maximum="320"
                                    TickFrequency="4"
                                    IsSnapToTickEnabled="False"
                                    Value="{Binding ExposureBrushRadius, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    AutomationProperties.Name="Exposure brush radius" />

                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Strength"
                                           Style="{StaticResource Text.Caption}" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding ExposureBrushStrengthText}"
                                           Style="{StaticResource Text.Caption}" />
                            </Grid>
                            <Slider Minimum="1"
                                    Maximum="100"
                                    TickFrequency="1"
                                    IsSnapToTickEnabled="False"
                                    Value="{Binding ExposureBrushStrength, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    AutomationProperties.Name="Exposure brush strength" />

                            <WrapPanel Margin="0,12,0,0">
                                <Button Command="{Binding ApplyExposureBrushCommand}"
                                        Style="{StaticResource ChromeButton}"
                                        Margin="0,0,8,8"
                                        AutomationProperties.Name="Apply local exposure brush to edit history">
                                    <TextBlock Text="Apply brush" />
                                </Button>
                                <Button Command="{Binding ClearExposureBrushCommand}"
                                        Style="{StaticResource ChromeButton}"
                                        Margin="0,0,8,8"
                                        AutomationProperties.Name="Clear local exposure brush strokes">
                                    <TextBlock Text="Clear" />
                                </Button>
                                <Button Command="{Binding CancelExposureBrushCommand}"
                                        Style="{StaticResource ChromeButton}"
                                        Margin="0,0,0,8"
                                        AutomationProperties.Name="Cancel local exposure brush">
                                    <TextBlock Text="Cancel" />
                                </Button>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Divider}" />

                    <!-- RED-EYE section -->
                    <TextBlock Text="Red-eye correction" Style="{StaticResource SectionLabel}" />
                    <Border Style="{StaticResource Card}"
                            Padding="13,12"
                            IsEnabled="{Binding CanUseRedEyeCorrection}">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{Binding RedEyeCorrectionModeText}"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextBrush}" />
                                    <TextBlock Text="{Binding RedEyeCorrectionModeHelpText}"
                                               Style="{StaticResource Text.Hint}"
                                               TextWrapping="Wrap"
                                               Margin="0,3,0,0" />
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Command="{Binding ToggleRedEyeModeCommand}"
                                        Style="{StaticResource ChromeButton}"
                                        MinWidth="72"
                                        Margin="12,0,0,0"
                                        AutomationProperties.Name="Toggle red-eye correction">
                                    <TextBlock Text="{Binding RedEyeCorrectionModeText}" />
                                </Button>
                            </Grid>

                            <Border Background="{StaticResource PanelBrush}"
                                    BorderBrush="{StaticResource HairlineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource Radius.Sm.CR}"
                                    Padding="10"
                                    Margin="0,12,0,0">
                                <StackPanel>
                                    <TextBlock Text="{Binding RedEyeCorrectionStatusText}"
                                               Style="{StaticResource Text.Caption}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding RedEyeCorrectionMarkText}"
                                               Style="{StaticResource Text.Body}"
                                               Margin="0,8,0,0" />
                                </StackPanel>
                            </Border>

                            <Grid Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Radius"
                                           Style="{StaticResource Text.Caption}" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding RedEyeCorrectionRadiusText}"
                                           Style="{StaticResource Text.Caption}" />
                            </Grid>
                            <Slider Minimum="4"
                                    Maximum="180"
                                    TickFrequency="2"
                                    IsSnapToTickEnabled="False"
                                    Value="{Binding RedEyeCorrectionRadius, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    AutomationProperties.Name="Red-eye correction radius" />

                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Strength"
                                           Style="{StaticResource Text.Caption}" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding RedEyeCorrectionStrengthText}"
                                           Style="{StaticResource Text.Caption}" />
                            </Grid>
                            <Slider Minimum="5"
                                    Maximum="100"
                                    TickFrequency="1"
                                    IsSnapToTickEnabled="False"
                                    Value="{Binding RedEyeCorrectionStrength, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    AutomationProperties.Name="Red-eye correction strength" />

                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Red threshold"
                                           Style="{StaticResource Text.Caption}" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding RedEyeCorrectionThresholdText}"
                                           Style="{StaticResource Text.Caption}" />
                            </Grid>
                            <Slider Minimum="0"
                                    Maximum="100"
                                    TickFrequency="1"
                                    IsSnapToTickEnabled="False"
                                    Value="{Binding RedEyeCorrectionThreshold, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    AutomationProperties.Name="Red-eye correction red threshold" />

                            <WrapPanel Margin="0,12,0,0">
                                <Button Command="{Binding ApplyRedEyeCorrectionCommand}"
                                        Style="{StaticResource ChromeButton}"
                                        Margin="0,0,8,8"
                                        AutomationProperties.Name="Apply red-eye correction to edit history">
                                    <TextBlock Text="Apply red-eye" />
                                </Button>
                                <Button Command="{Binding ClearRedEyeCorrectionCommand}"
                                        Style="{StaticResource ChromeButton}"
                                        Margin="0,0,8,8"
                                        AutomationProperties.Name="Clear red-eye correction marks">
                                    <TextBlock Text="Clear" />
                                </Button>
                                <Button Command="{Binding CancelRedEyeCorrectionCommand}"
                                        Style="{StaticResource ChromeButton}"
                                        Margin="0,0,0,8"
                                        AutomationProperties.Name="Cancel red-eye correction">
                                    <TextBlock Text="Cancel" />
                                </Button>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Divider}" />

                    <!-- INSPECTOR section -->
                    <TextBlock Text="Inspector" Style="{StaticResource SectionLabel}" />
                    <Border Style="{StaticResource Card}"
                            Padding="13,12"
                            IsEnabled="{Binding CanUseInspector}">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{Binding InspectorModeText}"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextBrush}" />
                                    <TextBlock Text="{Binding InspectorModeHelpText}"
                                               Style="{StaticResource Text.Hint}"
                                               TextWrapping="Wrap"
                                               Margin="0,3,0,0" />
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Command="{Binding ToggleInspectorCommand}"
                                        Style="{StaticResource ChromeButton}"
                                        MinWidth="72"
                                        Margin="12,0,0,0"
                                        AutomationProperties.Name="Toggle pixel inspector">
                                    <TextBlock Text="{Binding InspectorModeText}" />
                                </Button>
                            </Grid>

                            <CheckBox IsChecked="{Binding InspectorNearestNeighborPreview, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      Content="Nearest-neighbor preview"
                                      Margin="0,12,0,0"
                                      ToolTip="Use crisp scaling for pixel-art inspection."
                                      AutomationProperties.Name="Use nearest-neighbor preview scaling" />

                            <Border Background="{StaticResource PanelBrush}"
                                    BorderBrush="{StaticResource HairlineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource Radius.Sm.CR}"
                                    Padding="10"
                                    Margin="0,12,0,0">
                                <StackPanel>
                                    <TextBlock Text="{Binding InspectorStatusText}"
                                               Style="{StaticResource Text.Caption}"
                                               TextWrapping="Wrap" />
                                    <UniformGrid Columns="2" Margin="0,10,0,0">
                                        <StackPanel Margin="0,0,10,8">
                                            <TextBlock Text="Coordinate" Style="{StaticResource Text.Hint}" />
                                            <TextBlock Text="{Binding InspectorCoordinateText}" Style="{StaticResource Text.Body}" />
                                        </StackPanel>
                                        <StackPanel Margin="0,0,0,8">
                                            <TextBlock Text="Hex" Style="{StaticResource Text.Hint}" />
                                            <TextBlock Text="{Binding InspectorHexText}" Style="{StaticResource Text.Body}" />
                                        </StackPanel>
                                        <StackPanel Margin="0,0,10,8">
                                            <TextBlock Text="RGB" Style="{StaticResource Text.Hint}" />
                                            <TextBlock Text="{Binding InspectorRgbText}" Style="{StaticResource Text.Body}" />
                                        </StackPanel>
                                        <StackPanel Margin="0,0,0,8">
                                            <TextBlock Text="HSV / Alpha" Style="{StaticResource Text.Hint}" />
                                            <TextBlock Text="{Binding InspectorHsvText}" Style="{StaticResource Text.Body}" />
                                            <TextBlock Text="{Binding InspectorAlphaText}" Style="{StaticResource Text.Hint}" />
                                        </StackPanel>
                                    </UniformGrid>
                                    <TextBlock Text="{Binding InspectorSelectionText}"
                                               Style="{StaticResource Text.Caption}"
                                               Margin="0,2,0,0" />
                                </StackPanel>
                            </Border>

                            <WrapPanel Margin="0,12,0,0">
                                <Button Command="{Binding CopyInspectorHexCommand}"
                                        Style="{StaticResource ChromeButton}"
                                        Margin="0,0,8,8"
                                        AutomationProperties.Name="Copy HEX color">
                                    <TextBlock Text="Copy HEX" />
                                </Button>
                                <Button Command="{Binding CopyInspectorRgbCommand}"
                                        Style="{StaticResource ChromeButton}"
                                        Margin="0,0,8,8"
                                        AutomationProperties.Name="Copy RGB color">
                                    <TextBlock Text="Copy RGB" />
                                </Button>
                                <Button Command="{Binding CopyInspectorHsvCommand}"
                                        Style="{StaticResource ChromeButton}"
                                        Margin="0,0,8,8"
                                        AutomationProperties.Name="Copy HSV color">
                                    <TextBlock Text="Copy HSV" />
                                </Button>
                                <Button Command="{Binding ClearInspectorSelectionCommand}"
                                        Style="{StaticResource ChromeButton}"
                                        Margin="0,0,0,8"
                                        AutomationProperties.Name="Clear inspector measurement">
                                    <TextBlock Text="Clear measure" />
                                </Button>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <StackPanel Visibility="{Binding PhotoMetadataRows.Count, Converter={StaticResource BoolToVis}}">
                        <Border Style="{StaticResource Divider}" />
                        <TextBlock Text="Photo metadata" Style="{StaticResource SectionLabel}" />
                        <ItemsControl ItemsSource="{Binding PhotoMetadataRows}"
                                      AutomationProperties.Name="Photo metadata">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="1,0,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Label}"
                                                   Style="{StaticResource MetaLabel}" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Value}"
                                                   Style="{StaticResource MetaValue}"
                                                   ToolTip="{Binding Value}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <Border Style="{StaticResource Card}"
                            Margin="0,4,0,0"
                            Visibility="{Binding MetadataStatusText, Converter={StaticResource BoolToVis}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE946;"
                                       FontFamily="{StaticResource IconFontFamily}"
                                       FontSize="12"
                                       Foreground="{StaticResource OverlayBrush}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,9,0" />
                            <TextBlock Text="{Binding MetadataStatusText}"
                                       Style="{StaticResource Text.Hint}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
