                                           FontWeight="SemiBold" />
                                <TextBlock Text="{Binding OcrStatusDetail}"
                                           Foreground="{DynamicResource SubtextBrush}"
                                           FontSize="11.5"
                                           LineHeight="16"
                                           TextWrapping="Wrap"
                                           Margin="0,3,0,0" />
                            </StackPanel>

                            <Button Grid.Column="2"
                                    Command="{Binding ExtractTextCommand}"
                                    Content="&#xE711;"
                                    Style="{StaticResource ToolbarButton}"
                                    ToolTip="{Binding OcrModeTooltip}"
                                    Margin="12,0,0,0"
                                    VerticalAlignment="Top"
                                    AutomationProperties.Name="{Binding OcrModeTooltip}" />
                        </Grid>
                    </Border>

                    <!-- First-run gesture hint — fades in + slides up, auto-dismisses after 2.4s -->
                    <Border HorizontalAlignment="Center"
                            VerticalAlignment="Bottom"
                            Margin="0,0,0,144"
                            Visibility="{Binding ShowGestureHint, Converter={StaticResource BoolToVis}}"
                            IsHitTestVisible="False"
                            AutomationProperties.LiveSetting="Polite">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource FloatingChrome}">
                                <Setter Property="Opacity" Value="0" />
                                <Style.Triggers>
                                    <Trigger Property="IsVisible" Value="True">
                                        <Trigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                     From="0" To="1"
                                                                     Duration="{StaticResource Motion.Slow}">
                                                        <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </Trigger.EnterActions>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE7A5;"
                                       FontFamily="{StaticResource IconFontFamily}"
                                       FontSize="13"
                                       Foreground="{DynamicResource AccentBrush}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0" />
                            <TextBlock Text="Scroll to zoom  ·  drag to pan  ·  double-click to fit"
                                       Foreground="{DynamicResource FloatingChromeTextBrush}"
                                       FontSize="12"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <!-- V15-03: keyboard cheatsheet overlay — toggled by `?`, any key dismisses.
                         Sits above everything else in the viewport. Mouse passes through
                         everywhere except the card itself (IsHitTestVisible=False on the dimmer). -->
