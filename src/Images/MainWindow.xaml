<Window x:Class="Images.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Images.ViewModels"
        xmlns:ctl="clr-namespace:Images.Controls"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="{Binding WindowTitle}"
        Width="1280" Height="820"
        MinWidth="860" MinHeight="560"
        WindowStartupLocation="CenterScreen"
        AllowDrop="True"
        DragEnter="Window_DragEnter"
        DragLeave="Window_DragLeave"
        Drop="Window_Drop"
        DragOver="Window_DragOver"
        KeyDown="Window_KeyDown"
        PreviewMouseDown="Window_PreviewMouseDown"
        Background="{StaticResource BaseBrush}"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <!-- V15-07: side panel column collapses to 0 in fullscreen. Width="Auto" + the
                 Border's Visibility binding below drops the column to zero width when the
                 Border is Collapsed (Auto sizes to hidden-content width). -->
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!-- ============ LEFT: Viewport, floating chrome, bottom toolbar ============ -->
        <Grid Grid.Column="0" Background="{StaticResource ViewportBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid x:Name="Viewport" Grid.Row="0" ClipToBounds="True">
                <!-- V15-02: right-click context menu on the viewport. Rename-TextBox's own
                     built-in edit menu is unaffected because ContextMenu here is attached to
                     this Grid, not to descendants. -->
                <Grid.ContextMenu>
                    <ContextMenu Style="{StaticResource ViewportContextMenu}">
                        <MenuItem Header="Open…"             Command="{Binding OpenCommand}"           InputGestureText="Ctrl+O" />
                        <MenuItem Header="Reload"            Command="{Binding ReloadCommand}"         InputGestureText="Ctrl+Shift+R" />
                        <MenuItem Header="Save a copy…"      Command="{Binding SaveAsCopyCommand}"     InputGestureText="Ctrl+Shift+S" />
                        <MenuItem Header="Print…"            Command="{Binding PrintCommand}"          InputGestureText="Ctrl+P" />
                        <Separator />
                        <MenuItem Header="Reveal in Explorer" Command="{Binding RevealCommand}" />
                        <MenuItem Header="Copy path"          Command="{Binding CopyPathCommand}" />
                        <Separator />
                        <MenuItem Header="Rotate left"   Command="{Binding RotateCcwCommand}" />
                        <MenuItem Header="Rotate right"  Command="{Binding RotateCwCommand}" />
                        <MenuItem Header="Rotate 180°"   Command="{Binding Rotate180Command}" />
                        <MenuItem Header="Flip horizontal" Command="{Binding FlipHorizontalCommand}" />
                        <MenuItem Header="Flip vertical"   Command="{Binding FlipVerticalCommand}" />
                        <Separator />
                        <MenuItem Header="Set as desktop wallpaper" Command="{Binding SetAsWallpaperCommand}" />
                        <Separator />
                        <MenuItem Header="Delete (Recycle Bin)" Command="{Binding DeleteCommand}" InputGestureText="Del" />
                    </ContextMenu>
                </Grid.ContextMenu>

                <ctl:ZoomPanImage x:Name="Canvas"
                                   Source="{Binding CurrentImage}"
                                   Animation="{Binding CurrentAnimation}"
                                   Rotation="{Binding Rotation}"
                                   FlipHorizontal="{Binding FlipHorizontal}"
                                   FlipVertical="{Binding FlipVertical}" />

                <!-- Empty state — centered invitational card -->
                <Border Style="{StaticResource ElevatedCard}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        MaxWidth="440"
                        Visibility="{Binding IsViewerEmpty, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <Image Source="Resources/logo.png"
                               Width="84"
                               Height="84"
                               HorizontalAlignment="Center"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               Opacity="0.94" />
                        <TextBlock Style="{StaticResource Text.Display}"
                                   Text="Open an image to begin"
                                   HorizontalAlignment="Center"
                                   Margin="0,20,0,0" />
                        <TextBlock Style="{StaticResource Text.Subtitle}"
                                   Text="Drop a file anywhere in the window, or browse from disk. Navigate the folder, rename inline, and undo — without leaving the viewer."
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   Margin="0,10,0,0"
                                   MaxWidth="360" />
                        <Button Content="Open image…"
                                Command="{Binding OpenCommand}"
                                Style="{StaticResource PrimaryButton}"
                                HorizontalAlignment="Center"
                                Margin="0,26,0,0"
                                AutomationProperties.Name="Open image"
                                AutomationProperties.HelpText="Choose an image file from disk" />
                        <TextBlock Style="{StaticResource Text.Hint}"
                                   Text="Tip — arrow keys browse the folder, Enter commits a rename."
                                   HorizontalAlignment="Center"
                                   Margin="0,18,0,0" />
                    </StackPanel>
                </Border>

                <!-- Decode error state — semantic-red tinted card -->
                <Border Style="{StaticResource ElevatedCard}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        MaxWidth="500"
                        Background="{StaticResource DangerPanelBrush}"
                        BorderBrush="{StaticResource RedBrush}"
                        Visibility="{Binding HasLoadError, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="&#xE783;"
                                   FontFamily="{StaticResource IconFontFamily}"
                                   FontSize="38"
                                   HorizontalAlignment="Center"
                                   Foreground="{StaticResource RedBrush}" />
                        <TextBlock Style="{StaticResource Text.Title}"
                                   Text="This image couldn't be displayed"
                                   HorizontalAlignment="Center"
                                   Margin="0,14,0,0" />
                        <TextBlock Style="{StaticResource Text.Subtitle}"
                                   Text="{Binding LoadErrorMessage}"
                                   TextAlignment="Center"
                                   Margin="0,10,0,0" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,22,0,0">
                            <Button Content="Try another image"
                                    Command="{Binding OpenCommand}"
                                    Style="{StaticResource PrimaryButton}"
                                    AutomationProperties.Name="Try another image" />
                            <Button Content="Reveal file"
                                    Command="{Binding RevealCommand}"
                                    Style="{StaticResource ChromeButton}"
                                    Margin="12,0,0,0"
                                    AutomationProperties.Name="Reveal current file in Explorer" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Drag-and-drop confidence layer -->
                <Border Margin="32"
                        Background="{StaticResource DropOverlayBrush}"
                        BorderThickness="2"
                        CornerRadius="{StaticResource Radius.Xl.CR}"
                        Visibility="{Binding IsDropTargetActive, Converter={StaticResource BoolToVis}}">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="BorderBrush" Value="{StaticResource RedBrush}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsDropAccepted}" Value="True">
                                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Border Style="{StaticResource ElevatedCard}"
                            Background="{StaticResource DropOverlayPanelBrush}"
                            MaxWidth="420"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                        <StackPanel>
                            <TextBlock Text="{Binding IsDropAccepted, Converter={StaticResource DropAcceptedIcon}}"
                                       FontFamily="{StaticResource IconFontFamily}"
                                       FontSize="38"
                                       HorizontalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource RedBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsDropAccepted}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Style="{StaticResource Text.Title}"
                                       Text="{Binding DropOverlayTitle}"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       Margin="0,14,0,0" />
                            <TextBlock Style="{StaticResource Text.Subtitle}"
                                       Text="{Binding DropOverlayMessage}"
                                       TextAlignment="Center"
                                       Margin="0,8,0,0" />
                        </StackPanel>
                    </Border>
                </Border>

                <!-- Floating chrome (only when an image is present) -->
                <Grid Visibility="{Binding HasImage, Converter={StaticResource BoolToVis}}">

                    <!-- Hover-reveal nav arrows -->
                    <Button x:Name="PrevArrow"
                            Style="{StaticResource NavArrowButton}"
                            Command="{Binding PrevCommand}"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Margin="22,0,0,0"
                            Content="&#xE76B;"
                            Opacity="0"
                            AutomationProperties.Name="Previous image"
                            AutomationProperties.HelpText="Left arrow or Backspace" />
                    <Button x:Name="NextArrow"
                            Style="{StaticResource NavArrowButton}"
                            Command="{Binding NextCommand}"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Margin="0,0,22,0"
                            Content="&#xE76C;"
                            Opacity="0"
                            AutomationProperties.Name="Next image"
                            AutomationProperties.HelpText="Right arrow or Space" />

                    <!-- Position chip — elevated pill -->
                    <Border Style="{StaticResource FloatingPill}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Top"
                            Margin="0,20,0,0"
                            AutomationProperties.LiveSetting="Polite"
                            AutomationProperties.Name="Folder position">
                        <TextBlock Text="{Binding PositionText}"
                                   Foreground="{StaticResource FloatingChromeTextBrush}"
                                   FontSize="12"
                                   FontWeight="SemiBold" />
                    </Border>

                    <!-- First-run gesture hint — fades in + slides up, auto-dismisses after 2.4s -->
                    <Border HorizontalAlignment="Center"
                            VerticalAlignment="Bottom"
                            Margin="0,0,0,144"
                            Visibility="{Binding ShowGestureHint, Converter={StaticResource BoolToVis}}"
                            IsHitTestVisible="False"
                            AutomationProperties.LiveSetting="Polite">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource FloatingPill}">
                                <Setter Property="Opacity" Value="0" />
                                <Style.Triggers>
                                    <Trigger Property="IsVisible" Value="True">
                                        <Trigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                     From="0" To="1"
                                                                     Duration="{StaticResource Motion.Slow}">
                                                        <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </Trigger.EnterActions>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE7A5;"
                                       FontFamily="{StaticResource IconFontFamily}"
                                       FontSize="13"
                                       Foreground="{StaticResource AccentBrush}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0" />
                            <TextBlock Text="Scroll to zoom  ·  drag to pan  ·  double-click to fit"
                                       Foreground="{StaticResource FloatingChromeTextBrush}"
                                       FontSize="12"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <!-- V15-03: keyboard cheatsheet overlay — toggled by `?`, any key dismisses.
                         Sits above everything else in the viewport. Mouse passes through
                         everywhere except the card itself (IsHitTestVisible=False on the dimmer). -->
                    <Grid Visibility="{Binding ShowCheatsheet, Converter={StaticResource BoolToVis}}">
                        <Rectangle Fill="#CC000000" IsHitTestVisible="False" />
                        <Border Style="{StaticResource ElevatedCard}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                MaxWidth="540"
                                Padding="30,26,30,28">
                            <StackPanel>
                                <TextBlock Style="{StaticResource Text.Title}"
                                           Text="Keyboard shortcuts"
                                           HorizontalAlignment="Center" />
                                <TextBlock Style="{StaticResource Text.Subtitle}"
                                           Text="Press any key to dismiss."
                                           HorizontalAlignment="Center"
                                           Margin="0,6,0,22" />

                                <TextBlock Text="Navigate" Style="{StaticResource SectionLabel}" />
                                <Grid Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="← / →" />
                                    <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Previous / next image" />
                                    <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="Home / End" />
                                    <TextBlock Grid.Row="1" Grid.Column="1" Style="{StaticResource MetaValue}" Text="First / last image" />
                                    <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="Space / Bksp" />
                                    <TextBlock Grid.Row="2" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Next / previous image" />
                                    <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="Mouse X1 / X2" />
                                    <TextBlock Grid.Row="3" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Previous / next image (5-button mouse)" />
                                    <TextBlock Grid.Row="4" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="F5" />
                                    <TextBlock Grid.Row="4" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Rescan folder" />
                                </Grid>

                                <TextBlock Text="View" Style="{StaticResource SectionLabel}" />
                                <Grid Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="Wheel" />
                                    <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Zoom about cursor" />
                                    <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="Shift + Wheel" />
                                    <TextBlock Grid.Row="1" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Pan horizontally" />
                                    <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="+ / −" />
                                    <TextBlock Grid.Row="2" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Zoom in / out" />
                                    <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="0 / 1" />
                                    <TextBlock Grid.Row="3" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Fit to viewport / 1:1 pixel" />
                                    <TextBlock Grid.Row="4" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="F11" />
                                    <TextBlock Grid.Row="4" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Toggle fullscreen" />
                                </Grid>

                                <TextBlock Text="File" Style="{StaticResource SectionLabel}" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="Ctrl+O" />
                                    <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Open image" />
                                    <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="Ctrl+Shift+S" />
                                    <TextBlock Grid.Row="1" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Save a copy" />
                                    <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="Ctrl+P" />
                                    <TextBlock Grid.Row="2" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Print current image" />
                                    <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="Del" />
                                    <TextBlock Grid.Row="3" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Send to Recycle Bin" />
                                    <TextBlock Grid.Row="4" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="Ctrl+Shift+R" />
                                    <TextBlock Grid.Row="4" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Reload current image" />
                                    <TextBlock Grid.Row="5" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="Enter" />
                                    <TextBlock Grid.Row="5" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Commit rename (in rename box)" />
                                    <TextBlock Grid.Row="6" Grid.Column="0" Style="{StaticResource MetaLabel}" FontFamily="Consolas" Text="Esc" />
                                    <TextBlock Grid.Row="6" Grid.Column="1" Style="{StaticResource MetaValue}" Text="Revert rename / dismiss overlay / exit fullscreen" />
                                </Grid>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Toast notification — elevated pill, fades on show via Opacity trigger -->
                    <Border x:Name="ToastHost"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Bottom"
                            Margin="0,0,0,88"
                            Visibility="{Binding ToastMessage, Converter={StaticResource BoolToVis}}"
                            AutomationProperties.LiveSetting="Polite">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource Toast}">
                                <Setter Property="Opacity" Value="0" />
                                <Style.Triggers>
                                    <Trigger Property="IsVisible" Value="True">
                                        <Trigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                     From="0" To="1"
                                                                     Duration="{StaticResource Motion.Base}">
                                                        <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </Trigger.EnterActions>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE930;"
                                       FontFamily="{StaticResource IconFontFamily}"
                                       FontSize="13"
                                       Foreground="{StaticResource AccentBrush}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0" />
                            <TextBlock Text="{Binding ToastMessage}"
                                       Foreground="{StaticResource FloatingChromeTextBrush}"
                                       FontSize="13"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>

            <!-- Bottom toolbar — premium horizontal chrome bar with 1-px top highlight.
                 V20-32: peek-mode hides the entire toolbar so the image fills the window with
                 zero chrome. The Width="Auto" outer column on the side panel + IsFullscreen=true
                 binding handles the right-side panel; this Visibility handles the toolbar row. -->
            <Grid Grid.Row="1"
                  Visibility="{Binding IsPeekMode, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="1" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <!-- Subtle top highlight: sits just inside the divider line, gives the toolbar a
                     gently lit edge like polished macOS / Win11 chrome. -->
                <Border Grid.Row="0" Height="1" Background="#12CDD6F4" />
                <Border Grid.Row="1"
                        Background="{StaticResource MantleBrush}"
                        BorderBrush="{StaticResource HairlineBrush}"
                        BorderThickness="0,1,0,0">
                    <Grid Margin="20,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Left: current file info -->
                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Visibility="{Binding HasImage, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding CurrentFileName}"
                                   Foreground="{StaticResource TextBrush}"
                                   FontWeight="SemiBold"
                                   FontSize="13"
                                   MaxWidth="300"
                                   TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="  ·  "
                                   Foreground="{StaticResource OverlayBrush}"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="{Binding DimensionsText}"
                                   Foreground="{StaticResource SubtextBrush}"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="  ·  "
                                   Foreground="{StaticResource OverlayBrush}"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="{Binding FileSizeText}"
                                   Foreground="{StaticResource SubtextBrush}"
                                   VerticalAlignment="Center" />

                        <!-- Animated-image chip — only surfaces when CurrentAnimation is non-null.
                             Small green pill so the GIF/APNG/animated-WebP state reads at a glance
                             without competing with the primary metadata row. -->
                        <Border Margin="10,0,0,0"
                                Padding="8,2"
                                CornerRadius="{StaticResource Radius.Sm.CR}"
                                Background="#2AA6E3A1"
                                BorderBrush="{StaticResource GreenBrush}"
                                BorderThickness="1"
                                VerticalAlignment="Center"
                                Visibility="{Binding IsAnimated, Converter={StaticResource BoolToVis}}"
                                AutomationProperties.Name="Animated image">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE768;"
                                           FontFamily="{StaticResource IconFontFamily}"
                                           FontSize="10"
                                           Foreground="{StaticResource GreenBrush}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,5,0" />
                                <TextBlock Text="{Binding AnimationFrameCountText}"
                                           FontSize="10.5"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource GreenBrush}"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Visibility="{Binding HasImage, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}">
                        <TextBlock Text="Ready"
                                   Foreground="{StaticResource TextBrush}"
                                   FontWeight="SemiBold"
                                   FontSize="13"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="  ·  "
                                   Foreground="{StaticResource OverlayBrush}"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="Open or drop an image to start reviewing."
                                   Foreground="{StaticResource SubtextBrush}"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <!-- Center: primary nav + rotate + delete cluster -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Style="{StaticResource ToolbarButton}" Command="{Binding PrevCommand}"     Content="&#xE76B;" ToolTip="Previous (Left)" AutomationProperties.Name="Previous image" />
                        <Button Style="{StaticResource ToolbarButton}" Command="{Binding RotateCcwCommand}" Content="&#xE7AD;" ToolTip="Rotate left" Margin="4,0,0,0" AutomationProperties.Name="Rotate left" />
                        <Button Style="{StaticResource ToolbarButton}" Command="{Binding OpenCommand}"      Content="&#xE8E5;" ToolTip="Open…" Margin="4,0,0,0" AutomationProperties.Name="Open image" />
                        <Button Style="{StaticResource ToolbarButton}" Command="{Binding RotateCwCommand}"  Content="&#xE7AC;" ToolTip="Rotate right" Margin="4,0,0,0" AutomationProperties.Name="Rotate right" />
                        <Button Style="{StaticResource ToolbarButton}" Command="{Binding NextCommand}"      Content="&#xE76C;" ToolTip="Next (Right)" Margin="4,0,0,0" AutomationProperties.Name="Next image" />
                        <Border Width="1" Background="{StaticResource HairlineBrush}" Margin="14,6" />
                        <Button Style="{StaticResource ToolbarButton}" Command="{Binding DeleteCommand}"    Content="&#xE74D;" ToolTip="Delete (Recycle Bin)" AutomationProperties.Name="Send image to Recycle Bin" />
                    </StackPanel>

                    <!-- Right: utility cluster -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                        <Button Style="{StaticResource ToolbarButton}" Command="{Binding RevealCommand}"   Content="&#xE838;" ToolTip="Reveal in Explorer" AutomationProperties.Name="Reveal image in Explorer" />
                        <Button Style="{StaticResource ToolbarButton}" Command="{Binding CopyPathCommand}" Content="&#xE8C8;" ToolTip="Copy path" Margin="4,0,0,0" AutomationProperties.Name="Copy file path" />
                        <Button Style="{StaticResource ToolbarButton}" Command="{Binding RefreshCommand}"  Content="&#xE72C;" ToolTip="Refresh folder (F5)" Margin="4,0,0,0" AutomationProperties.Name="Refresh folder" />
                    </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- ============ RIGHT: Rename + Recent + Details panel ============ -->
        <Border Grid.Column="1"
                Width="360"
                Visibility="{Binding IsFullscreen, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}"
                Background="{StaticResource MantleBrush}"
                BorderBrush="{StaticResource HairlineBrush}"
                BorderThickness="1,0,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0">
                <StackPanel Margin="22,22,22,28">

                    <!-- Panel header -->
                    <Grid Margin="0,0,0,22">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Style="{StaticResource Text.Display}"
                                       Text="Images" />
                            <TextBlock Style="{StaticResource Text.Subtitle}"
                                       Text="Review, rename, and move through a folder without breaking flow."
                                       Margin="0,6,0,0" />
                        </StackPanel>
                        <!-- V15-06: click the info icon for the About dialog. Keeps the header
                             visually clean — no visible button chrome, just an accent on hover. -->
                        <Button Grid.Column="1"
                                Command="{Binding AboutCommand}"
                                Style="{StaticResource ToolbarButton}"
                                Content="&#xE946;"
                                ToolTip="About Images"
                                AutomationProperties.Name="About Images"
                                VerticalAlignment="Top"
                                Margin="8,0,0,0" />
                    </Grid>

                    <Border Style="{StaticResource Card}"
                            Background="#1F89B4FA"
                            BorderBrush="{StaticResource AccentBrush}"
                            Margin="0,0,0,20"
                            Visibility="{Binding HasUpdateAvailable, Converter={StaticResource BoolToVis}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="&#xE895;"
                                       FontFamily="{StaticResource IconFontFamily}"
                                       FontSize="14"
                                       Foreground="{StaticResource AccentBrush}"
                                       Margin="0,1,10,0"
                                       VerticalAlignment="Top" />
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{Binding LatestUpdateTag, StringFormat=Update {0} is available}"
                                           FontSize="12.5"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextBrush}" />
                                <TextBlock Text="Open the release page when you are ready to install it."
                                           Style="{StaticResource Text.Hint}"
                                           Margin="0,3,0,0" />
                            </StackPanel>
                            <Button Grid.Column="2"
                                    Content="View"
                                    Command="{Binding OpenLatestUpdateCommand}"
                                    Style="{StaticResource ChromeButton}"
                                    Padding="12,4"
                                    MinHeight="28"
                                    Margin="12,0,0,0"
                                    VerticalAlignment="Center"
                                    AutomationProperties.Name="View available update" />
                        </Grid>
                    </Border>

                    <!-- RENAME section -->
                    <TextBlock Text="Rename" Style="{StaticResource SectionLabel}" />

                    <!-- Stem editor + locked extension chip -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="StemEditor"
                                 Grid.Column="0"
                                 Text="{Binding EditableStem, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="15"
                                 IsEnabled="{Binding HasImage}"
                                 PreviewKeyDown="StemEditor_PreviewKeyDown"
                                 AutomationProperties.Name="File name without extension" />
                        <Button Grid.Column="1"
                                Margin="10,0,0,0"
                                Padding="11,0"
                                MinWidth="72"
                                Height="36"
                                Command="{Binding UnlockExtensionCommand}"
                                IsEnabled="{Binding HasImage}"
                                ToolTip="Click to edit the extension (normally locked)"
                                AutomationProperties.Name="Toggle extension editing">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ChromeButton}">
                                    <Style.Triggers>
                                        <!-- Locked (default) already carries the chrome treatment.
                                             Unlocked echoes the YellowBrush warning accent from the
                                             panel below so the two read as the same state. -->
                                        <DataTrigger Binding="{Binding IsExtensionUnlocked}" Value="True">
                                            <Setter Property="BorderBrush" Value="{StaticResource YellowBrush}" />
                                            <Setter Property="Background" Value="{StaticResource WarningPanelBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <!-- Locked padlock -->
                                <TextBlock Text="&#xE72E;"
                                           FontFamily="{StaticResource IconFontFamily}"
                                           FontSize="11"
                                           VerticalAlignment="Center"
                                           Margin="0,0,7,0"
                                           Foreground="{StaticResource SubtextBrush}"
                                           Visibility="{Binding IsExtensionUnlocked, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}" />
                                <!-- Unlocked pencil-edit -->
                                <TextBlock Text="&#xE70F;"
                                           FontFamily="{StaticResource IconFontFamily}"
                                           FontSize="11"
                                           VerticalAlignment="Center"
                                           Margin="0,0,7,0"
                                           Foreground="{StaticResource YellowBrush}"
                                           Visibility="{Binding IsExtensionUnlocked, Converter={StaticResource BoolToVis}}" />
                                <TextBlock Text="{Binding Extension}"
                                           VerticalAlignment="Center"
                                           FontFamily="Consolas"
                                           FontSize="13" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <!-- Extension-unlocked warning + editor -->
                    <Border Margin="0,12,0,0"
                            Padding="13,11"
                            Background="{StaticResource WarningPanelBrush}"
                            BorderBrush="{StaticResource YellowBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource Radius.Sm.CR}"
                            Visibility="{Binding IsExtensionUnlocked, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <TextBlock Text="Changing the extension renames the file — it won't convert the image."
                                       Foreground="{StaticResource YellowBrush}"
                                       FontSize="12"
                                       LineHeight="17"
                                       TextWrapping="Wrap" />
                            <TextBox Text="{Binding Extension, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,8,0,0"
                                     FontFamily="Consolas"
                                     AutomationProperties.Name="File extension" />
                        </StackPanel>
                    </Border>

                    <!-- Live status card — preview + colored status dot -->
                    <Border Style="{StaticResource StatusCard}" Margin="0,14,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- Status dot: color transitions are DataTrigger SolidColorBrush swaps.
                                 The success-pulse ScaleTransform grows on 'Saved' via a triggered
                                 storyboard so a rename commit feels confirmed, not silent. -->
                            <Ellipse Grid.Column="0" RenderTransformOrigin="0.5,0.5">
                                <Ellipse.RenderTransform>
                                    <ScaleTransform ScaleX="1" ScaleY="1" />
                                </Ellipse.RenderTransform>
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse" BasedOn="{StaticResource StatusDot}">
                                        <Setter Property="Fill" Value="{StaticResource OverlayBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding RenameStatus}" Value="Pending">
                                                <Setter Property="Fill" Value="{StaticResource YellowBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding RenameStatus}" Value="Saved">
                                                <Setter Property="Fill" Value="{StaticResource GreenBrush}" />
                                                <DataTrigger.EnterActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <!-- Walk the RenderTransform path so the animation resolves on the triggered
                                                                 Ellipse itself; style-scoped TargetName can't reach a templated child. -->
                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                                             From="1" To="1.5"
                                                                             AutoReverse="True"
                                                                             Duration="{StaticResource Motion.Base}">
                                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
                                                            </DoubleAnimation>
                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                                             From="1" To="1.5"
                                                                             AutoReverse="True"
                                                                             Duration="{StaticResource Motion.Base}">
                                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
                                                            </DoubleAnimation>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </DataTrigger.EnterActions>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding RenameStatus}" Value="Conflict">
                                                <Setter Property="Fill" Value="{StaticResource MauveBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding RenameStatus}" Value="Error">
                                                <Setter Property="Fill" Value="{StaticResource RedBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{Binding RenameStatusText}"
                                           Foreground="{StaticResource TextBrush}"
                                           FontSize="12.5"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="{Binding RenamePreview}"
                                           Foreground="{StaticResource SubtextBrush}"
                                           FontSize="12"
                                           Margin="0,3,0,0"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <TextBlock Style="{StaticResource Text.Hint}"
                               Text="Renames save on pause. Enter commits now · Esc reverts."
                               Margin="1,10,0,0" />

                    <Border Style="{StaticResource Divider}" />

                    <!-- RECENT RENAMES section -->
                    <TextBlock Text="Recent renames" Style="{StaticResource SectionLabel}" />

                    <Border Style="{StaticResource Card}"
                            Visibility="{Binding RecentRenames.Count, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}">
                        <StackPanel>
                            <TextBlock Text="No renames yet"
                                       Foreground="{StaticResource TextBrush}"
                                       FontSize="12.5"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="Your undo list will appear here."
                                       Foreground="{StaticResource OverlayBrush}"
                                       FontSize="12"
                                       LineHeight="17"
                                       TextWrapping="Wrap"
                                       Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>

                    <ItemsControl ItemsSource="{Binding RecentRenames}"
                                  KeyboardNavigation.DirectionalNavigation="Cycle"
                                  KeyboardNavigation.TabNavigation="Continue"
                                  AutomationProperties.Name="Recent renames">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource InteractiveCard}"
                                        Padding="13,10"
                                        Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock FontSize="12" TextTrimming="CharacterEllipsis">
                                                <Run Text="{Binding FromPath, Converter={x:Static vm:PathToFileNameConverter.Instance}, Mode=OneWay}"
                                                     Foreground="{StaticResource SubtextBrush}" />
                                            </TextBlock>
                                            <TextBlock FontSize="12" TextTrimming="CharacterEllipsis" Margin="0,2,0,0">
                                                <Run Text="→ " Foreground="{StaticResource OverlayBrush}" />
                                                <Run Text="{Binding ToPath, Converter={x:Static vm:PathToFileNameConverter.Instance}, Mode=OneWay}"
                                                     Foreground="{StaticResource TextBrush}" />
                                            </TextBlock>
                                        </StackPanel>
                                        <Button Grid.Column="1"
                                                Content="Undo"
                                                Style="{StaticResource ChromeButton}"
                                                Padding="14,4"
                                                MinHeight="28"
                                                VerticalAlignment="Center"
                                                Margin="12,0,0,0"
                                                Command="{Binding DataContext.UndoRenameCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                AutomationProperties.Name="Undo rename" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- RECENT FOLDERS section (V20-02 UI consumer — data layer shipped v0.1.7).
                         Whole block hides when the MRU is empty so a fresh install / first-run
                         user doesn't see an orphan "Recent folders" header above nothing. -->
                    <StackPanel Visibility="{Binding RecentFolders.Count, Converter={StaticResource BoolToVis}}">
                        <Border Style="{StaticResource Divider}" />
                        <TextBlock Text="Recent folders" Style="{StaticResource SectionLabel}" />
                        <ItemsControl ItemsSource="{Binding RecentFolders}"
                                      KeyboardNavigation.DirectionalNavigation="Cycle"
                                      KeyboardNavigation.TabNavigation="Continue"
                                      AutomationProperties.Name="Recent folders">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource ChromeButton}"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Stretch"
                                            Padding="13,10"
                                            Margin="0,0,0,8"
                                            Command="{Binding DataContext.OpenRecentFolderCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="{Binding}"
                                            AutomationProperties.Name="{Binding}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="&#xE8B7;"
                                                       FontFamily="{StaticResource IconFontFamily}"
                                                       FontSize="13"
                                                       Foreground="{StaticResource SubtextBrush}"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,10,0" />
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{Binding Converter={x:Static vm:PathToFileNameConverter.Instance}, Mode=OneWay}"
                                                           FontSize="12.5"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis"
                                                           Foreground="{StaticResource TextBrush}" />
                                                <TextBlock Text="{Binding Converter={x:Static vm:PathToParentConverter.Instance}, Mode=OneWay}"
                                                           FontSize="11.5"
                                                           Margin="0,2,0,0"
                                                           TextTrimming="CharacterEllipsis"
                                                           Foreground="{StaticResource OverlayBrush}" />
                                            </StackPanel>
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <Border Style="{StaticResource Divider}" />

                    <!-- DETAILS section -->
                    <TextBlock Text="Details" Style="{StaticResource SectionLabel}" />

                    <Grid Margin="1,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Folder"  Style="{StaticResource MetaLabel}" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding CurrentFolder}"   Style="{StaticResource MetaValue}" ToolTip="{Binding CurrentFolder}" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Size"    Style="{StaticResource MetaLabel}" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding FileSizeText}"    Style="{StaticResource MetaValue}" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Pixels"  Style="{StaticResource MetaLabel}" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding DimensionsText}"  Style="{StaticResource MetaValue}" />

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Decoder" Style="{StaticResource MetaLabel}" />
                        <Border Grid.Row="3" Grid.Column="1"
                                Style="{StaticResource Badge}"
                                Margin="0,0,0,10"
                                VerticalAlignment="Center">
                            <TextBlock Text="{Binding DecoderUsed}"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource SubtextBrush}" />
                        </Border>
                    </Grid>

                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
