<Window x:Class="Images.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Images.ViewModels"
        xmlns:ctl="clr-namespace:Images.Controls"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="Images"
        Width="1280" Height="820"
        MinWidth="800" MinHeight="540"
        WindowStartupLocation="CenterScreen"
        AllowDrop="True"
        Drop="Window_Drop"
        DragOver="Window_DragOver"
        KeyDown="Window_KeyDown"
        Background="{StaticResource BaseBrush}"
        TextOptions.TextFormattingMode="Display">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <vm:BooleanToVisibilityConverter x:Key="BoolToVis" />

        <Style x:Key="StatusDot" TargetType="Ellipse">
            <Setter Property="Width" Value="10" />
            <Setter Property="Height" Value="10" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="340" />
        </Grid.ColumnDefinitions>

        <!-- ============ LEFT: Image viewport + nav chrome + bottom toolbar ============ -->
        <Grid Grid.Column="0" Background="{StaticResource ViewportBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Viewport with hover-reveal arrows -->
            <Grid x:Name="Viewport" Grid.Row="0" ClipToBounds="True">
                <ctl:ZoomPanImage x:Name="Canvas"
                                   Source="{Binding CurrentImage}"
                                   Rotation="{Binding Rotation}" />

                <!-- Empty state -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                            Visibility="{Binding HasImage, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}">
                    <TextBlock Text="&#xE8B9;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="96"
                               HorizontalAlignment="Center"
                               Foreground="{StaticResource Surface2Brush}" />
                    <TextBlock Text="Drag an image here, or click Open"
                               Foreground="{StaticResource SubtextBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,16,0,0"
                               FontSize="15" />
                    <Button Content="Open…"
                            Command="{Binding OpenCommand}"
                            Style="{StaticResource ChromeButton}"
                            HorizontalAlignment="Center"
                            Margin="0,18,0,0"
                            Padding="24,8" />
                </StackPanel>

                <!-- Hover-reveal nav arrows (only when image present) -->
                <Grid Visibility="{Binding HasImage, Converter={StaticResource BoolToVis}}">
                    <Button x:Name="PrevArrow"
                            Style="{StaticResource NavArrowButton}"
                            Command="{Binding PrevCommand}"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Margin="18,0,0,0"
                            Content="&#xE76B;"
                            FontFamily="Segoe MDL2 Assets"
                            FontSize="20"
                            Opacity="0">
                        <Button.Triggers>
                            <EventTrigger RoutedEvent="Button.Loaded">
                                <BeginStoryboard>
                                    <Storyboard />
                                </BeginStoryboard>
                            </EventTrigger>
                        </Button.Triggers>
                    </Button>
                    <Button x:Name="NextArrow"
                            Style="{StaticResource NavArrowButton}"
                            Command="{Binding NextCommand}"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Margin="0,0,18,0"
                            Content="&#xE76C;"
                            FontFamily="Segoe MDL2 Assets"
                            FontSize="20"
                            Opacity="0" />

                    <!-- Position chip -->
                    <Border HorizontalAlignment="Center"
                            VerticalAlignment="Top"
                            Margin="0,16,0,0"
                            Background="#99000000"
                            CornerRadius="12"
                            Padding="12,5">
                        <TextBlock Text="{Binding PositionText}"
                                   Foreground="#FFEAEAEA"
                                   FontSize="12" />
                    </Border>

                    <!-- Toast notification -->
                    <Border HorizontalAlignment="Center"
                            VerticalAlignment="Bottom"
                            Margin="0,0,0,80"
                            Background="#CC000000"
                            BorderBrush="{StaticResource AccentBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="16,10"
                            Visibility="{Binding ToastMessage, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding ToastMessage}"
                                   Foreground="#FFEAEAEA"
                                   FontSize="13" />
                    </Border>
                </Grid>
            </Grid>

            <!-- Bottom toolbar (Win7-style row) -->
            <Border Grid.Row="1"
                    Background="{StaticResource MantleBrush}"
                    BorderBrush="{StaticResource Surface0Brush}"
                    BorderThickness="0,1,0,0">
                <Grid Margin="12,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Left: info -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{Binding CurrentFileName}"
                                   Foreground="{StaticResource TextBrush}"
                                   FontWeight="SemiBold"
                                   FontSize="13"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="  ·  "
                                   Foreground="{StaticResource OverlayBrush}"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="{Binding DimensionsText}"
                                   Foreground="{StaticResource SubtextBrush}"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="  ·  "
                                   Foreground="{StaticResource OverlayBrush}"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="{Binding FileSizeText}"
                                   Foreground="{StaticResource SubtextBrush}"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <!-- Center: primary controls (Win7 layout: prev, rotate-l, play, rotate-r, next, delete) -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Style="{StaticResource ToolbarButton}" Command="{Binding PrevCommand}"     Content="&#xE76B;" ToolTip="Previous (Left)" />
                        <Button Style="{StaticResource ToolbarButton}" Command="{Binding RotateCcwCommand}" Content="&#xE7AD;" ToolTip="Rotate left" Margin="6,0,0,0" />
                        <Button Style="{StaticResource ToolbarButton}" Command="{Binding OpenCommand}"      Content="&#xE8E5;" ToolTip="Open…" Margin="6,0,0,0" />
                        <Button Style="{StaticResource ToolbarButton}" Command="{Binding RotateCwCommand}"  Content="&#xE7AC;" ToolTip="Rotate right" Margin="6,0,0,0" />
                        <Button Style="{StaticResource ToolbarButton}" Command="{Binding NextCommand}"      Content="&#xE76C;" ToolTip="Next (Right)" Margin="6,0,0,0" />
                        <Border Width="1" Background="{StaticResource Surface1Brush}" Margin="10,4" />
                        <Button Style="{StaticResource ToolbarButton}" Command="{Binding DeleteCommand}"    Content="&#xE74D;" ToolTip="Delete (Recycle Bin)" />
                    </StackPanel>

                    <!-- Right: utility -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                        <Button Style="{StaticResource ToolbarButton}" Command="{Binding RevealCommand}"  Content="&#xE838;" ToolTip="Reveal in Explorer" />
                        <Button Style="{StaticResource ToolbarButton}" Command="{Binding CopyPathCommand}" Content="&#xE8C8;" ToolTip="Copy path" Margin="6,0,0,0" />
                        <Button Style="{StaticResource ToolbarButton}" Command="{Binding RefreshCommand}"  Content="&#xE72C;" ToolTip="Refresh folder (F5)" Margin="6,0,0,0" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- ============ RIGHT: Rename panel ============ -->
        <Border Grid.Column="1"
                Background="{StaticResource MantleBrush}"
                BorderBrush="{StaticResource Surface0Brush}"
                BorderThickness="1,0,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0">
                <StackPanel Margin="16">

                    <TextBlock Text="RENAME"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource OverlayBrush}"
                               Margin="2,0,0,8" />

                    <!-- Stem + extension chip, side by side -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="StemEditor"
                                 Grid.Column="0"
                                 Text="{Binding EditableStem, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="15"
                                 IsEnabled="{Binding HasImage}"
                                 PreviewKeyDown="StemEditor_PreviewKeyDown" />
                        <Button Grid.Column="1"
                                Margin="8,0,0,0"
                                Padding="10,0"
                                MinWidth="64"
                                Height="34"
                                Command="{Binding UnlockExtensionCommand}"
                                IsEnabled="{Binding HasImage}"
                                Style="{StaticResource ChromeButton}"
                                ToolTip="Click to edit extension (normally locked)">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE72E;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="11"
                                           VerticalAlignment="Center"
                                           Margin="0,0,6,0"
                                           Foreground="{StaticResource SubtextBrush}"
                                           Visibility="{Binding IsExtensionUnlocked, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}" />
                                <TextBlock Text="{Binding Extension}"
                                           VerticalAlignment="Center"
                                           FontFamily="Consolas"
                                           FontSize="13" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <!-- Extension unlocked warning + editor -->
                    <StackPanel Margin="0,8,0,0" Visibility="{Binding IsExtensionUnlocked, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Extension unlocked — changing it will not convert the file."
                                   Foreground="{StaticResource YellowBrush}"
                                   FontSize="11"
                                   TextWrapping="Wrap" />
                        <TextBox Text="{Binding Extension, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,6,0,0"
                                 FontFamily="Consolas" />
                    </StackPanel>

                    <!-- Live preview + status -->
                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0" Margin="0,0,0,0" VerticalAlignment="Center">
                            <Ellipse>
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse" BasedOn="{StaticResource StatusDot}">
                                        <Setter Property="Fill" Value="{StaticResource OverlayBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding RenameStatus}" Value="Pending">
                                                <Setter Property="Fill" Value="{StaticResource YellowBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding RenameStatus}" Value="Saved">
                                                <Setter Property="Fill" Value="{StaticResource GreenBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding RenameStatus}" Value="Conflict">
                                                <Setter Property="Fill" Value="{StaticResource MauveBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding RenameStatus}" Value="Error">
                                                <Setter Property="Fill" Value="{StaticResource RedBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                        </Grid>

                        <TextBlock Grid.Column="1"
                                   VerticalAlignment="Center"
                                   Text="{Binding RenamePreview}"
                                   Foreground="{StaticResource SubtextBrush}"
                                   FontSize="12"
                                   TextTrimming="CharacterEllipsis" />
                    </Grid>

                    <TextBlock Text="Auto-saves 0.6 s after you stop typing. Press Enter to save now, Esc to revert."
                               Foreground="{StaticResource OverlayBrush}"
                               FontSize="11"
                               Margin="0,6,0,0"
                               TextWrapping="Wrap" />

                    <!-- Divider -->
                    <Border Height="1" Background="{StaticResource Surface0Brush}" Margin="0,18,0,18" />

                    <!-- Recent renames -->
                    <TextBlock Text="RECENT RENAMES"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource OverlayBrush}"
                               Margin="2,0,0,8" />

                    <TextBlock Text="Nothing to undo yet."
                               Foreground="{StaticResource OverlayBrush}"
                               FontSize="12"
                               Margin="2,0,0,0"
                               Visibility="{Binding RecentRenames.Count, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}" />

                    <ItemsControl ItemsSource="{Binding RecentRenames}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource Surface0Brush}"
                                        CornerRadius="6"
                                        Padding="10,8"
                                        Margin="0,0,0,6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock FontSize="12" TextTrimming="CharacterEllipsis">
                                                <Run Text="{Binding FromPath, Converter={x:Static vm:PathToFileNameConverter.Instance}, Mode=OneWay}"
                                                     Foreground="{StaticResource SubtextBrush}" />
                                            </TextBlock>
                                            <TextBlock FontSize="12" TextTrimming="CharacterEllipsis">
                                                <Run Text="→ " Foreground="{StaticResource OverlayBrush}" />
                                                <Run Text="{Binding ToPath, Converter={x:Static vm:PathToFileNameConverter.Instance}, Mode=OneWay}"
                                                     Foreground="{StaticResource TextBrush}" />
                                            </TextBlock>
                                        </StackPanel>
                                        <Button Grid.Column="1"
                                                Content="Undo"
                                                Style="{StaticResource ChromeButton}"
                                                Padding="10,2"
                                                VerticalAlignment="Center"
                                                Margin="10,0,0,0"
                                                Command="{Binding DataContext.UndoRenameCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Divider -->
                    <Border Height="1" Background="{StaticResource Surface0Brush}" Margin="0,18,0,18" />

                    <!-- Metadata -->
                    <TextBlock Text="DETAILS"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource OverlayBrush}"
                               Margin="2,0,0,8" />

                    <Grid Margin="2,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Folder" Foreground="{StaticResource OverlayBrush}" Margin="0,0,12,4" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding CurrentFolder}" TextTrimming="CharacterEllipsis" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Size" Foreground="{StaticResource OverlayBrush}" Margin="0,0,12,4" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding FileSizeText}" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Pixels" Foreground="{StaticResource OverlayBrush}" Margin="0,0,12,4" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding DimensionsText}" />

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Decoder" Foreground="{StaticResource OverlayBrush}" Margin="0,0,12,4" />
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding DecoderUsed}" />
                    </Grid>

                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
