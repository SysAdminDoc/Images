<UserControl x:Class="Images.Controls.SelectionOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{x:Null}">
    <Grid>
        <Canvas x:Name="OverlayCanvas"
                IsHitTestVisible="False">
            <Border x:Name="SelectionBox"
                    Visibility="Collapsed"
                    BorderBrush="{StaticResource AccentBrush}"
                    BorderThickness="2"
                    CornerRadius="2"
                    Background="#1F89B4FA"
                    SnapsToDevicePixels="True">
                <Grid>
                    <Rectangle Stroke="#B8F5F5F8"
                               StrokeThickness="1"
                               StrokeDashArray="3 3"
                               Fill="Transparent"
                               Margin="3" />
                    <TextBlock x:Name="SelectionLabel"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Top"
                               Margin="8"
                               Padding="7,3"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource FloatingChromeTextBrush}"
                               Background="{StaticResource FloatingChromeBrush}" />
                </Grid>
            </Border>
        </Canvas>

        <Canvas x:Name="ActionCanvas"
                Background="{x:Null}">
            <StackPanel x:Name="ActionPanel"
                        Orientation="Horizontal"
                        Visibility="Collapsed">
                <Button Command="{Binding RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, Path=CopyCommand}"
                        Style="{StaticResource ChromeButton}"
                        MinWidth="72"
                        MinHeight="32"
                        Padding="10,6"
                        Margin="0,0,8,0"
                        AutomationProperties.Name="Copy selection"
                        ToolTip="Copy selection">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontFamily="{StaticResource IconFontFamily}"
                                   Text="&#xE8C8;"
                                   FontSize="11"
                                   Margin="0,0,7,0"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="Copy"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Command="{Binding RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, Path=ClearCommand}"
                        Style="{StaticResource ChromeButton}"
                        MinWidth="72"
                        MinHeight="32"
                        Padding="10,6"
                        AutomationProperties.Name="Clear selection"
                        ToolTip="Clear selection">
                    <TextBlock Text="Clear"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                </Button>
            </StackPanel>
        </Canvas>
    </Grid>
</UserControl>
