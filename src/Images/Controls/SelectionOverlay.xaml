<UserControl x:Class="Images.Controls.SelectionOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:Images.Localization"
             Background="{x:Null}">
    <Grid>
        <Canvas x:Name="OverlayCanvas"
                IsHitTestVisible="False">
            <Border x:Name="SelectionBox"
                    Visibility="Collapsed"
                    BorderBrush="{DynamicResource AccentBrush}"
                    BorderThickness="2"
                    CornerRadius="2"
                    Background="{DynamicResource AccentPanelBrush}"
                    SnapsToDevicePixels="True">
                <Grid>
                    <Rectangle Stroke="{DynamicResource OverlayGuideStrongBrush}"
                               StrokeThickness="1"
                               StrokeDashArray="3 3"
                               Fill="Transparent"
                               Margin="3" />
                    <TextBlock x:Name="SelectionLabel"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Top"
                               Margin="8"
                               Padding="7,3"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource FloatingChromeTextBrush}"
                               Background="{DynamicResource FloatingChromeBrush}" />
                </Grid>
            </Border>
        </Canvas>

        <Canvas x:Name="ActionCanvas"
                Background="{x:Null}">
            <StackPanel x:Name="ActionPanel"
                        Orientation="Horizontal"
                        Visibility="Collapsed">
                <Button Command="{Binding RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, Path=CopyCommand}"
                        Style="{StaticResource ChromeButton}"
                        MinWidth="72"
                        MinHeight="32"
                        Padding="10,6"
                        Margin="0,0,8,0"
                        AutomationProperties.Name="{loc:Loc CopySelection}"
                        ToolTip="{loc:Loc CopySelection}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontFamily="{StaticResource IconFontFamily}"
                                   Text="&#xE8C8;"
                                   FontSize="11"
                                   Margin="0,0,7,0"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="{loc:Loc Copy}"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Command="{Binding RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, Path=ClearCommand}"
                        Style="{StaticResource ChromeButton}"
                        MinWidth="72"
                        MinHeight="32"
                        Padding="10,6"
                        AutomationProperties.Name="{loc:Loc ClearSelection}"
                        ToolTip="{loc:Loc ClearSelection}">
                    <TextBlock Text="{loc:Loc Clear}"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                </Button>
            </StackPanel>
        </Canvas>
    </Grid>
</UserControl>
