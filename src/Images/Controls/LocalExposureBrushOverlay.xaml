<UserControl x:Class="Images.Controls.LocalExposureBrushOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:svc="clr-namespace:Images.Services"
             IsHitTestVisible="False"
             Background="Transparent">
    <Grid>
        <Canvas x:Name="OverlayCanvas">
            <ItemsControl ItemsSource="{Binding RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, Path=Strokes}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Canvas />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="Canvas.Left" Value="{Binding Left}" />
                        <Setter Property="Canvas.Top" Value="{Binding Top}" />
                    </Style>
                </ItemsControl.ItemContainerStyle>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type svc:LocalExposureBrushStroke}">
                        <Ellipse Width="{Binding Diameter}"
                                 Height="{Binding Diameter}"
                                 StrokeThickness="2"
                                 StrokeDashArray="2 2"
                                 Fill="{DynamicResource BrushTintAccentBrush}"
                                 SnapsToDevicePixels="True">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Stroke" Value="{DynamicResource AccentBrush}" />
                                    <Setter Property="Opacity" Value="0.78" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDodge}" Value="False">
                                            <Setter Property="Stroke" Value="{DynamicResource YellowBrush}" />
                                            <Setter Property="Fill" Value="{DynamicResource BrushTintYellowBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Canvas>
    </Grid>
</UserControl>
