<UserControl x:Class="Images.Controls.CropOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             IsHitTestVisible="False"
             Background="Transparent">
    <Grid>
        <Canvas x:Name="OverlayCanvas">
            <Border x:Name="SelectionBox"
                    Visibility="Collapsed"
                    BorderBrush="{StaticResource AccentBrush}"
                    BorderThickness="2"
                    CornerRadius="2"
                    Background="#2689B4FA"
                    SnapsToDevicePixels="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>
                    <Border Grid.RowSpan="3"
                            Grid.Column="1"
                            BorderBrush="#8CF5F5F8"
                            BorderThickness="1,0,1,0" />
                    <Border Grid.Row="1"
                            Grid.ColumnSpan="3"
                            BorderBrush="#8CF5F5F8"
                            BorderThickness="0,1,0,1" />
                    <TextBlock x:Name="SelectionLabel"
                               Grid.RowSpan="3"
                               Grid.ColumnSpan="3"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Top"
                               Margin="8"
                               Padding="7,3"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource FloatingChromeTextBrush}"
                               Background="{StaticResource FloatingChromeBrush}" />
                </Grid>
            </Border>
        </Canvas>
    </Grid>
</UserControl>
