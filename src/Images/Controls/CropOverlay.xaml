<UserControl x:Class="Images.Controls.CropOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:Images.Localization"
             Background="{x:Null}">
    <Grid>
        <Canvas x:Name="OverlayCanvas"
                IsHitTestVisible="False">
            <Border x:Name="SelectionBox"
                    Visibility="Collapsed"
                    BorderBrush="{DynamicResource AccentBrush}"
                    BorderThickness="2"
                    CornerRadius="2"
                    Background="{DynamicResource AccentSelectionBrush}"
                    SnapsToDevicePixels="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>
                    <Border Grid.RowSpan="3"
                            Grid.Column="1"
                            BorderBrush="{DynamicResource OverlayGuideBrush}"
                            BorderThickness="1,0,1,0" />
                    <Border Grid.Row="1"
                            Grid.ColumnSpan="3"
                            BorderBrush="{DynamicResource OverlayGuideBrush}"
                            BorderThickness="0,1,0,1" />
                    <TextBlock x:Name="SelectionLabel"
                               Grid.RowSpan="3"
                               Grid.ColumnSpan="3"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Top"
                               Margin="8"
                               Padding="7,3"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource FloatingChromeTextBrush}"
                               Background="{DynamicResource FloatingChromeBrush}" />
                </Grid>
            </Border>
        </Canvas>

        <Canvas x:Name="ActionCanvas"
                Background="{x:Null}">
            <Button x:Name="ApplyButton"
                    Command="{Binding RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, Path=ApplyCommand}"
                    Style="{StaticResource ChromeButton}"
                    MinWidth="78"
                    MinHeight="32"
                    Padding="10,6"
                    Visibility="Collapsed"
                    AutomationProperties.Name="{loc:Loc ApplyCrop}"
                    ToolTip="{loc:Loc ApplyCrop}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock FontFamily="{StaticResource IconFontFamily}"
                               Text="&#xE73E;"
                               FontSize="12"
                               Margin="0,0,7,0"
                               VerticalAlignment="Center" />
                    <TextBlock Text="{loc:Loc Apply}"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Button>
        </Canvas>
    </Grid>
</UserControl>
