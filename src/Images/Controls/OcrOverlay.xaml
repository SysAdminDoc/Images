<UserControl x:Class="Images.Controls.OcrOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:Images.Localization"
             xmlns:vm="clr-namespace:Images.ViewModels"
             IsHitTestVisible="True"
             Background="Transparent">
    <Grid x:Name="Root">
        <ItemsControl x:Name="OverlayItems"
                       ItemsSource="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=DataContext.OcrOverlayLines}"
                       AutomationProperties.Name="{loc:Loc OcrTextRegions}"
                       AutomationProperties.HelpText="{loc:Loc OcrTextRegionsHelpText}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <Canvas />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemContainerStyle>
                <Style TargetType="{x:Type ContentPresenter}">
                    <Setter Property="Canvas.Left" Value="{Binding BoundingBox.X}" />
                    <Setter Property="Canvas.Top" Value="{Binding BoundingBox.Y}" />
                </Style>
            </ItemsControl.ItemContainerStyle>
            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:OcrTextLine}">
                    <Border BorderBrush="{StaticResource AccentBrush}"
                            BorderThickness="1"
                            CornerRadius="2"
                            Width="{Binding BoundingBox.Width}"
                            Height="{Binding BoundingBox.Height}"
                            Focusable="False"
                            ToolTip="{Binding Text, StringFormat={x:Static loc:Strings.OcrTextTooltipFormat}}"
                            AutomationProperties.Name="{Binding Text}"
                            AutomationProperties.HelpText="{loc:Loc OcrTextRegionHelpText}">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{StaticResource OcrRegionBrush}" />
                                <Style.Triggers>
                                    <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                        <Setter Property="Background" Value="{StaticResource OcrRegionFocusBrush}" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBox Text="{Binding Text, Mode=OneWay}"
                                 IsReadOnly="True"
                                 IsReadOnlyCaretVisible="True"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Foreground="{StaticResource TextBrush}"
                                 SelectionBrush="{StaticResource AccentBrush}"
                                 SelectionOpacity="0.5"
                                 Padding="2,0"
                                 MinWidth="0"
                                 MinHeight="0"
                                 FontSize="12"
                                 FontWeight="SemiBold"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalContentAlignment="Center"
                                 HorizontalContentAlignment="Left"
                                 Cursor="IBeam"
                                 ToolTip="{Binding Text, StringFormat={x:Static loc:Strings.OcrSelectCopyTooltipFormat}}"
                                 AutomationProperties.Name="{Binding Text}"
                                 AutomationProperties.HelpText="{loc:Loc OcrTextBoxHelpText}" />
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</UserControl>
