<UserControl x:Class="Images.Controls.OcrOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Images.ViewModels"
             IsHitTestVisible="True"
             Background="Transparent">
    <Grid x:Name="Root">
        <ItemsControl x:Name="OverlayItems"
                       ItemsSource="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=DataContext.OcrOverlayLines}"
                       AutomationProperties.Name="OCR text regions"
                       AutomationProperties.HelpText="Select text inside a region, then copy it with Ctrl+C or the text box context menu">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <Canvas />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemContainerStyle>
                <Style TargetType="{x:Type ContentPresenter}">
                    <Setter Property="Canvas.Left" Value="{Binding BoundingBox.X}" />
                    <Setter Property="Canvas.Top" Value="{Binding BoundingBox.Y}" />
                </Style>
            </ItemsControl.ItemContainerStyle>
            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:OcrTextLine}">
                    <Border BorderBrush="#89B4FA"
                            BorderThickness="1"
                            CornerRadius="2"
                            Width="{Binding BoundingBox.Width}"
                            Height="{Binding BoundingBox.Height}"
                            Focusable="False"
                            ToolTip="{Binding Text, StringFormat=OCR text: {0}}"
                            AutomationProperties.Name="{Binding Text}"
                            AutomationProperties.HelpText="Selectable OCR text region">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#4D89B4FA" />
                                <Style.Triggers>
                                    <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                        <Setter Property="Background" Value="#9989B4FA" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBox Text="{Binding Text, Mode=OneWay}"
                                 IsReadOnly="True"
                                 IsReadOnlyCaretVisible="True"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Foreground="#CDD6F4"
                                 SelectionBrush="#89B4FA"
                                 SelectionOpacity="0.5"
                                 Padding="2,0"
                                 MinWidth="0"
                                 MinHeight="0"
                                 FontSize="12"
                                 FontWeight="SemiBold"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalContentAlignment="Center"
                                 HorizontalContentAlignment="Left"
                                 Cursor="IBeam"
                                 ToolTip="{Binding Text, StringFormat=Select and copy: {0}}"
                                 AutomationProperties.Name="{Binding Text}"
                                 AutomationProperties.HelpText="Selectable OCR text. Drag to highlight text, then press Ctrl+C or use the context menu to copy." />
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</UserControl>
