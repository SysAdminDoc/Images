<Window x:Class="Images.BatchProcessorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:Images.Localization"
        xmlns:a11y="clr-namespace:Images.Services"
        Title="{x:Static loc:Strings.BatchTitle}"
        Width="1120"
        Height="760"
        MinWidth="920"
        MinHeight="620"
        WindowStartupLocation="CenterOwner">
    <Grid Background="{DynamicResource BaseBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource ToolWindowHeader}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="{x:Static loc:Strings.BatchHeading}" Style="{StaticResource Text.Title}" />
                    <TextBlock Text="{x:Static loc:Strings.BatchSubtitle}"
                               Style="{StaticResource Text.Caption}"
                               Margin="0,3,0,0" />
                </StackPanel>
                <WrapPanel Grid.Column="1" HorizontalAlignment="Right">
                    <Button Style="{StaticResource ChromeButton}"
                            Margin="8,0,0,0"
                            Click="LoadPresetButton_Click"
                            AutomationProperties.Name="{x:Static loc:Strings.BatchLoadPresetAutomationName}">
                        <TextBlock Text="{x:Static loc:Strings.BatchLoadPreset}" />
                    </Button>
                    <Button Style="{StaticResource ChromeButton}"
                            Margin="8,0,0,0"
                            Click="SavePresetButton_Click"
                            AutomationProperties.Name="{x:Static loc:Strings.BatchSavePresetAutomationName}">
                        <TextBlock Text="{x:Static loc:Strings.BatchSavePreset}" />
                    </Button>
                </WrapPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource ToolWindowSidebar}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="{x:Static loc:Strings.BatchSourcesHeading}" Style="{StaticResource SectionLabel}" />
                        <Border Style="{StaticResource Card}" Padding="12">
                            <StackPanel>
                                <WrapPanel>
                                    <Button x:Name="AddFilesButton"
                                            Style="{StaticResource ChromeButton}"
                                            Margin="0,0,8,0"
                                            Click="AddFilesButton_Click">
                                        <TextBlock Text="{x:Static loc:Strings.BatchAddFiles}" />
                                    </Button>
                                    <Button x:Name="AddFolderButton"
                                            Style="{StaticResource ChromeButton}"
                                            Click="AddFolderButton_Click">
                                        <TextBlock Text="{x:Static loc:Strings.BatchAddFolder}" />
                                    </Button>
                                </WrapPanel>
                                <ListBox x:Name="SourceList"
                                         MinHeight="112"
                                         Margin="0,10,0,0"
                                         AutomationProperties.Name="{x:Static loc:Strings.BatchSourcesAutomationName}" />
                                <Button Style="{StaticResource ChromeButton}"
                                        Margin="0,10,0,0"
                                        HorizontalAlignment="Left"
                                        Click="ClearSourcesButton_Click">
                                    <TextBlock Text="{x:Static loc:Strings.BatchClearSources}" />
                                </Button>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Divider}" />

                        <TextBlock Text="{x:Static loc:Strings.BatchPresetHeading}" Style="{StaticResource SectionLabel}" />
                        <Border Style="{StaticResource Card}" Padding="12">
                            <StackPanel>
                                <ComboBox x:Name="PresetCombo"
                                          SelectionChanged="PresetCombo_SelectionChanged"
                                          AutomationProperties.Name="{x:Static loc:Strings.BatchPresetAutomationName}" />
                                <TextBlock Text="{x:Static loc:Strings.BatchPresetName}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}"
                                           Margin="0,12,0,0" />
                                <TextBox x:Name="PresetNameBox" TextChanged="SettingsChanged"
                                         AutomationProperties.Name="{x:Static loc:Strings.BatchPresetName}" />
                                <TextBlock Text="{x:Static loc:Strings.BatchPresetExtension}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}"
                                           Margin="0,10,0,0" />
                                <TextBox x:Name="ExtensionBox" TextChanged="SettingsChanged"
                                         AutomationProperties.Name="{x:Static loc:Strings.BatchPresetExtension}" />
                                <TextBlock Text="{x:Static loc:Strings.BatchPresetQuality}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}"
                                           Margin="0,10,0,0" />
                                <Slider x:Name="QualitySlider"
                                        AutomationProperties.Name="{x:Static loc:Strings.BatchPresetQuality}"
                                        Minimum="1"
                                        Maximum="100"
                                        TickFrequency="1"
                                        IsSnapToTickEnabled="True"
                                        ValueChanged="QualitySlider_ValueChanged" />
                                <TextBlock x:Name="QualityText" Style="{StaticResource Text.Caption}" />
                                <TextBlock Text="{x:Static loc:Strings.BatchPresetMaxDimensions}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}"
                                           Margin="0,10,0,0" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="MaxWidthBox"
                                             Grid.Column="0"
                                             TextChanged="SettingsChanged"
                                             AutomationProperties.Name="{x:Static loc:Strings.BatchMaxWidthAutomationName}" />
                                    <TextBox x:Name="MaxHeightBox"
                                             Grid.Column="2"
                                             TextChanged="SettingsChanged"
                                             AutomationProperties.Name="{x:Static loc:Strings.BatchMaxHeightAutomationName}" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Divider}" />

                        <TextBlock Text="{x:Static loc:Strings.BatchOperationsHeading}" Style="{StaticResource SectionLabel}" />
                        <Border Style="{StaticResource Card}" Padding="12">
                            <StackPanel>
                                <TextBlock Text="{x:Static loc:Strings.BatchOperationsHint}"
                                           Style="{StaticResource Text.Caption}"
                                           TextWrapping="Wrap" />
                                <ComboBox x:Name="OperationKindCombo"
                                          Margin="0,10,0,0"
                                          DisplayMemberPath="Name"
                                          SelectionChanged="OperationKindCombo_SelectionChanged"
                                          AutomationProperties.Name="{x:Static loc:Strings.BatchOperationKindAutomationName}" />
                                <Grid x:Name="OperationParameterGrid" Margin="0,10,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock x:Name="OperationParamOneLabel"
                                               Grid.Row="0"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextBrush}" />
                                    <TextBox x:Name="OperationParamOneBox"
                                             AutomationProperties.LabeledBy="{Binding ElementName=OperationParamOneLabel}"
                                             Grid.Row="1"
                                             Margin="0,4,0,8" />
                                    <TextBlock x:Name="OperationParamTwoLabel"
                                               Grid.Row="2"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextBrush}" />
                                    <TextBox x:Name="OperationParamTwoBox"
                                             AutomationProperties.LabeledBy="{Binding ElementName=OperationParamTwoLabel}"
                                             Grid.Row="3"
                                             Margin="0,4,0,0" />
                                </Grid>
                                <Button x:Name="AddOperationButton"
                                        Style="{StaticResource ChromeButton}"
                                        Margin="0,10,0,0"
                                        HorizontalAlignment="Left"
                                        Click="AddOperationButton_Click">
                                    <TextBlock Text="{x:Static loc:Strings.BatchAddOperation}" />
                                </Button>
                                <ListBox x:Name="OperationList"
                                         MinHeight="120"
                                         Margin="0,10,0,0"
                                         AutomationProperties.Name="{x:Static loc:Strings.BatchOperationListAutomationName}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,4">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" />
                                                <TextBlock Text="{Binding Summary}" Style="{StaticResource Text.Hint}" TextWrapping="Wrap" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <WrapPanel Margin="0,10,0,0">
                                    <Button x:Name="MoveOperationUpButton"
                                            Style="{StaticResource ChromeButton}"
                                            Margin="0,0,8,0"
                                            Click="MoveOperationUpButton_Click">
                                        <TextBlock Text="{x:Static loc:Strings.BatchMoveOperationUp}" />
                                    </Button>
                                    <Button x:Name="MoveOperationDownButton"
                                            Style="{StaticResource ChromeButton}"
                                            Margin="0,0,8,0"
                                            Click="MoveOperationDownButton_Click">
                                        <TextBlock Text="{x:Static loc:Strings.BatchMoveOperationDown}" />
                                    </Button>
                                    <Button x:Name="RemoveOperationButton"
                                            Style="{StaticResource ChromeButton}"
                                            Click="RemoveOperationButton_Click">
                                        <TextBlock Text="{x:Static loc:Strings.BatchRemoveOperation}" />
                                    </Button>
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Divider}" />

                        <TextBlock Text="{x:Static loc:Strings.BatchOutputHeading}" Style="{StaticResource SectionLabel}" />
                        <Border Style="{StaticResource Card}" Padding="12">
                            <StackPanel>
                                <TextBlock x:Name="OutputFolderText"
                                           Text="{x:Static loc:Strings.BatchOutputFolderDefault}"
                                           Style="{StaticResource Text.Caption}"
                                           TextWrapping="Wrap" />
                                <Button Style="{StaticResource ChromeButton}"
                                        Margin="0,10,0,0"
                                        HorizontalAlignment="Left"
                                        Click="ChooseOutputButton_Click">
                                    <TextBlock Text="{x:Static loc:Strings.BatchChooseOutput}" />
                                </Button>
                                <CheckBox x:Name="DryRunCheckBox"
                                          Content="{x:Static loc:Strings.BatchDryRunOnly}"
                                          IsChecked="True"
                                          Margin="0,12,0,0" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <GridSplitter Grid.Column="1"
                          Style="{StaticResource VerticalGridSplitter}" />

            <Grid Grid.Column="2"
                  Background="{DynamicResource ViewportBrush}"
                  Margin="18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="220" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Style="{StaticResource Card}"
                        Padding="12"
                        Margin="0,0,0,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="PreviewSummaryText"
                                   Text="{x:Static loc:Strings.BatchPreviewHint}"
                                   Style="{StaticResource Text.Caption}"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center" />
                        <Button x:Name="PreviewButton"
                                Grid.Column="1"
                                Style="{StaticResource ChromeButton}"
                                Margin="14,0,0,0"
                                Click="PreviewButton_Click">
                            <TextBlock Text="{x:Static loc:Strings.BatchBuildPreview}" />
                        </Button>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Style="{StaticResource Card}"
                        Padding="14">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="{x:Static loc:Strings.BatchPreviewHeading}" Style="{StaticResource SectionLabel}" />
                        <ListBox x:Name="PreviewList"
                                 Grid.Row="1"
                                 Margin="0,8,0,0"
                                 AutomationProperties.Name="{x:Static loc:Strings.BatchPreviewItemsAutomationName}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="12,10" Style="{StaticResource Card}">
                                        <StackPanel>
                                            <TextBlock Text="{Binding FileName}" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" />
                                            <TextBlock Text="{Binding StatusText}" Style="{StaticResource Text.Caption}" Margin="0,3,0,0" />
                                            <TextBlock Text="{Binding OutputPath}" Style="{StaticResource Text.Hint}" TextWrapping="Wrap" Margin="0,3,0,0" />
                                            <TextBlock Text="{Binding OutputDimensions}" Style="{StaticResource Text.Hint}" Margin="0,3,0,0" />
                                            <TextBlock Text="{Binding EstimatedOutputSizeText, StringFormat=Estimated output: {0}}" Style="{StaticResource Text.Hint}" Margin="0,3,0,0" />
                                            <TextBlock Text="{Binding DeltaText, StringFormat=Delta: {0}}" Style="{StaticResource Text.Hint}" Margin="0,3,0,0" />
                                            <TextBlock Text="{Binding WarningsText}" Style="{StaticResource Text.Hint}" TextWrapping="Wrap" Margin="0,3,0,0" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>

                <Border Grid.Row="2"
                        Style="{StaticResource Card}"
                        Padding="14"
                        Margin="0,16,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="{x:Static loc:Strings.BatchRunLogHeading}" Style="{StaticResource SectionLabel}" />
                        <ListBox x:Name="ResultList"
                                 Grid.Row="1"
                                 Margin="0,8,0,0"
                                 AutomationProperties.Name="{x:Static loc:Strings.BatchRunLogAutomationName}" />
                    </Grid>
                </Border>

                <Border Grid.Row="3"
                        Style="{StaticResource Card}"
                        Padding="12"
                        Margin="0,16,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="RunSummaryText"
                                   Text="{x:Static loc:Strings.BatchDryRunHint}"
                                   Style="{StaticResource Text.Caption}"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    Margin="14,0,0,0">
                            <Button x:Name="RunButton"
                                    Style="{StaticResource PrimaryButton}"
                                    Click="RunButton_Click">
                                <TextBlock Text="{x:Static loc:Strings.BatchRunBatch}" />
                            </Button>
                            <Button x:Name="CancelButton"
                                    Style="{StaticResource ChromeButton}"
                                    Margin="8,0,0,0"
                                    IsEnabled="False"
                                    Click="CancelButton_Click">
                                <TextBlock Text="{x:Static loc:Strings.Cancel}" />
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Border Grid.Row="2"
                Style="{StaticResource WindowStatusBar}">
            <StackPanel Orientation="Horizontal">
                <Ellipse x:Name="StatusDot"
                         Width="8"
                         Height="8"
                         Fill="{DynamicResource GreenBrush}"
                         Margin="0,0,9,0"
                         VerticalAlignment="Center" />
                <TextBlock x:Name="StatusText"
                           Text="{x:Static loc:Strings.BatchReadyStatus}"
                           Style="{StaticResource Text.Caption}"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center"
                           AutomationProperties.LiveSetting="Polite"
                           a11y:LiveRegionBehavior.AnnounceChanges="True" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
