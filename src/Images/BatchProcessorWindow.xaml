<Window x:Class="Images.BatchProcessorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Images - Batch processor"
        Width="1120"
        Height="760"
        MinWidth="920"
        MinHeight="620"
        WindowStartupLocation="CenterOwner">
    <Grid Background="{StaticResource BaseBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource HairlineBrush}"
                BorderThickness="0,0,0,1"
                Padding="18,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Batch processor" Style="{StaticResource Text.Title}" />
                    <TextBlock Text="Preview resize/convert settings, save presets, and export collision-safe copies."
                               Style="{StaticResource Text.Caption}"
                               Margin="0,3,0,0" />
                </StackPanel>
                <WrapPanel Grid.Column="1" HorizontalAlignment="Right">
                    <Button Style="{StaticResource ChromeButton}"
                            Margin="8,0,0,0"
                            Click="LoadPresetButton_Click"
                            AutomationProperties.Name="Load batch preset">
                        <TextBlock Text="Load preset" />
                    </Button>
                    <Button Style="{StaticResource ChromeButton}"
                            Margin="8,0,0,0"
                            Click="SavePresetButton_Click"
                            AutomationProperties.Name="Save batch preset">
                        <TextBlock Text="Save preset" />
                    </Button>
                </WrapPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource HairlineBrush}"
                    BorderThickness="0,0,1,0"
                    Padding="16">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Sources" Style="{StaticResource SectionLabel}" />
                        <Border Style="{StaticResource Card}" Padding="12">
                            <StackPanel>
                                <WrapPanel>
                                    <Button x:Name="AddFilesButton"
                                            Style="{StaticResource ChromeButton}"
                                            Margin="0,0,8,0"
                                            Click="AddFilesButton_Click">
                                        <TextBlock Text="Add files" />
                                    </Button>
                                    <Button x:Name="AddFolderButton"
                                            Style="{StaticResource ChromeButton}"
                                            Click="AddFolderButton_Click">
                                        <TextBlock Text="Add folder" />
                                    </Button>
                                </WrapPanel>
                                <ListBox x:Name="SourceList"
                                         MinHeight="112"
                                         Margin="0,10,0,0"
                                         AutomationProperties.Name="Batch processor sources" />
                                <Button Style="{StaticResource ChromeButton}"
                                        Margin="0,10,0,0"
                                        HorizontalAlignment="Left"
                                        Click="ClearSourcesButton_Click">
                                    <TextBlock Text="Clear sources" />
                                </Button>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Divider}" />

                        <TextBlock Text="Preset" Style="{StaticResource SectionLabel}" />
                        <Border Style="{StaticResource Card}" Padding="12">
                            <StackPanel>
                                <ComboBox x:Name="PresetCombo"
                                          SelectionChanged="PresetCombo_SelectionChanged"
                                          AutomationProperties.Name="Batch preset" />
                                <TextBlock Text="Name"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextBrush}"
                                           Margin="0,12,0,0" />
                                <TextBox x:Name="PresetNameBox" TextChanged="SettingsChanged" />
                                <TextBlock Text="Extension"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextBrush}"
                                           Margin="0,10,0,0" />
                                <TextBox x:Name="ExtensionBox" TextChanged="SettingsChanged" />
                                <TextBlock Text="Quality"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextBrush}"
                                           Margin="0,10,0,0" />
                                <Slider x:Name="QualitySlider"
                                        Minimum="1"
                                        Maximum="100"
                                        TickFrequency="1"
                                        IsSnapToTickEnabled="True"
                                        ValueChanged="QualitySlider_ValueChanged" />
                                <TextBlock x:Name="QualityText" Style="{StaticResource Text.Caption}" />
                                <TextBlock Text="Max dimensions"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextBrush}"
                                           Margin="0,10,0,0" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="MaxWidthBox"
                                             Grid.Column="0"
                                             TextChanged="SettingsChanged"
                                             AutomationProperties.Name="Batch max width" />
                                    <TextBox x:Name="MaxHeightBox"
                                             Grid.Column="2"
                                             TextChanged="SettingsChanged"
                                             AutomationProperties.Name="Batch max height" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Divider}" />

                        <TextBlock Text="Output" Style="{StaticResource SectionLabel}" />
                        <Border Style="{StaticResource Card}" Padding="12">
                            <StackPanel>
                                <TextBlock x:Name="OutputFolderText"
                                           Text="Output folder: Images batch output beside each source"
                                           Style="{StaticResource Text.Caption}"
                                           TextWrapping="Wrap" />
                                <Button Style="{StaticResource ChromeButton}"
                                        Margin="0,10,0,0"
                                        HorizontalAlignment="Left"
                                        Click="ChooseOutputButton_Click">
                                    <TextBlock Text="Choose output" />
                                </Button>
                                <CheckBox x:Name="DryRunCheckBox"
                                          Content="Dry run only"
                                          IsChecked="True"
                                          Margin="0,12,0,0" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="1"
                          HorizontalAlignment="Stretch"
                          Background="{StaticResource HairlineBrush}" />

            <Grid Grid.Column="2"
                  Background="{StaticResource ViewportBrush}"
                  Margin="18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="220" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Style="{StaticResource Card}"
                        Padding="12"
                        Margin="0,0,0,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="PreviewSummaryText"
                                   Text="Build a preview to see output paths and dimensions."
                                   Style="{StaticResource Text.Caption}"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center" />
                        <Button x:Name="PreviewButton"
                                Grid.Column="1"
                                Style="{StaticResource ChromeButton}"
                                Margin="14,0,0,0"
                                Click="PreviewButton_Click">
                            <TextBlock Text="Build preview" />
                        </Button>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Style="{StaticResource Card}"
                        Padding="14">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="Preview" Style="{StaticResource SectionLabel}" />
                        <ListBox x:Name="PreviewList"
                                 Grid.Row="1"
                                 Margin="0,8,0,0"
                                 AutomationProperties.Name="Batch preview items">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="12,10" Style="{StaticResource Card}">
                                        <StackPanel>
                                            <TextBlock Text="{Binding FileName}" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" />
                                            <TextBlock Text="{Binding StatusText}" Style="{StaticResource Text.Caption}" Margin="0,3,0,0" />
                                            <TextBlock Text="{Binding OutputPath}" Style="{StaticResource Text.Hint}" TextWrapping="Wrap" Margin="0,3,0,0" />
                                            <TextBlock Text="{Binding OutputDimensions}" Style="{StaticResource Text.Hint}" Margin="0,3,0,0" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>

                <Border Grid.Row="2"
                        Style="{StaticResource Card}"
                        Padding="14"
                        Margin="0,16,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="Run log" Style="{StaticResource SectionLabel}" />
                        <ListBox x:Name="ResultList"
                                 Grid.Row="1"
                                 Margin="0,8,0,0"
                                 AutomationProperties.Name="Batch processor run log" />
                    </Grid>
                </Border>

                <Border Grid.Row="3"
                        Style="{StaticResource Card}"
                        Padding="12"
                        Margin="0,16,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="RunSummaryText"
                                   Text="Dry run is on by default. Turn it off when the preview looks correct."
                                   Style="{StaticResource Text.Caption}"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center" />
                        <Button x:Name="RunButton"
                                Grid.Column="1"
                                Style="{StaticResource PrimaryButton}"
                                Margin="14,0,0,0"
                                Click="RunButton_Click">
                            <TextBlock Text="Run batch" />
                        </Button>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Border Grid.Row="2"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource HairlineBrush}"
                BorderThickness="0,1,0,0"
                Padding="16,10">
            <StackPanel Orientation="Horizontal">
                <Ellipse x:Name="StatusDot"
                         Width="8"
                         Height="8"
                         Fill="{StaticResource GreenBrush}"
                         Margin="0,0,9,0"
                         VerticalAlignment="Center" />
                <TextBlock x:Name="StatusText"
                           Text="Ready. Add files or a folder to begin."
                           Style="{StaticResource Text.Caption}"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
