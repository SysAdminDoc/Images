<Window x:Class="Images.ConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Confirm action"
        Width="520"
        SizeToContent="Height"
        MinWidth="500"
        MaxWidth="620"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Background="{StaticResource BaseBrush}"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True">

    <Border Padding="26,24,26,22">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Width="44"
                        Height="44"
                        CornerRadius="{StaticResource Radius.Md.CR}"
                        Background="{StaticResource DangerPanelBrush}"
                        BorderBrush="{StaticResource RedBrush}"
                        BorderThickness="1"
                        VerticalAlignment="Top">
                    <TextBlock x:Name="IconText"
                               Text="&#xE74D;"
                               FontFamily="{StaticResource IconFontFamily}"
                               FontSize="20"
                               Foreground="{StaticResource RedBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>

                <StackPanel Grid.Column="1" Margin="16,0,0,0">
                    <TextBlock x:Name="TitleText"
                               Style="{StaticResource Text.Title}"
                               TextWrapping="Wrap" />
                    <TextBlock x:Name="MessageText"
                               Style="{StaticResource Text.Subtitle}"
                               Margin="0,7,0,0"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Grid>

            <Border Grid.Row="1"
                    Style="{StaticResource Card}"
                    Margin="0,20,0,0"
                    Padding="13,11">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="&#xE8A5;"
                               FontFamily="{StaticResource IconFontFamily}"
                               FontSize="15"
                               Foreground="{StaticResource OverlayBrush}"
                               VerticalAlignment="Top"
                               Margin="0,1,11,0" />
                    <StackPanel Grid.Column="1">
                        <TextBlock x:Name="SubjectText"
                                   Foreground="{StaticResource TextBrush}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock x:Name="DetailText"
                                   Style="{StaticResource Text.Hint}"
                                   Margin="0,3,0,0"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Grid>
            </Border>

            <TextBlock Grid.Row="2"
                       x:Name="FootnoteText"
                       Style="{StaticResource Text.Hint}"
                       Margin="2,14,2,0"
                       TextWrapping="Wrap" />

            <Border x:Name="DontAskAgainPanel"
                    Grid.Row="3"
                    Style="{StaticResource Card}"
                    Padding="12,10"
                    Margin="0,16,0,0"
                    Visibility="Collapsed">
                <CheckBox x:Name="DontAskAgainCheckBox"
                          Content="Don't ask again for Recycle Bin deletes"
                          AutomationProperties.Name="Do not ask again for Recycle Bin deletes"
                          AutomationProperties.HelpText="When checked, future Delete actions move images to the Recycle Bin without this confirmation. You can turn confirmation back on in Settings." />
            </Border>

            <StackPanel Grid.Row="4"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,24,0,0">
                <Button x:Name="CancelButton"
                        Style="{StaticResource ChromeButton}"
                        Click="CancelButton_Click"
                        IsDefault="True"
                        IsCancel="True"
                        MinWidth="108"
                        AutomationProperties.Name="Cancel">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="&#xE711;"
                                   FontFamily="{StaticResource IconFontFamily}"
                                   FontSize="12"
                                   Margin="0,0,8,0"
                                   VerticalAlignment="Center" />
                        <TextBlock x:Name="CancelButtonText" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button x:Name="ConfirmButton"
                        Style="{StaticResource DangerButton}"
                        Click="ConfirmButton_Click"
                        MinWidth="166"
                        Margin="12,0,0,0"
                        AutomationProperties.Name="Confirm destructive action">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock x:Name="ConfirmIconText"
                                   Text="&#xE74D;"
                                   FontFamily="{StaticResource IconFontFamily}"
                                   FontSize="12"
                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                   Margin="0,0,8,0"
                                   VerticalAlignment="Center" />
                        <TextBlock x:Name="ConfirmButtonText"
                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
