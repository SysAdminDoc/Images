<Window x:Class="Images.ExportPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Images - Export workbench"
        Width="1160"
        Height="760"
        MinWidth="960"
        MinHeight="640"
        WindowStartupLocation="CenterOwner">
    <Grid Background="{StaticResource BaseBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource HairlineBrush}"
                BorderThickness="0,0,0,1"
                Padding="18,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Export workbench" Style="{StaticResource Text.Title}" />
                    <TextBlock x:Name="SourceText"
                               Style="{StaticResource Text.Caption}"
                               Margin="0,3,0,0"
                               TextWrapping="Wrap" />
                </StackPanel>
                <WrapPanel Grid.Column="1" HorizontalAlignment="Right">
                    <Button x:Name="PreviewButton"
                            Style="{StaticResource ChromeButton}"
                            Click="PreviewButton_Click">
                        <TextBlock Text="Preview" />
                    </Button>
                    <Button x:Name="SaveCopyButton"
                            Style="{StaticResource PrimaryButton}"
                            Margin="8,0,0,0"
                            Click="SaveCopyButton_Click">
                        <TextBlock Text="Save copy" />
                    </Button>
                </WrapPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource HairlineBrush}"
                    BorderThickness="0,0,1,0"
                    Padding="16">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Preset" Style="{StaticResource SectionLabel}" />
                        <Border Style="{StaticResource Card}" Padding="12">
                            <StackPanel>
                                <ComboBox x:Name="PresetCombo"
                                          SelectionChanged="PresetCombo_SelectionChanged"
                                          AutomationProperties.Name="Export preview preset" />
                                <TextBlock Text="Extension"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextBrush}"
                                           Margin="0,12,0,0" />
                                <TextBox x:Name="ExtensionBox"
                                         TextChanged="SettingsChanged"
                                         AutomationProperties.Name="Export extension" />
                                <TextBlock Text="Quality"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextBrush}"
                                           Margin="0,10,0,0" />
                                <Slider x:Name="QualitySlider"
                                        Minimum="1"
                                        Maximum="100"
                                        TickFrequency="1"
                                        IsSnapToTickEnabled="True"
                                        ValueChanged="QualitySlider_ValueChanged" />
                                <TextBlock x:Name="QualityText" Style="{StaticResource Text.Caption}" />
                                <TextBlock Text="Max dimensions"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextBrush}"
                                           Margin="0,10,0,0" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="MaxWidthBox"
                                             Grid.Column="0"
                                             TextChanged="SettingsChanged"
                                             AutomationProperties.Name="Export max width" />
                                    <TextBox x:Name="MaxHeightBox"
                                             Grid.Column="2"
                                             TextChanged="SettingsChanged"
                                             AutomationProperties.Name="Export max height" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Divider}" />

                        <TextBlock Text="Size" Style="{StaticResource SectionLabel}" />
                        <Border Style="{StaticResource Card}" Padding="12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Source" Style="{StaticResource Text.Hint}" Margin="0,0,12,6" />
                                <TextBlock x:Name="SourceSizeText" Grid.Row="0" Grid.Column="1" Style="{StaticResource Text.Caption}" Margin="0,0,0,6" />
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Output" Style="{StaticResource Text.Hint}" Margin="0,0,12,6" />
                                <TextBlock x:Name="OutputSizeText" Grid.Row="1" Grid.Column="1" Style="{StaticResource Text.Caption}" Margin="0,0,0,6" />
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Delta" Style="{StaticResource Text.Hint}" Margin="0,0,12,6" />
                                <TextBlock x:Name="DeltaText" Grid.Row="2" Grid.Column="1" Style="{StaticResource Text.Caption}" Margin="0,0,0,6" />
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Pixels" Style="{StaticResource Text.Hint}" Margin="0,0,12,6" />
                                <TextBlock x:Name="DimensionsText" Grid.Row="3" Grid.Column="1" Style="{StaticResource Text.Caption}" Margin="0,0,0,6" />
                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Format" Style="{StaticResource Text.Hint}" Margin="0,0,12,0" />
                                <TextBlock x:Name="FormatText" Grid.Row="4" Grid.Column="1" Style="{StaticResource Text.Caption}" />
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource Divider}" />

                        <TextBlock Text="Warnings" Style="{StaticResource SectionLabel}" />
                        <Border Style="{StaticResource Card}" Padding="12">
                            <ItemsControl x:Name="WarningsList"
                                          AutomationProperties.Name="Export preview warnings">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}"
                                                   Style="{StaticResource Text.Caption}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,8" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="1"
                          HorizontalAlignment="Stretch"
                          Background="{StaticResource HairlineBrush}" />

            <Grid Grid.Column="2" Margin="18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="14" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Style="{StaticResource Card}" Padding="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="Original" Style="{StaticResource SectionLabel}" />
                        <Border Grid.Row="1"
                                Background="{StaticResource ViewportBrush}"
                                BorderBrush="{StaticResource HairlineBrush}"
                                BorderThickness="1"
                                Margin="0,8,0,0">
                            <Image x:Name="OriginalImage"
                                   Stretch="Uniform"
                                   RenderOptions.BitmapScalingMode="HighQuality" />
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource Card}" Padding="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="Encoded preview" Style="{StaticResource SectionLabel}" />
                        <Border Grid.Row="1"
                                Background="{StaticResource ViewportBrush}"
                                BorderBrush="{StaticResource HairlineBrush}"
                                BorderThickness="1"
                                Margin="0,8,0,0">
                            <Image x:Name="PreviewImage"
                                   Stretch="Uniform"
                                   RenderOptions.BitmapScalingMode="HighQuality" />
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Border Grid.Row="2"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource HairlineBrush}"
                BorderThickness="0,1,0,0"
                Padding="16,10">
            <StackPanel Orientation="Horizontal">
                <Ellipse x:Name="StatusDot"
                         Width="8"
                         Height="8"
                         Fill="{StaticResource GreenBrush}"
                         Margin="0,0,9,0"
                         VerticalAlignment="Center" />
                <TextBlock x:Name="StatusText"
                           Text="Ready."
                           Style="{StaticResource Text.Caption}"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
