<Window x:Class="Images.ExportPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:Images.Localization"
        xmlns:ctl="clr-namespace:Images.Controls"
        xmlns:a11y="clr-namespace:Images.Services"
        Title="{x:Static loc:Strings.ExportPreviewWindowTitle}"
        Width="1160"
        Height="760"
        MinWidth="960"
        MinHeight="640"
        WindowStartupLocation="CenterOwner">
    <Grid Background="{DynamicResource BaseBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource ToolWindowHeader}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="{x:Static loc:Strings.ExportPreviewHeading}" Style="{StaticResource Text.Title}" />
                    <TextBlock x:Name="SourceText"
                               Style="{StaticResource Text.Caption}"
                               Margin="0,3,0,0"
                               TextWrapping="Wrap" />
                </StackPanel>
                <WrapPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button x:Name="DifferenceToggle"
                            Style="{StaticResource ChromeButton}"
                            Click="DifferenceToggle_Click"
                            AutomationProperties.Name="{x:Static loc:Strings.ExportPreviewDifference}">
                        <TextBlock x:Name="DifferenceToggleText" Text="{x:Static loc:Strings.ExportPreviewDifference}" />
                    </Button>
                    <Button x:Name="PreviewButton"
                            Style="{StaticResource ChromeButton}"
                            Margin="8,0,0,0"
                            Click="PreviewButton_Click">
                        <TextBlock Text="{x:Static loc:Strings.ExportPreviewPreviewButton}" />
                    </Button>
                    <Button x:Name="SaveCopyButton"
                            Style="{StaticResource PrimaryButton}"
                            Margin="8,0,0,0"
                            Click="SaveCopyButton_Click">
                        <TextBlock Text="{x:Static loc:Strings.ExportPreviewSaveCopy}" />
                    </Button>
                </WrapPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource ToolWindowSidebar}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="{x:Static loc:Strings.ExportPreviewPreset}" Style="{StaticResource SectionLabel}" />
                        <Border Style="{StaticResource Card}" Padding="12">
                            <StackPanel>
                                <ComboBox x:Name="PresetCombo"
                                          SelectionChanged="PresetCombo_SelectionChanged"
                                          AutomationProperties.Name="{x:Static loc:Strings.ExportPreviewPreset}" />
                                <TextBlock Text="{x:Static loc:Strings.ExportPreviewExtension}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}"
                                           Margin="0,12,0,0" />
                                <TextBox x:Name="ExtensionBox"
                                         TextChanged="SettingsChanged"
                                         AutomationProperties.Name="{x:Static loc:Strings.ExportPreviewExtension}" />
                                <TextBlock x:Name="QualityLabel"
                                           Text="{x:Static loc:Strings.ExportPreviewQuality}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}"
                                           Margin="0,10,0,0" />
                                <Slider x:Name="QualitySlider"
                                        Minimum="1"
                                        Maximum="100"
                                        TickFrequency="1"
                                        IsSnapToTickEnabled="True"
                                        ValueChanged="QualitySlider_ValueChanged"
                                        AutomationProperties.LabeledBy="{Binding ElementName=QualityLabel}" />
                                <TextBlock x:Name="QualityText" Style="{StaticResource Text.Caption}" />
                                <TextBlock Text="{x:Static loc:Strings.ExportPreviewMaxDimensions}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}"
                                           Margin="0,10,0,0" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="MaxWidthBox"
                                             Grid.Column="0"
                                             TextChanged="SettingsChanged"
                                             AutomationProperties.Name="{x:Static loc:Strings.ExportPreviewMaxWidthAutomationName}" />
                                    <TextBox x:Name="MaxHeightBox"
                                             Grid.Column="2"
                                             TextChanged="SettingsChanged"
                                             AutomationProperties.Name="{x:Static loc:Strings.ExportPreviewMaxHeightAutomationName}" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Divider}" />

                        <TextBlock Text="{x:Static loc:Strings.ExportPreviewSize}" Style="{StaticResource SectionLabel}" />
                        <Border Style="{StaticResource Card}" Padding="12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="{x:Static loc:Strings.ExportPreviewSource}" Style="{StaticResource Text.Hint}" Margin="0,0,12,6" />
                                <TextBlock x:Name="SourceSizeText" Grid.Row="0" Grid.Column="1" Style="{StaticResource Text.Caption}" Margin="0,0,0,6" />
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="{x:Static loc:Strings.ExportPreviewOutput}" Style="{StaticResource Text.Hint}" Margin="0,0,12,6" />
                                <TextBlock x:Name="OutputSizeText" Grid.Row="1" Grid.Column="1" Style="{StaticResource Text.Caption}" Margin="0,0,0,6" />
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="{x:Static loc:Strings.ExportPreviewDelta}" Style="{StaticResource Text.Hint}" Margin="0,0,12,6" />
                                <TextBlock x:Name="DeltaText" Grid.Row="2" Grid.Column="1" Style="{StaticResource Text.Caption}" Margin="0,0,0,6" />
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="{x:Static loc:Strings.ExportPreviewPixels}" Style="{StaticResource Text.Hint}" Margin="0,0,12,6" />
                                <TextBlock x:Name="DimensionsText" Grid.Row="3" Grid.Column="1" Style="{StaticResource Text.Caption}" Margin="0,0,0,6" />
                                <TextBlock Grid.Row="4" Grid.Column="0" Text="{x:Static loc:Strings.ExportPreviewFormat}" Style="{StaticResource Text.Hint}" Margin="0,0,12,0" />
                                <TextBlock x:Name="FormatText" Grid.Row="4" Grid.Column="1" Style="{StaticResource Text.Caption}" />
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource Divider}" />

                        <TextBlock Text="{x:Static loc:Strings.ExportPreviewC2pa}" Style="{StaticResource SectionLabel}" />
                        <Border Style="{StaticResource Card}"
                                Padding="12"
                                AutomationProperties.Name="{x:Static loc:Strings.ExportPreviewC2pa}">
                            <StackPanel>
                                <TextBlock x:Name="C2paStatusText"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}"
                                           TextWrapping="Wrap"
                                           AutomationProperties.LiveSetting="Polite"
                                           a11y:LiveRegionBehavior.AnnounceChanges="True" />
                                <TextBlock x:Name="C2paDetailText"
                                           Style="{StaticResource Text.Caption}"
                                           TextWrapping="Wrap"
                                           Margin="0,6,0,0" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Divider}" />

                        <TextBlock Text="{x:Static loc:Strings.ExportPreviewWarnings}" Style="{StaticResource SectionLabel}" />
                        <Border Style="{StaticResource Card}" Padding="12">
                            <ItemsControl x:Name="WarningsList"
                                          AutomationProperties.Name="{x:Static loc:Strings.ExportPreviewWarnings}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}"
                                                   Style="{StaticResource Text.Caption}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,8" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <GridSplitter Grid.Column="1"
                          Style="{StaticResource VerticalGridSplitter}" />

            <Grid Grid.Column="2" Margin="18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="120" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" MinWidth="120" />
                </Grid.ColumnDefinitions>

                <!-- Side-by-side panes (visible when not in difference mode) -->
                <Border x:Name="OriginalPane" Grid.Column="0" Style="{StaticResource Card}" Padding="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="{x:Static loc:Strings.ExportPreviewOriginal}" Style="{StaticResource SectionLabel}" />
                        <Border Grid.Row="1"
                                Background="{DynamicResource ViewportBrush}"
                                BorderBrush="{DynamicResource HairlineBrush}"
                                BorderThickness="1"
                                Margin="0,8,0,0">
                            <ctl:ZoomPanImage x:Name="OriginalCanvas"
                                              ViewChanged="ExportCanvas_ViewChanged" />
                        </Border>
                    </Grid>
                </Border>

                <GridSplitter x:Name="ComparisonSplitter"
                              Grid.Column="1"
                              Width="8"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Stretch"
                              Background="{DynamicResource Surface0Brush}"
                              Cursor="SizeWE"
                              AutomationProperties.Name="{loc:Loc AutomationExportPreviewWindowComparisonDivider}"
                              ToolTip="Drag to adjust comparison split" />

                <Border x:Name="PreviewPane" Grid.Column="2" Style="{StaticResource Card}" Padding="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="{x:Static loc:Strings.ExportPreviewEncodedPreview}" Style="{StaticResource SectionLabel}" />
                        <Border Grid.Row="1"
                                Background="{DynamicResource ViewportBrush}"
                                BorderBrush="{DynamicResource HairlineBrush}"
                                BorderThickness="1"
                                Margin="0,8,0,0">
                            <ctl:ZoomPanImage x:Name="PreviewCanvas"
                                              ViewChanged="ExportCanvas_ViewChanged" />
                        </Border>
                    </Grid>
                </Border>

                <!-- Difference pane (full width, visible in difference mode) -->
                <Border x:Name="DifferencePane"
                        Grid.Column="0" Grid.ColumnSpan="3"
                        Style="{StaticResource Card}" Padding="12"
                        Visibility="Collapsed">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="{x:Static loc:Strings.ExportPreviewDifference}" Style="{StaticResource SectionLabel}" />
                        <Border Grid.Row="1"
                                Background="{DynamicResource ViewportBrush}"
                                BorderBrush="{DynamicResource HairlineBrush}"
                                BorderThickness="1"
                                Margin="0,8,0,0">
                            <ctl:ZoomPanImage x:Name="DifferenceCanvas"
                                              ViewChanged="ExportCanvas_ViewChanged" />
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Border Grid.Row="2"
                Style="{StaticResource WindowStatusBar}">
            <StackPanel Orientation="Horizontal">
                <Ellipse x:Name="StatusDot"
                         Width="8"
                         Height="8"
                         Fill="{DynamicResource GreenBrush}"
                         Margin="0,0,9,0"
                         VerticalAlignment="Center" />
                <TextBlock x:Name="StatusText"
                           Text="{x:Static loc:Strings.ExportPreviewReadyStatus}"
                           Style="{StaticResource Text.Caption}"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center"
                           AutomationProperties.LiveSetting="Polite"
                           a11y:LiveRegionBehavior.AnnounceChanges="True" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
