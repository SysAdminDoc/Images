<Window x:Class="Images.ResizeDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:Images.Localization"
        Title="{loc:Loc ResizeTitle}"
        Width="560"
        Height="600"
        MinWidth="520"
        MinHeight="540"
        WindowStartupLocation="CenterOwner">
    <Grid Background="{StaticResource BaseBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource HairlineBrush}"
                BorderThickness="0,0,0,1"
                Padding="18,14">
            <StackPanel>
                <TextBlock Text="{loc:Loc ResizeHeading}" Style="{StaticResource Text.Title}" />
                <TextBlock Text="{loc:Loc ResizeDescription}"
                           Style="{StaticResource Text.Caption}"
                           Margin="0,3,0,0" />
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="18">
                <TextBlock Text="{loc:Loc ResizeDimensions}" Style="{StaticResource SectionLabel}" />
                <Border Style="{StaticResource Card}" Padding="14">
                    <StackPanel>
                        <TextBlock x:Name="SourceText"
                                   Style="{StaticResource Text.Caption}"
                                   TextWrapping="Wrap" />

                        <TextBlock Text="{loc:Loc ResizeMode}"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}"
                                   Margin="0,14,0,4" />
                        <ComboBox x:Name="ModeCombo"
                                  DisplayMemberPath="Label"
                                  SelectionChanged="InputChanged"
                                  AutomationProperties.Name="{loc:Loc ResizeModeAutomationName}" />
                        <TextBlock x:Name="ModeDescriptionText"
                                   Style="{StaticResource Text.Hint}"
                                   TextWrapping="Wrap"
                                   Margin="0,5,0,0" />

                        <StackPanel x:Name="PercentPanel" Margin="0,14,0,0">
                            <TextBlock Text="{loc:Loc ResizePercent}"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextBrush}"
                                       Margin="0,0,0,4" />
                            <TextBox x:Name="PercentBox"
                                     TextChanged="InputChanged"
                                     AutomationProperties.Name="{loc:Loc ResizePercentAutomationName}" />
                        </StackPanel>

                        <StackPanel x:Name="PixelPanel" Margin="0,14,0,0">
                            <TextBlock Text="{loc:Loc ResizePixelSize}"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextBrush}"
                                       Margin="0,0,0,4" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="WidthBox"
                                         Grid.Column="0"
                                         TextChanged="InputChanged"
                                         AutomationProperties.Name="{loc:Loc ResizeWidthAutomationName}" />
                                <TextBox x:Name="HeightBox"
                                         Grid.Column="2"
                                         TextChanged="InputChanged"
                                         AutomationProperties.Name="{loc:Loc ResizeHeightAutomationName}" />
                            </Grid>
                            <CheckBox x:Name="AspectLockCheckBox"
                                      Content="{loc:Loc ResizeAspectLock}"
                                      IsChecked="True"
                                      Margin="0,10,0,0"
                                      Checked="InputChanged"
                                      Unchecked="InputChanged"
                                      AutomationProperties.Name="{loc:Loc ResizeAspectLockAutomationName}" />
                        </StackPanel>

                        <StackPanel x:Name="EdgePanel" Margin="0,14,0,0">
                            <TextBlock x:Name="EdgeLabel"
                                       Text="{loc:Loc ResizeEdge}"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextBrush}"
                                       Margin="0,0,0,4" />
                            <TextBox x:Name="EdgeBox"
                                     TextChanged="InputChanged"
                                     AutomationProperties.Name="{loc:Loc ResizeEdgePixelsAutomationName}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Divider}" />

                <TextBlock Text="{loc:Loc ResizeFilter}" Style="{StaticResource SectionLabel}" />
                <Border Style="{StaticResource Card}" Padding="14">
                    <StackPanel>
                        <ComboBox x:Name="FilterCombo"
                                  DisplayMemberPath="Label"
                                  SelectionChanged="InputChanged"
                                  AutomationProperties.Name="{loc:Loc ResizeFilterAutomationName}" />
                        <TextBlock x:Name="FilterDescriptionText"
                                   Style="{StaticResource Text.Hint}"
                                   TextWrapping="Wrap"
                                   Margin="0,6,0,0" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Divider}" />

                <TextBlock Text="{loc:Loc ResizePreview}" Style="{StaticResource SectionLabel}" />
                <Border Style="{StaticResource Card}" Padding="14">
                    <StackPanel>
                        <TextBlock x:Name="PreviewText"
                                   Style="{StaticResource Text.Body}"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="{loc:Loc ResizePreviewNote}"
                                   Style="{StaticResource Text.Hint}"
                                   TextWrapping="Wrap"
                                   Margin="0,8,0,0" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource HairlineBrush}"
                BorderThickness="0,1,0,0"
                Padding="14,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusText"
                           Style="{StaticResource Text.Caption}"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center" />
                <WrapPanel Grid.Column="1"
                           Margin="12,0,0,0">
                    <Button Style="{StaticResource ChromeButton}"
                            MinWidth="86"
                            Click="CancelButton_Click"
                            AutomationProperties.Name="{loc:Loc CancelResize}">
                        <TextBlock Text="{loc:Loc Cancel}" />
                    </Button>
                    <Button x:Name="AddButton"
                            Style="{StaticResource PrimaryButton}"
                            MinWidth="108"
                            Margin="8,0,0,0"
                            Click="AddButton_Click"
                            AutomationProperties.Name="{loc:Loc AddResizeToEditHistory}">
                        <TextBlock Text="{loc:Loc AddResizeButton}" />
                    </Button>
                </WrapPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
