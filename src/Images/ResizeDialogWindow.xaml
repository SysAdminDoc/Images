<Window x:Class="Images.ResizeDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Images - Resize"
        Width="560"
        Height="600"
        MinWidth="520"
        MinHeight="540"
        WindowStartupLocation="CenterOwner">
    <Grid Background="{StaticResource BaseBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource HairlineBrush}"
                BorderThickness="0,0,0,1"
                Padding="18,14">
            <StackPanel>
                <TextBlock Text="Resize" Style="{StaticResource Text.Title}" />
                <TextBlock Text="Add a non-destructive resize operation to edit history."
                           Style="{StaticResource Text.Caption}"
                           Margin="0,3,0,0" />
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="18">
                <TextBlock Text="Dimensions" Style="{StaticResource SectionLabel}" />
                <Border Style="{StaticResource Card}" Padding="14">
                    <StackPanel>
                        <TextBlock x:Name="SourceText"
                                   Style="{StaticResource Text.Caption}"
                                   TextWrapping="Wrap" />

                        <TextBlock Text="Mode"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}"
                                   Margin="0,14,0,4" />
                        <ComboBox x:Name="ModeCombo"
                                  DisplayMemberPath="Label"
                                  SelectionChanged="InputChanged"
                                  AutomationProperties.Name="Resize mode" />
                        <TextBlock x:Name="ModeDescriptionText"
                                   Style="{StaticResource Text.Hint}"
                                   TextWrapping="Wrap"
                                   Margin="0,5,0,0" />

                        <StackPanel x:Name="PercentPanel" Margin="0,14,0,0">
                            <TextBlock Text="Percent"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextBrush}"
                                       Margin="0,0,0,4" />
                            <TextBox x:Name="PercentBox"
                                     TextChanged="InputChanged"
                                     AutomationProperties.Name="Resize percent" />
                        </StackPanel>

                        <StackPanel x:Name="PixelPanel" Margin="0,14,0,0">
                            <TextBlock Text="Pixel size"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextBrush}"
                                       Margin="0,0,0,4" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="WidthBox"
                                         Grid.Column="0"
                                         TextChanged="InputChanged"
                                         AutomationProperties.Name="Resize width" />
                                <TextBox x:Name="HeightBox"
                                         Grid.Column="2"
                                         TextChanged="InputChanged"
                                         AutomationProperties.Name="Resize height" />
                            </Grid>
                            <CheckBox x:Name="AspectLockCheckBox"
                                      Content="Lock aspect ratio"
                                      IsChecked="True"
                                      Margin="0,10,0,0"
                                      Checked="InputChanged"
                                      Unchecked="InputChanged"
                                      AutomationProperties.Name="Lock resize aspect ratio" />
                        </StackPanel>

                        <StackPanel x:Name="EdgePanel" Margin="0,14,0,0">
                            <TextBlock x:Name="EdgeLabel"
                                       Text="Edge"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextBrush}"
                                       Margin="0,0,0,4" />
                            <TextBox x:Name="EdgeBox"
                                     TextChanged="InputChanged"
                                     AutomationProperties.Name="Resize edge pixels" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Divider}" />

                <TextBlock Text="Filter" Style="{StaticResource SectionLabel}" />
                <Border Style="{StaticResource Card}" Padding="14">
                    <StackPanel>
                        <ComboBox x:Name="FilterCombo"
                                  DisplayMemberPath="Label"
                                  SelectionChanged="InputChanged"
                                  AutomationProperties.Name="Resize filter" />
                        <TextBlock x:Name="FilterDescriptionText"
                                   Style="{StaticResource Text.Hint}"
                                   TextWrapping="Wrap"
                                   Margin="0,6,0,0" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Divider}" />

                <TextBlock Text="Preview" Style="{StaticResource SectionLabel}" />
                <Border Style="{StaticResource Card}" Padding="14">
                    <StackPanel>
                        <TextBlock x:Name="PreviewText"
                                   Style="{StaticResource Text.Body}"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="This records an edit operation only. Use Save a copy to export pixels with the resize applied."
                                   Style="{StaticResource Text.Hint}"
                                   TextWrapping="Wrap"
                                   Margin="0,8,0,0" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource HairlineBrush}"
                BorderThickness="0,1,0,0"
                Padding="14,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusText"
                           Style="{StaticResource Text.Caption}"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center" />
                <WrapPanel Grid.Column="1"
                           Margin="12,0,0,0">
                    <Button Style="{StaticResource ChromeButton}"
                            MinWidth="86"
                            Click="CancelButton_Click"
                            AutomationProperties.Name="Cancel resize">
                        <TextBlock Text="Cancel" />
                    </Button>
                    <Button x:Name="AddButton"
                            Style="{StaticResource PrimaryButton}"
                            MinWidth="108"
                            Margin="8,0,0,0"
                            Click="AddButton_Click"
                            AutomationProperties.Name="Add resize to edit history">
                        <TextBlock Text="Add resize" />
                    </Button>
                </WrapPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
