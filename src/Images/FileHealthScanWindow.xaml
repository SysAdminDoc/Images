<Window x:Class="Images.FileHealthScanWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:Images.Localization"
        Title="{x:Static loc:Strings.FileHealthScanWindowTitle}"
        Width="1120"
        Height="760"
        MinWidth="900"
        MinHeight="600"
        WindowStartupLocation="CenterOwner">
    <Grid Background="{DynamicResource BaseBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource ToolWindowHeader}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{x:Static loc:Strings.FileHealthScanHeading}" Style="{StaticResource Text.Title}" />
                    <TextBlock Text="{x:Static loc:Strings.FileHealthScanSubtitle}"
                               Style="{StaticResource Text.Caption}"
                               Margin="0,3,0,0" />
                </StackPanel>

                <WrapPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button x:Name="AddFolderButton"
                            Style="{StaticResource ChromeButton}"
                            Margin="8,0,0,0"
                            Click="AddFolderButton_Click"
                            AutomationProperties.Name="{x:Static loc:Strings.FileHealthScanAddFolder}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8B7;"
                                       FontFamily="{StaticResource IconFontFamily}"
                                       FontSize="12"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="{x:Static loc:Strings.FileHealthScanAddFolder}" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="ScanButton"
                            Style="{StaticResource PrimaryButton}"
                            Margin="8,0,0,0"
                            Click="ScanButton_Click"
                            AutomationProperties.Name="{x:Static loc:Strings.FileHealthScanScan}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE721;"
                                       FontFamily="{StaticResource IconFontFamily}"
                                       FontSize="12"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="{x:Static loc:Strings.FileHealthScanScan}" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="CancelScanButton"
                            Style="{StaticResource ChromeButton}"
                            Margin="8,0,0,0"
                            IsEnabled="False"
                            Click="CancelScanButton_Click"
                            AutomationProperties.Name="{x:Static loc:Strings.Cancel}">
                        <TextBlock Text="{x:Static loc:Strings.Cancel}" />
                    </Button>
                </WrapPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource ToolWindowSidebar}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="{x:Static loc:Strings.FileHealthScanFolders}" Style="{StaticResource SectionLabel}" />
                        <ListBox x:Name="ScanFoldersList"
                                 MinHeight="78"
                                 MaxHeight="130"
                                 AutomationProperties.Name="{x:Static loc:Strings.FileHealthScanFolders}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource Card}" Padding="10,8">
                                        <TextBlock Text="{Binding}"
                                                   Style="{StaticResource Text.Caption}"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding}" />
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <WrapPanel Margin="0,8,0,0">
                            <Button Style="{StaticResource ChromeButton}"
                                    Padding="10,5"
                                    Margin="0,0,8,0"
                                    Click="RemoveFolderButton_Click"
                                    AutomationProperties.Name="{x:Static loc:Strings.FileHealthScanRemove}">
                                <TextBlock Text="{x:Static loc:Strings.FileHealthScanRemove}" />
                            </Button>
                            <Button Style="{StaticResource ChromeButton}"
                                    Padding="10,5"
                                    Click="ClearFoldersButton_Click"
                                    AutomationProperties.Name="{x:Static loc:Strings.Clear}">
                                <TextBlock Text="{x:Static loc:Strings.Clear}" />
                            </Button>
                        </WrapPanel>
                    </StackPanel>

                    <Grid Grid.Row="1" Margin="0,18,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{x:Static loc:Strings.FileHealthScanFindings}" Style="{StaticResource SectionLabel}" />
                            <TextBlock x:Name="FindingCountText"
                                       Grid.Column="1"
                                       Text="0"
                                       Style="{StaticResource Text.Caption}"
                                       Margin="12,0,0,0" />
                        </Grid>

                        <ListBox x:Name="FindingsList"
                                 Grid.Row="1"
                                 SelectionChanged="FindingsList_SelectionChanged"
                                 AutomationProperties.Name="{x:Static loc:Strings.FileHealthScanFindings}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="12,10">
                                        <Border.Style>
                                            <Style TargetType="Border" BasedOn="{StaticResource InteractiveCard}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource AccentSelectionBrush}" />
                                                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}"
                                                       Style="{StaticResource Text.Body}"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding FileName}"
                                                       Style="{StaticResource Text.Caption}"
                                                       TextWrapping="Wrap"
                                                       Margin="0,4,0,0" />
                                            <TextBlock Text="{Binding Summary}"
                                                       Style="{StaticResource Text.Hint}"
                                                       TextWrapping="Wrap"
                                                       Margin="0,3,0,0" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1"
                          Style="{StaticResource VerticalGridSplitter}" />

            <Border Grid.Column="2"
                    Style="{StaticResource ToolWindowWorkspace}">
                <Grid>
                    <Border x:Name="EmptyState"
                            Style="{StaticResource EmptyStateCard}"
                            AutomationProperties.Name="{x:Static loc:Strings.FileHealthScanEmptyHeading}">
                        <StackPanel>
                            <Border Style="{StaticResource EmptyStateIcon}">
                                <TextBlock Text="&#xE946;"
                                           FontFamily="{StaticResource IconFontFamily}"
                                           FontSize="18"
                                           Foreground="{DynamicResource AccentBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Text="{x:Static loc:Strings.FileHealthScanEmptyHeading}"
                                       Style="{StaticResource Text.Display}"
                                       TextAlignment="Center" />
                            <TextBlock Text="{x:Static loc:Strings.FileHealthScanEmptyDescription}"
                                       Style="{StaticResource Text.Subtitle}"
                                       TextAlignment="Center"
                                       Margin="0,10,0,0" />
                        </StackPanel>
                    </Border>

                    <Grid x:Name="DetailPanel" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Style="{StaticResource Card}"
                                Padding="14"
                                Margin="0,0,0,14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock x:Name="DetailTitle" Style="{StaticResource Text.Title}" />
                                    <TextBlock x:Name="DetailSummary"
                                               Style="{StaticResource Text.Caption}"
                                               TextWrapping="Wrap"
                                               Margin="0,4,0,0" />
                                </StackPanel>
                                <WrapPanel Grid.Column="1"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center"
                                           Margin="16,0,0,0">
                                    <Button x:Name="RenameButton"
                                            Style="{StaticResource ChromeButton}"
                                            Margin="0,0,8,0"
                                            Click="RenameButton_Click"
                                            AutomationProperties.Name="{x:Static loc:Strings.FileHealthScanRename}">
                                        <TextBlock Text="{x:Static loc:Strings.FileHealthScanRename}" />
                                    </Button>
                                    <Button Style="{StaticResource ChromeButton}"
                                            Margin="0,0,8,0"
                                            Click="MarkReviewedButton_Click"
                                            AutomationProperties.Name="{x:Static loc:Strings.FileHealthScanMarkReviewed}">
                                        <TextBlock Text="{x:Static loc:Strings.FileHealthScanMarkReviewed}" />
                                    </Button>
                                    <Button Style="{StaticResource DangerButton}"
                                            Click="QuarantineButton_Click"
                                            AutomationProperties.Name="{x:Static loc:Strings.FileHealthScanQuarantine}">
                                        <TextBlock Text="{x:Static loc:Strings.FileHealthScanQuarantine}" />
                                    </Button>
                                </WrapPanel>
                            </Grid>
                        </Border>

                        <Border Grid.Row="1"
                                Background="{DynamicResource PanelBrush}"
                                BorderBrush="{DynamicResource HairlineBrush}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource Radius.Md.CR}"
                                Padding="14">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Border Background="{DynamicResource CrustBrush}"
                                        CornerRadius="{StaticResource Radius.Sm.CR}"
                                        ClipToBounds="True">
                                    <Image x:Name="PreviewImage"
                                           Stretch="Uniform"
                                           RenderOptions.BitmapScalingMode="HighQuality" />
                                </Border>
                                <Grid Grid.Row="1" Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition />
                                        <RowDefinition />
                                        <RowDefinition />
                                        <RowDefinition />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{x:Static loc:Strings.FileHealthScanMetaFile}" Style="{StaticResource MetaLabel}" />
                                    <TextBlock x:Name="FileNameText" Grid.Row="0" Grid.Column="1" Style="{StaticResource MetaValue}" />
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="{x:Static loc:Strings.FileHealthScanMetaFolder}" Style="{StaticResource MetaLabel}" />
                                    <TextBlock x:Name="FolderText" Grid.Row="1" Grid.Column="1" Style="{StaticResource MetaValue}" />
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="{x:Static loc:Strings.FileHealthScanMetaSize}" Style="{StaticResource MetaLabel}" />
                                    <TextBlock x:Name="SizeText" Grid.Row="2" Grid.Column="1" Style="{StaticResource MetaValue}" />
                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="{x:Static loc:Strings.FileHealthScanMetaDetail}" Style="{StaticResource MetaLabel}" />
                                    <TextBlock x:Name="DetailText"
                                               Grid.Row="3"
                                               Grid.Column="1"
                                               Style="{StaticResource MetaValue}"
                                               TextWrapping="Wrap" />
                                </Grid>
                            </Grid>
                        </Border>

                        <Border Grid.Row="2"
                                Style="{StaticResource Card}"
                                Padding="12"
                                Margin="0,14,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE946;"
                                           FontFamily="{StaticResource IconFontFamily}"
                                           FontSize="12"
                                           Foreground="{DynamicResource AccentBrush}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,9,0" />
                                <TextBlock x:Name="DetailHelpText"
                                           Text="{x:Static loc:Strings.FileHealthScanHelpDefault}"
                                           Style="{StaticResource Text.Caption}"
                                           TextWrapping="Wrap"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Style="{StaticResource WindowStatusBar}">
            <StackPanel Orientation="Horizontal">
                <Ellipse x:Name="StatusDot"
                         Width="8"
                         Height="8"
                         Fill="{DynamicResource GreenBrush}"
                         Margin="0,0,9,0"
                         VerticalAlignment="Center" />
                <TextBlock x:Name="StatusText"
                           Text="{x:Static loc:Strings.FileHealthScanReadyStatus}"
                           Style="{StaticResource Text.Caption}"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
