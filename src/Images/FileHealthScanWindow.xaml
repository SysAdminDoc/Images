<Window x:Class="Images.FileHealthScanWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Images - File health scan"
        Width="1120"
        Height="760"
        MinWidth="900"
        MinHeight="600"
        WindowStartupLocation="CenterOwner">
    <Grid Background="{StaticResource BaseBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource HairlineBrush}"
                BorderThickness="0,0,0,1"
                Padding="18,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="File health scan" Style="{StaticResource Text.Title}" />
                    <TextBlock Text="Find bad extensions, broken images, zero-byte files, and temporary artifacts locally."
                               Style="{StaticResource Text.Caption}"
                               Margin="0,3,0,0" />
                </StackPanel>

                <WrapPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button x:Name="AddFolderButton"
                            Style="{StaticResource ChromeButton}"
                            Margin="8,0,0,0"
                            Click="AddFolderButton_Click"
                            AutomationProperties.Name="Add folder to health scan">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8B7;"
                                       FontFamily="{StaticResource IconFontFamily}"
                                       FontSize="12"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="Add folder" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="ScanButton"
                            Style="{StaticResource PrimaryButton}"
                            Margin="8,0,0,0"
                            Click="ScanButton_Click"
                            AutomationProperties.Name="Scan file health">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE721;"
                                       FontFamily="{StaticResource IconFontFamily}"
                                       FontSize="12"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="Scan" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="CancelScanButton"
                            Style="{StaticResource ChromeButton}"
                            Margin="8,0,0,0"
                            IsEnabled="False"
                            Click="CancelScanButton_Click"
                            AutomationProperties.Name="Cancel file health scan">
                        <TextBlock Text="Cancel" />
                    </Button>
                </WrapPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource HairlineBrush}"
                    BorderThickness="0,0,1,0"
                    Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="Folders" Style="{StaticResource SectionLabel}" />
                        <ListBox x:Name="ScanFoldersList"
                                 MinHeight="78"
                                 MaxHeight="130"
                                 AutomationProperties.Name="Health scan folders">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource Card}" Padding="10,8">
                                        <TextBlock Text="{Binding}"
                                                   Style="{StaticResource Text.Caption}"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding}" />
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <WrapPanel Margin="0,8,0,0">
                            <Button Style="{StaticResource ChromeButton}"
                                    Padding="10,5"
                                    Margin="0,0,8,0"
                                    Click="RemoveFolderButton_Click"
                                    AutomationProperties.Name="Remove selected health scan folder">
                                <TextBlock Text="Remove" />
                            </Button>
                            <Button Style="{StaticResource ChromeButton}"
                                    Padding="10,5"
                                    Click="ClearFoldersButton_Click"
                                    AutomationProperties.Name="Clear health scan folders">
                                <TextBlock Text="Clear" />
                            </Button>
                        </WrapPanel>
                    </StackPanel>

                    <Grid Grid.Row="1" Margin="0,18,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Findings" Style="{StaticResource SectionLabel}" />
                            <TextBlock x:Name="FindingCountText"
                                       Grid.Column="1"
                                       Text="0"
                                       Style="{StaticResource Text.Caption}"
                                       Margin="12,0,0,0" />
                        </Grid>

                        <ListBox x:Name="FindingsList"
                                 Grid.Row="1"
                                 SelectionChanged="FindingsList_SelectionChanged"
                                 AutomationProperties.Name="File health findings">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="12,10">
                                        <Border.Style>
                                            <Style TargetType="Border" BasedOn="{StaticResource InteractiveCard}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                        <Setter Property="Background" Value="#2489B4FA" />
                                                        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}"
                                                       Style="{StaticResource Text.Body}"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding FileName}"
                                                       Style="{StaticResource Text.Caption}"
                                                       TextWrapping="Wrap"
                                                       Margin="0,4,0,0" />
                                            <TextBlock Text="{Binding Summary}"
                                                       Style="{StaticResource Text.Hint}"
                                                       TextWrapping="Wrap"
                                                       Margin="0,3,0,0" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="1"
                          HorizontalAlignment="Stretch"
                          Background="{StaticResource HairlineBrush}" />

            <Border Grid.Column="2"
                    Background="{StaticResource ViewportBrush}"
                    Padding="18">
                <Grid>
                    <Border x:Name="EmptyState"
                            Style="{StaticResource ElevatedCard}"
                            Width="470"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                        <StackPanel>
                            <TextBlock Text="Scan for file problems"
                                       Style="{StaticResource Text.Display}"
                                       TextAlignment="Center" />
                            <TextBlock Text="Review each finding before renaming an extension or moving a file into app-local quarantine."
                                       Style="{StaticResource Text.Subtitle}"
                                       TextAlignment="Center"
                                       Margin="0,10,0,0" />
                        </StackPanel>
                    </Border>

                    <Grid x:Name="DetailPanel" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Style="{StaticResource Card}"
                                Padding="14"
                                Margin="0,0,0,14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock x:Name="DetailTitle" Style="{StaticResource Text.Title}" />
                                    <TextBlock x:Name="DetailSummary"
                                               Style="{StaticResource Text.Caption}"
                                               TextWrapping="Wrap"
                                               Margin="0,4,0,0" />
                                </StackPanel>
                                <WrapPanel Grid.Column="1"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center"
                                           Margin="16,0,0,0">
                                    <Button x:Name="RenameButton"
                                            Style="{StaticResource ChromeButton}"
                                            Margin="0,0,8,0"
                                            Click="RenameButton_Click"
                                            AutomationProperties.Name="Rename file to detected extension">
                                        <TextBlock Text="Rename extension" />
                                    </Button>
                                    <Button Style="{StaticResource ChromeButton}"
                                            Margin="0,0,8,0"
                                            Click="MarkReviewedButton_Click"
                                            AutomationProperties.Name="Mark file health finding reviewed">
                                        <TextBlock Text="Mark reviewed" />
                                    </Button>
                                    <Button Style="{StaticResource DangerButton}"
                                            Click="QuarantineButton_Click"
                                            AutomationProperties.Name="Quarantine file health finding">
                                        <TextBlock Text="Quarantine" />
                                    </Button>
                                </WrapPanel>
                            </Grid>
                        </Border>

                        <Border Grid.Row="1"
                                Background="{StaticResource PanelBrush}"
                                BorderBrush="{StaticResource HairlineBrush}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource Radius.Md.CR}"
                                Padding="14">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Border Background="{StaticResource CrustBrush}"
                                        CornerRadius="{StaticResource Radius.Sm.CR}"
                                        ClipToBounds="True">
                                    <Image x:Name="PreviewImage"
                                           Stretch="Uniform"
                                           RenderOptions.BitmapScalingMode="HighQuality" />
                                </Border>
                                <Grid Grid.Row="1" Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition />
                                        <RowDefinition />
                                        <RowDefinition />
                                        <RowDefinition />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="File" Style="{StaticResource MetaLabel}" />
                                    <TextBlock x:Name="FileNameText" Grid.Row="0" Grid.Column="1" Style="{StaticResource MetaValue}" />
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Folder" Style="{StaticResource MetaLabel}" />
                                    <TextBlock x:Name="FolderText" Grid.Row="1" Grid.Column="1" Style="{StaticResource MetaValue}" />
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Size" Style="{StaticResource MetaLabel}" />
                                    <TextBlock x:Name="SizeText" Grid.Row="2" Grid.Column="1" Style="{StaticResource MetaValue}" />
                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Detail" Style="{StaticResource MetaLabel}" />
                                    <TextBlock x:Name="DetailText"
                                               Grid.Row="3"
                                               Grid.Column="1"
                                               Style="{StaticResource MetaValue}"
                                               TextWrapping="Wrap" />
                                </Grid>
                            </Grid>
                        </Border>

                        <Border Grid.Row="2"
                                Style="{StaticResource Card}"
                                Padding="12"
                                Margin="0,14,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE946;"
                                           FontFamily="{StaticResource IconFontFamily}"
                                           FontSize="12"
                                           Foreground="{StaticResource AccentBrush}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,9,0" />
                                <TextBlock x:Name="DetailHelpText"
                                           Text="Rename only changes the extension. Quarantine moves the file to app-local recovery storage."
                                           Style="{StaticResource Text.Caption}"
                                           TextWrapping="Wrap"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource HairlineBrush}"
                BorderThickness="0,1,0,0"
                Padding="16,10">
            <StackPanel Orientation="Horizontal">
                <Ellipse x:Name="StatusDot"
                         Width="8"
                         Height="8"
                         Fill="{StaticResource GreenBrush}"
                         Margin="0,0,9,0"
                         VerticalAlignment="Center" />
                <TextBlock x:Name="StatusText"
                           Text="Ready. Add one or more folders to scan."
                           Style="{StaticResource Text.Caption}"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
