<Window x:Class="Images.AdjustmentsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Images - Adjustments"
        Width="920"
        Height="680"
        MinWidth="760"
        MinHeight="560"
        WindowStartupLocation="CenterOwner"
        KeyDown="Window_KeyDown">
    <Grid Background="{StaticResource BaseBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource HairlineBrush}"
                BorderThickness="0,0,0,1"
                Padding="18,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Adjustments" Style="{StaticResource Text.Title}" />
                    <TextBlock Text="Preview levels, curve, and HSL before adding an edit."
                               Style="{StaticResource Text.Caption}"
                               Margin="0,3,0,0" />
                </StackPanel>
                <Border Grid.Column="1"
                        Style="{StaticResource Badge}"
                        VerticalAlignment="Center"
                        Margin="16,0,0,0">
                    <TextBlock Text="Enter applies"
                               Style="{StaticResource Text.Caption}"
                               FontWeight="SemiBold" />
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="330" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Levels" Style="{StaticResource SectionLabel}" />
                    <Border Style="{StaticResource Card}" Padding="14">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Black point"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextBrush}" />
                                <TextBlock x:Name="BlackPointText"
                                           Grid.Column="1"
                                           Style="{StaticResource Text.Caption}"
                                           Margin="12,0,0,0" />
                            </Grid>
                            <Slider x:Name="BlackPointSlider"
                                    Minimum="0"
                                    Maximum="30"
                                    TickFrequency="0.5"
                                    SmallChange="0.5"
                                    LargeChange="2"
                                    ValueChanged="AdjustmentSlider_ValueChanged"
                                    AutomationProperties.Name="Black point" />

                            <Grid Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="White point"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextBrush}" />
                                <TextBlock x:Name="WhitePointText"
                                           Grid.Column="1"
                                           Style="{StaticResource Text.Caption}"
                                           Margin="12,0,0,0" />
                            </Grid>
                            <Slider x:Name="WhitePointSlider"
                                    Minimum="70"
                                    Maximum="100"
                                    TickFrequency="0.5"
                                    SmallChange="0.5"
                                    LargeChange="2"
                                    ValueChanged="AdjustmentSlider_ValueChanged"
                                    AutomationProperties.Name="White point" />

                            <Grid Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Gamma"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextBrush}" />
                                <TextBlock x:Name="GammaText"
                                           Grid.Column="1"
                                           Style="{StaticResource Text.Caption}"
                                           Margin="12,0,0,0" />
                            </Grid>
                            <Slider x:Name="GammaSlider"
                                    Minimum="0.2"
                                    Maximum="3"
                                    TickFrequency="0.05"
                                    SmallChange="0.05"
                                    LargeChange="0.2"
                                    ValueChanged="AdjustmentSlider_ValueChanged"
                                    AutomationProperties.Name="Gamma" />

                            <Grid Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Curve"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextBrush}" />
                                <TextBlock x:Name="CurveText"
                                           Grid.Column="1"
                                           Style="{StaticResource Text.Caption}"
                                           Margin="12,0,0,0" />
                            </Grid>
                            <Slider x:Name="CurveSlider"
                                    Minimum="-50"
                                    Maximum="50"
                                    TickFrequency="1"
                                    SmallChange="1"
                                    LargeChange="5"
                                    ValueChanged="AdjustmentSlider_ValueChanged"
                                    AutomationProperties.Name="Curve" />
                            <TextBlock Text="Negative softens contrast; positive adds contrast."
                                       Style="{StaticResource Text.Hint}"
                                       TextWrapping="Wrap"
                                       Margin="0,6,0,0" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Divider}" />

                    <TextBlock Text="Color" Style="{StaticResource SectionLabel}" />
                    <Border Style="{StaticResource Card}" Padding="14">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Hue"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextBrush}" />
                                <TextBlock x:Name="HueText"
                                           Grid.Column="1"
                                           Style="{StaticResource Text.Caption}"
                                           Margin="12,0,0,0" />
                            </Grid>
                            <Slider x:Name="HueSlider"
                                    Minimum="-180"
                                    Maximum="180"
                                    TickFrequency="1"
                                    SmallChange="1"
                                    LargeChange="15"
                                    ValueChanged="AdjustmentSlider_ValueChanged"
                                    AutomationProperties.Name="Hue" />

                            <Grid Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Saturation"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextBrush}" />
                                <TextBlock x:Name="SaturationText"
                                           Grid.Column="1"
                                           Style="{StaticResource Text.Caption}"
                                           Margin="12,0,0,0" />
                            </Grid>
                            <Slider x:Name="SaturationSlider"
                                    Minimum="0"
                                    Maximum="200"
                                    TickFrequency="1"
                                    SmallChange="1"
                                    LargeChange="10"
                                    ValueChanged="AdjustmentSlider_ValueChanged"
                                    AutomationProperties.Name="Saturation" />

                            <Grid Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Lightness"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextBrush}" />
                                <TextBlock x:Name="LightnessText"
                                           Grid.Column="1"
                                           Style="{StaticResource Text.Caption}"
                                           Margin="12,0,0,0" />
                            </Grid>
                            <Slider x:Name="LightnessSlider"
                                    Minimum="0"
                                    Maximum="200"
                                    TickFrequency="1"
                                    SmallChange="1"
                                    LargeChange="10"
                                    ValueChanged="AdjustmentSlider_ValueChanged"
                                    AutomationProperties.Name="Lightness" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Divider}" />

                    <Border Style="{StaticResource Card}" Padding="14">
                        <TextBlock Text="This records an edit operation only. Use Save a copy to export pixels with the adjustment applied."
                                   Style="{StaticResource Text.Hint}"
                                   TextWrapping="Wrap" />
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Column="2"
                    Style="{StaticResource Card}"
                    Padding="14"
                    ClipToBounds="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Border Background="{StaticResource ViewerSurfaceBrush}"
                            BorderBrush="{StaticResource HairlineBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource Radius.Md.CR}">
                        <Image x:Name="PreviewImage"
                               Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               AutomationProperties.Name="Adjustment preview" />
                    </Border>
                    <TextBlock x:Name="SummaryText"
                               Grid.Row="1"
                               Style="{StaticResource Text.Caption}"
                               TextWrapping="Wrap"
                               Margin="0,12,0,0" />
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource HairlineBrush}"
                BorderThickness="0,1,0,0"
                Padding="14,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusText"
                           Style="{StaticResource Text.Caption}"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center"
                           AutomationProperties.LiveSetting="Polite" />
                <WrapPanel Grid.Column="1"
                           Margin="12,0,0,0">
                    <Button Style="{StaticResource ChromeButton}"
                            MinWidth="82"
                            Click="ResetButton_Click"
                            AutomationProperties.Name="Reset adjustments">
                        <TextBlock Text="Reset" />
                    </Button>
                    <Button Style="{StaticResource ChromeButton}"
                            MinWidth="82"
                            Margin="8,0,0,0"
                            Click="CloseButton_Click"
                            AutomationProperties.Name="Close adjustments">
                        <TextBlock Text="Close" />
                    </Button>
                    <Button x:Name="ApplyButton"
                            Style="{StaticResource PrimaryButton}"
                            MinWidth="118"
                            Margin="8,0,0,0"
                            Click="ApplyButton_Click"
                            AutomationProperties.Name="Apply adjustment to edit history">
                        <TextBlock Text="Apply" />
                    </Button>
                </WrapPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
