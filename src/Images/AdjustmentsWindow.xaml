<Window x:Class="Images.AdjustmentsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:Images.Localization"
        xmlns:a11y="clr-namespace:Images.Services"
        Title="{x:Static loc:Strings.AdjustmentsWindowTitle}"
        Width="920"
        Height="680"
        MinWidth="760"
        MinHeight="560"
        WindowStartupLocation="CenterOwner"
        KeyDown="Window_KeyDown">
    <Grid Background="{DynamicResource BaseBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource ToolWindowHeader}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="{x:Static loc:Strings.AdjustmentsHeading}" Style="{StaticResource Text.Title}" />
                    <TextBlock Text="{x:Static loc:Strings.AdjustmentsSubtitle}"
                               Style="{StaticResource Text.Caption}"
                               Margin="0,3,0,0" />
                </StackPanel>
                <Border Grid.Column="1"
                        Style="{StaticResource Badge}"
                        VerticalAlignment="Center"
                        Margin="16,0,0,0">
                    <TextBlock Text="{x:Static loc:Strings.AdjustmentsEnterApplies}"
                               Style="{StaticResource Text.Caption}"
                               FontWeight="SemiBold" />
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="330" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="{x:Static loc:Strings.AdjustmentsLevelsHeading}" Style="{StaticResource SectionLabel}" />
                    <Border Style="{StaticResource Card}" Padding="14">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{x:Static loc:Strings.AdjustmentsBlackPoint}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}" />
                                <TextBlock x:Name="BlackPointText"
                                           Grid.Column="1"
                                           Style="{StaticResource Text.Caption}"
                                           Margin="12,0,0,0" />
                            </Grid>
                            <Slider x:Name="BlackPointSlider"
                                    Minimum="0"
                                    Maximum="30"
                                    TickFrequency="0.5"
                                    SmallChange="0.5"
                                    LargeChange="2"
                                    ValueChanged="AdjustmentSlider_ValueChanged"
                                    AutomationProperties.Name="{x:Static loc:Strings.AdjustmentsBlackPoint}" />

                            <Grid Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{x:Static loc:Strings.AdjustmentsWhitePoint}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}" />
                                <TextBlock x:Name="WhitePointText"
                                           Grid.Column="1"
                                           Style="{StaticResource Text.Caption}"
                                           Margin="12,0,0,0" />
                            </Grid>
                            <Slider x:Name="WhitePointSlider"
                                    Minimum="70"
                                    Maximum="100"
                                    TickFrequency="0.5"
                                    SmallChange="0.5"
                                    LargeChange="2"
                                    ValueChanged="AdjustmentSlider_ValueChanged"
                                    AutomationProperties.Name="{x:Static loc:Strings.AdjustmentsWhitePoint}" />

                            <Grid Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{x:Static loc:Strings.AdjustmentsGamma}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}" />
                                <TextBlock x:Name="GammaText"
                                           Grid.Column="1"
                                           Style="{StaticResource Text.Caption}"
                                           Margin="12,0,0,0" />
                            </Grid>
                            <Slider x:Name="GammaSlider"
                                    Minimum="0.2"
                                    Maximum="3"
                                    TickFrequency="0.05"
                                    SmallChange="0.05"
                                    LargeChange="0.2"
                                    ValueChanged="AdjustmentSlider_ValueChanged"
                                    AutomationProperties.Name="{x:Static loc:Strings.AdjustmentsGamma}" />

                            <Grid Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{x:Static loc:Strings.AdjustmentsCurve}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}" />
                                <TextBlock x:Name="CurveText"
                                           Grid.Column="1"
                                           Style="{StaticResource Text.Caption}"
                                           Margin="12,0,0,0" />
                            </Grid>
                            <Slider x:Name="CurveSlider"
                                    Minimum="-50"
                                    Maximum="50"
                                    TickFrequency="1"
                                    SmallChange="1"
                                    LargeChange="5"
                                    ValueChanged="AdjustmentSlider_ValueChanged"
                                    AutomationProperties.Name="{x:Static loc:Strings.AdjustmentsCurve}" />
                            <TextBlock Text="{x:Static loc:Strings.AdjustmentsCurveHint}"
                                       Style="{StaticResource Text.Hint}"
                                       TextWrapping="Wrap"
                                       Margin="0,6,0,0" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Divider}" />

                    <TextBlock Text="{x:Static loc:Strings.AdjustmentsColorHeading}" Style="{StaticResource SectionLabel}" />
                    <Border Style="{StaticResource Card}" Padding="14">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{x:Static loc:Strings.AdjustmentsHue}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}" />
                                <TextBlock x:Name="HueText"
                                           Grid.Column="1"
                                           Style="{StaticResource Text.Caption}"
                                           Margin="12,0,0,0" />
                            </Grid>
                            <Slider x:Name="HueSlider"
                                    Minimum="-180"
                                    Maximum="180"
                                    TickFrequency="1"
                                    SmallChange="1"
                                    LargeChange="15"
                                    ValueChanged="AdjustmentSlider_ValueChanged"
                                    AutomationProperties.Name="{x:Static loc:Strings.AdjustmentsHue}" />

                            <Grid Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{x:Static loc:Strings.AdjustmentsSaturation}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}" />
                                <TextBlock x:Name="SaturationText"
                                           Grid.Column="1"
                                           Style="{StaticResource Text.Caption}"
                                           Margin="12,0,0,0" />
                            </Grid>
                            <Slider x:Name="SaturationSlider"
                                    Minimum="0"
                                    Maximum="200"
                                    TickFrequency="1"
                                    SmallChange="1"
                                    LargeChange="10"
                                    ValueChanged="AdjustmentSlider_ValueChanged"
                                    AutomationProperties.Name="{x:Static loc:Strings.AdjustmentsSaturation}" />

                            <Grid Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{x:Static loc:Strings.AdjustmentsLightness}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}" />
                                <TextBlock x:Name="LightnessText"
                                           Grid.Column="1"
                                           Style="{StaticResource Text.Caption}"
                                           Margin="12,0,0,0" />
                            </Grid>
                            <Slider x:Name="LightnessSlider"
                                    Minimum="0"
                                    Maximum="200"
                                    TickFrequency="1"
                                    SmallChange="1"
                                    LargeChange="10"
                                    ValueChanged="AdjustmentSlider_ValueChanged"
                                    AutomationProperties.Name="{x:Static loc:Strings.AdjustmentsLightness}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Divider}" />

                    <Border Style="{StaticResource Card}" Padding="14">
                        <TextBlock Text="{x:Static loc:Strings.AdjustmentsEditNotice}"
                                   Style="{StaticResource Text.Hint}"
                                   TextWrapping="Wrap" />
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Column="2"
                    Style="{StaticResource Card}"
                    Padding="14"
                    ClipToBounds="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Border Background="{DynamicResource ViewerSurfaceBrush}"
                            BorderBrush="{DynamicResource HairlineBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource Radius.Md.CR}">
                        <Image x:Name="PreviewImage"
                               Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               AutomationProperties.Name="{x:Static loc:Strings.AdjustmentsPreviewAutomationName}" />
                    </Border>
                    <TextBlock x:Name="SummaryText"
                               Grid.Row="1"
                               Style="{StaticResource Text.Caption}"
                               TextWrapping="Wrap"
                               Margin="0,12,0,0" />
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Style="{StaticResource WindowStatusBar}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusText"
                           Style="{StaticResource Text.Caption}"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center"
                           AutomationProperties.LiveSetting="Polite"
                           a11y:LiveRegionBehavior.AnnounceChanges="True" />
                <WrapPanel Grid.Column="1"
                           Margin="12,0,0,0">
                    <Button Style="{StaticResource ChromeButton}"
                            MinWidth="82"
                            Click="ResetButton_Click"
                            AutomationProperties.Name="{x:Static loc:Strings.AdjustmentsResetAutomationName}">
                        <TextBlock Text="{x:Static loc:Strings.AdjustmentsReset}" />
                    </Button>
                    <Button Style="{StaticResource ChromeButton}"
                            MinWidth="82"
                            Margin="8,0,0,0"
                            Click="CloseButton_Click"
                            AutomationProperties.Name="{x:Static loc:Strings.AdjustmentsCloseAutomationName}">
                        <TextBlock Text="{x:Static loc:Strings.Close}" />
                    </Button>
                    <Button x:Name="ApplyButton"
                            Style="{StaticResource PrimaryButton}"
                            MinWidth="118"
                            Margin="8,0,0,0"
                            Click="ApplyButton_Click"
                            AutomationProperties.Name="{x:Static loc:Strings.AdjustmentsApplyAutomationName}">
                        <TextBlock Text="{x:Static loc:Strings.AdjustmentsApply}" />
                    </Button>
                </WrapPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
