<Window x:Class="Images.EffectsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Images - Effects"
        Width="860"
        Height="620"
        MinWidth="720"
        MinHeight="520"
        WindowStartupLocation="CenterOwner"
        KeyDown="Window_KeyDown">
    <Grid Background="{StaticResource BaseBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource HairlineBrush}"
                BorderThickness="0,0,0,1"
                Padding="18,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Effects" Style="{StaticResource Text.Title}" />
                    <TextBlock Text="Preview sharpen, noise reduction, and vignette before adding an edit."
                               Style="{StaticResource Text.Caption}"
                               Margin="0,3,0,0" />
                </StackPanel>
                <Border Grid.Column="1"
                        Style="{StaticResource Badge}"
                        VerticalAlignment="Center"
                        Margin="16,0,0,0">
                    <TextBlock Text="Enter applies"
                               Style="{StaticResource Text.Caption}"
                               FontWeight="SemiBold" />
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Presets" Style="{StaticResource SectionLabel}" />
                    <Border Style="{StaticResource Card}" Padding="14">
                        <StackPanel>
                            <Button Style="{StaticResource ChromeButton}"
                                    Click="CrispButton_Click"
                                    AutomationProperties.Name="Apply crisp preset">
                                <TextBlock Text="Crisp" />
                            </Button>
                            <Button Style="{StaticResource ChromeButton}"
                                    Margin="0,8,0,0"
                                    Click="CleanButton_Click"
                                    AutomationProperties.Name="Apply clean preset">
                                <TextBlock Text="Clean" />
                            </Button>
                            <Button Style="{StaticResource ChromeButton}"
                                    Margin="0,8,0,0"
                                    Click="FocusButton_Click"
                                    AutomationProperties.Name="Apply focus preset">
                                <TextBlock Text="Focus" />
                            </Button>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Divider}" />

                    <TextBlock Text="Detail" Style="{StaticResource SectionLabel}" />
                    <Border Style="{StaticResource Card}" Padding="14">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Sharpen"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextBrush}" />
                                <TextBlock x:Name="SharpenText"
                                           Grid.Column="1"
                                           Style="{StaticResource Text.Caption}"
                                           Margin="12,0,0,0" />
                            </Grid>
                            <Slider x:Name="SharpenSlider"
                                    Minimum="0"
                                    Maximum="100"
                                    TickFrequency="1"
                                    SmallChange="1"
                                    LargeChange="10"
                                    ValueChanged="EffectSlider_ValueChanged"
                                    AutomationProperties.Name="Sharpen amount" />

                            <Grid Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Noise reduction"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextBrush}" />
                                <TextBlock x:Name="NoiseText"
                                           Grid.Column="1"
                                           Style="{StaticResource Text.Caption}"
                                           Margin="12,0,0,0" />
                            </Grid>
                            <Slider x:Name="NoiseSlider"
                                    Minimum="0"
                                    Maximum="100"
                                    TickFrequency="1"
                                    SmallChange="1"
                                    LargeChange="10"
                                    ValueChanged="EffectSlider_ValueChanged"
                                    AutomationProperties.Name="Noise reduction amount" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Divider}" />

                    <TextBlock Text="Edges" Style="{StaticResource SectionLabel}" />
                    <Border Style="{StaticResource Card}" Padding="14">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Vignette"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextBrush}" />
                                <TextBlock x:Name="VignetteText"
                                           Grid.Column="1"
                                           Style="{StaticResource Text.Caption}"
                                           Margin="12,0,0,0" />
                            </Grid>
                            <Slider x:Name="VignetteSlider"
                                    Minimum="0"
                                    Maximum="100"
                                    TickFrequency="1"
                                    SmallChange="1"
                                    LargeChange="10"
                                    ValueChanged="EffectSlider_ValueChanged"
                                    AutomationProperties.Name="Vignette amount" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Divider}" />

                    <Border Style="{StaticResource Card}" Padding="14">
                        <TextBlock Text="This records an edit operation only. Use Save a copy to export pixels with the effects applied."
                                   Style="{StaticResource Text.Hint}"
                                   TextWrapping="Wrap" />
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Column="2"
                    Style="{StaticResource Card}"
                    Padding="14"
                    ClipToBounds="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Border Background="{StaticResource ViewerSurfaceBrush}"
                            BorderBrush="{StaticResource HairlineBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource Radius.Md.CR}">
                        <Image x:Name="PreviewImage"
                               Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               AutomationProperties.Name="Effects preview" />
                    </Border>
                    <TextBlock x:Name="SummaryText"
                               Grid.Row="1"
                               Style="{StaticResource Text.Caption}"
                               TextWrapping="Wrap"
                               Margin="0,12,0,0" />
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource HairlineBrush}"
                BorderThickness="0,1,0,0"
                Padding="14,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusText"
                           Style="{StaticResource Text.Caption}"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center"
                           AutomationProperties.LiveSetting="Polite" />
                <WrapPanel Grid.Column="1"
                           Margin="12,0,0,0">
                    <Button Style="{StaticResource ChromeButton}"
                            MinWidth="82"
                            Click="ResetButton_Click"
                            AutomationProperties.Name="Reset effects">
                        <TextBlock Text="Reset" />
                    </Button>
                    <Button Style="{StaticResource ChromeButton}"
                            MinWidth="82"
                            Margin="8,0,0,0"
                            Click="CloseButton_Click"
                            AutomationProperties.Name="Close effects">
                        <TextBlock Text="Close" />
                    </Button>
                    <Button x:Name="ApplyButton"
                            Style="{StaticResource PrimaryButton}"
                            MinWidth="118"
                            Margin="8,0,0,0"
                            Click="ApplyButton_Click"
                            AutomationProperties.Name="Apply effects to edit history">
                        <TextBlock Text="Apply" />
                    </Button>
                </WrapPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
