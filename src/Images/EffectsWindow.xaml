<Window x:Class="Images.EffectsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:Images.Localization"
        xmlns:a11y="clr-namespace:Images.Services"
        Title="{loc:Loc EffectsWindowTitle}"
        Width="860"
        Height="620"
        MinWidth="720"
        MinHeight="520"
        WindowStartupLocation="CenterOwner"
        KeyDown="Window_KeyDown">
    <Grid Background="{DynamicResource BaseBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource ToolWindowHeader}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="{loc:Loc EffectsHeading}" Style="{StaticResource Text.Title}" />
                    <TextBlock Text="{loc:Loc EffectsSubtitle}"
                               Style="{StaticResource Text.Caption}"
                               Margin="0,3,0,0" />
                </StackPanel>
                <Border Grid.Column="1"
                        Style="{StaticResource Badge}"
                        VerticalAlignment="Center"
                        Margin="16,0,0,0">
                    <TextBlock Text="{loc:Loc EffectsEnterApplies}"
                               Style="{StaticResource Text.Caption}"
                               FontWeight="SemiBold" />
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="{loc:Loc EffectsPresetsHeading}" Style="{StaticResource SectionLabel}" />
                    <Border Style="{StaticResource Card}" Padding="14">
                        <StackPanel>
                            <Button Style="{StaticResource ChromeButton}"
                                    Click="CrispButton_Click"
                                    AutomationProperties.Name="{loc:Loc EffectsApplyCrispPreset}">
                                <TextBlock Text="{loc:Loc EffectsPresetCrisp}" />
                            </Button>
                            <Button Style="{StaticResource ChromeButton}"
                                    Margin="0,8,0,0"
                                    Click="CleanButton_Click"
                                    AutomationProperties.Name="{loc:Loc EffectsApplyCleanPreset}">
                                <TextBlock Text="{loc:Loc EffectsPresetClean}" />
                            </Button>
                            <Button Style="{StaticResource ChromeButton}"
                                    Margin="0,8,0,0"
                                    Click="FocusButton_Click"
                                    AutomationProperties.Name="{loc:Loc EffectsApplyFocusPreset}">
                                <TextBlock Text="{loc:Loc EffectsPresetFocus}" />
                            </Button>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Divider}" />

                    <TextBlock Text="{loc:Loc EffectsDetailHeading}" Style="{StaticResource SectionLabel}" />
                    <Border Style="{StaticResource Card}" Padding="14">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{loc:Loc EffectsSharpenLabel}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}" />
                                <TextBlock x:Name="SharpenText"
                                           Grid.Column="1"
                                           Style="{StaticResource Text.Caption}"
                                           Margin="12,0,0,0" />
                            </Grid>
                            <Slider x:Name="SharpenSlider"
                                    Minimum="0"
                                    Maximum="100"
                                    TickFrequency="1"
                                    SmallChange="1"
                                    LargeChange="10"
                                    ValueChanged="EffectSlider_ValueChanged"
                                    AutomationProperties.Name="{loc:Loc EffectsSharpenAmountAutomationName}" />

                            <Grid Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{loc:Loc EffectsNoiseReductionLabel}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}" />
                                <TextBlock x:Name="NoiseText"
                                           Grid.Column="1"
                                           Style="{StaticResource Text.Caption}"
                                           Margin="12,0,0,0" />
                            </Grid>
                            <Slider x:Name="NoiseSlider"
                                    Minimum="0"
                                    Maximum="100"
                                    TickFrequency="1"
                                    SmallChange="1"
                                    LargeChange="10"
                                    ValueChanged="EffectSlider_ValueChanged"
                                    AutomationProperties.Name="{loc:Loc EffectsNoiseReductionAmountAutomationName}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Divider}" />

                    <TextBlock Text="{loc:Loc EffectsEdgesHeading}" Style="{StaticResource SectionLabel}" />
                    <Border Style="{StaticResource Card}" Padding="14">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{loc:Loc EffectsVignetteLabel}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}" />
                                <TextBlock x:Name="VignetteText"
                                           Grid.Column="1"
                                           Style="{StaticResource Text.Caption}"
                                           Margin="12,0,0,0" />
                            </Grid>
                            <Slider x:Name="VignetteSlider"
                                    Minimum="0"
                                    Maximum="100"
                                    TickFrequency="1"
                                    SmallChange="1"
                                    LargeChange="10"
                                    ValueChanged="EffectSlider_ValueChanged"
                                    AutomationProperties.Name="{loc:Loc EffectsVignetteAmountAutomationName}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Divider}" />

                    <Border Style="{StaticResource Card}" Padding="14">
                        <TextBlock Text="{loc:Loc EffectsEditNotice}"
                                   Style="{StaticResource Text.Hint}"
                                   TextWrapping="Wrap" />
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Column="2"
                    Style="{StaticResource Card}"
                    Padding="14"
                    ClipToBounds="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Border Background="{DynamicResource ViewerSurfaceBrush}"
                            BorderBrush="{DynamicResource HairlineBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource Radius.Md.CR}">
                        <Image x:Name="PreviewImage"
                               Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               AutomationProperties.Name="{loc:Loc EffectsPreviewAutomationName}" />
                    </Border>
                    <TextBlock x:Name="SummaryText"
                               Grid.Row="1"
                               Style="{StaticResource Text.Caption}"
                               TextWrapping="Wrap"
                               Margin="0,12,0,0" />
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Style="{StaticResource WindowStatusBar}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusText"
                           Style="{StaticResource Text.Caption}"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center"
                           AutomationProperties.LiveSetting="Polite"
                           a11y:LiveRegionBehavior.AnnounceChanges="True" />
                <WrapPanel Grid.Column="1"
                           Margin="12,0,0,0">
                    <Button Style="{StaticResource ChromeButton}"
                            MinWidth="82"
                            Click="ResetButton_Click"
                            AutomationProperties.Name="{loc:Loc EffectsResetAutomationName}">
                        <TextBlock Text="{loc:Loc Reset}" />
                    </Button>
                    <Button Style="{StaticResource ChromeButton}"
                            MinWidth="82"
                            Margin="8,0,0,0"
                            Click="CloseButton_Click"
                            AutomationProperties.Name="{loc:Loc EffectsCloseAutomationName}">
                        <TextBlock Text="{loc:Loc Close}" />
                    </Button>
                    <Button x:Name="ApplyButton"
                            Style="{StaticResource PrimaryButton}"
                            MinWidth="118"
                            Margin="8,0,0,0"
                            Click="ApplyButton_Click"
                            AutomationProperties.Name="{loc:Loc EffectsApplyAutomationName}">
                        <TextBlock Text="{loc:Loc Apply}" />
                    </Button>
                </WrapPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
