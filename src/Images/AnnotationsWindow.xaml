<Window x:Class="Images.AnnotationsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Images - Annotations"
        Width="1040"
        Height="720"
        MinWidth="860"
        MinHeight="560"
        WindowStartupLocation="CenterOwner"
        KeyDown="Window_KeyDown">
    <Grid Background="{StaticResource BaseBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource HairlineBrush}"
                BorderThickness="0,0,0,1"
                Padding="18,14">
            <StackPanel>
                <TextBlock Text="Annotations" Style="{StaticResource Text.Title}" />
                <TextBlock Text="Draw markup or redaction regions, then add them to the edit history."
                           Style="{StaticResource Text.Caption}"
                           Margin="0,3,0,0" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="286" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Tool" Style="{StaticResource SectionLabel}" />
                    <Border Style="{StaticResource Card}" Padding="14">
                        <UniformGrid Columns="2">
                            <Button Style="{StaticResource ChromeButton}" Tag="Arrow" Click="ToolButton_Click" Margin="0,0,8,8">
                                <TextBlock Text="Arrow" />
                            </Button>
                            <Button Style="{StaticResource ChromeButton}" Tag="Rectangle" Click="ToolButton_Click" Margin="0,0,0,8">
                                <TextBlock Text="Box" />
                            </Button>
                            <Button Style="{StaticResource ChromeButton}" Tag="Ellipse" Click="ToolButton_Click" Margin="0,0,8,8">
                                <TextBlock Text="Circle" />
                            </Button>
                            <Button Style="{StaticResource ChromeButton}" Tag="Text" Click="ToolButton_Click" Margin="0,0,0,8">
                                <TextBlock Text="Text" />
                            </Button>
                            <Button Style="{StaticResource ChromeButton}" Tag="Number" Click="ToolButton_Click" Margin="0,0,8,8">
                                <TextBlock Text="Step" />
                            </Button>
                            <Button Style="{StaticResource ChromeButton}" Tag="Freehand" Click="ToolButton_Click" Margin="0,0,0,8">
                                <TextBlock Text="Pen" />
                            </Button>
                            <Button Style="{StaticResource ChromeButton}" Tag="Blur" Click="ToolButton_Click" Margin="0,0,8,0">
                                <TextBlock Text="Blur" />
                            </Button>
                            <Button Style="{StaticResource ChromeButton}" Tag="Pixelate" Click="ToolButton_Click">
                                <TextBlock Text="Pixelate" />
                            </Button>
                        </UniformGrid>
                    </Border>

                    <Border Style="{StaticResource Divider}" />

                    <TextBlock Text="Text" Style="{StaticResource SectionLabel}" />
                    <Border Style="{StaticResource Card}" Padding="14">
                        <TextBox x:Name="AnnotationTextBox"
                                 Text="Note"
                                 MinHeight="34"
                                 AutomationProperties.Name="Annotation text" />
                    </Border>

                    <Border Style="{StaticResource Divider}" />

                    <TextBlock Text="Style" Style="{StaticResource SectionLabel}" />
                    <Border Style="{StaticResource Card}" Padding="14">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Stroke" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" />
                                <TextBlock x:Name="StrokeText" Grid.Column="1" Style="{StaticResource Text.Caption}" />
                            </Grid>
                            <Slider x:Name="StrokeSlider"
                                    Minimum="1"
                                    Maximum="24"
                                    Value="4"
                                    TickFrequency="1"
                                    SmallChange="1"
                                    LargeChange="4"
                                    ValueChanged="StyleSlider_ValueChanged"
                                    AutomationProperties.Name="Annotation stroke width" />

                            <Grid Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Text size" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" />
                                <TextBlock x:Name="FontText" Grid.Column="1" Style="{StaticResource Text.Caption}" />
                            </Grid>
                            <Slider x:Name="FontSlider"
                                    Minimum="12"
                                    Maximum="96"
                                    Value="34"
                                    TickFrequency="1"
                                    SmallChange="1"
                                    LargeChange="8"
                                    ValueChanged="StyleSlider_ValueChanged"
                                    AutomationProperties.Name="Annotation text size" />

                            <WrapPanel Margin="0,14,0,0">
                                <Button Tag="#F38BA8" Click="ColorButton_Click" Width="34" Height="30" Margin="0,0,8,8" Background="#F38BA8" BorderBrush="{StaticResource HairlineBrush}" />
                                <Button Tag="#F9E2AF" Click="ColorButton_Click" Width="34" Height="30" Margin="0,0,8,8" Background="#F9E2AF" BorderBrush="{StaticResource HairlineBrush}" />
                                <Button Tag="#A6E3A1" Click="ColorButton_Click" Width="34" Height="30" Margin="0,0,8,8" Background="#A6E3A1" BorderBrush="{StaticResource HairlineBrush}" />
                                <Button Tag="#89B4FA" Click="ColorButton_Click" Width="34" Height="30" Margin="0,0,8,8" Background="#89B4FA" BorderBrush="{StaticResource HairlineBrush}" />
                                <Button Tag="#FFFFFF" Click="ColorButton_Click" Width="34" Height="30" Margin="0,0,8,8" Background="#FFFFFF" BorderBrush="{StaticResource HairlineBrush}" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Divider}" />

                    <Border Style="{StaticResource Card}" Padding="14">
                        <TextBlock x:Name="ToolStatusText"
                                   Style="{StaticResource Text.Caption}"
                                   TextWrapping="Wrap" />
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Column="2"
                    Style="{StaticResource Card}"
                    Padding="10"
                    ClipToBounds="True">
                <Canvas x:Name="PreviewCanvas"
                        Background="{StaticResource ViewerSurfaceBrush}"
                        ClipToBounds="True"
                        SizeChanged="PreviewCanvas_SizeChanged"
                        MouseLeftButtonDown="PreviewCanvas_MouseLeftButtonDown"
                        MouseMove="PreviewCanvas_MouseMove"
                        MouseLeftButtonUp="PreviewCanvas_MouseLeftButtonUp">
                    <Image x:Name="PreviewImage"
                           Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           AutomationProperties.Name="Annotation preview" />
                </Canvas>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource HairlineBrush}"
                BorderThickness="0,1,0,0"
                Padding="14,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusText"
                           Style="{StaticResource Text.Caption}"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center"
                           AutomationProperties.LiveSetting="Polite" />
                <WrapPanel Grid.Column="1" Margin="12,0,0,0">
                    <Button Style="{StaticResource ChromeButton}" MinWidth="82" Click="UndoButton_Click">
                        <TextBlock Text="Undo" />
                    </Button>
                    <Button Style="{StaticResource ChromeButton}" MinWidth="82" Margin="8,0,0,0" Click="ResetButton_Click">
                        <TextBlock Text="Reset" />
                    </Button>
                    <Button Style="{StaticResource ChromeButton}" MinWidth="82" Margin="8,0,0,0" Click="CloseButton_Click">
                        <TextBlock Text="Close" />
                    </Button>
                    <Button x:Name="ApplyButton" Style="{StaticResource PrimaryButton}" MinWidth="118" Margin="8,0,0,0" Click="ApplyButton_Click">
                        <TextBlock Text="Apply" />
                    </Button>
                </WrapPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
