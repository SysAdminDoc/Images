<Window x:Class="Images.AnnotationsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:Images.Localization"
        Title="{loc:Loc AnnotationTitle}"
        Width="1040"
        Height="720"
        MinWidth="860"
        MinHeight="560"
        WindowStartupLocation="CenterOwner"
        KeyDown="Window_KeyDown">
    <Grid Background="{DynamicResource BaseBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource ToolWindowHeader}">
            <StackPanel>
                <TextBlock Text="{loc:Loc AnnotationHeading}" Style="{StaticResource Text.Title}" />
                <TextBlock Text="{loc:Loc AnnotationDescription}"
                           Style="{StaticResource Text.Caption}"
                           Margin="0,3,0,0" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="286" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="{loc:Loc AnnotationTool}" Style="{StaticResource SectionLabel}" />
                    <Border Style="{StaticResource Card}" Padding="14">
                        <UniformGrid Columns="2">
                            <Button Style="{StaticResource ChromeButton}" Tag="Arrow" Click="ToolButton_Click" Margin="0,0,8,8">
                                <TextBlock Text="{loc:Loc AnnotationArrowTool}" />
                            </Button>
                            <Button Style="{StaticResource ChromeButton}" Tag="Rectangle" Click="ToolButton_Click" Margin="0,0,0,8">
                                <TextBlock Text="{loc:Loc AnnotationBoxTool}" />
                            </Button>
                            <Button Style="{StaticResource ChromeButton}" Tag="Ellipse" Click="ToolButton_Click" Margin="0,0,8,8">
                                <TextBlock Text="{loc:Loc AnnotationCircleTool}" />
                            </Button>
                            <Button Style="{StaticResource ChromeButton}" Tag="Text" Click="ToolButton_Click" Margin="0,0,0,8">
                                <TextBlock Text="{loc:Loc AnnotationTextTool}" />
                            </Button>
                            <Button Style="{StaticResource ChromeButton}" Tag="Number" Click="ToolButton_Click" Margin="0,0,8,8">
                                <TextBlock Text="{loc:Loc AnnotationStepTool}" />
                            </Button>
                            <Button Style="{StaticResource ChromeButton}" Tag="Freehand" Click="ToolButton_Click" Margin="0,0,0,8">
                                <TextBlock Text="{loc:Loc AnnotationPenTool}" />
                            </Button>
                            <Button Style="{StaticResource ChromeButton}" Tag="Blur" Click="ToolButton_Click" Margin="0,0,8,0">
                                <TextBlock Text="{loc:Loc AnnotationBlurTool}" />
                            </Button>
                            <Button Style="{StaticResource ChromeButton}" Tag="Pixelate" Click="ToolButton_Click">
                                <TextBlock Text="{loc:Loc AnnotationPixelateTool}" />
                            </Button>
                        </UniformGrid>
                    </Border>

                    <Border Style="{StaticResource Divider}" />

                    <TextBlock Text="{loc:Loc AnnotationTextTool}" Style="{StaticResource SectionLabel}" />
                    <Border Style="{StaticResource Card}" Padding="14">
                        <TextBox x:Name="AnnotationTextBox"
                                 Text="{loc:Loc AnnotationDefaultText}"
                                 MinHeight="34"
                                 AutomationProperties.Name="{loc:Loc AnnotationTextAutomationName}" />
                    </Border>

                    <Border Style="{StaticResource Divider}" />

                    <TextBlock Text="{loc:Loc Style}" Style="{StaticResource SectionLabel}" />
                    <Border Style="{StaticResource Card}" Padding="14">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{loc:Loc Stroke}" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" />
                                <TextBlock x:Name="StrokeText" Grid.Column="1" Style="{StaticResource Text.Caption}" />
                            </Grid>
                            <Slider x:Name="StrokeSlider"
                                    Minimum="1"
                                    Maximum="24"
                                    Value="4"
                                    TickFrequency="1"
                                    SmallChange="1"
                                    LargeChange="4"
                                    ValueChanged="StyleSlider_ValueChanged"
                                    AutomationProperties.Name="{loc:Loc AnnotationStrokeWidthAutomationName}" />

                            <Grid Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{loc:Loc AnnotationTextSize}" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" />
                                <TextBlock x:Name="FontText" Grid.Column="1" Style="{StaticResource Text.Caption}" />
                            </Grid>
                            <Slider x:Name="FontSlider"
                                    Minimum="12"
                                    Maximum="96"
                                    Value="34"
                                    TickFrequency="1"
                                    SmallChange="1"
                                    LargeChange="8"
                                    ValueChanged="StyleSlider_ValueChanged"
                                    AutomationProperties.Name="{loc:Loc AnnotationFontSizeAutomationName}" />

                            <WrapPanel Margin="0,14,0,0">
                                <Button Tag="#F38BA8" Click="ColorButton_Click" Width="34" Height="30" Margin="0,0,8,8" Background="#F38BA8" BorderBrush="{DynamicResource HairlineBrush}" ToolTip="Red" AutomationProperties.Name="Red color" />
                                <Button Tag="#F9E2AF" Click="ColorButton_Click" Width="34" Height="30" Margin="0,0,8,8" Background="#F9E2AF" BorderBrush="{DynamicResource HairlineBrush}" ToolTip="Yellow" AutomationProperties.Name="Yellow color" />
                                <Button Tag="#A6E3A1" Click="ColorButton_Click" Width="34" Height="30" Margin="0,0,8,8" Background="#A6E3A1" BorderBrush="{DynamicResource HairlineBrush}" ToolTip="Green" AutomationProperties.Name="Green color" />
                                <Button Tag="#89B4FA" Click="ColorButton_Click" Width="34" Height="30" Margin="0,0,8,8" Background="#89B4FA" BorderBrush="{DynamicResource HairlineBrush}" ToolTip="Blue" AutomationProperties.Name="Blue color" />
                                <Button Tag="#FFFFFF" Click="ColorButton_Click" Width="34" Height="30" Margin="0,0,8,8" Background="#FFFFFF" BorderBrush="{DynamicResource HairlineBrush}" ToolTip="White" AutomationProperties.Name="White color" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Divider}" />

                    <Border Style="{StaticResource Card}" Padding="14">
                        <TextBlock x:Name="ToolStatusText"
                                   Style="{StaticResource Text.Caption}"
                                   TextWrapping="Wrap" />
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Column="2"
                    Style="{StaticResource Card}"
                    Padding="10"
                    ClipToBounds="True">
                <Canvas x:Name="PreviewCanvas"
                        Background="{DynamicResource ViewerSurfaceBrush}"
                        ClipToBounds="True"
                        SizeChanged="PreviewCanvas_SizeChanged"
                        MouseLeftButtonDown="PreviewCanvas_MouseLeftButtonDown"
                        MouseMove="PreviewCanvas_MouseMove"
                        MouseLeftButtonUp="PreviewCanvas_MouseLeftButtonUp">
                    <Image x:Name="PreviewImage"
                           Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           AutomationProperties.Name="{loc:Loc AnnotationPreview}" />
                </Canvas>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Style="{StaticResource WindowStatusBar}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusText"
                           Style="{StaticResource Text.Caption}"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center"
                           AutomationProperties.LiveSetting="Polite" />
                <WrapPanel Grid.Column="1" Margin="12,0,0,0">
                    <Button Style="{StaticResource ChromeButton}" MinWidth="82" Click="UndoButton_Click">
                        <TextBlock Text="{loc:Loc Undo}" />
                    </Button>
                    <Button Style="{StaticResource ChromeButton}" MinWidth="82" Margin="8,0,0,0" Click="ResetButton_Click">
                        <TextBlock Text="{loc:Loc Reset}" />
                    </Button>
                    <Button Style="{StaticResource ChromeButton}" MinWidth="82" Margin="8,0,0,0" Click="CloseButton_Click">
                        <TextBlock Text="{loc:Loc Close}" />
                    </Button>
                    <Button x:Name="ApplyButton" Style="{StaticResource PrimaryButton}" MinWidth="118" Margin="8,0,0,0" Click="ApplyButton_Click">
                        <TextBlock Text="{loc:Loc Apply}" />
                    </Button>
                </WrapPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
