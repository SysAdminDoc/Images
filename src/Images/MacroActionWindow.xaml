<Window x:Class="Images.MacroActionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:Images.Localization"
        Title="{x:Static loc:Strings.MacroWindowTitle}"
        Width="1120"
        Height="760"
        MinWidth="920"
        MinHeight="620"
        WindowStartupLocation="CenterOwner">
    <Grid Background="{StaticResource BaseBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource HairlineBrush}"
                BorderThickness="0,0,0,1"
                Padding="18,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="{x:Static loc:Strings.MacroHeading}" Style="{StaticResource Text.Title}" />
                    <TextBlock Text="{x:Static loc:Strings.MacroSubtitle}"
                               Style="{StaticResource Text.Caption}"
                               Margin="0,3,0,0" />
                </StackPanel>
                <WrapPanel Grid.Column="1" HorizontalAlignment="Right">
                    <Button Style="{StaticResource ChromeButton}"
                            Margin="8,0,0,0"
                            Click="LoadPlanButton_Click"
                            AutomationProperties.Name="{x:Static loc:Strings.MacroLoadJson}">
                        <TextBlock Text="{x:Static loc:Strings.MacroLoadJson}" />
                    </Button>
                    <Button Style="{StaticResource ChromeButton}"
                            Margin="8,0,0,0"
                            Click="SavePlanButton_Click"
                            AutomationProperties.Name="{x:Static loc:Strings.MacroSaveJson}">
                        <TextBlock Text="{x:Static loc:Strings.MacroSaveJson}" />
                    </Button>
                </WrapPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource HairlineBrush}"
                    BorderThickness="0,0,1,0"
                    Padding="16">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="{x:Static loc:Strings.MacroSources}" Style="{StaticResource SectionLabel}" />
                        <Border Style="{StaticResource Card}" Padding="12">
                            <StackPanel>
                                <WrapPanel>
                                    <Button x:Name="AddFilesButton"
                                            Style="{StaticResource ChromeButton}"
                                            Margin="0,0,8,0"
                                            Click="AddFilesButton_Click"
                                            AutomationProperties.Name="{x:Static loc:Strings.MacroAddFiles}">
                                        <TextBlock Text="{x:Static loc:Strings.MacroAddFiles}" />
                                    </Button>
                                    <Button x:Name="AddFolderButton"
                                            Style="{StaticResource ChromeButton}"
                                            Click="AddFolderButton_Click"
                                            AutomationProperties.Name="{x:Static loc:Strings.MacroAddFolder}">
                                        <TextBlock Text="{x:Static loc:Strings.MacroAddFolder}" />
                                    </Button>
                                </WrapPanel>
                                <ListBox x:Name="SourceList"
                                         MinHeight="112"
                                         Margin="0,10,0,0"
                                         AutomationProperties.Name="{x:Static loc:Strings.MacroSources}" />
                                <Button Style="{StaticResource ChromeButton}"
                                        Margin="0,10,0,0"
                                        HorizontalAlignment="Left"
                                        Click="ClearSourcesButton_Click"
                                        AutomationProperties.Name="{x:Static loc:Strings.MacroClearSources}">
                                    <TextBlock Text="{x:Static loc:Strings.MacroClearSources}" />
                                </Button>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Divider}" />

                        <TextBlock Text="{x:Static loc:Strings.MacroOutput}" Style="{StaticResource SectionLabel}" />
                        <Border Style="{StaticResource Card}" Padding="12">
                            <StackPanel>
                                <TextBlock x:Name="OutputFolderText"
                                           Text="{x:Static loc:Strings.MacroOutputFolderDefault}"
                                           Style="{StaticResource Text.Caption}"
                                           TextWrapping="Wrap" />
                                <Button Style="{StaticResource ChromeButton}"
                                        Margin="0,10,0,0"
                                        HorizontalAlignment="Left"
                                        Click="ChooseOutputButton_Click"
                                        AutomationProperties.Name="{x:Static loc:Strings.MacroChooseOutput}">
                                    <TextBlock Text="{x:Static loc:Strings.MacroChooseOutput}" />
                                </Button>
                                <CheckBox x:Name="DryRunCheckBox"
                                          Content="{x:Static loc:Strings.MacroDryRunOnly}"
                                          IsChecked="True"
                                          Margin="0,12,0,0"
                                          AutomationProperties.Name="{x:Static loc:Strings.MacroDryRunOnly}" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Divider}" />

                        <TextBlock Text="{x:Static loc:Strings.MacroActionPresets}" Style="{StaticResource SectionLabel}" />
                        <Border Style="{StaticResource Card}" Padding="12">
                            <StackPanel>
                                <Button Style="{StaticResource ChromeButton}"
                                        Margin="0,0,0,8"
                                        Click="AddStripGpsButton_Click"
                                        AutomationProperties.Name="{x:Static loc:Strings.MacroAddStripGps}">
                                    <TextBlock Text="{x:Static loc:Strings.MacroAddStripGps}" />
                                </Button>
                                <Button Style="{StaticResource ChromeButton}"
                                        Margin="0,0,0,8"
                                        Click="AddExportPngButton_Click"
                                        AutomationProperties.Name="{x:Static loc:Strings.MacroAddExportPng}">
                                    <TextBlock Text="{x:Static loc:Strings.MacroAddExportPng}" />
                                </Button>
                                <Button Style="{StaticResource ChromeButton}"
                                        Click="AddRenamePatternButton_Click"
                                        AutomationProperties.Name="{x:Static loc:Strings.MacroAddRenamePattern}">
                                    <TextBlock Text="{x:Static loc:Strings.MacroAddRenamePattern}" />
                                </Button>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="1"
                          HorizontalAlignment="Stretch"
                          Background="{StaticResource HairlineBrush}" />

            <Grid Grid.Column="2"
                  Background="{StaticResource ViewportBrush}"
                  Margin="18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="220" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Style="{StaticResource Card}"
                        Padding="14">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{x:Static loc:Strings.MacroJsonHeading}" Style="{StaticResource SectionLabel}" />
                            <Button Grid.Column="1"
                                    Style="{StaticResource ChromeButton}"
                                    Click="ValidatePlanButton_Click"
                                    AutomationProperties.Name="{x:Static loc:Strings.MacroValidate}">
                                <TextBlock Text="{x:Static loc:Strings.MacroValidate}" />
                            </Button>
                        </Grid>
                        <TextBox x:Name="MacroJsonBox"
                                 Grid.Row="1"
                                 Margin="0,10,0,0"
                                 AcceptsReturn="True"
                                 AcceptsTab="True"
                                 FontFamily="Consolas"
                                 FontSize="12"
                                 TextWrapping="NoWrap"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 AutomationProperties.Name="{x:Static loc:Strings.MacroJsonHeading}" />
                    </Grid>
                </Border>

                <Border Grid.Row="2"
                        Style="{StaticResource Card}"
                        Padding="14">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="{x:Static loc:Strings.MacroRunLog}" Style="{StaticResource SectionLabel}" />
                        <ListBox x:Name="ResultList"
                                 Grid.Row="1"
                                 Margin="0,8,0,0"
                                 AutomationProperties.Name="{x:Static loc:Strings.MacroRunLog}" />
                    </Grid>
                </Border>

                <Border Grid.Row="3"
                        Style="{StaticResource Card}"
                        Padding="12"
                        Margin="0,16,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="PlanSummaryText"
                                   Text="{x:Static loc:Strings.MacroDefaultSummary}"
                                   Style="{StaticResource Text.Caption}"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center" />
                        <Button x:Name="RunButton"
                                Grid.Column="1"
                                Style="{StaticResource PrimaryButton}"
                                Margin="14,0,0,0"
                                Click="RunButton_Click"
                                AutomationProperties.Name="{x:Static loc:Strings.MacroRunButton}">
                            <TextBlock Text="{x:Static loc:Strings.MacroRunButton}" />
                        </Button>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Border Grid.Row="2"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource HairlineBrush}"
                BorderThickness="0,1,0,0"
                Padding="16,10">
            <StackPanel Orientation="Horizontal">
                <Ellipse x:Name="StatusDot"
                         Width="8"
                         Height="8"
                         Fill="{StaticResource GreenBrush}"
                         Margin="0,0,9,0"
                         VerticalAlignment="Center" />
                <TextBlock x:Name="StatusText"
                           Text="{x:Static loc:Strings.MacroReadyStatus}"
                           Style="{StaticResource Text.Caption}"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
