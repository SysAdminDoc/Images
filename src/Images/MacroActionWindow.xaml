<Window x:Class="Images.MacroActionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:Images.Localization"
        Title="{x:Static loc:Strings.MacroWindowTitle}"
        Width="1120"
        Height="760"
        MinWidth="920"
        MinHeight="620"
        WindowStartupLocation="CenterOwner">
    <Grid Background="{DynamicResource BaseBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource ToolWindowHeader}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="{x:Static loc:Strings.MacroHeading}" Style="{StaticResource Text.Title}" />
                    <TextBlock Text="{x:Static loc:Strings.MacroSubtitle}"
                               Style="{StaticResource Text.Caption}"
                               Margin="0,3,0,0" />
                </StackPanel>
                <WrapPanel Grid.Column="1" HorizontalAlignment="Right">
                    <Button Style="{StaticResource ChromeButton}"
                            Margin="8,0,0,0"
                            Click="LoadPlanButton_Click"
                            AutomationProperties.Name="{x:Static loc:Strings.MacroLoadJson}">
                        <TextBlock Text="{x:Static loc:Strings.MacroLoadJson}" />
                    </Button>
                    <Button Style="{StaticResource ChromeButton}"
                            Margin="8,0,0,0"
                            Click="SavePlanButton_Click"
                            AutomationProperties.Name="{x:Static loc:Strings.MacroSaveJson}">
                        <TextBlock Text="{x:Static loc:Strings.MacroSaveJson}" />
                    </Button>
                </WrapPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource ToolWindowSidebar}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="{x:Static loc:Strings.MacroSources}" Style="{StaticResource SectionLabel}" />
                        <Border Style="{StaticResource Card}" Padding="12">
                            <StackPanel>
                                <WrapPanel>
                                    <Button x:Name="AddFilesButton"
                                            Style="{StaticResource ChromeButton}"
                                            Margin="0,0,8,0"
                                            Click="AddFilesButton_Click"
                                            AutomationProperties.Name="{x:Static loc:Strings.MacroAddFiles}">
                                        <TextBlock Text="{x:Static loc:Strings.MacroAddFiles}" />
                                    </Button>
                                    <Button x:Name="AddFolderButton"
                                            Style="{StaticResource ChromeButton}"
                                            Click="AddFolderButton_Click"
                                            AutomationProperties.Name="{x:Static loc:Strings.MacroAddFolder}">
                                        <TextBlock Text="{x:Static loc:Strings.MacroAddFolder}" />
                                    </Button>
                                </WrapPanel>
                                <ListBox x:Name="SourceList"
                                         MinHeight="112"
                                         Margin="0,10,0,0"
                                         AutomationProperties.Name="{x:Static loc:Strings.MacroSources}" />
                                <Button Style="{StaticResource ChromeButton}"
                                        Margin="0,10,0,0"
                                        HorizontalAlignment="Left"
                                        Click="ClearSourcesButton_Click"
                                        AutomationProperties.Name="{x:Static loc:Strings.MacroClearSources}">
                                    <TextBlock Text="{x:Static loc:Strings.MacroClearSources}" />
                                </Button>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Divider}" />

                        <TextBlock Text="{x:Static loc:Strings.MacroOutput}" Style="{StaticResource SectionLabel}" />
                        <Border Style="{StaticResource Card}" Padding="12">
                            <StackPanel>
                                <TextBlock x:Name="OutputFolderText"
                                           Text="{x:Static loc:Strings.MacroOutputFolderDefault}"
                                           Style="{StaticResource Text.Caption}"
                                           TextWrapping="Wrap" />
                                <Button Style="{StaticResource ChromeButton}"
                                        Margin="0,10,0,0"
                                        HorizontalAlignment="Left"
                                        Click="ChooseOutputButton_Click"
                                        AutomationProperties.Name="{x:Static loc:Strings.MacroChooseOutput}">
                                    <TextBlock Text="{x:Static loc:Strings.MacroChooseOutput}" />
                                </Button>
                                <CheckBox x:Name="DryRunCheckBox"
                                          Content="{x:Static loc:Strings.MacroDryRunOnly}"
                                          IsChecked="True"
                                          Margin="0,12,0,0"
                                          AutomationProperties.Name="{x:Static loc:Strings.MacroDryRunOnly}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <GridSplitter Grid.Column="1"
                          Style="{StaticResource VerticalGridSplitter}" />

            <!-- Right panel: pipeline steps + preview + action bar -->
            <Grid Grid.Column="2"
                  Background="{DynamicResource ViewportBrush}"
                  Margin="18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="220" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Pipeline steps card -->
                <Border Grid.Row="0"
                        Style="{StaticResource Card}"
                        Padding="14">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <TextBlock Grid.Row="0"
                                   Text="{x:Static loc:Strings.MacroPipelineSteps}"
                                   Style="{StaticResource SectionLabel}" />

                        <!-- Step list -->
                        <ListBox x:Name="StepList"
                                 Grid.Row="1"
                                 Margin="0,10,0,0"
                                 HorizontalContentAlignment="Stretch"
                                 AutomationProperties.Name="{x:Static loc:Strings.MacroPipelineSteps}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource Card}"
                                            Padding="10"
                                            Margin="0,0,0,6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <!-- Step number badge -->
                                            <Border Grid.Column="0"
                                                    Style="{StaticResource Badge}"
                                                    Margin="0,0,10,0"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{Binding StepLabel}"
                                                           Style="{StaticResource Text.Caption}"
                                                           FontWeight="SemiBold" />
                                            </Border>

                                            <!-- Kind + parameter summary -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding KindLabel}"
                                                           Style="{StaticResource Text.Body}"
                                                           FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding ParameterSummary}"
                                                           Style="{StaticResource Text.Caption}"
                                                           TextWrapping="Wrap"
                                                           Margin="0,2,0,0" />
                                            </StackPanel>

                                            <!-- Move / Remove buttons -->
                                            <StackPanel Grid.Column="2"
                                                        Orientation="Horizontal"
                                                        VerticalAlignment="Center">
                                                <Button Style="{StaticResource ChromeButton}"
                                                        Content="{x:Static loc:Strings.MacroMoveUp}"
                                                        Margin="4,0,0,0"
                                                        Click="MoveStepUp_Click"
                                                        Tag="{Binding}"
                                                        AutomationProperties.Name="{x:Static loc:Strings.MacroMoveUp}" />
                                                <Button Style="{StaticResource ChromeButton}"
                                                        Content="{x:Static loc:Strings.MacroMoveDown}"
                                                        Margin="4,0,0,0"
                                                        Click="MoveStepDown_Click"
                                                        Tag="{Binding}"
                                                        AutomationProperties.Name="{x:Static loc:Strings.MacroMoveDown}" />
                                                <Button Style="{StaticResource ChromeButton}"
                                                        Content="{x:Static loc:Strings.MacroRemoveStep}"
                                                        Margin="4,0,0,0"
                                                        Click="RemoveStep_Click"
                                                        Tag="{Binding}"
                                                        AutomationProperties.Name="{x:Static loc:Strings.MacroRemoveStep}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <!-- Empty state -->
                        <TextBlock x:Name="NoStepsText"
                                   Grid.Row="1"
                                   Text="{x:Static loc:Strings.MacroNoSteps}"
                                   Style="{StaticResource Text.Caption}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />

                        <!-- Add step buttons -->
                        <WrapPanel Grid.Row="2" Margin="0,10,0,0">
                            <TextBlock Text="{x:Static loc:Strings.MacroAddStep}"
                                       Style="{StaticResource Text.Caption}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0" />
                            <Button Style="{StaticResource ChromeButton}"
                                    Margin="0,0,6,0"
                                    Click="AddStripGpsStep_Click"
                                    AutomationProperties.Name="{x:Static loc:Strings.MacroStripGps}">
                                <TextBlock Text="{x:Static loc:Strings.MacroStripGps}" />
                            </Button>
                            <Button Style="{StaticResource ChromeButton}"
                                    Margin="0,0,6,0"
                                    Click="AddStripMetadataStep_Click"
                                    AutomationProperties.Name="{x:Static loc:Strings.MacroStripMetadata}">
                                <TextBlock Text="{x:Static loc:Strings.MacroStripMetadata}" />
                            </Button>
                            <Button Style="{StaticResource ChromeButton}"
                                    Margin="0,0,6,0"
                                    Click="AddExportCopyStep_Click"
                                    AutomationProperties.Name="{x:Static loc:Strings.MacroExportCopy}">
                                <TextBlock Text="{x:Static loc:Strings.MacroExportCopy}" />
                            </Button>
                            <Button Style="{StaticResource ChromeButton}"
                                    Click="AddRenamePatternStep_Click"
                                    AutomationProperties.Name="{x:Static loc:Strings.MacroRenamePattern}">
                                <TextBlock Text="{x:Static loc:Strings.MacroRenamePattern}" />
                            </Button>
                        </WrapPanel>
                    </Grid>
                </Border>

                <!-- Preview / run log card -->
                <Border Grid.Row="2"
                        Style="{StaticResource Card}"
                        Padding="14">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock x:Name="PreviewHeading"
                                   Text="{x:Static loc:Strings.MacroPreviewResults}"
                                   Style="{StaticResource SectionLabel}" />
                        <ListBox x:Name="ResultList"
                                 Grid.Row="1"
                                 Margin="0,8,0,0"
                                 AutomationProperties.Name="{x:Static loc:Strings.MacroPreviewResults}" />
                    </Grid>
                </Border>

                <!-- Action bar -->
                <Border Grid.Row="3"
                        Style="{StaticResource Card}"
                        Padding="12"
                        Margin="0,16,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="PlanSummaryText"
                                   Text="{x:Static loc:Strings.MacroDefaultSummary}"
                                   Style="{StaticResource Text.Caption}"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center" />
                        <Button x:Name="PreviewButton"
                                Grid.Column="1"
                                Style="{StaticResource ChromeButton}"
                                Margin="14,0,0,0"
                                Click="PreviewButton_Click"
                                AutomationProperties.Name="{x:Static loc:Strings.MacroPreview}">
                            <TextBlock Text="{x:Static loc:Strings.MacroPreview}" />
                        </Button>
                        <Button x:Name="CancelButton"
                                Grid.Column="2"
                                Style="{StaticResource ChromeButton}"
                                Margin="8,0,0,0"
                                Click="CancelButton_Click"
                                Visibility="Collapsed"
                                AutomationProperties.Name="{x:Static loc:Strings.MacroCancelButton}">
                            <TextBlock Text="{x:Static loc:Strings.MacroCancelButton}" />
                        </Button>
                        <Button x:Name="RunButton"
                                Grid.Column="3"
                                Style="{StaticResource PrimaryButton}"
                                Margin="8,0,0,0"
                                Click="RunButton_Click"
                                AutomationProperties.Name="{x:Static loc:Strings.MacroRunButton}">
                            <TextBlock Text="{x:Static loc:Strings.MacroRunButton}" />
                        </Button>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Border Grid.Row="2"
                Style="{StaticResource WindowStatusBar}">
            <StackPanel Orientation="Horizontal">
                <Ellipse x:Name="StatusDot"
                         Width="8"
                         Height="8"
                         Fill="{DynamicResource GreenBrush}"
                         Margin="0,0,9,0"
                         VerticalAlignment="Center" />
                <TextBlock x:Name="StatusText"
                           Text="{x:Static loc:Strings.MacroReadyStatus}"
                           Style="{StaticResource Text.Caption}"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
