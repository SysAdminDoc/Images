<Window x:Class="Images.DuplicateCleanupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:Images.Localization"
        Title="{x:Static loc:Strings.DuplicateCleanupWindowTitle}"
        Width="1240"
        Height="820"
        MinWidth="980"
        MinHeight="640"
        WindowStartupLocation="CenterOwner">
    <Grid Background="{DynamicResource BaseBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource ToolWindowHeader}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{x:Static loc:Strings.DuplicateCleanupHeading}" Style="{StaticResource Text.Title}" />
                    <TextBlock Text="{x:Static loc:Strings.DuplicateCleanupSubtitle}"
                               Style="{StaticResource Text.Caption}"
                               Margin="0,3,0,0" />
                </StackPanel>

                <WrapPanel Grid.Column="1"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center">
                    <Button x:Name="AddFolderButton"
                            Style="{StaticResource ChromeButton}"
                            Margin="8,0,0,0"
                            Click="AddFolderButton_Click"
                            ToolTip="{x:Static loc:Strings.DuplicateCleanupAddFolderTooltip}"
                            AutomationProperties.Name="{x:Static loc:Strings.DuplicateCleanupAddFolderAutomationName}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8B7;"
                                       FontFamily="{StaticResource IconFontFamily}"
                                       FontSize="12"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="{x:Static loc:Strings.DuplicateCleanupAddFolderButton}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="AddReferenceFolderButton"
                            Style="{StaticResource ChromeButton}"
                            Margin="8,0,0,0"
                            Click="AddReferenceFolderButton_Click"
                            ToolTip="{x:Static loc:Strings.DuplicateCleanupReferenceTooltip}"
                            AutomationProperties.Name="{x:Static loc:Strings.DuplicateCleanupReferenceFolderAutomationName}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE946;"
                                       FontFamily="{StaticResource IconFontFamily}"
                                       FontSize="12"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="{x:Static loc:Strings.DuplicateCleanupReferenceButton}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="ScanButton"
                            Style="{StaticResource PrimaryButton}"
                            Margin="8,0,0,0"
                            Click="ScanButton_Click"
                            ToolTip="{x:Static loc:Strings.DuplicateCleanupScanTooltip}"
                            AutomationProperties.Name="{x:Static loc:Strings.DuplicateCleanupScanAutomationName}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE721;"
                                       FontFamily="{StaticResource IconFontFamily}"
                                       FontSize="12"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="{x:Static loc:Strings.DuplicateCleanupScanButton}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="CancelScanButton"
                            Style="{StaticResource ChromeButton}"
                            Margin="8,0,0,0"
                            Click="CancelScanButton_Click"
                            IsEnabled="False"
                            ToolTip="{x:Static loc:Strings.DuplicateCleanupCancelTooltip}"
                            AutomationProperties.Name="{x:Static loc:Strings.DuplicateCleanupCancelAutomationName}">
                        <TextBlock Text="{x:Static loc:Strings.DuplicateCleanupCancelButton}" />
                    </Button>
                </WrapPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource ToolWindowSidebar}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="{x:Static loc:Strings.DuplicateCleanupFoldersToScan}" Style="{StaticResource SectionLabel}" />
                        <ListBox x:Name="ScanFoldersList"
                                 MinHeight="74"
                                 MaxHeight="120"
                                 AutomationProperties.Name="{x:Static loc:Strings.DuplicateCleanupScanFoldersAutomationName}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource Card}" Padding="10,8">
                                        <TextBlock Text="{Binding}"
                                                   Style="{StaticResource Text.Caption}"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding}" />
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <WrapPanel Margin="0,8,0,0">
                            <Button Style="{StaticResource ChromeButton}"
                                    Padding="10,5"
                                    Margin="0,0,8,0"
                                    Click="RemoveScanFolderButton_Click"
                                    AutomationProperties.Name="{x:Static loc:Strings.DuplicateCleanupRemoveScanFolderAutomationName}">
                                <TextBlock Text="{x:Static loc:Strings.DuplicateCleanupRemove}" />
                            </Button>
                            <Button Style="{StaticResource ChromeButton}"
                                    Padding="10,5"
                                    Click="ClearScanFoldersButton_Click"
                                    AutomationProperties.Name="{x:Static loc:Strings.DuplicateCleanupClearScanFoldersAutomationName}">
                                <TextBlock Text="{x:Static loc:Strings.DuplicateCleanupClear}" />
                            </Button>
                        </WrapPanel>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Margin="0,18,0,0">
                        <TextBlock Text="{x:Static loc:Strings.DuplicateCleanupReferenceFolders}" Style="{StaticResource SectionLabel}" />
                        <TextBlock Text="{x:Static loc:Strings.DuplicateCleanupReferenceFoldersHint}"
                                   Style="{StaticResource Text.Hint}"
                                   TextWrapping="Wrap"
                                   Margin="0,-4,0,8" />
                        <ListBox x:Name="ReferenceFoldersList"
                                 MinHeight="52"
                                 MaxHeight="96"
                                 AutomationProperties.Name="{x:Static loc:Strings.DuplicateCleanupReferenceFoldersListAutomationName}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource Card}" Padding="10,8">
                                        <TextBlock Text="{Binding}"
                                                   Style="{StaticResource Text.Caption}"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding}" />
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <WrapPanel Margin="0,8,0,0">
                            <Button Style="{StaticResource ChromeButton}"
                                    Padding="10,5"
                                    Margin="0,0,8,0"
                                    Click="RemoveReferenceFolderButton_Click"
                                    AutomationProperties.Name="{x:Static loc:Strings.DuplicateCleanupRemoveReferenceFolderAutomationName}">
                                <TextBlock Text="{x:Static loc:Strings.DuplicateCleanupRemove}" />
                            </Button>
                            <Button Style="{StaticResource ChromeButton}"
                                    Padding="10,5"
                                    Click="ClearReferenceFoldersButton_Click"
                                    AutomationProperties.Name="{x:Static loc:Strings.DuplicateCleanupClearReferenceFoldersAutomationName}">
                                <TextBlock Text="{x:Static loc:Strings.DuplicateCleanupClear}" />
                            </Button>
                        </WrapPanel>
                    </StackPanel>

                    <Border Grid.Row="2"
                            Style="{StaticResource Card}"
                            Padding="12"
                            Margin="0,18,0,0">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{x:Static loc:Strings.DuplicateCleanupSimilarityThreshold}"
                                           Style="{StaticResource Text.Body}"
                                           FontWeight="SemiBold" />
                                <TextBlock x:Name="ThresholdText"
                                           Grid.Column="1"
                                           Text="6"
                                           Style="{StaticResource Text.Caption}"
                                           Margin="12,0,0,0" />
                            </Grid>
                            <Slider x:Name="ThresholdSlider"
                                    Minimum="0"
                                    Maximum="16"
                                    TickFrequency="1"
                                    IsSnapToTickEnabled="True"
                                    Value="6"
                                    Margin="0,10,0,0"
                                    ValueChanged="ThresholdSlider_ValueChanged"
                                    AutomationProperties.Name="{x:Static loc:Strings.DuplicateCleanupSimilarityThreshold}" />
                            <TextBlock Text="{x:Static loc:Strings.DuplicateCleanupThresholdHint}"
                                       Style="{StaticResource Text.Hint}"
                                       TextWrapping="Wrap"
                                       Margin="0,6,0,0" />
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="3" Margin="0,18,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{x:Static loc:Strings.DuplicateCleanupFindings}" Style="{StaticResource SectionLabel}" />
                            <TextBlock x:Name="FindingCountText"
                                       Grid.Column="1"
                                       Text="0"
                                       Style="{StaticResource Text.Caption}"
                                       Margin="12,0,0,0" />
                        </Grid>

                        <ListBox x:Name="FindingsList"
                                 Grid.Row="1"
                                 SelectionChanged="FindingsList_SelectionChanged"
                                 AutomationProperties.Name="{x:Static loc:Strings.DuplicateCleanupFindingsAutomationName}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="12,10">
                                        <Border.Style>
                                            <Style TargetType="Border" BasedOn="{StaticResource InteractiveCard}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource AccentSelectionBrush}" />
                                                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}"
                                                       Style="{StaticResource Text.Body}"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding Summary}"
                                                       Style="{StaticResource Text.Caption}"
                                                       TextWrapping="Wrap"
                                                       Margin="0,4,0,0" />
                                            <TextBlock Text="{Binding ActionSummary}"
                                                       Style="{StaticResource Text.Hint}"
                                                       TextWrapping="Wrap"
                                                       Margin="0,3,0,0" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="1"
                          HorizontalAlignment="Stretch"
                          Background="{DynamicResource HairlineBrush}"
                          ShowsPreview="False" />

            <Border Grid.Column="2"
                    Style="{StaticResource ToolWindowWorkspace}">
                <Grid>
                <Border x:Name="EmptyState"
                        Style="{StaticResource EmptyStateCard}"
                        AutomationProperties.Name="{x:Static loc:Strings.DuplicateCleanupEmptyStateHeading}">
                    <StackPanel>
                        <Border Style="{StaticResource EmptyStateIcon}">
                            <TextBlock Text="&#xE8C8;"
                                       FontFamily="{StaticResource IconFontFamily}"
                                       FontSize="18"
                                       Foreground="{DynamicResource AccentBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="{x:Static loc:Strings.DuplicateCleanupEmptyStateHeading}"
                                   Style="{StaticResource Text.Display}"
                                   TextAlignment="Center" />
                        <TextBlock Text="{x:Static loc:Strings.DuplicateCleanupEmptyStateDescription}"
                                   Style="{StaticResource Text.Subtitle}"
                                   TextAlignment="Center"
                                   Margin="0,10,0,0" />
                    </StackPanel>
                </Border>

                <Grid x:Name="DetailPanel" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Style="{StaticResource Card}"
                            Padding="14"
                            Margin="0,0,0,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock x:Name="DetailTitle"
                                           Text="{x:Static loc:Strings.DuplicateCleanupFinding}"
                                           Style="{StaticResource Text.Title}" />
                                <TextBlock x:Name="DetailSummary"
                                           Text=""
                                           Style="{StaticResource Text.Caption}"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                            <WrapPanel Grid.Column="1"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       Margin="16,0,0,0">
                                <Button Style="{StaticResource ChromeButton}"
                                        Margin="0,0,8,0"
                                        Click="CompareSelectedButton_Click"
                                        AutomationProperties.Name="{x:Static loc:Strings.DuplicateCleanupCompareAutomationName}">
                                    <TextBlock Text="{x:Static loc:Strings.DuplicateCleanupCompareButton}" />
                                </Button>
                                <Button Style="{StaticResource ChromeButton}"
                                        Margin="0,0,8,0"
                                        Click="MarkNotDuplicateButton_Click"
                                        AutomationProperties.Name="{x:Static loc:Strings.DuplicateCleanupMarkNotDuplicateAutomationName}">
                                    <TextBlock Text="{x:Static loc:Strings.DuplicateCleanupMarkNotDuplicateButton}" />
                                </Button>
                                <Button Style="{StaticResource ChromeButton}"
                                        Margin="0,0,8,0"
                                        Click="QuarantineExtrasButton_Click"
                                        AutomationProperties.Name="{x:Static loc:Strings.DuplicateCleanupQuarantineExtrasAutomationName}">
                                    <TextBlock Text="{x:Static loc:Strings.DuplicateCleanupQuarantineExtrasButton}" />
                                </Button>
                                <Button Style="{StaticResource DangerButton}"
                                        Click="RecycleExtrasButton_Click"
                                        AutomationProperties.Name="{x:Static loc:Strings.DuplicateCleanupRecycleExtrasAutomationName}">
                                    <TextBlock Text="{x:Static loc:Strings.DuplicateCleanupRecycleExtrasButton}" />
                                </Button>
                            </WrapPanel>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Background="{DynamicResource PanelBrush}"
                                BorderBrush="{DynamicResource HairlineBrush}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource Radius.Md.CR}"
                                Padding="14">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Border Background="{DynamicResource CrustBrush}"
                                        CornerRadius="{StaticResource Radius.Sm.CR}"
                                        ClipToBounds="True">
                                    <Image x:Name="PrimaryPreview"
                                           Stretch="Uniform"
                                           RenderOptions.BitmapScalingMode="HighQuality" />
                                </Border>
                                <StackPanel Grid.Row="1" Margin="0,12,0,0">
                                    <WrapPanel>
                                        <Border x:Name="PrimaryReferenceBadge"
                                                Style="{StaticResource Badge}"
                                                Margin="0,0,8,8">
                                            <TextBlock Text="{x:Static loc:Strings.DuplicateCleanupKeepCandidate}"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource AccentBrush}" />
                                        </Border>
                                        <TextBlock x:Name="PrimarySizeText"
                                                   Style="{StaticResource Text.Caption}"
                                                   Margin="0,0,8,8" />
                                    </WrapPanel>
                                    <TextBlock x:Name="PrimaryNameText"
                                               Style="{StaticResource Text.Body}"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock x:Name="PrimaryFolderText"
                                               Style="{StaticResource Text.Hint}"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="0,3,0,0" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Grid.Column="2"
                                Background="{DynamicResource PanelBrush}"
                                BorderBrush="{DynamicResource HairlineBrush}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource Radius.Md.CR}"
                                Padding="14">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Border Background="{DynamicResource CrustBrush}"
                                        CornerRadius="{StaticResource Radius.Sm.CR}"
                                        ClipToBounds="True">
                                    <Image x:Name="SecondaryPreview"
                                           Stretch="Uniform"
                                           RenderOptions.BitmapScalingMode="HighQuality" />
                                </Border>
                                <StackPanel Grid.Row="1" Margin="0,12,0,0">
                                    <WrapPanel>
                                        <Border x:Name="SecondaryReferenceBadge"
                                                Style="{StaticResource Badge}"
                                                Margin="0,0,8,8">
                                            <TextBlock Text="{x:Static loc:Strings.DuplicateCleanupExtraCandidate}"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource YellowBrush}" />
                                        </Border>
                                        <TextBlock x:Name="SecondarySizeText"
                                                   Style="{StaticResource Text.Caption}"
                                                   Margin="0,0,8,8" />
                                    </WrapPanel>
                                    <TextBlock x:Name="SecondaryNameText"
                                               Style="{StaticResource Text.Body}"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock x:Name="SecondaryFolderText"
                                               Style="{StaticResource Text.Hint}"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="0,3,0,0" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>

                    <Border Grid.Row="2"
                            Style="{StaticResource Card}"
                            Padding="12"
                            Margin="0,14,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE946;"
                                       FontFamily="{StaticResource IconFontFamily}"
                                       FontSize="12"
                                       Foreground="{DynamicResource AccentBrush}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,9,0" />
                            <TextBlock x:Name="DetailHelpText"
                                       Text="{x:Static loc:Strings.DuplicateCleanupHelpText}"
                                       Style="{StaticResource Text.Caption}"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </Grid>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Style="{StaticResource WindowStatusBar}">
            <StackPanel Orientation="Horizontal">
                <Ellipse x:Name="StatusDot"
                         Width="8"
                         Height="8"
                         Fill="{DynamicResource GreenBrush}"
                         Margin="0,0,9,0"
                         VerticalAlignment="Center" />
                <TextBlock x:Name="StatusText"
                           Text="{x:Static loc:Strings.DuplicateCleanupReadyStatus}"
                           Style="{StaticResource Text.Caption}"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
