<Window x:Class="Images.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About Images"
        Width="540" Height="720"
        MinWidth="500" MinHeight="620"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="CanResizeWithGrip"
        Background="{StaticResource BaseBrush}"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True">

    <Border Padding="28,24,28,22">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      CanContentScroll="False">
            <StackPanel>
            <!-- Logo -->
            <Image Source="Resources/logo.png"
                   Width="80" Height="80"
                   HorizontalAlignment="Center"
                   RenderOptions.BitmapScalingMode="HighQuality" />

            <TextBlock Style="{StaticResource Text.Display}"
                       Text="Images"
                       HorizontalAlignment="Center"
                       Margin="0,16,0,0" />

            <TextBlock x:Name="VersionText"
                       Style="{StaticResource Text.Subtitle}"
                       HorizontalAlignment="Center"
                       Margin="0,4,0,0"
                       FontWeight="SemiBold" />

            <TextBlock Style="{StaticResource Text.Hint}"
                       Text="Windows 7–style classic image viewer, reimagined in dark mode"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       Margin="0,8,0,22"
                       MaxWidth="360"
                       TextWrapping="Wrap" />

            <Border Style="{StaticResource Card}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource MetaLabel}" Text="Build" />
                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="BuildText"   Style="{StaticResource MetaValue}" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource MetaLabel}" Text="Runtime" />
                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="RuntimeText" Style="{StaticResource MetaValue}" />

                    <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource MetaLabel}" Text="OS" />
                    <TextBlock Grid.Row="2" Grid.Column="1" x:Name="OsText"      Style="{StaticResource MetaValue}" />

                    <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource MetaLabel}" Text="Codecs" />
                    <TextBlock Grid.Row="3" Grid.Column="1" x:Name="CodecText" Style="{StaticResource MetaValue}" TextWrapping="Wrap" />

                    <TextBlock Grid.Row="4" Grid.Column="0" Style="{StaticResource MetaLabel}" Text="Documents" />
                    <TextBlock Grid.Row="4" Grid.Column="1" x:Name="DocumentCodecText" Style="{StaticResource MetaValue}" TextWrapping="Wrap" />

                    <TextBlock Grid.Row="5" Grid.Column="0" Style="{StaticResource MetaLabel}" Text="Text extraction" />
                    <TextBlock Grid.Row="5" Grid.Column="1" x:Name="OcrStatusText" Style="{StaticResource MetaValue}" TextWrapping="Wrap" />
                </Grid>
            </Border>

            <TextBlock Style="{StaticResource SectionLabel}"
                       Text="Codec capability"
                       Margin="1,18,0,10" />

            <StackPanel>
                <Border Style="{StaticResource Card}" Margin="0,0,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Width="34"
                                Height="34"
                                CornerRadius="{StaticResource Radius.Md.CR}"
                                Background="#1F89B4FA"
                                BorderBrush="{StaticResource AccentBrush}"
                                BorderThickness="1"
                                Margin="0,0,12,0"
                                VerticalAlignment="Top">
                            <TextBlock Text="&#xE8B9;"
                                       FontFamily="{StaticResource IconFontFamily}"
                                       FontSize="14"
                                       Foreground="{StaticResource AccentBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>

                        <StackPanel Grid.Column="1">
                            <TextBlock x:Name="OpenCapabilityTitleText"
                                       Style="{StaticResource Text.Caption}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextBrush}" />
                            <TextBlock x:Name="OpenCapabilityDetailText"
                                       Style="{StaticResource Text.Hint}"
                                       TextWrapping="Wrap"
                                       Margin="0,3,0,0" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Style="{StaticResource Card}" Margin="0,0,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Width="34"
                                Height="34"
                                CornerRadius="{StaticResource Radius.Md.CR}"
                                Background="#1FA6E3A1"
                                BorderBrush="{StaticResource GreenBrush}"
                                BorderThickness="1"
                                Margin="0,0,12,0"
                                VerticalAlignment="Top">
                            <TextBlock Text="&#xE74E;"
                                       FontFamily="{StaticResource IconFontFamily}"
                                       FontSize="14"
                                       Foreground="{StaticResource GreenBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>

                        <StackPanel Grid.Column="1">
                            <TextBlock x:Name="ExportCapabilityTitleText"
                                       Style="{StaticResource Text.Caption}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextBrush}" />
                            <TextBlock x:Name="ExportCapabilityDetailText"
                                       Style="{StaticResource Text.Hint}"
                                       TextWrapping="Wrap"
                                       Margin="0,3,0,0" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border x:Name="DocumentCapabilityCard"
                        Style="{StaticResource Card}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Width="34"
                                Height="34"
                                CornerRadius="{StaticResource Radius.Md.CR}"
                                Background="#1FF9E2AF"
                                BorderBrush="{StaticResource YellowBrush}"
                                BorderThickness="1"
                                Margin="0,0,12,0"
                                VerticalAlignment="Top">
                            <TextBlock x:Name="DocumentCapabilityIcon"
                                       Text="&#xE783;"
                                       FontFamily="{StaticResource IconFontFamily}"
                                       FontSize="14"
                                       Foreground="{StaticResource YellowBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>

                        <StackPanel Grid.Column="1">
                            <TextBlock x:Name="DocumentCapabilityTitleText"
                                       Style="{StaticResource Text.Caption}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextBrush}" />
                            <TextBlock x:Name="DocumentCapabilityDetailText"
                                       Style="{StaticResource Text.Hint}"
                                       TextWrapping="Wrap"
                                       Margin="0,3,0,0" />
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>

            <!-- Capability matrix (X-02) — per-family rows so "broad codec support" is auditable. -->
            <TextBlock Style="{StaticResource SectionLabel}"
                       Text="Capability matrix"
                       Margin="1,18,0,10" />

            <ItemsControl x:Name="CapabilityMatrixItems"
                          AutomationProperties.Name="Codec capability matrix">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource Card}" Margin="0,0,0,8">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Style="{StaticResource Text.Caption}"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextBrush}"
                                               Text="{Binding Family}" />
                                    <TextBlock Grid.Column="1"
                                               Style="{StaticResource Text.Caption}"
                                               Foreground="{StaticResource SubtextBrush}"
                                               Text="{Binding CountSummary}" />
                                </Grid>
                                <TextBlock Style="{StaticResource Text.Hint}"
                                           Foreground="{StaticResource SubtextBrush}"
                                           Margin="0,4,0,0"
                                           Text="{Binding Facets}" />
                                <TextBlock Style="{StaticResource Text.Hint}"
                                           Foreground="{StaticResource SubtextBrush}"
                                           Margin="0,2,0,0"
                                           Text="{Binding RuntimeLine}" />
                                <TextBlock Style="{StaticResource Text.Hint}"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0"
                                           Text="{Binding Notes}" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Runtime provenance — paths/versions/hashes for support and license review. -->
            <TextBlock Style="{StaticResource SectionLabel}"
                       Text="Runtime provenance"
                       Margin="1,12,0,10" />

            <Border Style="{StaticResource Card}">
                <StackPanel x:Name="ProvenancePanel" />
            </Border>

            <!-- V20-02: update-check opt-out surface. Persisted to settings.db. -->
            <CheckBox x:Name="UpdateCheckCheckBox"
                      Content="Check for updates automatically"
                      HorizontalAlignment="Center"
                      Margin="0,16,0,0"
                      ToolTip="Off by default. When enabled, Images checks GitHub Releases at startup."
                      AutomationProperties.Name="Check for updates automatically"
                      AutomationProperties.HelpText="Off by default. When enabled, Images checks GitHub Releases at startup. No image, file, or folder metadata is sent."
                      Checked="UpdateCheckOptIn_Changed"
                      Unchecked="UpdateCheckOptIn_Changed" />

            <Border x:Name="UpdateStatusCard"
                    Style="{StaticResource Card}"
                    Margin="0,14,0,0"
                    Visibility="Collapsed">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="UpdateStatusIcon"
                               Grid.Column="0"
                               Text="&#xE930;"
                               FontFamily="{StaticResource IconFontFamily}"
                               FontSize="13"
                               Foreground="{StaticResource AccentBrush}"
                               Margin="0,1,10,0"
                               VerticalAlignment="Top" />
                    <TextBlock x:Name="UpdateStatusText"
                               Grid.Column="1"
                               Style="{StaticResource Text.Caption}"
                               Foreground="{StaticResource SubtextBrush}"
                               TextWrapping="Wrap" />
                    <Button x:Name="UpdateReleaseButton"
                            Grid.Column="2"
                            Style="{StaticResource ChromeButton}"
                            Click="UpdateReleaseButton_Click"
                            Padding="12,4"
                            MinHeight="28"
                            Margin="12,0,0,0"
                            VerticalAlignment="Center"
                            Visibility="Collapsed"
                            AutomationProperties.Name="View available update">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="&#xE8A7;"
                                       FontFamily="{StaticResource IconFontFamily}"
                                       FontSize="11"
                                       Margin="0,0,7,0"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="View" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <TextBlock Style="{StaticResource Text.Caption}"
                       Text="MIT licensed · © 2026 SysAdminDoc"
                       HorizontalAlignment="Center"
                       Margin="0,14,0,0" />

            <UniformGrid Columns="2" Margin="0,18,0,0">
                <Button Style="{StaticResource ChromeButton}"
                        Click="CheckUpdatesButton_Click"
                        Margin="0,0,6,8"
                        AutomationProperties.Name="Check for updates">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="&#xE72C;"
                                   FontFamily="{StaticResource IconFontFamily}"
                                   FontSize="12"
                                   Margin="0,0,8,0"
                                   VerticalAlignment="Center" />
                        <TextBlock x:Name="CheckUpdatesButtonText"
                                   Text="Check updates"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource ChromeButton}"
                        Click="GitHubButton_Click"
                        Margin="6,0,0,8"
                        AutomationProperties.Name="Open GitHub project page">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="&#xE71B;"
                                   FontFamily="{StaticResource IconFontFamily}"
                                   FontSize="12"
                                   Margin="0,0,8,0"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="GitHub project" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource ChromeButton}"
                        Click="CrashLogButton_Click"
                        Margin="0,0,6,0"
                        AutomationProperties.Name="Open crash log folder">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="&#xE838;"
                                   FontFamily="{StaticResource IconFontFamily}"
                                   FontSize="12"
                                   Margin="0,0,8,0"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="Crash logs" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource ChromeButton}"
                        Click="CopyCodecReportButton_Click"
                        Margin="6,0,0,0"
                        AutomationProperties.Name="Copy codec report">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="&#xE8C8;"
                                   FontFamily="{StaticResource IconFontFamily}"
                                   FontSize="12"
                                   Margin="0,0,8,0"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="Codec report" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </UniformGrid>

            <UniformGrid Columns="2" Margin="0,8,0,0">
                <Button Style="{StaticResource ChromeButton}"
                        Click="SaveSystemInfoButton_Click"
                        Margin="0,0,6,0"
                        AutomationProperties.Name="Save system info to a text file"
                        ToolTip="Writes Images --system-info output to a text file in your temp folder and reveals it in Explorer.">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="&#xE74E;"
                                   FontFamily="{StaticResource IconFontFamily}"
                                   FontSize="12"
                                   Margin="0,0,8,0"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="Save system info" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource ChromeButton}"
                        Click="OpenAppDataButton_Click"
                        Margin="6,0,0,0"
                        AutomationProperties.Name="Open Images data folder"
                        ToolTip="Opens %LOCALAPPDATA%\Images — logs, settings.db, thumbs, update-check.json all live here.">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="&#xE8DA;"
                                   FontFamily="{StaticResource IconFontFamily}"
                                   FontSize="12"
                                   Margin="0,0,8,0"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="Open data folder" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </UniformGrid>

            <Button Style="{StaticResource PrimaryButton}"
                    Click="CloseButton_Click"
                    Margin="0,14,0,0"
                    HorizontalAlignment="Stretch"
                    IsDefault="True"
                    IsCancel="True"
                    AutomationProperties.Name="Close About window">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="&#xE711;"
                               FontFamily="{StaticResource IconFontFamily}"
                               FontSize="12"
                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                               Margin="0,0,8,0"
                               VerticalAlignment="Center" />
                    <TextBlock Text="Close"
                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Button>
            </StackPanel>
        </ScrollViewer>
    </Border>
</Window>
