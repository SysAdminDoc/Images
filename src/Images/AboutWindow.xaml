<Window x:Class="Images.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About Images"
        Width="500" Height="560"
        MinWidth="500" MinHeight="560"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="CanResizeWithGrip"
        Background="{StaticResource BaseBrush}"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True">

    <Border Padding="28,24,28,22">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      CanContentScroll="False">
            <StackPanel>
            <!-- Logo -->
            <Image Source="Resources/logo.png"
                   Width="80" Height="80"
                   HorizontalAlignment="Center"
                   RenderOptions.BitmapScalingMode="HighQuality" />

            <TextBlock Style="{StaticResource Text.Display}"
                       Text="Images"
                       HorizontalAlignment="Center"
                       Margin="0,16,0,0" />

            <TextBlock x:Name="VersionText"
                       Style="{StaticResource Text.Subtitle}"
                       HorizontalAlignment="Center"
                       Margin="0,4,0,0"
                       FontWeight="SemiBold" />

            <TextBlock Style="{StaticResource Text.Hint}"
                       Text="Windows 7–style classic image viewer, reimagined in dark mode"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       Margin="0,8,0,22"
                       MaxWidth="360"
                       TextWrapping="Wrap" />

            <Border Style="{StaticResource Card}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource MetaLabel}" Text="Build" />
                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="BuildText"   Style="{StaticResource MetaValue}" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource MetaLabel}" Text="Runtime" />
                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="RuntimeText" Style="{StaticResource MetaValue}" />

                    <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource MetaLabel}" Text="OS" />
                    <TextBlock Grid.Row="2" Grid.Column="1" x:Name="OsText"      Style="{StaticResource MetaValue}" />

                    <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource MetaLabel}" Text="Codecs" />
                    <TextBlock Grid.Row="3" Grid.Column="1" x:Name="CodecText" Style="{StaticResource MetaValue}" TextWrapping="Wrap" />

                    <TextBlock Grid.Row="4" Grid.Column="0" Style="{StaticResource MetaLabel}" Text="Documents" />
                    <TextBlock Grid.Row="4" Grid.Column="1" x:Name="DocumentCodecText" Style="{StaticResource MetaValue}" TextWrapping="Wrap" />
                </Grid>
            </Border>

            <!-- V20-02: update-check opt-out surface. Persisted to settings.db. -->
            <CheckBox x:Name="UpdateCheckCheckBox"
                      Content="Automatically check for updates"
                      HorizontalAlignment="Center"
                      Margin="0,16,0,0"
                      Checked="UpdateCheckOptIn_Changed"
                      Unchecked="UpdateCheckOptIn_Changed" />

            <Border x:Name="UpdateStatusCard"
                    Style="{StaticResource Card}"
                    Margin="0,14,0,0"
                    Visibility="Collapsed">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="UpdateStatusIcon"
                               Grid.Column="0"
                               Text="&#xE930;"
                               FontFamily="{StaticResource IconFontFamily}"
                               FontSize="13"
                               Foreground="{StaticResource AccentBrush}"
                               Margin="0,1,10,0"
                               VerticalAlignment="Top" />
                    <TextBlock x:Name="UpdateStatusText"
                               Grid.Column="1"
                               Style="{StaticResource Text.Caption}"
                               Foreground="{StaticResource SubtextBrush}"
                               TextWrapping="Wrap" />
                    <Button x:Name="UpdateReleaseButton"
                            Grid.Column="2"
                            Content="View"
                            Style="{StaticResource ChromeButton}"
                            Click="UpdateReleaseButton_Click"
                            Padding="12,4"
                            MinHeight="28"
                            Margin="12,0,0,0"
                            VerticalAlignment="Center"
                            Visibility="Collapsed" />
                </Grid>
            </Border>

            <TextBlock Style="{StaticResource Text.Caption}"
                       Text="MIT licensed · © 2026 SysAdminDoc"
                       HorizontalAlignment="Center"
                       Margin="0,14,0,0" />

            <UniformGrid Columns="2" Rows="2" Margin="0,18,0,0">
                <Button Style="{StaticResource ChromeButton}"
                        Click="CheckUpdatesButton_Click"
                        Margin="0,0,6,6"
                        AutomationProperties.Name="Check for updates">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="&#xE72C;"
                                   FontFamily="{StaticResource IconFontFamily}"
                                   FontSize="12"
                                   Margin="0,0,8,0"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="Check updates" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource ChromeButton}"
                        Click="GitHubButton_Click"
                        Margin="6,0,0,6"
                        AutomationProperties.Name="Open GitHub project page">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="&#xE71B;"
                                   FontFamily="{StaticResource IconFontFamily}"
                                   FontSize="12"
                                   Margin="0,0,8,0"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="GitHub project" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource ChromeButton}"
                        Click="CrashLogButton_Click"
                        Margin="0,6,6,0"
                        AutomationProperties.Name="Open crash log folder">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="&#xE838;"
                                   FontFamily="{StaticResource IconFontFamily}"
                                   FontSize="12"
                                   Margin="0,0,8,0"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="Crash logs" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource PrimaryButton}"
                        Click="CloseButton_Click"
                        Margin="6,6,0,0"
                        IsDefault="True"
                        IsCancel="True"
                        AutomationProperties.Name="Close About window">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="&#xE711;"
                                   FontFamily="{StaticResource IconFontFamily}"
                                   FontSize="12"
                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                   Margin="0,0,8,0"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="Close"
                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </UniformGrid>
            </StackPanel>
        </ScrollViewer>
    </Border>
</Window>
