<Window x:Class="Images.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About Images"
        Width="460" Height="520"
        MinWidth="460" MinHeight="520"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Background="{StaticResource BaseBrush}"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True">

    <Border Padding="28,24,28,22">
        <StackPanel>
            <!-- Logo -->
            <Image Source="Resources/logo.png"
                   Width="80" Height="80"
                   HorizontalAlignment="Center"
                   RenderOptions.BitmapScalingMode="HighQuality" />

            <TextBlock Style="{StaticResource Text.Display}"
                       Text="Images"
                       HorizontalAlignment="Center"
                       Margin="0,16,0,0" />

            <TextBlock x:Name="VersionText"
                       Style="{StaticResource Text.Subtitle}"
                       HorizontalAlignment="Center"
                       Margin="0,4,0,0"
                       FontWeight="SemiBold" />

            <TextBlock Style="{StaticResource Text.Hint}"
                       Text="Windows 7–style classic image viewer, reimagined in dark mode"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       Margin="0,8,0,22"
                       MaxWidth="360"
                       TextWrapping="Wrap" />

            <Border Style="{StaticResource Card}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource MetaLabel}" Text="Build" />
                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="BuildText"   Style="{StaticResource MetaValue}" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource MetaLabel}" Text="Runtime" />
                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="RuntimeText" Style="{StaticResource MetaValue}" />

                    <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource MetaLabel}" Text="OS" />
                    <TextBlock Grid.Row="2" Grid.Column="1" x:Name="OsText"      Style="{StaticResource MetaValue}" />

                    <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource MetaLabel}" Text="Decoders" />
                    <TextBlock Grid.Row="3" Grid.Column="1" Style="{StaticResource MetaValue}" Text="WIC · Magick.NET 14.13" />
                </Grid>
            </Border>

            <TextBlock Style="{StaticResource Text.Caption}"
                       Text="MIT licensed · © 2026 SysAdminDoc"
                       HorizontalAlignment="Center"
                       Margin="0,18,0,0" />

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,0">
                <Button Content="Check for updates"
                        Style="{StaticResource ChromeButton}"
                        Click="CheckUpdatesButton_Click"
                        MinWidth="140" />
                <Button Content="GitHub"
                        Style="{StaticResource ChromeButton}"
                        Click="GitHubButton_Click"
                        Margin="10,0,0,0"
                        MinWidth="90" />
                <Button Content="Logs"
                        Style="{StaticResource ChromeButton}"
                        Click="CrashLogButton_Click"
                        Margin="10,0,0,0"
                        MinWidth="80" />
                <Button Content="Close"
                        Style="{StaticResource PrimaryButton}"
                        Click="CloseButton_Click"
                        Margin="10,0,0,0"
                        MinWidth="90"
                        IsDefault="True"
                        IsCancel="True" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
