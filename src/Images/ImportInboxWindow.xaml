<Window x:Class="Images.ImportInboxWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:Images.Localization"
        Title="{x:Static loc:Strings.ImportInboxWindowTitle}"
        Width="1160"
        Height="780"
        MinWidth="940"
        MinHeight="640"
        WindowStartupLocation="CenterOwner">
    <Grid Background="{DynamicResource BaseBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource ToolWindowHeader}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="{x:Static loc:Strings.ImportInboxHeading}" Style="{StaticResource Text.Title}" />
                    <TextBlock Text="{x:Static loc:Strings.ImportInboxSubtitle}"
                               Style="{StaticResource Text.Caption}"
                               Margin="0,3,0,0" />
                </StackPanel>
                <WrapPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button x:Name="AddFilesButton"
                            Style="{StaticResource ChromeButton}"
                            Margin="8,0,0,0"
                            Click="AddFilesButton_Click"
                            AutomationProperties.Name="{x:Static loc:Strings.ImportInboxAddFiles}">
                        <TextBlock Text="{x:Static loc:Strings.ImportInboxAddFiles}" />
                    </Button>
                    <Button x:Name="AddFolderButton"
                            Style="{StaticResource ChromeButton}"
                            Margin="8,0,0,0"
                            Click="AddFolderButton_Click"
                            AutomationProperties.Name="{x:Static loc:Strings.ImportInboxAddFolder}">
                        <TextBlock Text="{x:Static loc:Strings.ImportInboxAddFolder}" />
                    </Button>
                    <Button x:Name="ImportPicasaButton"
                            Style="{StaticResource ChromeButton}"
                            Margin="8,0,0,0"
                            Click="ImportPicasaButton_Click"
                            AutomationProperties.Name="{x:Static loc:Strings.ImportInboxImportPicasa}">
                        <TextBlock Text="{x:Static loc:Strings.ImportInboxImportPicasa}" />
                    </Button>
                    <Button x:Name="RefreshButton"
                            Style="{StaticResource ChromeButton}"
                            Margin="8,0,0,0"
                            Click="RefreshButton_Click"
                            AutomationProperties.Name="{x:Static loc:Strings.ImportInboxRefresh}">
                        <TextBlock Text="{x:Static loc:Strings.ImportInboxRefresh}" />
                    </Button>
                </WrapPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="400" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource ToolWindowSidebar}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="{x:Static loc:Strings.ImportInboxDestination}" Style="{StaticResource SectionLabel}" />
                        <Border Style="{StaticResource Card}" Padding="12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock x:Name="DestinationText"
                                               Text="{x:Static loc:Strings.ImportInboxChooseDestination}"
                                               Style="{StaticResource Text.Body}"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{x:Static loc:Strings.ImportInboxDuplicateCheckHint}"
                                               Style="{StaticResource Text.Hint}"
                                               TextWrapping="Wrap"
                                               Margin="0,3,0,0" />
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Style="{StaticResource ChromeButton}"
                                        Margin="12,0,0,0"
                                        Click="ChooseDestinationButton_Click"
                                        AutomationProperties.Name="{x:Static loc:Strings.ImportInboxChoose}">
                                    <TextBlock Text="{x:Static loc:Strings.ImportInboxChoose}" />
                                </Button>
                            </Grid>
                        </Border>

                        <Grid Margin="0,14,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{x:Static loc:Strings.ImportInboxStagedFiles}" Style="{StaticResource SectionLabel}" />
                            <TextBlock x:Name="InboxCountText"
                                       Grid.Column="1"
                                       Text="0"
                                       Style="{StaticResource Text.Caption}"
                                       Margin="12,0,0,0" />
                        </Grid>
                    </StackPanel>

                    <ListBox x:Name="InboxList"
                             Grid.Row="1"
                             SelectionMode="Extended"
                             SelectionChanged="InboxList_SelectionChanged"
                             AutomationProperties.Name="{x:Static loc:Strings.ImportInboxStagedFiles}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="12,10">
                                    <Border.Style>
                                        <Style TargetType="Border" BasedOn="{StaticResource InteractiveCard}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource AccentSelectionBrush}" />
                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <CheckBox IsChecked="{Binding IsIncluded, Mode=TwoWay}"
                                                  AutomationProperties.Name="{Binding FileName}"
                                                  VerticalAlignment="Top"
                                                  Margin="0,2,10,0" />
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding FileName}"
                                                       Style="{StaticResource Text.Body}"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding StatusText}"
                                                       Style="{StaticResource Text.Caption}"
                                                       TextWrapping="Wrap"
                                                       Margin="0,4,0,0" />
                                            <TextBlock Text="{Binding SizeText}"
                                                       Style="{StaticResource Text.Hint}"
                                                       Margin="0,3,0,0" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="1"
                          HorizontalAlignment="Stretch"
                          Background="{DynamicResource HairlineBrush}" />

            <Grid Grid.Column="2"
                  Background="{DynamicResource ViewportBrush}"
                  Margin="18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Style="{StaticResource Card}"
                        Padding="14"
                        Margin="0,0,0,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock x:Name="DetailTitle" Text="{x:Static loc:Strings.ImportInboxNoFileSelected}" Style="{StaticResource Text.Title}" />
                            <TextBlock x:Name="DetailSubtitle"
                                       Text="{x:Static loc:Strings.ImportInboxNoFileSelectedHint}"
                                       Style="{StaticResource Text.Caption}"
                                       TextWrapping="Wrap"
                                       Margin="0,4,0,0" />
                        </StackPanel>
                        <WrapPanel Grid.Column="1"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   Margin="16,0,0,0">
                            <Button x:Name="ApplyToIncludedButton"
                                    Style="{StaticResource ChromeButton}"
                                    Margin="0,0,8,0"
                                    Click="ApplyToIncludedButton_Click"
                                    AutomationProperties.Name="{x:Static loc:Strings.ImportInboxApplyToIncluded}">
                                <TextBlock Text="{x:Static loc:Strings.ImportInboxApplyToIncluded}" />
                            </Button>
                            <Button x:Name="RecycleSelectedButton"
                                    Style="{StaticResource DangerButton}"
                                    Click="RecycleSelectedButton_Click"
                                    AutomationProperties.Name="{x:Static loc:Strings.ImportInboxRecycleSelected}">
                                <TextBlock Text="{x:Static loc:Strings.ImportInboxRecycleSelected}" />
                            </Button>
                        </WrapPanel>
                    </Grid>
                </Border>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="18" />
                        <ColumnDefinition Width="320" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Background="{DynamicResource PanelBrush}"
                            BorderBrush="{DynamicResource HairlineBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource Radius.Md.CR}"
                            Padding="14">
                        <Border Background="{DynamicResource CrustBrush}"
                                CornerRadius="{StaticResource Radius.Sm.CR}"
                                ClipToBounds="True">
                            <Image x:Name="PreviewImage"
                                   Stretch="Uniform"
                                   RenderOptions.BitmapScalingMode="HighQuality" />
                        </Border>
                    </Border>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="{x:Static loc:Strings.ImportInboxMetadata}" Style="{StaticResource SectionLabel}" />
                        <Border Style="{StaticResource Card}" Padding="13,12">
                            <StackPanel x:Name="MetadataEditorPanel">
                                <TextBlock Text="{x:Static loc:Strings.ImportInboxTags}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}" />
                                <TextBox x:Name="TagsBox"
                                         MinHeight="110"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         Text="{Binding TagsText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         AutomationProperties.Name="{x:Static loc:Strings.ImportInboxTags}" />
                                <TextBlock Text="{x:Static loc:Strings.ImportInboxTagsHint}"
                                           Style="{StaticResource Text.Hint}"
                                           TextWrapping="Wrap"
                                           Margin="0,6,0,0" />

                                <TextBlock Text="{x:Static loc:Strings.ImportInboxRating}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}"
                                           Margin="0,14,0,0" />
                                <Slider x:Name="RatingSlider"
                                        Minimum="-1"
                                        Maximum="5"
                                        TickFrequency="1"
                                        IsSnapToTickEnabled="True"
                                        Value="{Binding RatingValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        AutomationProperties.Name="{x:Static loc:Strings.ImportInboxRating}" />
                                <TextBlock Text="{Binding RatingText}"
                                           Style="{StaticResource Text.Caption}" />
                                <CheckBox x:Name="WriteRatingCheckBox"
                                          Content="{x:Static loc:Strings.ImportInboxWriteRatingSidecar}"
                                          IsChecked="{Binding WriteRating, Mode=TwoWay}"
                                          Margin="0,8,0,0"
                                          AutomationProperties.Name="{x:Static loc:Strings.ImportInboxWriteRatingSidecar}" />

                                <CheckBox x:Name="StripGpsCheckBox"
                                          Content="{x:Static loc:Strings.ImportInboxStripGps}"
                                          IsChecked="{Binding StripGps, Mode=TwoWay}"
                                          Margin="0,14,0,0"
                                          AutomationProperties.Name="{x:Static loc:Strings.ImportInboxStripGps}" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Divider}" />

                        <TextBlock Text="{x:Static loc:Strings.ImportInboxAction}" Style="{StaticResource SectionLabel}" />
                        <Border Style="{StaticResource Card}" Padding="13,12">
                            <StackPanel>
                                <CheckBox x:Name="MoveOriginalsCheckBox"
                                          Content="{x:Static loc:Strings.ImportInboxMoveOriginals}"
                                          AutomationProperties.Name="{x:Static loc:Strings.ImportInboxMoveOriginals}" />
                                <TextBlock Text="{x:Static loc:Strings.ImportInboxMoveOriginalsHint}"
                                           Style="{StaticResource Text.Hint}"
                                           TextWrapping="Wrap"
                                           Margin="0,6,0,0" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <Border Grid.Row="2"
                        Style="{StaticResource Card}"
                        Padding="12"
                        Margin="0,14,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="ImportSummaryText"
                                   Text="{x:Static loc:Strings.ImportInboxChooseDestinationThenImport}"
                                   Style="{StaticResource Text.Caption}"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center" />
                        <Button x:Name="ImportButton"
                                Grid.Column="1"
                                Style="{StaticResource PrimaryButton}"
                                Margin="14,0,0,0"
                                Click="ImportButton_Click"
                                AutomationProperties.Name="{x:Static loc:Strings.ImportInboxImportIncluded}">
                            <TextBlock Text="{x:Static loc:Strings.ImportInboxImportIncluded}" />
                        </Button>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Border Grid.Row="2"
                Style="{StaticResource WindowStatusBar}">
            <StackPanel Orientation="Horizontal">
                <Ellipse x:Name="StatusDot"
                         Width="8"
                         Height="8"
                         Fill="{DynamicResource GreenBrush}"
                         Margin="0,0,9,0"
                         VerticalAlignment="Center" />
                <TextBlock x:Name="StatusText"
                           Text="{x:Static loc:Strings.ImportInboxReadyStatus}"
                           Style="{StaticResource Text.Caption}"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
