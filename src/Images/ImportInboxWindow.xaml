<Window x:Class="Images.ImportInboxWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Images - Import inbox"
        Width="1160"
        Height="780"
        MinWidth="940"
        MinHeight="640"
        WindowStartupLocation="CenterOwner">
    <Grid Background="{StaticResource BaseBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource HairlineBrush}"
                BorderThickness="0,0,0,1"
                Padding="18,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Import inbox" Style="{StaticResource Text.Title}" />
                    <TextBlock Text="Stage new images, resolve duplicates, add sidecar tags and ratings, then import locally."
                               Style="{StaticResource Text.Caption}"
                               Margin="0,3,0,0" />
                </StackPanel>
                <WrapPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button x:Name="AddFilesButton"
                            Style="{StaticResource ChromeButton}"
                            Margin="8,0,0,0"
                            Click="AddFilesButton_Click"
                            AutomationProperties.Name="Add files to import inbox">
                        <TextBlock Text="Add files" />
                    </Button>
                    <Button x:Name="AddFolderButton"
                            Style="{StaticResource ChromeButton}"
                            Margin="8,0,0,0"
                            Click="AddFolderButton_Click"
                            AutomationProperties.Name="Add folder to import inbox">
                        <TextBlock Text="Add folder" />
                    </Button>
                    <Button x:Name="RefreshButton"
                            Style="{StaticResource ChromeButton}"
                            Margin="8,0,0,0"
                            Click="RefreshButton_Click"
                            AutomationProperties.Name="Refresh import inbox">
                        <TextBlock Text="Refresh" />
                    </Button>
                </WrapPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="400" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource HairlineBrush}"
                    BorderThickness="0,0,1,0"
                    Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="Destination" Style="{StaticResource SectionLabel}" />
                        <Border Style="{StaticResource Card}" Padding="12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock x:Name="DestinationText"
                                               Text="Choose a destination folder"
                                               Style="{StaticResource Text.Body}"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="Duplicate checks compare staged files against this folder recursively."
                                               Style="{StaticResource Text.Hint}"
                                               TextWrapping="Wrap"
                                               Margin="0,3,0,0" />
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Style="{StaticResource ChromeButton}"
                                        Margin="12,0,0,0"
                                        Click="ChooseDestinationButton_Click"
                                        AutomationProperties.Name="Choose import destination">
                                    <TextBlock Text="Choose" />
                                </Button>
                            </Grid>
                        </Border>

                        <Grid Margin="0,14,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Staged files" Style="{StaticResource SectionLabel}" />
                            <TextBlock x:Name="InboxCountText"
                                       Grid.Column="1"
                                       Text="0"
                                       Style="{StaticResource Text.Caption}"
                                       Margin="12,0,0,0" />
                        </Grid>
                    </StackPanel>

                    <ListBox x:Name="InboxList"
                             Grid.Row="1"
                             SelectionMode="Extended"
                             SelectionChanged="InboxList_SelectionChanged"
                             AutomationProperties.Name="Import inbox files">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="12,10">
                                    <Border.Style>
                                        <Style TargetType="Border" BasedOn="{StaticResource InteractiveCard}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                    <Setter Property="Background" Value="#2489B4FA" />
                                                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <CheckBox IsChecked="{Binding IsIncluded, Mode=TwoWay}"
                                                  VerticalAlignment="Top"
                                                  Margin="0,2,10,0"
                                                  AutomationProperties.Name="Include staged file" />
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding FileName}"
                                                       Style="{StaticResource Text.Body}"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding StatusText}"
                                                       Style="{StaticResource Text.Caption}"
                                                       TextWrapping="Wrap"
                                                       Margin="0,4,0,0" />
                                            <TextBlock Text="{Binding SizeText}"
                                                       Style="{StaticResource Text.Hint}"
                                                       Margin="0,3,0,0" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="1"
                          HorizontalAlignment="Stretch"
                          Background="{StaticResource HairlineBrush}" />

            <Grid Grid.Column="2"
                  Background="{StaticResource ViewportBrush}"
                  Margin="18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Style="{StaticResource Card}"
                        Padding="14"
                        Margin="0,0,0,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock x:Name="DetailTitle" Text="No staged file selected" Style="{StaticResource Text.Title}" />
                            <TextBlock x:Name="DetailSubtitle"
                                       Text="Add files or folders, then select an item to tag, rate, strip GPS, or skip."
                                       Style="{StaticResource Text.Caption}"
                                       TextWrapping="Wrap"
                                       Margin="0,4,0,0" />
                        </StackPanel>
                        <WrapPanel Grid.Column="1"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   Margin="16,0,0,0">
                            <Button x:Name="ApplyToIncludedButton"
                                    Style="{StaticResource ChromeButton}"
                                    Margin="0,0,8,0"
                                    Click="ApplyToIncludedButton_Click"
                                    AutomationProperties.Name="Apply selected import metadata to included files">
                                <TextBlock Text="Apply to included" />
                            </Button>
                            <Button x:Name="RecycleSelectedButton"
                                    Style="{StaticResource DangerButton}"
                                    Click="RecycleSelectedButton_Click"
                                    AutomationProperties.Name="Recycle selected staged files">
                                <TextBlock Text="Recycle selected" />
                            </Button>
                        </WrapPanel>
                    </Grid>
                </Border>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="18" />
                        <ColumnDefinition Width="320" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Background="{StaticResource PanelBrush}"
                            BorderBrush="{StaticResource HairlineBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource Radius.Md.CR}"
                            Padding="14">
                        <Border Background="{StaticResource CrustBrush}"
                                CornerRadius="{StaticResource Radius.Sm.CR}"
                                ClipToBounds="True">
                            <Image x:Name="PreviewImage"
                                   Stretch="Uniform"
                                   RenderOptions.BitmapScalingMode="HighQuality" />
                        </Border>
                    </Border>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Import metadata" Style="{StaticResource SectionLabel}" />
                        <Border Style="{StaticResource Card}" Padding="13,12">
                            <StackPanel x:Name="MetadataEditorPanel">
                                <TextBlock Text="Tags"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextBrush}" />
                                <TextBox x:Name="TagsBox"
                                         MinHeight="110"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         Text="{Binding TagsText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         AutomationProperties.Name="Import inbox tags" />
                                <TextBlock Text="Tags are written to XMP sidecars. Aliases and parents from Tag relationships are applied on import."
                                           Style="{StaticResource Text.Hint}"
                                           TextWrapping="Wrap"
                                           Margin="0,6,0,0" />

                                <TextBlock Text="Rating"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextBrush}"
                                           Margin="0,14,0,0" />
                                <Slider x:Name="RatingSlider"
                                        Minimum="-1"
                                        Maximum="5"
                                        TickFrequency="1"
                                        IsSnapToTickEnabled="True"
                                        Value="{Binding RatingValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        AutomationProperties.Name="Import rating" />
                                <TextBlock Text="{Binding RatingText}"
                                           Style="{StaticResource Text.Caption}" />
                                <CheckBox x:Name="WriteRatingCheckBox"
                                          Content="Write rating sidecar"
                                          IsChecked="{Binding WriteRating, Mode=TwoWay}"
                                          Margin="0,8,0,0"
                                          AutomationProperties.Name="Write import rating sidecar" />

                                <CheckBox x:Name="StripGpsCheckBox"
                                          Content="Strip GPS metadata on imported copy"
                                          IsChecked="{Binding StripGps, Mode=TwoWay}"
                                          Margin="0,14,0,0"
                                          AutomationProperties.Name="Strip GPS metadata on import" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Divider}" />

                        <TextBlock Text="Import action" Style="{StaticResource SectionLabel}" />
                        <Border Style="{StaticResource Card}" Padding="13,12">
                            <StackPanel>
                                <CheckBox x:Name="MoveOriginalsCheckBox"
                                          Content="Move originals instead of copying"
                                          AutomationProperties.Name="Move originals during import" />
                                <TextBlock Text="Copy keeps the source files untouched. Move is faster when this inbox is already your temporary intake folder."
                                           Style="{StaticResource Text.Hint}"
                                           TextWrapping="Wrap"
                                           Margin="0,6,0,0" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <Border Grid.Row="2"
                        Style="{StaticResource Card}"
                        Padding="12"
                        Margin="0,14,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="ImportSummaryText"
                                   Text="Choose a destination, then import included files."
                                   Style="{StaticResource Text.Caption}"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center" />
                        <Button x:Name="ImportButton"
                                Grid.Column="1"
                                Style="{StaticResource PrimaryButton}"
                                Margin="14,0,0,0"
                                Click="ImportButton_Click"
                                AutomationProperties.Name="Import included files">
                            <TextBlock Text="Import included" />
                        </Button>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Border Grid.Row="2"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource HairlineBrush}"
                BorderThickness="0,1,0,0"
                Padding="16,10">
            <StackPanel Orientation="Horizontal">
                <Ellipse x:Name="StatusDot"
                         Width="8"
                         Height="8"
                         Fill="{StaticResource GreenBrush}"
                         Margin="0,0,9,0"
                         VerticalAlignment="Center" />
                <TextBlock x:Name="StatusText"
                           Text="Ready. Add files or a folder to stage imports."
                           Style="{StaticResource Text.Caption}"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
