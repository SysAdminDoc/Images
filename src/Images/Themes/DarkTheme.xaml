<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    xmlns:vm="clr-namespace:Images.ViewModels">

    <!-- ============================================================
         Images — Catppuccin Mocha design system (dark)
         Token order: palette → semantic brushes → radii → elevation →
         motion → text → controls.
         ============================================================ -->

    <!-- Converters (global) -->
    <vm:BooleanToVisibilityConverter x:Key="BoolToVis" />
    <vm:PathToFileNameConverter x:Key="PathToFileNameConverter" />
    <vm:PathToParentConverter x:Key="PathToParentConverter" />
    <vm:DropAcceptedIconConverter x:Key="DropAcceptedIcon" />
    <vm:DirectorySortModeMatchesConverter x:Key="SortModeMatches" />

    <!-- ============ Palette — Catppuccin Mocha ============ -->
    <Color x:Key="BaseColor">#FF1E1E2E</Color>
    <Color x:Key="MantleColor">#FF181825</Color>
    <Color x:Key="CrustColor">#FF11111B</Color>
    <Color x:Key="Surface0Color">#FF313244</Color>
    <Color x:Key="Surface1Color">#FF45475A</Color>
    <Color x:Key="Surface2Color">#FF585B70</Color>
    <Color x:Key="OverlayColor">#FF6C7086</Color>
    <Color x:Key="TextColor">#FFCDD6F4</Color>
    <Color x:Key="SubtextColor">#FFA6ADC8</Color>
    <Color x:Key="BlueColor">#FF89B4FA</Color>
    <Color x:Key="LavenderColor">#FFB4BEFE</Color>
    <Color x:Key="MauveColor">#FFCBA6F7</Color>
    <Color x:Key="RedColor">#FFF38BA8</Color>
    <Color x:Key="RedHoverColor">#FFFFA4BA</Color>
    <Color x:Key="GreenColor">#FFA6E3A1</Color>
    <Color x:Key="YellowColor">#FFF9E2AF</Color>

    <SolidColorBrush x:Key="BaseBrush" Color="{StaticResource BaseColor}" />
    <SolidColorBrush x:Key="MantleBrush" Color="{StaticResource MantleColor}" />
    <SolidColorBrush x:Key="CrustBrush" Color="{StaticResource CrustColor}" />
    <SolidColorBrush x:Key="Surface0Brush" Color="{StaticResource Surface0Color}" />
    <SolidColorBrush x:Key="Surface1Brush" Color="{StaticResource Surface1Color}" />
    <SolidColorBrush x:Key="Surface2Brush" Color="{StaticResource Surface2Color}" />
    <SolidColorBrush x:Key="OverlayBrush" Color="{StaticResource OverlayColor}" />
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}" />
    <SolidColorBrush x:Key="SubtextBrush" Color="{StaticResource SubtextColor}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource BlueColor}" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource LavenderColor}" />
    <SolidColorBrush x:Key="MauveBrush" Color="{StaticResource MauveColor}" />
    <SolidColorBrush x:Key="RedBrush" Color="{StaticResource RedColor}" />
    <SolidColorBrush x:Key="RedHoverBrush" Color="{StaticResource RedHoverColor}" />
    <SolidColorBrush x:Key="GreenBrush" Color="{StaticResource GreenColor}" />
    <SolidColorBrush x:Key="YellowBrush" Color="{StaticResource YellowColor}" />

    <!-- ============ Semantic surfaces + chrome ============ -->
    <!-- Viewport is deep near-black for image contrast; panels use Mantle; overlays use translucent Crust -->
    <SolidColorBrush x:Key="ViewportBrush" Color="#FF0A0A10" />
    <SolidColorBrush x:Key="PanelBrush" Color="#F2181825" />
    <SolidColorBrush x:Key="SurfacePanelBrush" Color="#8A313244" />
    <SolidColorBrush x:Key="HairlineBrush" Color="#4045475A" />
    <SolidColorBrush x:Key="DividerBrush" Color="#33CDD6F4" />
    <SolidColorBrush x:Key="FloatingChromeBrush" Color="#BF11111B" />
    <SolidColorBrush x:Key="FloatingChromeBorderBrush" Color="#3FCDD6F4" />
    <SolidColorBrush x:Key="FloatingChromeTextBrush" Color="#FFE8ECF7" />
    <SolidColorBrush x:Key="ToastBrush" Color="#EB11111B" />
    <SolidColorBrush x:Key="WarningPanelBrush" Color="#1FF9E2AF" />
    <SolidColorBrush x:Key="DangerPanelBrush" Color="#1FF38BA8" />
    <SolidColorBrush x:Key="FocusRingBrush" Color="#CC89B4FA" />
    <SolidColorBrush x:Key="DropOverlayBrush" Color="#D911111B" />
    <SolidColorBrush x:Key="DropOverlayPanelBrush" Color="#F211111B" />
    <SolidColorBrush x:Key="OcrRegionBrush" Color="#4D89B4FA" />
    <SolidColorBrush x:Key="OcrRegionFocusBrush" Color="#9989B4FA" />
    <SolidColorBrush x:Key="AccentPanelBrush" Color="#1F89B4FA" />
    <SolidColorBrush x:Key="AccentSelectionBrush" Color="#2689B4FA" />
    <SolidColorBrush x:Key="StatusPanelBrush" Color="#66313244" />
    <SolidColorBrush x:Key="SuccessPanelBrush" Color="#1FA6E3A1" />
    <SolidColorBrush x:Key="MauvePanelBrush" Color="#20CBA6F7" />
    <SolidColorBrush x:Key="OverlayGuideBrush" Color="#8CF5F5F8" />
    <SolidColorBrush x:Key="OverlayGuideStrongBrush" Color="#B8F5F5F8" />
    <SolidColorBrush x:Key="OverlayDimmerBrush" Color="#CC000000" />
    <SolidColorBrush x:Key="SubtleSurfaceBrush" Color="#10313244" />

    <!-- ============ Radius scale ============ -->
    <!-- Restrained geometry keeps dense tool surfaces professional and compact. -->
    <sys:Double x:Key="Radius.Sm">6</sys:Double>
    <sys:Double x:Key="Radius.Md">8</sys:Double>
    <sys:Double x:Key="Radius.Lg">8</sys:Double>
    <sys:Double x:Key="Radius.Xl">8</sys:Double>
    <CornerRadius x:Key="Radius.Sm.CR">6</CornerRadius>
    <CornerRadius x:Key="Radius.Md.CR">8</CornerRadius>
    <CornerRadius x:Key="Radius.Lg.CR">8</CornerRadius>
    <CornerRadius x:Key="Radius.Xl.CR">8</CornerRadius>

    <!-- ============ Elevation scale ============ -->
    <!-- Chrome/buttons stay flat. Floating chrome gets enough depth to separate without haze. -->
    <DropShadowEffect x:Key="Elevation.Low"
                      BlurRadius="10" ShadowDepth="2"
                      Direction="270" Opacity="0.30" Color="#FF000000" />
    <DropShadowEffect x:Key="Elevation.Medium"
                      BlurRadius="16" ShadowDepth="4"
                      Direction="270" Opacity="0.36" Color="#FF000000" />
    <DropShadowEffect x:Key="Elevation.High"
                      BlurRadius="24" ShadowDepth="7"
                      Direction="270" Opacity="0.40" Color="#FF000000" />
    <DropShadowEffect x:Key="Elevation.Focus"
                      BlurRadius="18" ShadowDepth="0"
                      Opacity="0.55" Color="#FF89B4FA" />

    <!-- ============ Motion tokens ============ -->
    <!-- Consistent 140ms / CubicEase EaseOut across all interaction state changes -->
    <Duration x:Key="Motion.Fast">0:0:0.12</Duration>
    <Duration x:Key="Motion.Base">0:0:0.18</Duration>
    <Duration x:Key="Motion.Slow">0:0:0.28</Duration>
    <CubicEase x:Key="Motion.EaseOut" EasingMode="EaseOut" />
    <CubicEase x:Key="Motion.EaseInOut" EasingMode="EaseInOut" />

    <!-- Shared FocusVisualStyle — visible on custom templates without looking like legacy WPF chrome. -->
    <Style x:Key="FocusVisual">
        <Setter Property="Control.Template">
            <Setter.Value>
                <ControlTemplate>
                    <Rectangle Margin="1"
                               Stroke="{DynamicResource FocusRingBrush}"
                               StrokeThickness="2"
                               RadiusX="5"
                               RadiusY="5"
                               SnapsToDevicePixels="True" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============ Icon font ============ -->
    <!-- The app uses MDL2 PUA glyphs throughout. Keep icon-only controls pinned to the stable
         Windows MDL2 font instead of relying on composite fallback, which can render blank
         glyph boxes inside templated button content on some WPF/font stacks. -->
    <FontFamily x:Key="IconFontFamily">Segoe MDL2 Assets</FontFamily>

    <!-- ============ Text defaults ============ -->
    <!-- Segoe UI Variable is the Windows 11 system variable font; fallback gracefully on Win10. -->
    <Style TargetType="Window">
        <Setter Property="Background" Value="{DynamicResource BaseBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
    </Style>

    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <!-- Typography scale — explicit text styles so screens compose from tokens, not ad-hoc values -->
    <Style x:Key="Text.Display" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe UI Variable Display, Segoe UI" />
        <Setter Property="FontSize" Value="22" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
    </Style>
    <Style x:Key="Text.Title" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe UI Variable Display, Segoe UI" />
        <Setter Property="FontSize" Value="19" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
    </Style>
    <Style x:Key="Text.Subtitle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="LineHeight" Value="19" />
        <Setter Property="Foreground" Value="{DynamicResource SubtextBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>
    <Style x:Key="Text.Body" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="LineHeight" Value="19" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
    </Style>
    <Style x:Key="Text.Caption" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="LineHeight" Value="17" />
        <Setter Property="Foreground" Value="{DynamicResource SubtextBrush}" />
    </Style>
    <Style x:Key="Text.Hint" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="LineHeight" Value="16" />
        <Setter Property="Foreground" Value="{DynamicResource OverlayBrush}" />
    </Style>

    <!-- Section label — uppercase, medium weight, subtle tracking via extra spacing in markup -->
    <Style x:Key="SectionLabel" TargetType="TextBlock">
        <Setter Property="FontSize" Value="10.5" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource OverlayBrush}" />
        <Setter Property="Margin" Value="1,0,0,10" />
        <Setter Property="Typography.Capitals" Value="AllSmallCaps" />
    </Style>

    <!-- Metadata row labels -->
    <Style x:Key="MetaLabel" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource OverlayBrush}" />
        <Setter Property="Margin" Value="0,0,16,10" />
        <Setter Property="FontSize" Value="12" />
    </Style>
    <Style x:Key="MetaValue" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        <Setter Property="Margin" Value="0,0,0,10" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>

    <!-- ============ Status dot ============ -->
    <Style x:Key="StatusDot" TargetType="Ellipse">
        <Setter Property="Width" Value="9" />
        <Setter Property="Height" Value="9" />
        <Setter Property="Margin" Value="0,0,10,0" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!-- ============ Chromeless rounded button ============ -->
    <Style x:Key="ChromeButton" TargetType="Button">
        <Setter Property="Background" Value="{DynamicResource Surface0Brush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Surface1Brush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="12,7" />
        <Setter Property="MinHeight" Value="34" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource FocusVisual}" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            CornerRadius="{StaticResource Radius.Sm.CR}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          RecognizesAccessKey="True" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Surface1Brush}" />
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Surface2Brush}" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource FocusRingBrush}" />
                            <Setter TargetName="Bd" Property="BorderThickness" Value="2" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.42" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============ Primary action button ============ -->
    <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource ChromeButton}">
        <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource CrustBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Padding" Value="20,9" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            CornerRadius="{StaticResource Radius.Md.CR}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          RecognizesAccessKey="True" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentHoverBrush}" />
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentHoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Surface2Brush}" />
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource Surface2Brush}" />
                            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource TextBrush}" />
                            <Setter TargetName="Bd" Property="BorderThickness" Value="2" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}" />

    <!-- ============ Destructive action button ============ -->
    <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource ChromeButton}">
        <Setter Property="Background" Value="{DynamicResource RedBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource CrustBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource RedBrush}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Padding" Value="18,9" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            CornerRadius="{StaticResource Radius.Md.CR}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          RecognizesAccessKey="True" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource RedHoverBrush}" />
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource RedHoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Surface2Brush}" />
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource RedBrush}" />
                            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource TextBrush}" />
                            <Setter TargetName="Bd" Property="BorderThickness" Value="2" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============ Circular nav arrow (Win7-inspired edge chrome) ============ -->
    <!-- Starts subtle, grows on hover with a soft elevation + tint + scale cue -->
    <Style x:Key="NavArrowButton" TargetType="Button">
        <Setter Property="Width" Value="58" />
        <Setter Property="Height" Value="58" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Background" Value="{DynamicResource FloatingChromeBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource FloatingChromeBorderBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource FloatingChromeTextBrush}" />
        <Setter Property="FontSize" Value="24" />
        <Setter Property="FontFamily" Value="{StaticResource IconFontFamily}" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource FocusVisual}" />
        <Setter Property="Effect" Value="{StaticResource Elevation.Medium}" />
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <Grid.RenderTransform>
                            <ScaleTransform x:Name="Scale" ScaleX="1" ScaleY="1" />
                        </Grid.RenderTransform>
                        <Grid.RenderTransformOrigin>0.5,0.5</Grid.RenderTransformOrigin>
                        <Ellipse x:Name="Bg"
                                 Fill="{TemplateBinding Background}"
                                 Stroke="{TemplateBinding BorderBrush}"
                                 StrokeThickness="1.25" />
                        <TextBlock Text="{TemplateBinding Content}"
                                   FontFamily="{StaticResource IconFontFamily}"
                                   FontSize="{TemplateBinding FontSize}"
                                   Foreground="{TemplateBinding Foreground}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Fill" Value="{DynamicResource DropOverlayBrush}" />
                            <Setter TargetName="Bg" Property="Stroke" Value="{DynamicResource AccentBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bg" Property="Fill" Value="{DynamicResource DropOverlayPanelBrush}" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Bg" Property="Stroke" Value="{DynamicResource FocusRingBrush}" />
                            <Setter TargetName="Bg" Property="StrokeThickness" Value="2" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.3" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============ Toolbar icon button ============ -->
    <Style x:Key="ToolbarButton" TargetType="Button" BasedOn="{StaticResource ChromeButton}">
        <Setter Property="Width" Value="40" />
        <Setter Property="Height" Value="34" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="FontFamily" Value="{StaticResource IconFontFamily}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            CornerRadius="{StaticResource Radius.Sm.CR}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="1"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <TextBlock Text="{TemplateBinding Content}"
                                   FontFamily="{StaticResource IconFontFamily}"
                                   FontSize="{TemplateBinding FontSize}"
                                   Foreground="{TemplateBinding Foreground}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Surface0Brush}" />
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource Surface1Brush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Surface1Brush}" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource FocusRingBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============ Context menu (viewport right-click) ============ -->
    <!-- Default WPF ContextMenu renders with system-light colors that clash on Mocha. Custom
         template pulls MantleBrush surface, HairlineBrush separator, AccentBrush hover, and
         matches the floating chrome radius/elevation treatment used elsewhere. -->
    <Style x:Key="ViewportContextMenu" TargetType="ContextMenu">
        <Setter Property="Background" Value="{DynamicResource MantleBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource HairlineBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="6" />
        <Setter Property="MaxHeight" Value="520" />
        <Setter Property="HasDropShadow" Value="True" />
        <Setter Property="Effect" Value="{StaticResource Elevation.Medium}" />
        <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="KeyboardNavigation.DirectionalNavigation" Value="Cycle" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContextMenu">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource Radius.Md.CR}"
                            Padding="{TemplateBinding Padding}">
                        <ScrollViewer MaxHeight="{TemplateBinding MaxHeight}"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      CanContentScroll="False">
                            <StackPanel IsItemsHost="True"
                                        KeyboardNavigation.DirectionalNavigation="Cycle" />
                        </ScrollViewer>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="MenuItem">
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        <Setter Property="Padding" Value="10,7,12,7" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="MenuItem">
                    <Grid>
                        <Border x:Name="Bd"
                                Background="Transparent"
                                CornerRadius="{StaticResource Radius.Sm.CR}"
                                Padding="{TemplateBinding Padding}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0"
                                      Width="18"
                                      Margin="0,0,10,0"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center">
                                    <ContentPresenter x:Name="IconPresenter"
                                                      ContentSource="Icon"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center" />
                                    <TextBlock x:Name="CheckGlyph"
                                               Text="&#xE73E;"
                                               FontFamily="{StaticResource IconFontFamily}"
                                               FontSize="11"
                                               Foreground="{DynamicResource AccentBrush}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Opacity="0" />
                                </Grid>
                                <ContentPresenter Grid.Column="1"
                                                  ContentSource="Header"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True" />
                                <TextBlock x:Name="GestureText"
                                           Grid.Column="2"
                                           Text="{TemplateBinding InputGestureText}"
                                           Foreground="{DynamicResource OverlayBrush}"
                                           Margin="24,0,0,0"
                                           VerticalAlignment="Center" />
                                <TextBlock x:Name="SubmenuGlyph"
                                           Grid.Column="3"
                                           Text="&#xE76C;"
                                           FontFamily="{StaticResource IconFontFamily}"
                                           FontSize="10"
                                           Foreground="{DynamicResource OverlayBrush}"
                                           Margin="18,0,0,0"
                                           VerticalAlignment="Center"
                                           Visibility="Collapsed" />
                            </Grid>
                        </Border>
                        <Popup x:Name="PART_Popup"
                               AllowsTransparency="True"
                               Focusable="False"
                               IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                               PlacementTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                               Placement="Right"
                               PopupAnimation="Fade">
                            <Border Background="{DynamicResource MantleBrush}"
                                    BorderBrush="{DynamicResource HairlineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource Radius.Md.CR}"
                                    Padding="6"
                                    Effect="{StaticResource Elevation.Medium}"
                                    SnapsToDevicePixels="True">
                                <ScrollViewer MaxHeight="520"
                                              VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled"
                                              CanContentScroll="False">
                                    <StackPanel IsItemsHost="True"
                                                KeyboardNavigation.DirectionalNavigation="Cycle" />
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#1A89B4FA" />
                            <Setter TargetName="CheckGlyph" Property="Opacity" Value="1" />
                            <Setter TargetName="IconPresenter" Property="Opacity" Value="0" />
                        </Trigger>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Surface0Brush}" />
                        </Trigger>
                        <Trigger Property="HasItems" Value="True">
                            <Setter TargetName="SubmenuGlyph" Property="Visibility" Value="Visible" />
                            <Setter TargetName="GestureText" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="IsSubmenuOpen" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Surface0Brush}" />
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="MenuItemIcon" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource IconFontFamily}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{DynamicResource OverlayBrush}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="TextAlignment" Value="Center" />
    </Style>

    <Style TargetType="Separator">
        <Setter Property="Height" Value="1" />
        <Setter Property="Margin" Value="6,5" />
        <Setter Property="Background" Value="{DynamicResource HairlineBrush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Separator">
                    <Border Background="{TemplateBinding Background}" Height="1" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============ ToolTip ============ -->
    <Style TargetType="ToolTip">
        <Setter Property="Background" Value="{DynamicResource FloatingChromeBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource FloatingChromeTextBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource FloatingChromeBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="10,7" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI" />
        <Setter Property="HasDropShadow" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToolTip">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource Radius.Sm.CR}"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============ ComboBox ============ -->
    <Style TargetType="ComboBox">
        <Setter Property="Background" Value="{DynamicResource PanelBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Surface1Brush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="11,7" />
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource FocusVisual}" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid SnapsToDevicePixels="True">
                        <ToggleButton x:Name="ToggleButton"
                                      Focusable="False"
                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                      ClickMode="Press"
                                      Background="{TemplateBinding Background}"
                                      BorderBrush="{TemplateBinding BorderBrush}"
                                      BorderThickness="{TemplateBinding BorderThickness}">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border x:Name="Bd"
                                            CornerRadius="{StaticResource Radius.Sm.CR}"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}">
                                        <TextBlock Text="&#xE70D;"
                                                   FontFamily="{StaticResource IconFontFamily}"
                                                   FontSize="10"
                                                   Foreground="{DynamicResource SubtextBrush}"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,12,0" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                        </Trigger>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Surface0Brush}" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>

                        <ContentPresenter x:Name="ContentSite"
                                          IsHitTestVisible="False"
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                          ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                          Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          RecognizesAccessKey="True" />

                        <Popup x:Name="PART_Popup"
                               Placement="Bottom"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               AllowsTransparency="True"
                               Focusable="False"
                               PopupAnimation="Fade">
                            <Border MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                    MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                    Background="{DynamicResource PanelBrush}"
                                    BorderBrush="{DynamicResource FloatingChromeBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource Radius.Sm.CR}"
                                    Padding="4"
                                    Effect="{StaticResource Elevation.Medium}">
                                <ScrollViewer CanContentScroll="True">
                                    <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="ToggleButton" Property="BorderBrush" Value="{DynamicResource FocusRingBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ComboBoxItem">
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        <Setter Property="Padding" Value="10,7" />
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource FocusVisual}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="Bd"
                            CornerRadius="{StaticResource Radius.Sm.CR}"
                            Background="Transparent"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentPanelBrush}" />
                            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentSelectionBrush}" />
                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============ TabControl ============ -->
    <Style TargetType="TabControl">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabControl">
                    <Grid KeyboardNavigation.TabNavigation="Local">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TabPanel x:Name="HeaderPanel"
                                  Grid.Row="0"
                                  IsItemsHost="True"
                                  Margin="0,0,0,14"
                                  KeyboardNavigation.TabIndex="1" />
                        <Border Grid.Row="1"
                                Background="Transparent"
                                BorderThickness="0"
                                KeyboardNavigation.TabNavigation="Local">
                            <ContentPresenter x:Name="PART_SelectedContentHost"
                                              ContentSource="SelectedContent"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="TabItem">
        <Setter Property="Foreground" Value="{DynamicResource SubtextBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{DynamicResource HairlineBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="13,7" />
        <Setter Property="MinHeight" Value="34" />
        <Setter Property="Margin" Value="0,0,8,8" />
        <Setter Property="FontSize" Value="12.5" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource FocusVisual}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabItem">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource Radius.Sm.CR}"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter ContentSource="Header"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          RecognizesAccessKey="True" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentPanelBrush}" />
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource FocusRingBrush}" />
                            <Setter TargetName="Bd" Property="BorderThickness" Value="2" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============ CheckBox ============ -->
    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="{DynamicResource SubtextBrush}" />
        <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="MinHeight" Value="30" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource FocusVisual}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <Grid SnapsToDevicePixels="True">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border x:Name="Box"
                                Width="18"
                                Height="18"
                                CornerRadius="5"
                                Background="{DynamicResource PanelBrush}"
                                BorderBrush="{DynamicResource Surface1Brush}"
                                BorderThickness="1"
                                VerticalAlignment="Center">
                            <TextBlock x:Name="Check"
                                       Text="&#xE73E;"
                                       FontFamily="{StaticResource IconFontFamily}"
                                       FontSize="10"
                                       Foreground="{DynamicResource CrustBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Opacity="0" />
                        </Border>
                        <ContentPresenter Grid.Column="1"
                                          Margin="9,0,0,0"
                                          VerticalAlignment="Center"
                                          RecognizesAccessKey="True" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource FocusRingBrush}" />
                            <Setter TargetName="Box" Property="BorderThickness" Value="2" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Box" Property="Background" Value="{DynamicResource AccentBrush}" />
                            <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                            <Setter TargetName="Check" Property="Opacity" Value="1" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============ TextBox ============ -->
    <Style TargetType="TextBox">
        <Setter Property="Background" Value="{DynamicResource PanelBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        <Setter Property="CaretBrush" Value="{DynamicResource AccentBrush}" />
        <Setter Property="SelectionBrush" Value="{DynamicResource AccentBrush}" />
        <Setter Property="SelectionOpacity" Value="0.35" />
        <Setter Property="BorderBrush" Value="{DynamicResource Surface1Brush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="10,7" />
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource FocusVisual}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="Bd"
                            CornerRadius="{StaticResource Radius.Sm.CR}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Padding="{TemplateBinding Padding}"
                                      VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource Surface2Brush}" />
                        </Trigger>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                            <Setter TargetName="Bd" Property="BorderThickness" Value="2" />
                        </Trigger>
                        <Trigger Property="IsReadOnly" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SubtleSurfaceBrush}" />
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource HairlineBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============ DataGrid ============ -->
    <Style TargetType="DataGrid">
        <Setter Property="Background" Value="{DynamicResource SurfacePanelBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource HairlineBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="RowHeaderWidth" Value="0" />
        <Setter Property="GridLinesVisibility" Value="Horizontal" />
        <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource HairlineBrush}" />
        <Setter Property="VerticalGridLinesBrush" Value="Transparent" />
        <Setter Property="HeadersVisibility" Value="Column" />
        <Setter Property="AlternationCount" Value="2" />
        <Setter Property="AlternatingRowBackground" Value="{DynamicResource SurfacePanelBrush}" />
        <Setter Property="RowBackground" Value="Transparent" />
        <Setter Property="SelectionMode" Value="Single" />
        <Setter Property="SelectionUnit" Value="FullRow" />
        <Setter Property="CanUserAddRows" Value="False" />
        <Setter Property="CanUserDeleteRows" Value="False" />
        <Setter Property="CanUserResizeRows" Value="False" />
        <Setter Property="EnableRowVirtualization" Value="True" />
        <Setter Property="EnableColumnVirtualization" Value="True" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource FocusVisual}" />
    </Style>

    <Style TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="{DynamicResource PanelBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource SubtextBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource HairlineBrush}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="Padding" Value="10,8" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="DataGridColumnHeader">
                    <Border x:Name="HeaderBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          RecognizesAccessKey="True"
                                          SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="HeaderBorder" Property="Background" Value="{DynamicResource Surface0Brush}" />
                            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="DataGridRow">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        <Setter Property="MinHeight" Value="46" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource FocusVisual}" />
        <Style.Triggers>
            <Trigger Property="AlternationIndex" Value="1">
                <Setter Property="Background" Value="{DynamicResource SurfacePanelBrush}" />
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource Surface0Brush}" />
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{DynamicResource AccentSelectionBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource FloatingChromeTextBrush}" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.55" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="DataGridCell">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource FocusVisual}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="DataGridCell">
                    <Border x:Name="CellBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="CellBorder" Property="BorderBrush" Value="{DynamicResource FocusRingBrush}" />
                            <Setter TargetName="CellBorder" Property="BorderThickness" Value="1" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="CellBorder" Property="Background" Value="Transparent" />
                            <Setter Property="Foreground" Value="{DynamicResource FloatingChromeTextBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============ Slider ============ -->
    <Style TargetType="Slider">
        <Setter Property="Height" Value="24" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource FocusVisual}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Slider">
                    <Grid Background="Transparent"
                          VerticalAlignment="Center"
                          SnapsToDevicePixels="True">
                        <Track x:Name="PART_Track"
                               VerticalAlignment="Center"
                               Height="18">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Command="{x:Static Slider.DecreaseLarge}"
                                              IsTabStop="False">
                                    <RepeatButton.Template>
                                        <ControlTemplate TargetType="RepeatButton">
                                            <Border Height="4"
                                                    CornerRadius="2"
                                                    Background="{DynamicResource AccentBrush}" />
                                        </ControlTemplate>
                                    </RepeatButton.Template>
                                </RepeatButton>
                            </Track.DecreaseRepeatButton>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Command="{x:Static Slider.IncreaseLarge}"
                                              IsTabStop="False">
                                    <RepeatButton.Template>
                                        <ControlTemplate TargetType="RepeatButton">
                                            <Border Height="4"
                                                    CornerRadius="2"
                                                    Background="{DynamicResource Surface1Brush}" />
                                        </ControlTemplate>
                                    </RepeatButton.Template>
                                </RepeatButton>
                            </Track.IncreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb Width="14"
                                       Height="14">
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Border x:Name="ThumbBorder"
                                                    CornerRadius="7"
                                                    Background="{DynamicResource FloatingChromeTextBrush}"
                                                    BorderBrush="{DynamicResource AccentBrush}"
                                                    BorderThickness="2" />
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="ThumbBorder" Property="Background" Value="{DynamicResource AccentHoverBrush}" />
                                                </Trigger>
                                                <Trigger Property="IsDragging" Value="True">
                                                    <Setter TargetName="ThumbBorder" Property="Background" Value="{DynamicResource AccentBrush}" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============ ScrollBar ============ -->
    <Style TargetType="Thumb" x:Key="ScrollThumb">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border CornerRadius="5" Background="{DynamicResource Surface2Brush}" Margin="2,0" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ScrollBar">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource Surface2Brush}" />
        <Setter Property="Width" Value="10" />
        <Setter Property="MinWidth" Value="10" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid Background="Transparent">
                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                            <Track.Thumb>
                                <Thumb Style="{StaticResource ScrollThumb}" />
                            </Track.Thumb>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Horizontal">
                <Setter Property="Width" Value="Auto" />
                <Setter Property="MinWidth" Value="0" />
                <Setter Property="Height" Value="10" />
                <Setter Property="MinHeight" Value="10" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ============ ListBox ============ -->
    <Style TargetType="ListBox">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
    </Style>

    <Style TargetType="ListBoxItem">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="0,0,0,6" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource FocusVisual}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="ItemBorder"
                            Background="{TemplateBinding Background}"
                            CornerRadius="{StaticResource Radius.Sm.CR}"
                            BorderBrush="Transparent"
                            BorderThickness="1">
                        <ContentPresenter />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource Surface0Brush}" />
                            <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{DynamicResource HairlineBrush}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource AccentSelectionBrush}" />
                            <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                            <Setter Property="Foreground" Value="{DynamicResource FloatingChromeTextBrush}" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{DynamicResource FocusRingBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.55" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============ Card / floating surface building blocks ============ -->
    <!-- Use Style="{StaticResource Card}" on a Border for a consistent inset panel -->
    <Style x:Key="Card" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource SurfacePanelBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource HairlineBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource Radius.Md.CR}" />
        <Setter Property="Padding" Value="14,12" />
    </Style>

    <!-- Interactive card variant — hovering lifts the border toward the accent so the recent-rename
         entries read as tappable rows, not static blocks. -->
    <Style x:Key="InteractiveCard" TargetType="Border" BasedOn="{StaticResource Card}">
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="StatusCard" TargetType="Border" BasedOn="{StaticResource Card}">
        <Setter Property="Background" Value="{DynamicResource StatusPanelBrush}" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding RenameStatus}" Value="Pending">
                <Setter Property="Background" Value="{DynamicResource WarningPanelBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource YellowBrush}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding RenameStatus}" Value="Saved">
                <Setter Property="Background" Value="{DynamicResource SuccessPanelBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource GreenBrush}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding RenameStatus}" Value="Conflict">
                <Setter Property="Background" Value="{DynamicResource MauvePanelBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource MauveBrush}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding RenameStatus}" Value="Error">
                <Setter Property="Background" Value="{DynamicResource DangerPanelBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource RedBrush}" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- Compact badge — used for decoder/status details so terse values read as labels, not raw text. -->
    <Style x:Key="Badge" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource Surface0Brush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource HairlineBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="7,2" />
        <Setter Property="HorizontalAlignment" Value="Left" />
    </Style>

    <!-- Divider — subtler hairline; 1px dividers were reading too hard against Mantle -->
    <Style x:Key="Divider" TargetType="Border">
        <Setter Property="Height" Value="1" />
        <Setter Property="Background" Value="{DynamicResource HairlineBrush}" />
        <Setter Property="Margin" Value="0,18,0,18" />
    </Style>

    <!-- Floating chrome (position, transient status, HUD chrome) — elevated and translucent. -->
    <Style x:Key="FloatingChrome" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource FloatingChromeBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource FloatingChromeBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource Radius.Lg.CR}" />
        <Setter Property="Padding" Value="14,7" />
        <Setter Property="Effect" Value="{StaticResource Elevation.Low}" />
    </Style>

    <!-- Toast — floats with soft elevation, accent-tinted border -->
    <Style x:Key="Toast" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource ToastBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource Radius.Md.CR}" />
        <Setter Property="Padding" Value="16,11" />
        <Setter Property="Effect" Value="{StaticResource Elevation.Medium}" />
    </Style>

    <!-- Elevated card — used for the empty/error modals centered in the viewport -->
    <Style x:Key="ElevatedCard" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource PanelBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource HairlineBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource Radius.Lg.CR}" />
        <Setter Property="Padding" Value="36,32" />
        <Setter Property="Effect" Value="{StaticResource Elevation.High}" />
    </Style>

    <!-- Reusable tool-window shell pieces. Secondary workflows use the same header/sidebar/status
         structure so dense utilities feel like one product instead of separate dialogs. -->
    <Style x:Key="ToolWindowHeader" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource PanelBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource HairlineBrush}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="Padding" Value="20,15" />
    </Style>

    <Style x:Key="ToolWindowSidebar" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource PanelBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource HairlineBrush}" />
        <Setter Property="BorderThickness" Value="0,0,1,0" />
        <Setter Property="Padding" Value="16" />
    </Style>

    <Style x:Key="ToolWindowWorkspace" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource ViewportBrush}" />
        <Setter Property="Padding" Value="18" />
    </Style>

    <Style x:Key="WindowStatusBar" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource PanelBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource HairlineBrush}" />
        <Setter Property="BorderThickness" Value="0,1,0,0" />
        <Setter Property="Padding" Value="16,10" />
    </Style>

    <Style x:Key="IconTile" TargetType="Border">
        <Setter Property="Width" Value="42" />
        <Setter Property="Height" Value="42" />
        <Setter Property="CornerRadius" Value="{StaticResource Radius.Md.CR}" />
        <Setter Property="Background" Value="{DynamicResource AccentPanelBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="VerticalAlignment" Value="Top" />
    </Style>

    <Style x:Key="SidePanelToolButton" TargetType="Button" BasedOn="{StaticResource ChromeButton}">
        <Setter Property="MinWidth" Value="102" />
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
    </Style>

    <Style x:Key="EmptyStateCard" TargetType="Border" BasedOn="{StaticResource ElevatedCard}">
        <Setter Property="Width" Value="500" />
        <Setter Property="Padding" Value="30,27" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="EmptyStateIcon" TargetType="Border" BasedOn="{StaticResource IconTile}">
        <Setter Property="Width" Value="48" />
        <Setter Property="Height" Value="48" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="Margin" Value="0,0,0,16" />
    </Style>

</ResourceDictionary>
