<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- ============================================================
         Images — Catppuccin Latte design system (light)
         Overrides the Mocha palette keys so control styles (which use
         DynamicResource) pick up the light-theme values at runtime.
         ============================================================ -->

    <sys:String x:Key="Images.Theme.Name">Latte</sys:String>

    <!-- ============ Palette — Catppuccin Latte ============ -->
    <Color x:Key="BaseColor">#FFF4F5F7</Color>
    <Color x:Key="MantleColor">#FFE9EBEF</Color>
    <Color x:Key="CrustColor">#FFDDE1E7</Color>
    <Color x:Key="Surface0Color">#FFE1E4E9</Color>
    <Color x:Key="Surface1Color">#FFD0D5DD</Color>
    <Color x:Key="Surface2Color">#FFB8C0CB</Color>
    <Color x:Key="OverlayColor">#FF69717D</Color>
    <Color x:Key="TextColor">#FF20242B</Color>
    <Color x:Key="SubtextColor">#FF525A66</Color>
    <Color x:Key="BlueColor">#FF9A6110</Color>
    <Color x:Key="LavenderColor">#FFB7791F</Color>
    <Color x:Key="MauveColor">#FF8839EF</Color>
    <Color x:Key="RedColor">#FFD20F39</Color>
    <Color x:Key="RedHoverColor">#FFE64553</Color>
    <Color x:Key="GreenColor">#FF40A02B</Color>
    <Color x:Key="YellowColor">#FFDF8E1D</Color>

    <SolidColorBrush x:Key="BaseBrush" Color="{StaticResource BaseColor}" />
    <SolidColorBrush x:Key="MantleBrush" Color="{StaticResource MantleColor}" />
    <SolidColorBrush x:Key="CrustBrush" Color="{StaticResource CrustColor}" />
    <SolidColorBrush x:Key="Surface0Brush" Color="{StaticResource Surface0Color}" />
    <SolidColorBrush x:Key="Surface1Brush" Color="{StaticResource Surface1Color}" />
    <SolidColorBrush x:Key="Surface2Brush" Color="{StaticResource Surface2Color}" />
    <SolidColorBrush x:Key="OverlayBrush" Color="{StaticResource OverlayColor}" />
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}" />
    <SolidColorBrush x:Key="SubtextBrush" Color="{StaticResource SubtextColor}" />
    <SolidColorBrush x:Key="HintTextBrush" Color="#FF5E6673" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource BlueColor}" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource LavenderColor}" />
    <SolidColorBrush x:Key="OnAccentBrush" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="MauveBrush" Color="{StaticResource MauveColor}" />
    <SolidColorBrush x:Key="RedBrush" Color="{StaticResource RedColor}" />
    <SolidColorBrush x:Key="RedHoverBrush" Color="{StaticResource RedHoverColor}" />
    <SolidColorBrush x:Key="GreenBrush" Color="{StaticResource GreenColor}" />
    <SolidColorBrush x:Key="YellowBrush" Color="{StaticResource YellowColor}" />

    <!-- ============ Semantic surfaces + chrome ============ -->
    <SolidColorBrush x:Key="ViewportBrush" Color="#FFF8F9FB" />
    <SolidColorBrush x:Key="ViewerSurfaceBrush" Color="#FFF8F9FB" />
    <SolidColorBrush x:Key="PanelBrush" Color="#FCF4F5F7" />
    <SolidColorBrush x:Key="SurfacePanelBrush" Color="#FFE9EBEF" />
    <SolidColorBrush x:Key="HairlineBrush" Color="#997B8491" />
    <SolidColorBrush x:Key="DividerBrush" Color="#667B8491" />
    <SolidColorBrush x:Key="FloatingChromeBrush" Color="#FAF4F5F7" />
    <SolidColorBrush x:Key="FloatingChromeBorderBrush" Color="#8069717D" />
    <SolidColorBrush x:Key="FloatingChromeTextBrush" Color="{StaticResource TextColor}" />
    <SolidColorBrush x:Key="ToastBrush" Color="#FBEFF1F5" />
    <SolidColorBrush x:Key="WarningPanelBrush" Color="#26DF8E1D" />
    <SolidColorBrush x:Key="DangerPanelBrush" Color="#22D20F39" />
    <SolidColorBrush x:Key="FocusRingBrush" Color="#FF9A6110" />
    <SolidColorBrush x:Key="DropOverlayBrush" Color="#DDEFF1F5" />
    <SolidColorBrush x:Key="DropOverlayPanelBrush" Color="#FBEFF1F5" />
    <SolidColorBrush x:Key="OcrRegionBrush" Color="#451E66F5" />
    <SolidColorBrush x:Key="OcrRegionFocusBrush" Color="#881E66F5" />
    <SolidColorBrush x:Key="AccentPanelBrush" Color="#269A6110" />
    <SolidColorBrush x:Key="AccentSelectionBrush" Color="#389A6110" />
    <SolidColorBrush x:Key="StatusPanelBrush" Color="#DDE6E9EF" />
    <SolidColorBrush x:Key="SuccessPanelBrush" Color="#2640A02B" />
    <SolidColorBrush x:Key="MauvePanelBrush" Color="#228839EF" />
    <SolidColorBrush x:Key="OverlayGuideBrush" Color="#8C4C4F69" />
    <SolidColorBrush x:Key="OverlayGuideStrongBrush" Color="#B84C4F69" />
    <SolidColorBrush x:Key="OverlayDimmerBrush" Color="#99000000" />
    <SolidColorBrush x:Key="SubtleSurfaceBrush" Color="#0DACE0F9" />
    <SolidColorBrush x:Key="BrushTintYellowBrush" Color="#24DF8E1D" />
    <SolidColorBrush x:Key="BrushTintAccentBrush" Color="#1F1E66F5" />
    <SolidColorBrush x:Key="BrushTintRedBrush" Color="#24D20F39" />
    <SolidColorBrush x:Key="AccentWarmBrush" Color="#FF9A6110" />
    <SolidColorBrush x:Key="AccentWarmPanelBrush" Color="#269A6110" />
    <SolidColorBrush x:Key="NavRailBrush" Color="#F4E5E8EC" />
    <SolidColorBrush x:Key="NavRailBorderBrush" Color="#66BCC0CC" />
    <SolidColorBrush x:Key="WorkspaceTopBarBrush" Color="#F8EFF1F5" />
    <SolidColorBrush x:Key="WorkspaceTopBarBorderBrush" Color="#8C7C7F93" />
    <SolidColorBrush x:Key="InspectorPanelBrush" Color="#F8E9ECF3" />

</ResourceDictionary>
