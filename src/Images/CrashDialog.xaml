<Window x:Class="Images.CrashDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Images — unexpected error"
        Width="560" Height="540"
        MinWidth="560" MinHeight="420"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="CanResize"
        Background="{StaticResource BaseBrush}"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True">

    <Border Padding="26,22,26,22">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header — semantic-red icon + title -->
            <StackPanel Grid.Row="0" Orientation="Horizontal">
                <TextBlock Text="&#xE783;"
                           FontFamily="{StaticResource IconFontFamily}"
                           FontSize="28"
                           Foreground="{StaticResource RedBrush}"
                           VerticalAlignment="Center" />
                <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                    <TextBlock Style="{StaticResource Text.Title}"
                               Text="Images hit an unexpected error" />
                    <TextBlock x:Name="HeadlineText"
                               Style="{StaticResource Text.Subtitle}"
                               Margin="0,4,0,0" />
                </StackPanel>
            </StackPanel>

            <TextBlock Grid.Row="1"
                       Style="{StaticResource Text.Hint}"
                       Margin="0,16,0,10"
                       TextWrapping="Wrap"
                       Text="Full details are written to the crash log. Use the buttons below to copy a shareable summary, open the log folder, or open a GitHub issue with the context pre-filled." />

            <!-- Details scroll area -->
            <Border Grid.Row="2"
                    Style="{StaticResource Card}"
                    Padding="14,12">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                    <TextBox x:Name="DetailsBox"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             TextWrapping="NoWrap"
                             FontFamily="Consolas"
                             FontSize="11"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="{StaticResource SubtextBrush}" />
                </ScrollViewer>
            </Border>

            <!-- Footer recovery actions -->
            <StackPanel Grid.Row="3" Margin="0,16,0,0">
                <Border x:Name="StatusCard"
                        Style="{StaticResource Card}"
                        Padding="12,9"
                        Margin="0,0,0,12"
                        Visibility="Collapsed"
                        AutomationProperties.LiveSetting="Polite">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="StatusIcon"
                                   Text="&#xE930;"
                                   FontFamily="{StaticResource IconFontFamily}"
                                   FontSize="12"
                                   Foreground="{StaticResource AccentBrush}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,9,0" />
                        <TextBlock x:Name="StatusText"
                                   Style="{StaticResource Text.Caption}"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Border>

                <UniformGrid Columns="2" Rows="2">
                    <Button Content="Copy details"
                            Style="{StaticResource ChromeButton}"
                            Click="CopyButton_Click"
                            Margin="0,0,6,6" />
                    <Button Content="Open log folder"
                            Style="{StaticResource ChromeButton}"
                            Click="OpenLogsButton_Click"
                            Margin="6,0,0,6" />
                    <Button Content="Open GitHub issue"
                            Style="{StaticResource ChromeButton}"
                            Click="OpenIssueButton_Click"
                            Margin="0,6,6,0" />
                    <Button Content="Close"
                            Style="{StaticResource PrimaryButton}"
                            Click="CloseButton_Click"
                            Margin="6,6,0,0"
                            IsDefault="True"
                            IsCancel="True" />
                </UniformGrid>
            </StackPanel>
        </Grid>
    </Border>
</Window>
