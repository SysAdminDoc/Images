<Window x:Class="Images.ModelManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Images - Model manager"
        Width="1180"
        Height="780"
        MinWidth="940"
        MinHeight="620"
        WindowStartupLocation="CenterOwner">
    <Grid Background="{StaticResource BaseBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource HairlineBrush}"
                BorderThickness="0,0,0,1"
                Padding="18,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Model manager" Style="{StaticResource Text.Title}" />
                    <TextBlock Text="Approved local model files stay under app data. Downloads are manual and SHA-256 verified before future AI tools can use them."
                               Style="{StaticResource Text.Caption}"
                               Margin="0,3,0,0" />
                </StackPanel>

                <WrapPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Style="{StaticResource ChromeButton}"
                            Margin="8,0,0,0"
                            Click="RefreshButton_Click"
                            AutomationProperties.Name="Refresh model status">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE72C;"
                                       FontFamily="{StaticResource IconFontFamily}"
                                       FontSize="12"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="Refresh" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="RevealRootButton"
                            Style="{StaticResource ChromeButton}"
                            Margin="8,0,0,0"
                            Click="RevealRootButton_Click"
                            AutomationProperties.Name="Reveal model storage">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8B7;"
                                       FontFamily="{StaticResource IconFontFamily}"
                                       FontSize="12"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="Reveal storage" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="ImportButton"
                            Style="{StaticResource PrimaryButton}"
                            Margin="8,0,0,0"
                            Click="ImportButton_Click"
                            AutomationProperties.Name="Import selected model">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8B7;"
                                       FontFamily="{StaticResource IconFontFamily}"
                                       FontSize="12"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="Import ONNX" />
                        </StackPanel>
                    </Button>
                </WrapPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="390" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource HairlineBrush}"
                    BorderThickness="0,0,1,0"
                    Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource Card}" Padding="12" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="Runtime" Style="{StaticResource SectionLabel}" />
                            <TextBlock x:Name="RuntimeStatusText"
                                       Style="{StaticResource Text.Caption}"
                                       TextWrapping="Wrap"
                                       Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Approved models" Style="{StaticResource SectionLabel}" />
                        <TextBlock x:Name="ModelCountText"
                                   Grid.Column="1"
                                   Text="0"
                                   Style="{StaticResource Text.Caption}"
                                   Margin="12,0,0,0" />
                    </Grid>

                    <ListBox x:Name="ModelsList"
                             Grid.Row="2"
                             SelectionChanged="ModelsList_SelectionChanged"
                             AutomationProperties.Name="Approved local models">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="12,10">
                                    <Border.Style>
                                        <Style TargetType="Border" BasedOn="{StaticResource InteractiveCard}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                    <Setter Property="Background" Value="#2489B4FA" />
                                                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <TextBlock Text="{Binding DisplayName}"
                                                   Style="{StaticResource Text.Body}"
                                                   FontWeight="SemiBold"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding Purpose}"
                                                   Style="{StaticResource Text.Caption}"
                                                   Margin="0,4,0,0" />
                                        <TextBlock Text="{Binding StatusText}"
                                                   Style="{StaticResource Text.Hint}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,3,0,0" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="1"
                          HorizontalAlignment="Stretch"
                          Background="{StaticResource HairlineBrush}" />

            <Border Grid.Column="2"
                    Background="{StaticResource ViewportBrush}"
                    Padding="18">
                <Grid>
                    <Border x:Name="EmptyState"
                            Style="{StaticResource ElevatedCard}"
                            Width="500"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                        <StackPanel>
                            <TextBlock Text="No model selected"
                                       Style="{StaticResource Text.Display}"
                                       TextAlignment="Center" />
                            <TextBlock Text="Select an approved model to inspect its source, hash, local status, and import requirements."
                                       Style="{StaticResource Text.Subtitle}"
                                       TextAlignment="Center"
                                       Margin="0,10,0,0" />
                        </StackPanel>
                    </Border>

                    <Grid x:Name="DetailPanel" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Style="{StaticResource Card}"
                                Padding="14"
                                Margin="0,0,0,14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock x:Name="DetailTitle" Style="{StaticResource Text.Title}" TextWrapping="Wrap" />
                                    <TextBlock x:Name="DetailStatus"
                                               Style="{StaticResource Text.Caption}"
                                               TextWrapping="Wrap"
                                               Margin="0,4,0,0" />
                                </StackPanel>
                                <WrapPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                                    <Button Style="{StaticResource ChromeButton}"
                                            Margin="0,0,8,0"
                                            Click="OpenSourceButton_Click"
                                            AutomationProperties.Name="Open selected model source">
                                        <TextBlock Text="Source" />
                                    </Button>
                                    <Button x:Name="DeleteButton"
                                            Style="{StaticResource DangerButton}"
                                            Click="DeleteButton_Click"
                                            AutomationProperties.Name="Delete selected local model">
                                        <TextBlock Text="Delete local" />
                                    </Button>
                                </WrapPanel>
                            </Grid>
                        </Border>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <Border Style="{StaticResource Card}" Padding="14">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition />
                                            <RowDefinition />
                                            <RowDefinition />
                                            <RowDefinition />
                                            <RowDefinition />
                                            <RowDefinition />
                                            <RowDefinition />
                                            <RowDefinition />
                                            <RowDefinition />
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Purpose" Style="{StaticResource MetaLabel}" />
                                        <TextBlock x:Name="PurposeText" Grid.Row="0" Grid.Column="1" Style="{StaticResource MetaValue}" TextWrapping="Wrap" />
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="License" Style="{StaticResource MetaLabel}" />
                                        <TextBlock x:Name="LicenseText" Grid.Row="1" Grid.Column="1" Style="{StaticResource MetaValue}" TextWrapping="Wrap" />
                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Runtime" Style="{StaticResource MetaLabel}" />
                                        <TextBlock x:Name="RuntimeText" Grid.Row="2" Grid.Column="1" Style="{StaticResource MetaValue}" TextWrapping="Wrap" />
                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Source" Style="{StaticResource MetaLabel}" />
                                        <TextBlock x:Name="SourceText" Grid.Row="3" Grid.Column="1" Style="{StaticResource MetaValue}" TextWrapping="Wrap" />
                                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Download" Style="{StaticResource MetaLabel}" />
                                        <TextBlock x:Name="DownloadText" Grid.Row="4" Grid.Column="1" Style="{StaticResource MetaValue}" TextWrapping="Wrap" />
                                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Expected SHA-256" Style="{StaticResource MetaLabel}" />
                                        <TextBlock x:Name="ExpectedShaText" Grid.Row="5" Grid.Column="1" Style="{StaticResource MetaValue}" TextWrapping="Wrap" />
                                        <TextBlock Grid.Row="6" Grid.Column="0" Text="Local SHA-256" Style="{StaticResource MetaLabel}" />
                                        <TextBlock x:Name="LocalShaText" Grid.Row="6" Grid.Column="1" Style="{StaticResource MetaValue}" TextWrapping="Wrap" />
                                        <TextBlock Grid.Row="7" Grid.Column="0" Text="Local path" Style="{StaticResource MetaLabel}" />
                                        <TextBlock x:Name="LocalPathText" Grid.Row="7" Grid.Column="1" Style="{StaticResource MetaValue}" TextWrapping="Wrap" />
                                        <TextBlock Grid.Row="8" Grid.Column="0" Text="Imported" Style="{StaticResource MetaLabel}" />
                                        <TextBlock x:Name="ImportedText" Grid.Row="8" Grid.Column="1" Style="{StaticResource MetaValue}" TextWrapping="Wrap" />
                                    </Grid>
                                </Border>

                                <Border Style="{StaticResource Card}" Padding="14" Margin="0,14,0,0">
                                    <StackPanel>
                                        <TextBlock Text="Notes" Style="{StaticResource SectionLabel}" />
                                        <TextBlock x:Name="NotesText"
                                                   Style="{StaticResource Text.Caption}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,4,0,0" />
                                        <TextBlock x:Name="ActionText"
                                                   Style="{StaticResource Text.Hint}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,8,0,0" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>

                        <Border Grid.Row="2"
                                Style="{StaticResource Card}"
                                Padding="12"
                                Margin="0,14,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE946;"
                                           FontFamily="{StaticResource IconFontFamily}"
                                           FontSize="12"
                                           Foreground="{StaticResource AccentBrush}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,9,0" />
                                <TextBlock Text="Images never downloads models automatically. Import only model files you chose from an approved source; mismatched hashes stay disabled."
                                           Style="{StaticResource Text.Caption}"
                                           TextWrapping="Wrap"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource HairlineBrush}"
                BorderThickness="0,1,0,0"
                Padding="16,10">
            <StackPanel Orientation="Horizontal">
                <Ellipse x:Name="StatusDot"
                         Width="8"
                         Height="8"
                         Fill="{StaticResource GreenBrush}"
                         Margin="0,0,9,0"
                         VerticalAlignment="Center" />
                <TextBlock x:Name="StatusText"
                           Text="Ready."
                           Style="{StaticResource Text.Caption}"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
