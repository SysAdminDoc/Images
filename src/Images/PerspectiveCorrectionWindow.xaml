<Window x:Class="Images.PerspectiveCorrectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:Images.Localization"
        xmlns:a11y="clr-namespace:Images.Services"
        Title="{loc:Loc PerspectiveTitle}"
        Width="940"
        Height="680"
        MinWidth="760"
        MinHeight="560"
        WindowStartupLocation="CenterOwner"
        KeyDown="Window_KeyDown">
    <Grid Background="{DynamicResource BaseBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource ToolWindowHeader}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="{loc:Loc PerspectiveHeading}" Style="{StaticResource Text.Title}" />
                    <TextBlock Text="{loc:Loc PerspectiveDescription}"
                               Style="{StaticResource Text.Caption}"
                               Margin="0,3,0,0" />
                </StackPanel>
                <Border Grid.Column="1"
                        Style="{StaticResource Badge}"
                        VerticalAlignment="Center"
                        Margin="16,0,0,0">
                    <TextBlock Text="{loc:Loc EnterApplies}"
                               Style="{StaticResource Text.Caption}"
                               FontWeight="SemiBold" />
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="{loc:Loc PerspectiveShape}" Style="{StaticResource SectionLabel}" />
                    <Border Style="{StaticResource Card}" Padding="10,8">
                        <StackPanel>
                            <Button Style="{StaticResource ChromeButton}"
                                    Click="ResetButton_Click"
                                    AutomationProperties.Name="{loc:Loc ResetPerspectiveCorners}">
                                <TextBlock Text="{loc:Loc PerspectiveResetCorners}" />
                            </Button>
                            <Button Style="{StaticResource ChromeButton}"
                                    Margin="0,8,0,0"
                                    Click="InsetButton_Click"
                                    AutomationProperties.Name="{loc:Loc InsetPerspectiveCorners}">
                                <TextBlock Text="{loc:Loc InsetPerspectiveHandles}" />
                            </Button>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Divider}" />

                    <TextBlock Text="{loc:Loc PerspectiveKeystone}" Style="{StaticResource SectionLabel}" />
                    <Border Style="{StaticResource Card}" Padding="10,8">
                        <StackPanel>
                            <UniformGrid Columns="2">
                                <Button Style="{StaticResource ChromeButton}"
                                        Margin="0,0,6,8"
                                        Click="TopNarrowButton_Click"
                                        AutomationProperties.Name="{loc:Loc NarrowTopEdge}">
                                    <TextBlock Text="{loc:Loc PerspectiveTopIn}" />
                                </Button>
                                <Button Style="{StaticResource ChromeButton}"
                                        Margin="6,0,0,8"
                                        Click="BottomNarrowButton_Click"
                                        AutomationProperties.Name="{loc:Loc NarrowBottomEdge}">
                                    <TextBlock Text="{loc:Loc PerspectiveBottomIn}" />
                                </Button>
                                <Button Style="{StaticResource ChromeButton}"
                                        Margin="0,0,6,0"
                                        Click="LeftShortButton_Click"
                                        AutomationProperties.Name="{loc:Loc NarrowLeftEdge}">
                                    <TextBlock Text="{loc:Loc PerspectiveLeftIn}" />
                                </Button>
                                <Button Style="{StaticResource ChromeButton}"
                                        Margin="6,0,0,0"
                                        Click="RightShortButton_Click"
                                        AutomationProperties.Name="{loc:Loc NarrowRightEdge}">
                                    <TextBlock Text="{loc:Loc PerspectiveRightIn}" />
                                </Button>
                            </UniformGrid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Divider}" />

                    <Border Style="{StaticResource Card}" Padding="10,8">
                        <StackPanel>
                            <TextBlock Text="{loc:Loc PerspectiveCorners}"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextBrush}" />
                            <TextBlock x:Name="CornerText"
                                       Style="{StaticResource Text.Caption}"
                                       TextWrapping="Wrap"
                                       Margin="0,8,0,0" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}" Padding="10,8" Margin="0,12,0,0">
                        <TextBlock Text="{loc:Loc PerspectivePreviewNote}"
                                   Style="{StaticResource Text.Hint}"
                                   TextWrapping="Wrap" />
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Column="2"
                    Style="{StaticResource Card}"
                    Padding="10,8"
                    ClipToBounds="True">
                <Canvas x:Name="PreviewCanvas"
                        Background="{DynamicResource ViewerSurfaceBrush}"
                        ClipToBounds="True"
                        SizeChanged="PreviewCanvas_SizeChanged"
                        MouseLeftButtonDown="PreviewCanvas_MouseLeftButtonDown"
                        MouseMove="PreviewCanvas_MouseMove"
                        MouseLeftButtonUp="PreviewCanvas_MouseLeftButtonUp"
                        MouseLeave="PreviewCanvas_MouseLeave">
                    <Image x:Name="PreviewImage"
                           Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           AutomationProperties.Name="{loc:Loc PerspectiveSourcePreview}" />
                </Canvas>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Style="{StaticResource WindowStatusBar}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusText"
                           Style="{StaticResource Text.Caption}"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center"
                           AutomationProperties.LiveSetting="Polite"
                           a11y:LiveRegionBehavior.AnnounceChanges="True" />
                <WrapPanel Grid.Column="1"
                           Margin="12,0,0,0">
                    <Button Style="{StaticResource ChromeButton}"
                            MinWidth="82"
                            Click="CloseButton_Click"
                            AutomationProperties.Name="{loc:Loc PerspectiveClose}">
                        <TextBlock Text="{loc:Loc Close}" />
                    </Button>
                    <Button x:Name="ApplyButton"
                            Style="{StaticResource PrimaryButton}"
                            MinWidth="118"
                            Margin="8,0,0,0"
                            Click="ApplyButton_Click"
                            AutomationProperties.Name="{loc:Loc PerspectiveApplyToEditHistory}">
                        <TextBlock Text="{loc:Loc Apply}" />
                    </Button>
                </WrapPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
