<Window x:Class="Images.PerspectiveCorrectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Images - Perspective"
        Width="940"
        Height="680"
        MinWidth="760"
        MinHeight="560"
        WindowStartupLocation="CenterOwner"
        KeyDown="Window_KeyDown">
    <Grid Background="{StaticResource BaseBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource HairlineBrush}"
                BorderThickness="0,0,0,1"
                Padding="18,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Perspective" Style="{StaticResource Text.Title}" />
                    <TextBlock Text="Drag the four source corners, then add a perspective correction edit."
                               Style="{StaticResource Text.Caption}"
                               Margin="0,3,0,0" />
                </StackPanel>
                <Border Grid.Column="1"
                        Style="{StaticResource Badge}"
                        VerticalAlignment="Center"
                        Margin="16,0,0,0">
                    <TextBlock Text="Enter applies"
                               Style="{StaticResource Text.Caption}"
                               FontWeight="SemiBold" />
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Shape" Style="{StaticResource SectionLabel}" />
                    <Border Style="{StaticResource Card}" Padding="14">
                        <StackPanel>
                            <Button Style="{StaticResource ChromeButton}"
                                    Click="ResetButton_Click"
                                    AutomationProperties.Name="Reset perspective corners">
                                <TextBlock Text="Reset corners" />
                            </Button>
                            <Button Style="{StaticResource ChromeButton}"
                                    Margin="0,8,0,0"
                                    Click="InsetButton_Click"
                                    AutomationProperties.Name="Inset perspective corners">
                                <TextBlock Text="Inset handles" />
                            </Button>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Divider}" />

                    <TextBlock Text="Keystone" Style="{StaticResource SectionLabel}" />
                    <Border Style="{StaticResource Card}" Padding="14">
                        <StackPanel>
                            <UniformGrid Columns="2">
                                <Button Style="{StaticResource ChromeButton}"
                                        Margin="0,0,6,8"
                                        Click="TopNarrowButton_Click"
                                        AutomationProperties.Name="Narrow top edge">
                                    <TextBlock Text="Top in" />
                                </Button>
                                <Button Style="{StaticResource ChromeButton}"
                                        Margin="6,0,0,8"
                                        Click="BottomNarrowButton_Click"
                                        AutomationProperties.Name="Narrow bottom edge">
                                    <TextBlock Text="Bottom in" />
                                </Button>
                                <Button Style="{StaticResource ChromeButton}"
                                        Margin="0,0,6,0"
                                        Click="LeftShortButton_Click"
                                        AutomationProperties.Name="Shorten left edge">
                                    <TextBlock Text="Left in" />
                                </Button>
                                <Button Style="{StaticResource ChromeButton}"
                                        Margin="6,0,0,0"
                                        Click="RightShortButton_Click"
                                        AutomationProperties.Name="Shorten right edge">
                                    <TextBlock Text="Right in" />
                                </Button>
                            </UniformGrid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Divider}" />

                    <Border Style="{StaticResource Card}" Padding="14">
                        <StackPanel>
                            <TextBlock Text="Corners"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextBrush}" />
                            <TextBlock x:Name="CornerText"
                                       Style="{StaticResource Text.Caption}"
                                       TextWrapping="Wrap"
                                       Margin="0,8,0,0" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}" Padding="14" Margin="0,12,0,0">
                        <TextBlock Text="This records an edit operation only. Use Save a copy to export pixels with the perspective correction applied."
                                   Style="{StaticResource Text.Hint}"
                                   TextWrapping="Wrap" />
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Column="2"
                    Style="{StaticResource Card}"
                    Padding="14"
                    ClipToBounds="True">
                <Canvas x:Name="PreviewCanvas"
                        Background="{StaticResource ViewerSurfaceBrush}"
                        ClipToBounds="True"
                        SizeChanged="PreviewCanvas_SizeChanged"
                        MouseLeftButtonDown="PreviewCanvas_MouseLeftButtonDown"
                        MouseMove="PreviewCanvas_MouseMove"
                        MouseLeftButtonUp="PreviewCanvas_MouseLeftButtonUp"
                        MouseLeave="PreviewCanvas_MouseLeave">
                    <Image x:Name="PreviewImage"
                           Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           AutomationProperties.Name="Perspective source preview" />
                </Canvas>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource HairlineBrush}"
                BorderThickness="0,1,0,0"
                Padding="14,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusText"
                           Style="{StaticResource Text.Caption}"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center"
                           AutomationProperties.LiveSetting="Polite" />
                <WrapPanel Grid.Column="1"
                           Margin="12,0,0,0">
                    <Button Style="{StaticResource ChromeButton}"
                            MinWidth="82"
                            Click="CloseButton_Click"
                            AutomationProperties.Name="Close perspective correction">
                        <TextBlock Text="Close" />
                    </Button>
                    <Button x:Name="ApplyButton"
                            Style="{StaticResource PrimaryButton}"
                            MinWidth="118"
                            Margin="8,0,0,0"
                            Click="ApplyButton_Click"
                            AutomationProperties.Name="Apply perspective correction to edit history">
                        <TextBlock Text="Apply" />
                    </Button>
                </WrapPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
