<Window x:Class="Images.RecoveryCenterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Images - Recovery center"
        Width="1120"
        Height="760"
        MinWidth="900"
        MinHeight="600"
        WindowStartupLocation="CenterOwner">
    <Grid Background="{StaticResource BaseBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource HairlineBrush}"
                BorderThickness="0,0,0,1"
                Padding="18,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Recovery center" Style="{StaticResource Text.Title}" />
                    <TextBlock Text="Review recent moves, quarantines, writebacks, and Recycle Bin actions recorded locally."
                               Style="{StaticResource Text.Caption}"
                               Margin="0,3,0,0" />
                </StackPanel>

                <WrapPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Style="{StaticResource ChromeButton}"
                            Margin="8,0,0,0"
                            Click="RefreshButton_Click"
                            AutomationProperties.Name="Refresh recovery records">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE72C;"
                                       FontFamily="{StaticResource IconFontFamily}"
                                       FontSize="12"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="Refresh" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="RevealButton"
                            Style="{StaticResource ChromeButton}"
                            Margin="8,0,0,0"
                            Click="RevealButton_Click"
                            AutomationProperties.Name="Reveal selected recovery path">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8B7;"
                                       FontFamily="{StaticResource IconFontFamily}"
                                       FontSize="12"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="Reveal" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="RestoreButton"
                            Style="{StaticResource PrimaryButton}"
                            Margin="8,0,0,0"
                            Click="RestoreButton_Click"
                            AutomationProperties.Name="Restore selected recovery record">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE777;"
                                       FontFamily="{StaticResource IconFontFamily}"
                                       FontSize="12"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="Restore" />
                        </StackPanel>
                    </Button>
                </WrapPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource HairlineBrush}"
                    BorderThickness="0,0,1,0"
                    Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Recent operations" Style="{StaticResource SectionLabel}" />
                        <TextBlock x:Name="RecordCountText"
                                   Grid.Column="1"
                                   Text="0"
                                   Style="{StaticResource Text.Caption}"
                                   Margin="12,0,0,0" />
                    </Grid>

                    <ListBox x:Name="RecordsList"
                             Grid.Row="1"
                             SelectionChanged="RecordsList_SelectionChanged"
                             AutomationProperties.Name="Recovery records">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="12,10">
                                    <Border.Style>
                                        <Style TargetType="Border" BasedOn="{StaticResource InteractiveCard}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                    <Setter Property="Background" Value="#2489B4FA" />
                                                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}"
                                                   Style="{StaticResource Text.Body}"
                                                   FontWeight="SemiBold"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding KindText}"
                                                   Style="{StaticResource Text.Caption}"
                                                   Margin="0,4,0,0" />
                                        <TextBlock Text="{Binding CreatedText}"
                                                   Style="{StaticResource Text.Hint}"
                                                   Margin="0,3,0,0" />
                                        <TextBlock Text="{Binding RestoreStateText}"
                                                   Style="{StaticResource Text.Hint}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,3,0,0" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="1"
                          HorizontalAlignment="Stretch"
                          Background="{StaticResource HairlineBrush}" />

            <Border Grid.Column="2"
                    Background="{StaticResource ViewportBrush}"
                    Padding="18">
                <Grid>
                    <Border x:Name="EmptyState"
                            Style="{StaticResource ElevatedCard}"
                            Width="480"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                        <StackPanel>
                            <TextBlock Text="No recovery record selected"
                                       Style="{StaticResource Text.Display}"
                                       TextAlignment="Center" />
                            <TextBlock Text="Destructive moves, quarantines, writebacks, and Recycle Bin sends will appear here after they are recorded."
                                       Style="{StaticResource Text.Subtitle}"
                                       TextAlignment="Center"
                                       Margin="0,10,0,0" />
                        </StackPanel>
                    </Border>

                    <Grid x:Name="DetailPanel" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Style="{StaticResource Card}"
                                Padding="14"
                                Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock x:Name="DetailTitle" Style="{StaticResource Text.Title}" TextWrapping="Wrap" />
                                <TextBlock x:Name="DetailDescription"
                                           Style="{StaticResource Text.Caption}"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <Border Style="{StaticResource Card}" Padding="14">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition />
                                            <RowDefinition />
                                            <RowDefinition />
                                            <RowDefinition />
                                            <RowDefinition />
                                            <RowDefinition />
                                            <RowDefinition />
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Type" Style="{StaticResource MetaLabel}" />
                                        <TextBlock x:Name="KindText" Grid.Row="0" Grid.Column="1" Style="{StaticResource MetaValue}" />
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Created" Style="{StaticResource MetaLabel}" />
                                        <TextBlock x:Name="CreatedText" Grid.Row="1" Grid.Column="1" Style="{StaticResource MetaValue}" />
                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Status" Style="{StaticResource MetaLabel}" />
                                        <TextBlock x:Name="StatusValueText" Grid.Row="2" Grid.Column="1" Style="{StaticResource MetaValue}" TextWrapping="Wrap" />
                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Original" Style="{StaticResource MetaLabel}" />
                                        <TextBlock x:Name="OriginalPathText" Grid.Row="3" Grid.Column="1" Style="{StaticResource MetaValue}" TextWrapping="Wrap" />
                                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Current" Style="{StaticResource MetaLabel}" />
                                        <TextBlock x:Name="CurrentPathText" Grid.Row="4" Grid.Column="1" Style="{StaticResource MetaValue}" TextWrapping="Wrap" />
                                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Restore" Style="{StaticResource MetaLabel}" />
                                        <TextBlock x:Name="RestoreHintText" Grid.Row="5" Grid.Column="1" Style="{StaticResource MetaValue}" TextWrapping="Wrap" />
                                        <TextBlock Grid.Row="6" Grid.Column="0" Text="Retention" Style="{StaticResource MetaLabel}" />
                                        <TextBlock x:Name="ExpirationText" Grid.Row="6" Grid.Column="1" Style="{StaticResource MetaValue}" TextWrapping="Wrap" />
                                    </Grid>
                                </Border>

                                <Border x:Name="SidecarsPanel"
                                        Style="{StaticResource Card}"
                                        Padding="14"
                                        Margin="0,14,0,0">
                                    <StackPanel>
                                        <TextBlock Text="Sidecars" Style="{StaticResource SectionLabel}" />
                                        <ItemsControl x:Name="SidecarsList">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,6,0,0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition />
                                                            <RowDefinition />
                                                        </Grid.RowDefinitions>
                                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Original" Style="{StaticResource MetaLabel}" />
                                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding OriginalPath}" Style="{StaticResource MetaValue}" TextWrapping="Wrap" />
                                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Current" Style="{StaticResource MetaLabel}" />
                                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding CurrentPath}" Style="{StaticResource MetaValue}" TextWrapping="Wrap" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>

                        <Border Grid.Row="2"
                                Style="{StaticResource Card}"
                                Padding="12"
                                Margin="0,14,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE946;"
                                           FontFamily="{StaticResource IconFontFamily}"
                                           FontSize="12"
                                           Foreground="{StaticResource AccentBrush}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,9,0" />
                                <TextBlock x:Name="RulesText"
                                           Style="{StaticResource Text.Caption}"
                                           TextWrapping="Wrap"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource HairlineBrush}"
                BorderThickness="0,1,0,0"
                Padding="16,10">
            <StackPanel Orientation="Horizontal">
                <Ellipse x:Name="StatusDot"
                         Width="8"
                         Height="8"
                         Fill="{StaticResource GreenBrush}"
                         Margin="0,0,9,0"
                         VerticalAlignment="Center" />
                <TextBlock x:Name="StatusText"
                           Text="Ready."
                           Style="{StaticResource Text.Caption}"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
