<Window x:Class="Images.RecoveryCenterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:Images.Localization"
        xmlns:a11y="clr-namespace:Images.Services"
        Title="{x:Static loc:Strings.RecoveryCenterTitle}"
        Width="1120"
        Height="760"
        MinWidth="900"
        MinHeight="600"
        WindowStartupLocation="CenterOwner">
    <Grid Background="{DynamicResource BaseBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource ToolWindowHeader}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{x:Static loc:Strings.RecoveryCenterHeading}" Style="{StaticResource Text.Title}" />
                    <TextBlock Text="{x:Static loc:Strings.RecoveryCenterSubtitle}"
                               Style="{StaticResource Text.Caption}"
                               Margin="0,3,0,0" />
                </StackPanel>

                <WrapPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Style="{StaticResource ChromeButton}"
                            Margin="8,0,0,0"
                            Click="RefreshButton_Click"
                            AutomationProperties.Name="{x:Static loc:Strings.RecoveryCenterRefreshAutomationName}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE72C;"
                                       FontFamily="{StaticResource IconFontFamily}"
                                       FontSize="12"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="{x:Static loc:Strings.RecoveryCenterRefresh}" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="RevealButton"
                            Style="{StaticResource ChromeButton}"
                            Margin="8,0,0,0"
                            Click="RevealButton_Click"
                            AutomationProperties.Name="{x:Static loc:Strings.RecoveryCenterRevealAutomationName}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8B7;"
                                       FontFamily="{StaticResource IconFontFamily}"
                                       FontSize="12"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="{x:Static loc:Strings.RecoveryCenterReveal}" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="RestoreButton"
                            Style="{StaticResource PrimaryButton}"
                            Margin="8,0,0,0"
                            Click="RestoreButton_Click"
                            AutomationProperties.Name="{x:Static loc:Strings.RecoveryCenterRestoreAutomationName}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE777;"
                                       FontFamily="{StaticResource IconFontFamily}"
                                       FontSize="12"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="{x:Static loc:Strings.RecoveryCenterRestore}" />
                        </StackPanel>
                    </Button>
                </WrapPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource ToolWindowSidebar}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{x:Static loc:Strings.RecoveryCenterRecentOperations}" Style="{StaticResource SectionLabel}" />
                        <TextBlock x:Name="RecordCountText"
                                   Grid.Column="1"
                                   Text="0"
                                   Style="{StaticResource Text.Caption}"
                                   Margin="12,0,0,0" />
                    </Grid>

                    <ListBox x:Name="RecordsList"
                             Grid.Row="1"
                             SelectionChanged="RecordsList_SelectionChanged"
                             AutomationProperties.Name="{x:Static loc:Strings.RecoveryCenterRecordsAutomationName}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="12,10">
                                    <Border.Style>
                                        <Style TargetType="Border" BasedOn="{StaticResource InteractiveCard}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource AccentSelectionBrush}" />
                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}"
                                                   Style="{StaticResource Text.Body}"
                                                   FontWeight="SemiBold"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding KindText}"
                                                   Style="{StaticResource Text.Caption}"
                                                   Margin="0,4,0,0" />
                                        <TextBlock Text="{Binding CreatedText}"
                                                   Style="{StaticResource Text.Hint}"
                                                   Margin="0,3,0,0" />
                                        <TextBlock Text="{Binding RestoreStateText}"
                                                   Style="{StaticResource Text.Hint}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,3,0,0" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1"
                          Style="{StaticResource VerticalGridSplitter}" />

            <Border Grid.Column="2"
                    Style="{StaticResource ToolWindowWorkspace}">
                <Grid>
                    <Border x:Name="EmptyState"
                            Style="{StaticResource EmptyStateCard}"
                            AutomationProperties.Name="{x:Static loc:Strings.RecoveryCenterEmptyHeading}">
                        <StackPanel>
                            <Border Style="{StaticResource EmptyStateIcon}">
                                <TextBlock Text="&#xE777;"
                                           FontFamily="{StaticResource IconFontFamily}"
                                           FontSize="18"
                                           Foreground="{DynamicResource AccentBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Text="{x:Static loc:Strings.RecoveryCenterEmptyHeading}"
                                       Style="{StaticResource Text.Display}"
                                       TextAlignment="Center" />
                            <TextBlock Text="{x:Static loc:Strings.RecoveryCenterEmptyDescription}"
                                       Style="{StaticResource Text.Subtitle}"
                                       TextAlignment="Center"
                                       Margin="0,10,0,0" />
                        </StackPanel>
                    </Border>

                    <Grid x:Name="DetailPanel" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Style="{StaticResource Card}"
                                Padding="14"
                                Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock x:Name="DetailTitle" Style="{StaticResource Text.Title}" TextWrapping="Wrap" />
                                <TextBlock x:Name="DetailDescription"
                                           Style="{StaticResource Text.Caption}"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <Border Style="{StaticResource Card}" Padding="14">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition />
                                            <RowDefinition />
                                            <RowDefinition />
                                            <RowDefinition />
                                            <RowDefinition />
                                            <RowDefinition />
                                            <RowDefinition />
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{x:Static loc:Strings.RecoveryCenterMetaType}" Style="{StaticResource MetaLabel}" />
                                        <TextBlock x:Name="KindText" Grid.Row="0" Grid.Column="1" Style="{StaticResource MetaValue}" />
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="{x:Static loc:Strings.RecoveryCenterMetaCreated}" Style="{StaticResource MetaLabel}" />
                                        <TextBlock x:Name="CreatedText" Grid.Row="1" Grid.Column="1" Style="{StaticResource MetaValue}" />
                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="{x:Static loc:Strings.RecoveryCenterMetaStatus}" Style="{StaticResource MetaLabel}" />
                                        <TextBlock x:Name="StatusValueText" Grid.Row="2" Grid.Column="1" Style="{StaticResource MetaValue}" TextWrapping="Wrap"
                                                   AutomationProperties.LiveSetting="Polite"
                                                   a11y:LiveRegionBehavior.AnnounceChanges="True" />
                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="{x:Static loc:Strings.RecoveryCenterMetaOriginal}" Style="{StaticResource MetaLabel}" />
                                        <TextBlock x:Name="OriginalPathText" Grid.Row="3" Grid.Column="1" Style="{StaticResource MetaValue}" TextWrapping="Wrap" />
                                        <TextBlock Grid.Row="4" Grid.Column="0" Text="{x:Static loc:Strings.RecoveryCenterMetaCurrent}" Style="{StaticResource MetaLabel}" />
                                        <TextBlock x:Name="CurrentPathText" Grid.Row="4" Grid.Column="1" Style="{StaticResource MetaValue}" TextWrapping="Wrap" />
                                        <TextBlock Grid.Row="5" Grid.Column="0" Text="{x:Static loc:Strings.RecoveryCenterMetaRestore}" Style="{StaticResource MetaLabel}" />
                                        <TextBlock x:Name="RestoreHintText" Grid.Row="5" Grid.Column="1" Style="{StaticResource MetaValue}" TextWrapping="Wrap" />
                                        <TextBlock Grid.Row="6" Grid.Column="0" Text="{x:Static loc:Strings.RecoveryCenterMetaRetention}" Style="{StaticResource MetaLabel}" />
                                        <TextBlock x:Name="ExpirationText" Grid.Row="6" Grid.Column="1" Style="{StaticResource MetaValue}" TextWrapping="Wrap" />
                                    </Grid>
                                </Border>

                                <Border x:Name="SidecarsPanel"
                                        Style="{StaticResource Card}"
                                        Padding="14"
                                        Margin="0,14,0,0">
                                    <StackPanel>
                                        <TextBlock Text="{x:Static loc:Strings.RecoveryCenterSidecars}" Style="{StaticResource SectionLabel}" />
                                        <ItemsControl x:Name="SidecarsList">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,6,0,0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition />
                                                            <RowDefinition />
                                                        </Grid.RowDefinitions>
                                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{x:Static loc:Strings.RecoveryCenterMetaOriginal}" Style="{StaticResource MetaLabel}" />
                                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding OriginalPath}" Style="{StaticResource MetaValue}" TextWrapping="Wrap" />
                                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="{x:Static loc:Strings.RecoveryCenterMetaCurrent}" Style="{StaticResource MetaLabel}" />
                                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding CurrentPath}" Style="{StaticResource MetaValue}" TextWrapping="Wrap" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>

                        <Border Grid.Row="2"
                                Style="{StaticResource Card}"
                                Padding="12"
                                Margin="0,14,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE946;"
                                           FontFamily="{StaticResource IconFontFamily}"
                                           FontSize="12"
                                           Foreground="{DynamicResource AccentBrush}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,9,0" />
                                <TextBlock x:Name="RulesText"
                                           Style="{StaticResource Text.Caption}"
                                           TextWrapping="Wrap"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Style="{StaticResource WindowStatusBar}">
            <StackPanel Orientation="Horizontal">
                <Ellipse x:Name="StatusDot"
                         Width="8"
                         Height="8"
                         Fill="{DynamicResource GreenBrush}"
                         Margin="0,0,9,0"
                         VerticalAlignment="Center" />
                <TextBlock x:Name="StatusText"
                           Text="{x:Static loc:Strings.RecoveryCenterReady}"
                           Style="{StaticResource Text.Caption}"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center"
                           AutomationProperties.LiveSetting="Polite"
                           a11y:LiveRegionBehavior.AnnounceChanges="True" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
