<Window x:Class="Images.SemanticSearchWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Images - Semantic search"
        Width="1180"
        Height="780"
        MinWidth="940"
        MinHeight="620"
        WindowStartupLocation="CenterOwner">
    <Grid Background="{StaticResource BaseBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource HairlineBrush}"
                BorderThickness="0,0,0,1"
                Padding="18,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Semantic search" Style="{StaticResource Text.Title}" />
                    <TextBlock x:Name="ProviderStatusText"
                               Style="{StaticResource Text.Caption}"
                               TextWrapping="Wrap"
                               Margin="0,3,0,0" />
                </StackPanel>
                <WrapPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button x:Name="AddFolderButton"
                            Style="{StaticResource ChromeButton}"
                            Margin="8,0,0,0"
                            Click="AddFolderButton_Click"
                            AutomationProperties.Name="Add folder to semantic search">
                        <TextBlock Text="Add folder" />
                    </Button>
                    <Button x:Name="IndexButton"
                            Style="{StaticResource PrimaryButton}"
                            Margin="8,0,0,0"
                            Click="IndexButton_Click"
                            AutomationProperties.Name="Build semantic search index">
                        <TextBlock Text="Index" />
                    </Button>
                    <Button x:Name="CancelButton"
                            Style="{StaticResource ChromeButton}"
                            Margin="8,0,0,0"
                            IsEnabled="False"
                            Click="CancelButton_Click"
                            AutomationProperties.Name="Cancel semantic indexing">
                        <TextBlock Text="Cancel" />
                    </Button>
                </WrapPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource HairlineBrush}"
                    BorderThickness="0,0,1,0"
                    Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="Indexed folders" Style="{StaticResource SectionLabel}" />
                        <TextBlock Text="Indexing is explicit and local. The current MVP stores derived vectors in app-local SQLite and never contacts a network service."
                                   Style="{StaticResource Text.Caption}"
                                   TextWrapping="Wrap"
                                   Margin="0,5,0,12" />
                    </StackPanel>

                    <ListBox x:Name="RootsList"
                             Grid.Row="1"
                             AutomationProperties.Name="Semantic search roots" />

                    <StackPanel Grid.Row="2" Margin="0,14,0,0">
                        <Button x:Name="UseSelectedRootButton"
                                Style="{StaticResource ChromeButton}"
                                Click="UseSelectedRootButton_Click"
                                AutomationProperties.Name="Use selected root as search filter">
                            <TextBlock Text="Use selected as filter" />
                        </Button>
                        <Button x:Name="RemoveRootButton"
                                Style="{StaticResource ChromeButton}"
                                Margin="0,8,0,0"
                                Click="RemoveRootButton_Click"
                                AutomationProperties.Name="Remove selected semantic search root">
                            <TextBlock Text="Remove selected" />
                        </Button>
                        <Button x:Name="ClearRootsButton"
                                Style="{StaticResource ChromeButton}"
                                Margin="0,8,0,0"
                                Click="ClearRootsButton_Click"
                                AutomationProperties.Name="Clear semantic search roots">
                            <TextBlock Text="Clear roots" />
                        </Button>
                        <Button x:Name="ClearIndexButton"
                                Style="{StaticResource DangerButton}"
                                Margin="0,8,0,0"
                                Click="ClearIndexButton_Click"
                                AutomationProperties.Name="Delete semantic search index">
                            <TextBlock Text="Delete local index" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="1"
                          HorizontalAlignment="Stretch"
                          Background="{StaticResource HairlineBrush}" />

            <Border Grid.Column="2"
                    Background="{StaticResource ViewportBrush}"
                    Padding="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Style="{StaticResource Card}"
                            Padding="14"
                            Margin="0,0,0,14">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal">
                                <TextBlock Text="Query" Style="{StaticResource MetaLabel}" VerticalAlignment="Center" />
                                <TextBox x:Name="QueryTextBox"
                                         Width="360"
                                         Margin="12,0,0,0"
                                         VerticalAlignment="Center"
                                         AutomationProperties.Name="Semantic search query"
                                         KeyDown="QueryTextBox_KeyDown" />
                                <TextBlock Text="Filter"
                                           Style="{StaticResource MetaLabel}"
                                           Margin="18,0,0,0"
                                           VerticalAlignment="Center" />
                                <TextBox x:Name="FolderFilterTextBox"
                                         Width="300"
                                         Margin="12,0,0,0"
                                         VerticalAlignment="Center"
                                         AutomationProperties.Name="Semantic search folder filter" />
                            </StackPanel>

                            <WrapPanel Grid.Row="0" Grid.Column="1" Margin="12,0,0,0">
                                <Button x:Name="SearchButton"
                                        Style="{StaticResource PrimaryButton}"
                                        Click="SearchButton_Click"
                                        AutomationProperties.Name="Run semantic search">
                                    <TextBlock Text="Search" />
                                </Button>
                                <Button x:Name="OpenResultButton"
                                        Style="{StaticResource ChromeButton}"
                                        Margin="8,0,0,0"
                                        Click="OpenResultButton_Click"
                                        AutomationProperties.Name="Open selected semantic search result">
                                    <TextBlock Text="Open" />
                                </Button>
                                <Button x:Name="RevealResultButton"
                                        Style="{StaticResource ChromeButton}"
                                        Margin="8,0,0,0"
                                        Click="RevealResultButton_Click"
                                        AutomationProperties.Name="Reveal selected semantic search result">
                                    <TextBlock Text="Reveal" />
                                </Button>
                            </WrapPanel>

                            <TextBlock x:Name="IndexStatusText"
                                       Grid.Row="1"
                                       Grid.ColumnSpan="2"
                                       Style="{StaticResource Text.Caption}"
                                       TextWrapping="Wrap"
                                       Margin="0,10,0,0" />
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1">
                        <TextBlock x:Name="EmptyState"
                                   Text="Build an index, then search for words from filenames, sidecar tags, formats, or orientation hints."
                                   Style="{StaticResource Text.Subtitle}"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   Width="520"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />

                        <ListBox x:Name="ResultsList"
                                 Visibility="Collapsed"
                                 SelectionChanged="ResultsList_SelectionChanged"
                                 AutomationProperties.Name="Semantic search results">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource Card}" Padding="12" Margin="0,0,0,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding FileName}"
                                                           Style="{StaticResource Text.Body}"
                                                           FontWeight="SemiBold"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Text="{Binding Folder}"
                                                           Style="{StaticResource Text.Caption}"
                                                           TextWrapping="Wrap"
                                                           Margin="0,3,0,0" />
                                                <TextBlock Text="{Binding MatchedText}"
                                                           Style="{StaticResource Text.Hint}"
                                                           TextWrapping="Wrap"
                                                           Margin="0,4,0,0" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding ScoreText}"
                                                       Style="{StaticResource Text.Caption}"
                                                       Margin="16,0,0,0"
                                                       VerticalAlignment="Top" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource HairlineBrush}"
                BorderThickness="0,1,0,0"
                Padding="16,10">
            <StackPanel Orientation="Horizontal">
                <Ellipse x:Name="StatusDot"
                         Width="8"
                         Height="8"
                         Fill="{StaticResource GreenBrush}"
                         Margin="0,0,9,0"
                         VerticalAlignment="Center" />
                <TextBlock x:Name="StatusText"
                           Text="Ready."
                           Style="{StaticResource Text.Caption}"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
